@inject IClaudeSettingsService ClaudeSettingsService
@inject IMcpService McpService
@inject ISnackbar Snackbar

<div class="mcp-permissions">
    <div class="mcp-permissions-header">
        <MudIcon Icon="@Icons.Material.Filled.Security" Size="Size.Small"/>
        <span class="typo-subtitle2">도구 권한</span>
        <MudTooltip Text="Claude가 이 서버의 도구를 사용할 시기를 제어합니다">
            <MudIcon Icon="@Icons.Material.Filled.HelpOutline" Size="Size.Small" Style="opacity:0.5;"/>
        </MudTooltip>
    </div>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Size="Size.Small" Class="my-2"/>
    }
    else
    {
        @if (_permissions.Count > 0)
        {
            <div class="stack gap-1 mt-2">
                @foreach (var perm in _permissions)
                {
                    <div class="mcp-tool-row">
                        <span class="typo-caption mcp-tool-name">@perm.ToolName</span>
                        <div class="mcp-tool-actions">
                            <MudTooltip Text="허용">
                                <MudIconButton Icon="@Icons.Material.Filled.CheckCircle"
                                               Size="Size.Small"
                                               Color="@(perm.Level == McpPermissionLevel.Allow ? Color.Success : Color.Default)"
                                               OnClick="@(() => SetPermission(perm, McpPermissionLevel.Allow))"/>
                            </MudTooltip>
                            <MudTooltip Text="확인 후 허용">
                                <MudIconButton Icon="@Icons.Material.Filled.HelpOutline"
                                               Size="Size.Small"
                                               Color="@(perm.Level == McpPermissionLevel.Ask ? Color.Warning : Color.Default)"
                                               OnClick="@(() => SetPermission(perm, McpPermissionLevel.Ask))"/>
                            </MudTooltip>
                            <MudTooltip Text="금지">
                                <MudIconButton Icon="@Icons.Material.Filled.Block"
                                               Size="Size.Small"
                                               Color="@(perm.Level == McpPermissionLevel.Deny ? Color.Error : Color.Default)"
                                               OnClick="@(() => SetPermission(perm, McpPermissionLevel.Deny))"/>
                            </MudTooltip>
                            <MudTooltip Text="제거">
                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                               Size="Size.Small"
                                               OnClick="@(() => RemovePermission(perm))"/>
                            </MudTooltip>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="typo-caption text-secondary mt-2">설정된 도구 권한이 없습니다.</div>
        }

        @* Add new tool permission *@
        <div class="mcp-add-permission mt-2">
            @if (_addingNew)
            {
                <div class="d-flex gap-1 align-center">
                    <MudTextField @bind-Value="_newToolName" Placeholder="도구 이름 (예: get_screenshot)"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Style="flex: 1;" Immediate="true"/>
                    <MudSelect T="McpPermissionLevel" @bind-Value="_newLevel" Variant="Variant.Outlined"
                               Margin="Margin.Dense" Style="width: 100px;">
                        <MudSelectItem T="McpPermissionLevel" Value="McpPermissionLevel.Allow">허용</MudSelectItem>
                        <MudSelectItem T="McpPermissionLevel" Value="McpPermissionLevel.Ask">확인</MudSelectItem>
                        <MudSelectItem T="McpPermissionLevel" Value="McpPermissionLevel.Deny">금지</MudSelectItem>
                    </MudSelect>
                    <MudIconButton Icon="@Icons.Material.Filled.Check" Size="Size.Small" Color="Color.Primary"
                                   OnClick="AddPermission" Disabled="@string.IsNullOrWhiteSpace(_newToolName)"/>
                    <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                   OnClick="@(() => { _addingNew = false; _newToolName = ""; })"/>
                </div>
            }
            else
            {
                <MudButton StartIcon="@Icons.Material.Filled.Add" Size="Size.Small" Variant="Variant.Text"
                           OnClick="@(() => _addingNew = true)">
                    도구 권한 추가
                </MudButton>
            }
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public string ServerName { get; set; } = "";
    [Parameter] public McpScope Scope { get; set; }
    [Parameter] public string? ProjectPath { get; set; }

    private List<McpToolPermission> _permissions = [];
    private bool _loading;
    private bool _addingNew;
    private string _newToolName = "";
    private McpPermissionLevel _newLevel = McpPermissionLevel.Allow;

    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrEmpty(ServerName))
            await LoadPermissionsAsync();
    }

    private ClaudeSettingsScope GetSettingsScope() => Scope switch
    {
        McpScope.Project => ClaudeSettingsScope.Project,
        McpScope.Local => ClaudeSettingsScope.Local,
        _ => ClaudeSettingsScope.Global
    };

    private async Task LoadPermissionsAsync()
    {
        _loading = true;
        StateHasChanged();
        try
        {
            var settingsScope = GetSettingsScope();
            var settings = await ClaudeSettingsService.ReadAsync(settingsScope, ProjectPath);
            _permissions = McpService.ExtractToolPermissions(ServerName, settings.Permissions);
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task SetPermission(McpToolPermission perm, McpPermissionLevel newLevel)
    {
        var settingsScope = GetSettingsScope();
        var settings = await ClaudeSettingsService.ReadAsync(settingsScope, ProjectPath);
        settings.Permissions = McpService.ApplyToolPermission(settings.Permissions, ServerName, perm.ToolName, newLevel);
        await ClaudeSettingsService.WriteAsync(settingsScope, settings, ProjectPath);
        await LoadPermissionsAsync();
    }

    private async Task RemovePermission(McpToolPermission perm)
    {
        var settingsScope = GetSettingsScope();
        var settings = await ClaudeSettingsService.ReadAsync(settingsScope, ProjectPath);
        settings.Permissions = McpService.RemoveToolPermission(settings.Permissions, perm.RawPattern);
        await ClaudeSettingsService.WriteAsync(settingsScope, settings, ProjectPath);
        await LoadPermissionsAsync();
    }

    private async Task AddPermission()
    {
        if (string.IsNullOrWhiteSpace(_newToolName)) return;
        var settingsScope = GetSettingsScope();
        var settings = await ClaudeSettingsService.ReadAsync(settingsScope, ProjectPath);
        settings.Permissions = McpService.ApplyToolPermission(settings.Permissions, ServerName, _newToolName.Trim(), _newLevel);
        await ClaudeSettingsService.WriteAsync(settingsScope, settings, ProjectPath);
        _newToolName = "";
        _addingNew = false;
        Snackbar.Add("도구 권한이 추가되었습니다.", Severity.Success);
        await LoadPermissionsAsync();
    }
}

<style>
    .mcp-permissions {
        padding-top: 12px;
        border-top: 1px solid var(--mud-palette-lines-default);
        margin-top: 12px;
    }

    .mcp-permissions-header {
        display: flex;
        align-items: center;
        gap: 6px;
        margin-bottom: 4px;
    }

    .mcp-tool-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 2px 4px;
        border-radius: 4px;
    }

    .mcp-tool-row:hover {
        background: var(--mud-palette-action-default-hover);
    }

    .mcp-tool-name {
        font-family: var(--font-mono);
        flex: 1;
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .mcp-tool-actions {
        display: flex;
        gap: 0;
        flex-shrink: 0;
    }

    .mcp-add-permission {
        margin-top: 4px;
    }
</style>
