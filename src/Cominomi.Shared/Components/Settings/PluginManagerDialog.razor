@inject IPluginService PluginService
@inject IPluginExecutionEngine PluginEngine
@inject ISnackbar Snackbar

<MudDialog Visible="IsOpen" VisibleChanged="OnVisibleChanged" Options="_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Extension" Class="mr-2" />
            플러그인 관리
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true">
            @* Plugin List Tab *@
            <MudTabPanel Text="설치된 플러그인" Icon="@Icons.Material.Filled.List">
                @if (_loading)
                {
                    <div style="display: flex; justify-content: center; padding: 24px;">
                        <MudProgressCircular Indeterminate="true" Size="Size.Small" />
                    </div>
                }
                else if (_plugins.Count == 0)
                {
                    <div class="pa-4" style="text-align: center;">
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            설치된 플러그인이 없습니다.
                        </MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2">
                            <code>@PluginService.PluginsDirectory</code> 디렉토리에
                            플러그인 폴더와 <code>manifest.json</code>을 추가하세요.
                        </MudText>
                    </div>
                }
                else
                {
                    <MudSimpleTable Dense="true" Hover="true" Class="plugin-table">
                        <thead>
                            <tr>
                                <th>플러그인</th>
                                <th>버전</th>
                                <th>상태</th>
                                <th style="width: 120px;"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var plugin in _plugins)
                            {
                                <tr>
                                    <td>
                                        <div>
                                            <MudText Typo="Typo.body2" Style="font-weight: 500;">@plugin.Name</MudText>
                                            @if (!string.IsNullOrEmpty(plugin.Description))
                                            {
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">@plugin.Description</MudText>
                                            }
                                            @if (!string.IsNullOrEmpty(plugin.Author))
                                            {
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">by @plugin.Author</MudText>
                                            }
                                        </div>
                                    </td>
                                    <td>
                                        <MudText Typo="Typo.body2">@(plugin.Version ?? "-")</MudText>
                                    </td>
                                    <td>
                                        @{
                                            var (icon, color, label) = GetStatusDisplay(plugin);
                                        }
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="@color">
                                            <MudIcon Icon="@icon" Size="Size.Small" Style="width: 14px; height: 14px; margin-right: 4px;" />
                                            @label
                                        </MudChip>
                                        @if (!string.IsNullOrEmpty(plugin.Error))
                                        {
                                            <MudTooltip Text="@plugin.Error">
                                                <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small"
                                                         Color="Color.Warning" Style="width: 14px; height: 14px; margin-left: 4px; cursor: help;" />
                                            </MudTooltip>
                                        }
                                    </td>
                                    <td>
                                        <MudSwitch T="bool" Value="@plugin.IsEnabled"
                                                   ValueChanged="@(v => TogglePlugin(plugin, v))"
                                                   Color="Color.Primary" Size="Size.Small"
                                                   Disabled="@(plugin.Status == PluginStatus.Invalid || plugin.Status == PluginStatus.Error)" />
                                        @if (plugin.IsEnabled && plugin.Status == PluginStatus.Valid)
                                        {
                                            <MudIconButton Icon="@Icons.Material.Filled.PlayArrow" Size="Size.Small"
                                                           Color="Color.Primary" Title="로드"
                                                           OnClick="@(() => LoadPlugin(plugin))" />
                                        }
                                        @if (plugin.Status == PluginStatus.Loaded)
                                        {
                                            <MudIconButton Icon="@Icons.Material.Filled.Stop" Size="Size.Small"
                                                           Color="Color.Warning" Title="언로드"
                                                           OnClick="@(() => UnloadPlugin(plugin))" />
                                        }
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                       Color="Color.Error"
                                                       OnClick="@(() => RemovePlugin(plugin))" />
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </MudSimpleTable>
                }
                <div style="padding: 8px;">
                    <MudButton StartIcon="@Icons.Material.Filled.Refresh" Size="Size.Small"
                               Variant="Variant.Text" OnClick="RefreshPlugins">새로고침</MudButton>
                </div>
            </MudTabPanel>

            @* Info Tab *@
            <MudTabPanel Text="플러그인 만들기" Icon="@Icons.Material.Filled.Help">
                <MudStack Spacing="3" Class="pa-3">
                    <MudText Typo="Typo.subtitle2">플러그인 구조</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        플러그인은 <code>@PluginService.PluginsDirectory</code> 하위에 폴더로 생성합니다.
                        각 폴더에 <code>manifest.json</code> 파일이 필요합니다.
                    </MudText>

                    <MudText Typo="Typo.subtitle2" Class="mt-2">manifest.json 예시</MudText>
                    <pre style="background: var(--mud-palette-background-grey); padding: 12px; border-radius: 4px; font-size: 12px; overflow-x: auto;">
{
  "name": "My Plugin",
  "description": "플러그인 설명",
  "version": "1.0.0",
  "author": "작성자",
  "entryPoint": "main.js",
  "permissions": ["read", "write"],
  "hooks": [
    { "event": "OnMessageComplete", "command": "node {entryPoint} on-message" }
  ],
  "skills": [
    { "name": "my-skill", "description": "스킬 설명", "command": "node {entryPoint} skill" }
  ]
}</pre>

                    <MudText Typo="Typo.subtitle2" Class="mt-2">필드 설명</MudText>
                    <MudSimpleTable Dense="true">
                        <thead>
                            <tr><th>필드</th><th>필수</th><th>설명</th></tr>
                        </thead>
                        <tbody>
                            <tr><td><code>name</code></td><td>권장</td><td>플러그인 표시 이름</td></tr>
                            <tr><td><code>description</code></td><td>선택</td><td>플러그인 설명</td></tr>
                            <tr><td><code>version</code></td><td>선택</td><td>시맨틱 버전</td></tr>
                            <tr><td><code>author</code></td><td>선택</td><td>작성자</td></tr>
                            <tr><td><code>entryPoint</code></td><td>선택</td><td>실행 파일 경로 (.js, .py, .sh 등)</td></tr>
                            <tr><td><code>permissions</code></td><td>선택</td><td>요청 권한 목록</td></tr>
                            <tr><td><code>hooks</code></td><td>선택</td><td>이벤트 훅 배열 (event, command)</td></tr>
                            <tr><td><code>skills</code></td><td>선택</td><td>슬래시 커맨드 배열 (name, command, description)</td></tr>
                        </tbody>
                    </MudSimpleTable>

                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.FolderOpen"
                               OnClick="OpenPluginsDirectory"
                               Style="text-transform: none; align-self: flex-start;">
                        플러그인 디렉토리 열기
                    </MudButton>
                </MudStack>
            </MudTabPanel>
        </MudTabs>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close">닫기</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback<bool> IsOpenChanged { get; set; }

    private List<PluginInfo> _plugins = [];
    private bool _loading;

    private readonly DialogOptions _dialogOptions = new()
    {
        MaxWidth = MaxWidth.Medium,
        FullWidth = true
    };

    protected override async Task OnParametersSetAsync()
    {
        if (IsOpen && _plugins.Count == 0)
            await RefreshPlugins();
    }

    private async Task RefreshPlugins()
    {
        _loading = true;
        StateHasChanged();
        await PluginService.EnsurePluginsDirectoryAsync();
        _plugins = await PluginService.GetInstalledPluginsAsync();
        _loading = false;
        StateHasChanged();
    }

    private async Task TogglePlugin(PluginInfo plugin, bool enabled)
    {
        await PluginService.SetPluginEnabledAsync(plugin.Id, enabled);
        plugin.IsEnabled = enabled;

        if (enabled && plugin.Status == PluginStatus.Valid)
        {
            await LoadPlugin(plugin);
        }
        else if (!enabled && plugin.Status == PluginStatus.Loaded)
        {
            await UnloadPlugin(plugin);
        }

        Snackbar.Add($"'{plugin.Name}' 플러그인이 {(enabled ? "활성화" : "비활성화")}되었습니다.", Severity.Info);
        StateHasChanged();
    }

    private async Task LoadPlugin(PluginInfo plugin)
    {
        var success = await PluginService.LoadPluginAsync(plugin.Id);
        if (success)
        {
            plugin.Status = PluginStatus.Loaded;
            Snackbar.Add($"'{plugin.Name}' 플러그인이 로드되었습니다.", Severity.Success);
        }
        else
        {
            Snackbar.Add($"'{plugin.Name}' 플러그인 로드에 실패했습니다.", Severity.Error);
        }
        StateHasChanged();
    }

    private async Task UnloadPlugin(PluginInfo plugin)
    {
        await PluginService.UnloadPluginAsync(plugin.Id);
        plugin.Status = PluginStatus.Valid;
        Snackbar.Add($"'{plugin.Name}' 플러그인이 언로드되었습니다.", Severity.Info);
        StateHasChanged();
    }

    private async Task RemovePlugin(PluginInfo plugin)
    {
        var result = await PluginService.RemovePluginAsync(plugin.Id);
        if (result)
        {
            Snackbar.Add($"'{plugin.Name}' 플러그인이 제거되었습니다.", Severity.Success);
            await RefreshPlugins();
        }
        else
        {
            Snackbar.Add("플러그인 제거에 실패했습니다.", Severity.Error);
        }
    }

    private async Task OpenPluginsDirectory()
    {
        await PluginService.EnsurePluginsDirectoryAsync();
        try
        {
            System.Diagnostics.Process.Start(new System.Diagnostics.ProcessStartInfo
            {
                FileName = PluginService.PluginsDirectory,
                UseShellExecute = true
            });
        }
        catch
        {
            Snackbar.Add("디렉토리를 열 수 없습니다.", Severity.Warning);
        }
    }

    private static (string icon, Color color, string label) GetStatusDisplay(PluginInfo plugin)
    {
        if (!plugin.IsEnabled)
            return (Icons.Material.Filled.PauseCircle, Color.Default, "비활성");

        return plugin.Status switch
        {
            PluginStatus.Valid => (Icons.Material.Filled.CheckCircle, Color.Success, "정상"),
            PluginStatus.Loaded => (Icons.Material.Filled.CheckCircle, Color.Success, "로드됨"),
            PluginStatus.Invalid => (Icons.Material.Filled.Error, Color.Error, "오류"),
            PluginStatus.Error => (Icons.Material.Filled.Error, Color.Error, "오류"),
            _ => (Icons.Material.Filled.RadioButtonUnchecked, Color.Default, "확인 중"),
        };
    }

    private async Task OnVisibleChanged(bool visible)
    {
        if (IsOpen != visible)
        {
            IsOpen = visible;
            await IsOpenChanged.InvokeAsync(visible);
        }
    }

    private async Task Close()
    {
        IsOpen = false;
        await IsOpenChanged.InvokeAsync(false);
    }
}
