@inject ISettingsService SettingsService
@inject IFolderPickerService FolderPickerService

<MudDialog Visible="IsOpen" VisibleChanged="OnVisibleChanged" Options="_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Settings" Class="mr-2" />
            Settings
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3" Class="pa-2" Style="min-width: 400px;">
            <MudSelect T="string" @bind-Value="_settings.DefaultModel" Label="Default Model"
                       Variant="Variant.Outlined">
                @foreach (var model in ModelDefinitions.All)
                {
                    <MudSelectItem T="string" Value="@model.Id">@model.DisplayName</MudSelectItem>
                }
            </MudSelect>

            <MudSelect T="string" @bind-Value="_settings.Theme" Label="Theme" Variant="Variant.Outlined">
                <MudSelectItem T="string" Value="@("dark")">Dark</MudSelectItem>
                <MudSelectItem T="string" Value="@("light")">Light</MudSelectItem>
                <MudSelectItem T="string" Value="@("system")">System</MudSelectItem>
            </MudSelect>

            <MudTextField @bind-Value="_settings.ClaudePath" Label="Claude CLI Path"
                          Variant="Variant.Outlined" Placeholder="Auto-detect"
                          HelperText="Leave empty for auto-detection" />

            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                <MudTextField @bind-Value="_settings.DefaultCloneDirectory" Label="Clone Directory"
                              Variant="Variant.Outlined" Placeholder="~/Cominomi"
                              HelperText="Where repositories are cloned. Leave empty for default."
                              Style="flex: 1;" />
                <MudIconButton Icon="@Icons.Material.Filled.FolderOpen" Color="Color.Primary"
                               OnClick="BrowseCloneDirectory" Title="Browse..." />
            </MudStack>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Save">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback<bool> IsOpenChanged { get; set; }

    private AppSettings _settings = new();

    private readonly DialogOptions _dialogOptions = new()
    {
        MaxWidth = MaxWidth.Small,
        FullWidth = true
    };

    protected override async Task OnParametersSetAsync()
    {
        if (IsOpen)
        {
            _settings = await SettingsService.LoadAsync();
        }
    }

    private async Task BrowseCloneDirectory()
    {
        var path = await FolderPickerService.PickFolderAsync();
        if (!string.IsNullOrEmpty(path))
        {
            _settings.DefaultCloneDirectory = path;
        }
    }

    private async Task Save()
    {
        await SettingsService.SaveAsync(_settings);
        await Close();
    }

    private async Task OnVisibleChanged(bool visible)
    {
        if (IsOpen != visible)
        {
            IsOpen = visible;
            await IsOpenChanged.InvokeAsync(visible);
        }
    }

    private async Task Close()
    {
        IsOpen = false;
        await IsOpenChanged.InvokeAsync(false);
    }
}
