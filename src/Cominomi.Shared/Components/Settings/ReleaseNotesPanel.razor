@inject IReleaseNotesService ReleaseNotesService

<div class="release-notes-panel">
    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (_releases.Count > 0)
    {
        <MudTimeline TimelinePosition="TimelinePosition.Start">
            @foreach (var release in _releases)
            {
                var isCurrent = release.Version == _currentVersion;

                <MudTimelineItem Color="@(isCurrent ? Color.Primary : Color.Default)"
                                 Size="@(isCurrent ? Size.Medium : Size.Small)"
                                 Variant="@(isCurrent ? Variant.Filled : Variant.Outlined)">
                    <ItemOpposite>
                        <span class="typo-caption text-secondary">@release.Date</span>
                    </ItemOpposite>
                    <ItemContent>
                        <div class="release-note-item">
                            <div class="stack-row items-center gap-2" style="margin-bottom: 4px;">
                                <span class="typo-subtitle2">v@(release.Version)</span>
                                @if (isCurrent)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Primary"
                                             Variant="Variant.Outlined">현재 버전</MudChip>
                                }
                            </div>
                            <div class="release-note-changes">
                                @foreach (var change in release.Changes)
                                {
                                    <div class="release-note-change">
                                        <MudChip T="string" Size="Size.Small"
                                                 Color="@(change.Type == "feat" ? Color.Success : Color.Warning)"
                                                 Variant="Variant.Text"
                                                 Style="min-width: 40px; justify-content: center;">
                                            @(change.Type == "feat" ? "기능" : "수정")
                                        </MudChip>
                                        <span class="typo-body2">@change.Description</span>
                                    </div>
                                }
                            </div>
                        </div>
                    </ItemContent>
                </MudTimelineItem>
            }
        </MudTimeline>
    }
    else
    {
        <span class="typo-body2 text-secondary">릴리스 노트를 불러올 수 없습니다.</span>
    }
</div>

@code {
    private IReadOnlyList<ReleaseNote> _releases = [];
    private bool _loading = true;
    private string _currentVersion = "";

    protected override async Task OnInitializedAsync()
    {
        _currentVersion = System.Reflection.Assembly.GetEntryAssembly()
            ?.GetName().Version?.ToString(3) ?? "";
        _releases = await ReleaseNotesService.GetReleaseNotesAsync();
        _loading = false;
    }
}
