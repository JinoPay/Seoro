@using System.Reflection
@inject IReleaseNotesService ReleaseNotesService

<div class="release-notes-panel">
    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary"/>
    }
    else if (_releases.Count > 0)
    {
        @foreach (var release in _releases)
        {
            var isCurrent = release.Version == _currentVersion;

            <div class="rn-card @(isCurrent ? "rn-card--current" : "")">
                <div class="rn-header">
                    <div class="rn-version-row">
                        <span class="rn-version">v@(release.Version)</span>
                        @if (isCurrent)
                        {
                            <span class="rn-badge rn-badge--current">현재 버전</span>
                        }
                    </div>
                    <span class="rn-date">@FormatDate(release.Date)</span>
                </div>
                <div class="rn-changes">
                    @foreach (var change in release.Changes)
                    {
                        <div class="rn-change">
                            <span class="rn-tag rn-tag--@change.Type">@GetTypeLabel(change.Type)</span>
                            <span class="rn-desc">@change.Description</span>
                        </div>
                    }
                </div>
            </div>
        }
    }
    else
    {
        <span class="typo-body2 text-secondary">릴리스 노트를 불러올 수 없습니다.</span>
    }
</div>

@code {
    private IReadOnlyList<ReleaseNote> _releases = [];
    private bool _loading = true;
    private string _currentVersion = "";

    protected override async Task OnInitializedAsync()
    {
        _currentVersion = Assembly.GetEntryAssembly()
            ?.GetName().Version?.ToString(3) ?? "";
        _releases = await ReleaseNotesService.GetReleaseNotesAsync();
        _loading = false;
    }

    private static string GetTypeLabel(string type)
    {
        return type switch
        {
            "feat" => "기능",
            "fix" => "수정",
            "refactor" => "개선",
            _ => type
        };
    }

    private string FormatDate(string dateStr)
    {
        if (!DateOnly.TryParse(dateStr, out var date))
            return dateStr;

        var today = DateOnly.FromDateTime(DateTime.Now);
        var diff = today.DayNumber - date.DayNumber;

        var relative = diff switch
        {
            0 => "오늘",
            1 => "어제",
            2 => "그저께",
            _ when diff > 0 && diff <= 7 => $"{diff}일 전",
            _ => null
        };

        var formatted = $"{date.Year}년 {date.Month}월 {date.Day}일";
        return relative is not null ? $"{formatted} ({relative})" : formatted;
    }

}
