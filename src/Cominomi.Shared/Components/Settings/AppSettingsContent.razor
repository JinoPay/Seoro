@inject ISettingsService SettingsService
@inject ISnackbar Snackbar

<div class="settings-content-area">
    <div class="settings-content-header">
        @if (Section != "shortcuts" && Section != "extensions")
        {
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Save"
                       Size="Size.Small" Style="text-transform: none;">
                저장
            </MudButton>
        }
    </div>

    <div class="settings-content-body">
        @switch (Section)
        {
            case "general":
                <Sections.GeneralSection Settings="_settings" />
                break;
            case "notifications":
                <Sections.NotificationsSection Settings="_settings" OnSave="Save" />
                break;
            case "terminal":
                <Sections.TerminalSection Settings="_settings" OnSave="Save" />
                break;
            case "shortcuts":
                <Sections.ShortcutsSection />
                break;
            case "ai":
                <Sections.AiModelSection Settings="_settings" />
                break;
            case "integrations":
                <Sections.IntegrationsSection Settings="_settings" />
                break;
            case "extensions":
                <Sections.ExtensionsSection />
                break;
            case "advanced":
                <Sections.AdvancedSection Settings="_settings" />
                break;
            case "updates":
                <Sections.UpdatesSection Settings="_settings" />
                break;
        }
    </div>
</div>

@code {
    [Parameter] public string Section { get; set; } = "general";

    private AppSettings _settings = new();

    protected override async Task OnInitializedAsync()
    {
        _settings = await SettingsService.LoadAsync();
    }

    private async Task Save()
    {
        await SettingsService.SaveAsync(_settings);
        Snackbar.SettingsSaved();
    }
}
