@inject ISettingsService SettingsService
@inject IFolderPickerService FolderPickerService
@inject IClaudeService ClaudeService
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<div class="settings-content-area">
    <div class="settings-content-header">
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Save"
                   Size="Size.Small" Style="text-transform: none;">
            저장
        </MudButton>
    </div>

    <div class="settings-content-body">
        @if (Section == "general")
        {
            <div class="settings-section-title">일반</div>
            <div class="settings-section-desc">앱의 기본 동작을 설정합니다.</div>

            <div class="stack gap-3">
                <MudSelect T="string" @bind-Value="_settings.Theme" Label="테마"
                           Variant="Variant.Outlined" Margin="Margin.Dense">
                    <MudSelectItem T="string" Value="@("dark")">다크</MudSelectItem>
                    <MudSelectItem T="string" Value="@("light")">라이트</MudSelectItem>
                    <MudSelectItem T="string" Value="@("system")">시스템</MudSelectItem>
                </MudSelect>

                <div class="settings-group-title" style="margin-top: 16px;">화면 배율</div>

                <div class="stack gap-1">
                    <div class="stack-row items-center gap-2">
                        <MudSlider T="double"
                                   Value="@(_settings.UiScale == 0 ? _autoDefault : _settings.UiScale)"
                                   ValueChanged="@(v => { _settings.UiScale = v; _ = ApplyUiScalePreview(v); })"
                                   Min="0.8" Max="1.5" Step="0.05"
                                   Color="Color.Primary"
                                   Style="flex: 1;" />
                        <span class="typo-body2" style="min-width: 48px; text-align: right;">
                            @((_settings.UiScale == 0 ? _autoDefault : _settings.UiScale).ToString("P0"))
                        </span>
                    </div>

                    <div class="stack-row gap-1 items-center">
                        <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Default"
                                   OnClick="@(() => { _settings.UiScale = 0; _ = ApplyUiScalePreview(_autoDefault); })"
                                   Style="text-transform: none;">
                            자동 (플랫폼 기본값)
                        </MudButton>
                        <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Default"
                                   OnClick="@(() => { _settings.UiScale = 1.0; _ = ApplyUiScalePreview(1.0); })"
                                   Style="text-transform: none;">
                            100%
                        </MudButton>
                    </div>

                    <small class="typo-caption text-secondary">
                        macOS 기본값: 110%, Windows 기본값: 100%. 슬라이더 조작 시 바로 미리보기됩니다.
                    </small>
                </div>

                <div class="settings-group-title" style="margin-top: 16px;">알림</div>

                <MudSwitch T="bool" @bind-Value="_settings.NotificationsEnabled" Label="데스크톱 알림"
                           Color="Color.Primary" UncheckedColor="Color.Default" />
                <small class="typo-caption text-secondary" style="margin-top: -8px;">
                    작업 완료, 응답 대기, 플랜 리뷰 시 OS 알림을 발송합니다.
                </small>

                <MudSwitch T="bool" @bind-Value="_settings.NotificationSound" Label="알림 사운드"
                           Color="Color.Primary" UncheckedColor="Color.Default"
                           Disabled="@(!_settings.NotificationsEnabled)" />

                <div class="settings-group-title" style="margin-top: 16px;">Git 워크플로우</div>

                <div class="stack-row items-center gap-1">
                    <MudTextField @bind-Value="_settings.DefaultCloneDirectory" Label="클론 디렉토리"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Placeholder="~/Cominomi"
                                  HelperText="저장소가 클론되는 위치입니다. 비워두면 기본값을 사용합니다."
                                  Style="flex: 1;" />
                    <MudIconButton Icon="@Icons.Material.Filled.FolderOpen" Color="Color.Primary"
                                   OnClick="BrowseCloneDirectory" Title="찾아보기..." />
                </div>
            </div>
        }
        else if (Section == "ai")
        {
            <div class="settings-section-title">AI 모델</div>
            <div class="settings-section-desc">AI 모델 및 동작 방식을 설정합니다.</div>

            <div class="stack gap-3">
                <MudSelect T="string" @bind-Value="_settings.DefaultModel" Label="기본 모델"
                           Variant="Variant.Outlined" Margin="Margin.Dense">
                    @foreach (var model in ModelDefinitions.All)
                    {
                        <MudSelectItem T="string" Value="@model.Id">@model.DisplayName</MudSelectItem>
                    }
                </MudSelect>

                <MudSelect T="string" @bind-Value="_settings.DefaultEffortLevel" Label="기본 Effort 레벨"
                           Variant="Variant.Outlined" Margin="Margin.Dense"
                           HelperText="auto: 모델 기본값 / max: 확장 사고 모드 (Opus만 지원)">
                    <MudSelectItem T="string" Value="@("auto")">Auto</MudSelectItem>
                    <MudSelectItem T="string" Value="@("max")">Max (Thinking)</MudSelectItem>
                </MudSelect>

                <MudSelect T="string" @bind-Value="_settings.DefaultPermissionMode" Label="기본 권한 모드"
                           Variant="Variant.Outlined" Margin="Margin.Dense">
                    <MudSelectItem T="string" Value="@("bypassAll")">일반 모드</MudSelectItem>
                    <MudSelectItem T="string" Value="@("plan")">플랜 모드</MudSelectItem>
                </MudSelect>

                <MudTextField @bind-Value="_settings.FallbackModel" Label="Fallback 모델"
                              Variant="Variant.Outlined" Margin="Margin.Dense"
                              Placeholder="sonnet"
                              HelperText="기본 모델 과부하 시 대체 모델 (비워두면 미사용)" />

                <MudTextField @bind-Value="_settings.McpConfigPath" Label="MCP 설정 파일 경로"
                              Variant="Variant.Outlined" Margin="Margin.Dense"
                              Placeholder="./mcp.json"
                              HelperText="MCP 서버 설정 JSON 파일 경로 (비워두면 미사용)" />

                <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Hub"
                           OnClick="@(() => _mcpManagerOpen = true)"
                           Style="text-transform: none;">
                    MCP 서버 관리
                </MudButton>
            </div>
        }
        else if (Section == "integrations")
        {
            <div class="settings-section-title">연동</div>
            <div class="settings-section-desc">외부 서비스 연결 상태를 확인합니다.</div>

            <div class="settings-group">
                <div class="settings-group-title">Claude CLI</div>
                <div class="integration-status">
                    @if (_claudeCliChecking)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true"
                                             Style="width: 18px; height: 18px;" />
                        <span class="status-text">감지 중...</span>
                    }
                    else if (_claudeCliFound)
                    {
                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small"
                                 Class="status-ok" />
                        <span class="status-text">감지됨</span>
                        @if (!string.IsNullOrEmpty(_claudeCliResolvedPath))
                        {
                            <span class="status-path">@_claudeCliResolvedPath</span>
                        }
                    }
                    else
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Warning" Size="Size.Small"
                                 Class="status-warn" />
                        <span class="status-text">감지되지 않음</span>
                    }
                    <MudIconButton Icon="@Icons.Material.Filled.Refresh" Size="Size.Small"
                                   OnClick="CheckClaudeCli" Title="다시 확인" />
                </div>

                <MudTextField @bind-Value="_settings.ClaudePath" Label="Claude CLI 경로"
                              Variant="Variant.Outlined" Margin="Margin.Dense"
                              Placeholder="자동 감지" Class="mt-3"
                              HelperText="비워두면 자동으로 감지합니다" />
            </div>
        }
        else if (Section == "mcp")
        {
            <div class="settings-section-title">MCP 서버</div>
            <div class="settings-section-desc">Model Context Protocol 서버를 관리합니다.</div>

            <div class="stack gap-3">
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Hub"
                           OnClick="@(() => _mcpManagerOpen = true)"
                           Style="text-transform: none; align-self: flex-start;">
                    MCP 서버 관리 열기
                </MudButton>
                <small class="typo-caption text-secondary">
                    MCP 서버 추가/제거, Claude Desktop에서 가져오기, JSON 가져오기 등을 지원합니다.
                </small>
            </div>
        }
        else if (Section == "plugins")
        {
            <div class="settings-section-title">플러그인</div>
            <div class="settings-section-desc">플러그인을 설치하고 관리합니다.</div>

            <div class="stack gap-3">
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Extension"
                           OnClick="@(() => _pluginManagerOpen = true)"
                           Style="text-transform: none; align-self: flex-start;">
                    플러그인 관리 열기
                </MudButton>
                <small class="typo-caption text-secondary">
                    플러그인 설치, 활성화/비활성화, 제거를 관리합니다.
                </small>
            </div>
        }
        else if (Section == "commands")
        {
            <div class="settings-section-title">슬래시 명령어</div>
            <div class="settings-section-desc">커스텀 슬래시 명령어를 관리합니다.</div>

            <div class="stack gap-3">
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Code"
                           OnClick="@(() => _slashCommandsOpen = true)"
                           Style="text-transform: none; align-self: flex-start;">
                    명령어 관리 열기
                </MudButton>
                <small class="typo-caption text-secondary">
                    커스텀 슬래시 명령어를 만들고 편집합니다. ~/.claude/commands/ 또는 프로젝트별 .claude/commands/ 에 저장됩니다.
                </small>
            </div>
        }
        else if (Section == "advanced")
        {
            <div class="settings-section-title">고급</div>
            <div class="settings-section-desc">Claude CLI 고급 설정 및 환경변수를 관리합니다.</div>

            <div class="stack gap-3">
                <MudSwitch T="bool" @bind-Value="_settings.DebugMode" Label="디버그 모드"
                           Color="Color.Warning" UncheckedColor="Color.Default" />
                <small class="typo-caption text-secondary" style="margin-top: -8px;">
                    활성화하면 Claude CLI에 --debug 플래그를 전달합니다.
                </small>
            </div>

            <div class="settings-group-title" style="margin-top: 16px;">환경변수</div>

            <div class="stack gap-2">
                @foreach (var key in _settings.EnvironmentVariables.Keys.ToList())
                {
                    <div class="stack-row gap-1 items-center">
                        <MudTextField T="string" Value="@key" ReadOnly="true"
                                      Variant="Variant.Outlined" Margin="Margin.Dense"
                                      Style="flex: 0.4;" />
                        <MudTextField T="string" Value="@_settings.EnvironmentVariables[key]"
                                      ValueChanged="@(v => _settings.EnvironmentVariables[key] = v)"
                                      Variant="Variant.Outlined" Margin="Margin.Dense"
                                      Style="flex: 0.6;"
                                      InputType="@(key.Contains("KEY", StringComparison.OrdinalIgnoreCase) ? InputType.Password : InputType.Text)" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                       Color="Color.Error"
                                       OnClick="@(() => RemoveEnvVar(key))" />
                    </div>
                }

                <div class="stack-row gap-1 items-center">
                    <MudTextField @bind-Value="_newEnvKey" Placeholder="변수명"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Style="flex: 0.4;" />
                    <MudTextField @bind-Value="_newEnvValue" Placeholder="값"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Style="flex: 0.6;" />
                    <MudIconButton Icon="@Icons.Material.Filled.Add" Size="Size.Small"
                                   Color="Color.Primary"
                                   OnClick="AddEnvVar"
                                   Disabled="@(string.IsNullOrWhiteSpace(_newEnvKey))" />
                </div>

                <small class="typo-caption text-secondary">
                    예: ANTHROPIC_API_KEY, CLAUDE_CODE_USE_BEDROCK, CLAUDE_CODE_MAX_OUTPUT_TOKENS
                </small>
            </div>
        }
    </div>
</div>

<McpManagerDialog @bind-IsOpen="_mcpManagerOpen" />
<SlashCommandsEditor @bind-IsOpen="_slashCommandsOpen" />
<PluginManagerDialog @bind-IsOpen="_pluginManagerOpen" />

@code {
    [Parameter] public string Section { get; set; } = "general";

    private AppSettings _settings = new();
    private string _lastSection = "";

    private bool _claudeCliChecking;
    private bool _claudeCliFound;
    private string? _claudeCliResolvedPath;
    private string _newEnvKey = "";
    private string _newEnvValue = "";
    private bool _mcpManagerOpen;
    private bool _slashCommandsOpen;
    private bool _pluginManagerOpen;
    private double _autoDefault = 1.0;

    protected override async Task OnInitializedAsync()
    {
        _settings = await SettingsService.LoadAsync();
        try { _autoDefault = await JS.InvokeAsync<double>("getDefaultUiScale"); } catch { }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (Section != _lastSection)
        {
            _lastSection = Section;
            if (Section == "integrations")
            {
                _ = CheckIntegrations();
            }
        }
    }

    private async Task CheckIntegrations()
    {
        await CheckClaudeCli();
    }

    private async Task CheckClaudeCli()
    {
        _claudeCliChecking = true;
        StateHasChanged();
        var (found, path) = await ClaudeService.DetectCliAsync();
        _claudeCliFound = found;
        _claudeCliResolvedPath = path;
        _claudeCliChecking = false;
        StateHasChanged();
    }

    private async Task BrowseCloneDirectory()
    {
        var path = await FolderPickerService.PickFolderAsync();
        if (!string.IsNullOrEmpty(path))
        {
            _settings.DefaultCloneDirectory = path;
        }
    }

    private void AddEnvVar()
    {
        if (!string.IsNullOrWhiteSpace(_newEnvKey))
        {
            _settings.EnvironmentVariables[_newEnvKey.Trim()] = _newEnvValue;
            _newEnvKey = "";
            _newEnvValue = "";
        }
    }

    private void RemoveEnvVar(string key)
    {
        _settings.EnvironmentVariables.Remove(key);
    }

    private async Task ApplyUiScalePreview(double scale)
    {
        try { await JS.InvokeVoidAsync("setUiScale", scale); } catch { }
    }

    private async Task Save()
    {
        await SettingsService.SaveAsync(_settings);
        Snackbar.SettingsSaved();
    }
}
