@using System.Text
@using System.Text.Json
@inject IStatsCacheService StatsCacheService
@inject IGamificationService GamificationService
@inject IChatState ChatState
@inject IJSRuntime JS

<div class="usage-dashboard">
    @* 1. Date range filter + navigation *@
    <div class="usage-top-bar">
        <div class="usage-date-filter">
            <MudChipSet T="string" SelectedValue="_selectedRange" SelectedValueChanged="OnRangeChanged"
                        SelectionMode="SelectionMode.SingleSelection" CheckMark="false"
                        Variant="Variant.Outlined" Color="Color.Primary">
                <MudChip T="string" Value="@("7")">7일</MudChip>
                <MudChip T="string" Value="@("30")">30일</MudChip>
                <MudChip T="string" Value="@("all")">전체</MudChip>
            </MudChipSet>
        </div>
        <div style="display: flex; align-items: center; gap: 4px;">
            @if (_refreshing)
            {
                <MudProgressCircular Indeterminate="true" Size="Size.Small" Style="width: 20px; height: 20px;"/>
            }
            <MudIconButton Icon="@Icons.Material.Filled.Refresh" Size="Size.Small"
                           Disabled="_refreshing || _loading"
                           OnClick="OnRefreshClick"
                           Title="통계 새로고침"/>
            <button class="analytics-nav-link" @onclick="@(() => ChatState.SetSettingsSection("session-replay"))">
                <MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Small"/>
                세션 히스토리 →
            </button>
        </div>
    </div>

    @if (_loading)
    {
        <div style="display: flex; justify-content: center; padding: 40px;">
            <MudProgressCircular Indeterminate="true"/>
        </div>
    }
    else if (_stats != null)
    {
        @* 1.5. Global Activity Overview (filtered by selected period) *@
        <div class="analytics-activity-overview">
            @{
                var summary = GetFilteredActivitySummary();
            }
            <div class="analytics-activity-header">
                <div class="analytics-section-title" style="margin-bottom: 0;">
                    <MudIcon Icon="@Icons.Material.Filled.Insights" Size="Size.Small"/>
                    전체 활동 요약
                </div>
                <span
                    class="analytics-activity-badge">@(_selectedRange == "all" ? "컴퓨터 내 모든 세션" : $"최근 {_selectedRange}일")</span>
            </div>
            <div class="analytics-activity-stats">
                <div class="analytics-activity-stat">
                    <MudIcon Icon="@Icons.Material.Filled.Forum" Size="Size.Small" Style="font-size: 0.85rem;"/>
                    <span class="analytics-activity-num">@FormatNumber(summary.Sessions)</span>
                    <span class="analytics-activity-label">세션</span>
                </div>
                <div class="analytics-activity-stat">
                    <MudIcon Icon="@Icons.Material.Filled.ChatBubbleOutline" Size="Size.Small"
                             Style="font-size: 0.85rem;"/>
                    <span class="analytics-activity-num">@FormatNumber(summary.Messages)</span>
                    <span class="analytics-activity-label">메시지</span>
                </div>
                <div class="analytics-activity-stat">
                    <MudIcon Icon="@Icons.Material.Filled.Build" Size="Size.Small" Style="font-size: 0.85rem;"/>
                    <span class="analytics-activity-num">@FormatNumber(summary.ToolCalls)</span>
                    <span class="analytics-activity-label">도구 호출</span>
                </div>
                <div class="analytics-activity-stat">
                    <MudIcon Icon="@Icons.Material.Filled.CalendarToday" Size="Size.Small" Style="font-size: 0.85rem;"/>
                    <span class="analytics-activity-num">@summary.ActiveDays</span>
                    <span class="analytics-activity-label">활동일</span>
                </div>
            </div>
            @if (_dashStats.Cost is { } cost)
            {
                <div class="analytics-activity-cost">
                    <span>오늘 $@cost.Today.ToString("F2")</span>
                    <span class="analytics-activity-sep">·</span>
                    <span>이번달 $@cost.ThisMonth.ToString("F2")</span>
                    <span class="analytics-activity-sep">·</span>
                    <span>추정 $@cost.MonthlyProjection.ToString("F2")/월</span>
                </div>
            }
        </div>

        @* 2. Token/Cost Detail Stats (4-card grid) *@
        <div class="analytics-top-stats">
            <div class="analytics-stat-card">
                <div class="analytics-stat-icon" style="color: var(--mud-palette-success);">
                    <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Size="Size.Small"/>
                </div>
                <div class="analytics-stat-content">
                    <div class="analytics-stat-label">총 비용</div>
                    <div class="analytics-stat-value" style="color: var(--mud-palette-success);">
                        $@_stats.TotalCost.ToString("F2")
                    </div>
                    <div class="analytics-stat-subtitle">$@CostPerMessage.ToString("F4")/메시지 · @summary.Sessions 세션
                    </div>
                </div>
            </div>

            <div class="analytics-stat-card">
                <div class="analytics-stat-icon" style="color: var(--mud-palette-info);">
                    <MudIcon Icon="@Icons.Material.Filled.Token" Size="Size.Small"/>
                </div>
                <div class="analytics-stat-content">
                    <div class="analytics-stat-label">총 토큰</div>
                    <div class="analytics-stat-value" style="color: var(--mud-palette-info);">
                        @FormatTokens(_stats.TotalTokens)
                    </div>
                    <div class="analytics-stat-subtitle">평균 @FormatTokens(AvgDailyTokens)/일</div>
                </div>
            </div>

            <div class="analytics-stat-card">
                <div class="analytics-stat-icon" style="color: var(--mud-palette-warning);">
                    <MudIcon Icon="@Icons.Material.Filled.Timer" Size="Size.Small"/>
                </div>
                <div class="analytics-stat-content">
                    <div class="analytics-stat-label">최장 세션</div>
                    <div class="analytics-stat-value" style="color: var(--mud-palette-warning);">
                        @FormatDuration(_selectedRange == "all"
                            ? _dashStats.LongestSessionMs > 0 ? _dashStats.LongestSessionMs : _stats.LongestSession?.DurationMs ?? 0
                            : _stats.LongestSession?.DurationMs ?? 0)
                    </div>
                    <div
                        class="analytics-stat-subtitle">@(_selectedRange == "all" ? "전체 세션 중 최장" : $"최근 {_selectedRange}일 중 최장")</div>
                </div>
            </div>

            <div class="analytics-stat-card">
                <div class="analytics-stat-icon" style="color: var(--mud-palette-primary);">
                    <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" Size="Size.Small"/>
                </div>
                <div class="analytics-stat-content">
                    <div class="analytics-stat-label">활성 시작</div>
                    <div class="analytics-stat-value" style="color: var(--mud-palette-primary);">
                        @FormatActiveSince(_stats.FirstSessionDate)
                    </div>
                    <div class="analytics-stat-subtitle">@FormatDaysAgo(_stats.FirstSessionDate)</div>
                </div>
            </div>
        </div>

        @* 3. Model Usage *@
        @if (_stats.ByModel.Count > 0)
        {
            <div class="analytics-section-card">
                <div class="analytics-section-title">
                    <MudIcon Icon="@Icons.Material.Filled.Memory" Size="Size.Small"/>
                    모델별 사용량
                </div>
                @foreach (var model in _stats.ByModel)
                {
                    var color = GetModelColor(model.Model);
                    var pricing = ModelDefinitions.GetPricing(model.Model);
                    <div class="analytics-model-row">
                        <div class="analytics-model-header">
                            <div class="analytics-model-name">
                                <span class="analytics-model-dot" style="background: @color;"></span>
                                @model.Model
                            </div>
                            <div class="analytics-model-meta">
                                <span class="analytics-model-pct">@model.Percentage.ToString("F1")%</span>
                                <span class="analytics-model-cost">$@model.TotalCost.ToString("F4")</span>
                            </div>
                        </div>
                        <div class="analytics-model-bars">
                            @{ var modelTotal = Math.Max(model.InputTokens + model.OutputTokens + model.CacheCreationTokens + model.CacheReadTokens, 1); }
                            <div class="analytics-bar-item">
                                <div class="analytics-bar-label">
                                    <span>입력</span>
                                    <span>@FormatTokens(model.InputTokens)</span>
                                </div>
                                <div class="analytics-bar-track">
                                    <div class="analytics-bar-fill"
                                         style="width: @GetPercent(model.InputTokens, modelTotal)%; background: var(--mud-palette-info);"></div>
                                </div>
                            </div>
                            <div class="analytics-bar-item">
                                <div class="analytics-bar-label">
                                    <span>출력</span>
                                    <span>@FormatTokens(model.OutputTokens)</span>
                                </div>
                                <div class="analytics-bar-track">
                                    <div class="analytics-bar-fill"
                                         style="width: @GetPercent(model.OutputTokens, modelTotal)%; background: var(--mud-palette-success);"></div>
                                </div>
                            </div>
                            <div class="analytics-bar-item">
                                <div class="analytics-bar-label">
                                    <span>캐시 읽기</span>
                                    <span>@FormatTokens(model.CacheReadTokens)</span>
                                </div>
                                <div class="analytics-bar-track">
                                    <div class="analytics-bar-fill"
                                         style="width: @GetPercent(model.CacheReadTokens, modelTotal)%; background: var(--mud-palette-warning);"></div>
                                </div>
                            </div>
                            <div class="analytics-bar-item">
                                <div class="analytics-bar-label">
                                    <span>캐시 쓰기</span>
                                    <span>@FormatTokens(model.CacheCreationTokens)</span>
                                </div>
                                <div class="analytics-bar-track">
                                    <div class="analytics-bar-fill"
                                         style="width: @GetPercent(model.CacheCreationTokens, modelTotal)%; background: var(--mud-palette-primary);"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }

        @* 4. Charts (2-column grid) *@
        <div class="analytics-charts-grid">
            @* Daily Activity (session-replay based — covers ALL sessions) *@
            <div class="analytics-section-card">
                <div class="analytics-section-header">
                    <div class="analytics-section-title">
                        <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Size="Size.Small"/>
                        일별 활동 (@(_selectedRange == "all" ? "전체" : $"{_selectedRange}일"))
                    </div>
                    <span class="analytics-section-meta">평균 @AvgDailyMessages 메시지/일</span>
                </div>
                @{
                    var rangeDays = _selectedRange == "all"
                        ? _dashStats.DailyActivity.Count > 0
                            ? Math.Max((int)(DateTime.Today - DateTime.Parse(_dashStats.DailyActivity.First().Date)).TotalDays + 1, 30)
                            : 30
                        : int.Parse(_selectedRange);
                    var activityData = PadDailyActivity(GetFilteredDailyActivity(), rangeDays);
                    var maxDailyMessages = activityData.Count > 0 ? activityData.Max(d => d.MessageCount) : 1;
                    if (maxDailyMessages == 0)
                    {
                        maxDailyMessages = 1;
                    }
                }
                @if (activityData.Count > 0)
                {
                    <div class="analytics-chart-container">
                        <div class="analytics-chart-bars">
                            @foreach (var day in activityData)
                            {
                                var heightPct = day.MessageCount > 0 ? Math.Max((double)day.MessageCount / maxDailyMessages * 100, 2) : 2;
                                <div class="analytics-chart-bar-wrapper"
                                     title="@FormatChartDate(day.Date): @day.MessageCount 메시지 · @day.SessionCount 세션">
                                    <div class="analytics-chart-bar @(day.MessageCount == 0 ? "inactive" : "")"
                                         style="height: @heightPct.ToString("F1")%;"></div>
                                </div>
                            }
                        </div>
                        <div class="analytics-chart-x-labels">
                            <span>@activityData.First().Date[5..]</span>
                            <span>@activityData.Last().Date[5..]</span>
                        </div>
                    </div>
                }
                else
                {
                    <p class="analytics-no-data">데이터 없음</p>
                }
            </div>

            @* Hourly Activity (session-replay based — covers ALL sessions) *@
            <div class="analytics-section-card">
                @{
                    var hourCounts = _dashStats.HourCounts;
                    var peakHourIdx = hourCounts.Any(h => h > 0)
                        ? Array.IndexOf(hourCounts, hourCounts.Max())
                        : -1;
                }
                <div class="analytics-section-header">
                    <div class="analytics-section-title">
                        <MudIcon Icon="@Icons.Material.Filled.FlashOn" Size="Size.Small"/>
                        시간대별 활동
                    </div>
                    @if (peakHourIdx >= 0)
                    {
                        <span
                            class="analytics-section-meta">피크: @($"{peakHourIdx:D2}:00") (@hourCounts[peakHourIdx]건)</span>
                    }
                </div>
                @if (hourCounts.Any(h => h > 0))
                {
                    var maxHour = hourCounts.Max();
                    if (maxHour == 0)
                    {
                        maxHour = 1;
                    }

                    <div class="analytics-chart-container">
                        <div class="analytics-chart-bars">
                            @for (var h = 0; h < 24; h++)
                            {
                                var hourCount = hourCounts[h];
                                var heightPct = hourCount > 0 ? Math.Max((double)hourCount / maxHour * 100, 2) : 2;
                                var isPeak = h == peakHourIdx;
                                <div class="analytics-chart-bar-wrapper" title="@($"{h:D2}:00 — {hourCount}세션")">
                                    <div
                                        class="analytics-chart-bar @(isPeak ? "peak" : "") @(hourCount == 0 ? "inactive" : "")"
                                        style="height: @heightPct.ToString("F1")%;"></div>
                                </div>
                            }
                        </div>
                        <div class="analytics-chart-x-labels">
                            <span>0:00</span>
                            <span>6:00</span>
                            <span>12:00</span>
                            <span>18:00</span>
                            <span>23:00</span>
                        </div>
                    </div>
                }
                else
                {
                    <p class="analytics-no-data">데이터 없음</p>
                }
            </div>
        </div>

        @* 5. Cache Efficiency *@
        @if (TotalCacheTokens > 0)
        {
            <div class="analytics-section-card">
                <div class="analytics-section-title">
                    <MudIcon Icon="@Icons.Material.Filled.Storage" Size="Size.Small"/>
                    캐시 효율
                </div>
                <div class="analytics-cache-stats">
                    <div class="analytics-cache-stat">
                        <div class="analytics-cache-stat-label">캐시 히트율</div>
                        <div class="analytics-cache-stat-value" style="color: var(--mud-palette-success);">
                            @CacheEfficiencyRate.ToString("F1")%
                        </div>
                        <div class="analytics-cache-stat-sub">캐시에서 @FormatTokens(_stats?.TotalCacheReadTokens ?? 0) 토큰
                        </div>
                    </div>
                    <div class="analytics-cache-stat">
                        <div class="analytics-cache-stat-label">총 캐시 볼륨</div>
                        <div class="analytics-cache-stat-value" style="color: var(--mud-palette-info);">
                            @FormatTokens(TotalCacheTokens)
                        </div>
                        <div class="analytics-cache-stat-sub">읽기 @FormatTokens(_stats?.TotalCacheReadTokens ?? 0) ·
                            쓰기 @FormatTokens(_stats?.TotalCacheCreationTokens ?? 0)</div>
                    </div>
                    <div class="analytics-cache-stat">
                        <div class="analytics-cache-stat-label">예상 절감액</div>
                        <div class="analytics-cache-stat-value" style="color: var(--mud-palette-success);">
                            $@EstimatedCacheSavings.ToString("F2")
                        </div>
                        <div class="analytics-cache-stat-sub">정가 입력 토큰 대비</div>
                    </div>
                </div>

                @* Segmented bar *@
                @{
                    var allTokens = _stats.TotalInputTokens + _stats.TotalCacheReadTokens + _stats.TotalCacheCreationTokens;
                    if (allTokens == 0)
                    {
                        allTokens = 1;
                    }
                }
                <div class="analytics-segmented-bar">
                    <div class="analytics-segment input" style="width: @GetPercent(_stats.TotalInputTokens, allTokens)%"
                         title="입력: @FormatTokens(_stats.TotalInputTokens)"></div>
                    <div class="analytics-segment cache-read"
                         style="width: @GetPercent(_stats.TotalCacheReadTokens, allTokens)%"
                         title="캐시 읽기: @FormatTokens(_stats.TotalCacheReadTokens)"></div>
                    <div class="analytics-segment cache-write"
                         style="width: @GetPercent(_stats.TotalCacheCreationTokens, allTokens)%"
                         title="캐시 쓰기: @FormatTokens(_stats.TotalCacheCreationTokens)"></div>
                </div>
                <div class="analytics-segment-legend">
                    <span class="legend-item"><span
                            class="legend-dot input"></span>입력 (@GetPercent(_stats.TotalInputTokens, allTokens)%)</span>
                    <span class="legend-item"><span
                            class="legend-dot cache-read"></span>캐시 읽기 (@GetPercent(_stats.TotalCacheReadTokens, allTokens)%)</span>
                    <span class="legend-item"><span
                            class="legend-dot cache-write"></span>캐시 쓰기 (@GetPercent(_stats.TotalCacheCreationTokens, allTokens)%)</span>
                </div>
            </div>
        }

        @* 6. Project breakdown *@
        @if (_stats.ByProject.Count > 0)
        {
            <div class="analytics-section-card">
                <div class="analytics-section-title">
                    <MudIcon Icon="@Icons.Material.Filled.FolderOpen" Size="Size.Small"/>
                    프로젝트별 사용량
                </div>
                <MudSimpleTable Dense="true" Hover="true" Striped="true" Class="usage-table">
                    <thead>
                    <tr>
                        <th>프로젝트</th>
                        <th style="text-align: right;">비용</th>
                        <th style="text-align: right;">토큰</th>
                        <th style="text-align: right;">세션</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var p in _stats.ByProject)
                    {
                        <tr>
                            <td title="@p.ProjectPath">@p.ProjectName</td>
                            <td style="text-align: right;">$@p.TotalCost.ToString("F4")</td>
                            <td style="text-align: right;">@FormatTokens(p.TotalTokens)</td>
                            <td style="text-align: right;">@p.SessionCount</td>
                        </tr>
                    }
                    </tbody>
                </MudSimpleTable>
            </div>
        }

        @* 7. Export actions *@
        <div class="usage-export-actions">
            <MudButton OnClick="ExportCsv" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Download"
                       Disabled="_exporting" Size="Size.Small">
                @(_exporting ? "내보내는 중..." : "CSV 내보내기")
            </MudButton>
            <MudButton OnClick="ExportJson" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.DataObject"
                       Disabled="_exporting" Size="Size.Small">
                @(_exporting ? "내보내는 중..." : "JSON 내보내기")
            </MudButton>
        </div>
    }
    else
    {
        <p class="analytics-no-data" style="padding: 40px; text-align: center;">
            사용량 데이터가 없습니다.
        </p>
    }
</div>

@code {
    private UsageStats? _stats;
    private DashboardStats _dashStats = new();
    private bool _loading;
    private bool _refreshing;
    private bool _exporting;
    private string _selectedRange = "30";

    // Model colors for visual distinction
    private static readonly string[] _modelColors =
    [
        "var(--mud-palette-primary)",
        "var(--mud-palette-success)",
        "var(--mud-palette-warning)",
        "var(--mud-palette-info)",
        "#e879f9", // fuchsia-400
        "#fb923c", // orange-400
        "#22d3ee", // cyan-400
        "#a78bfa" // violet-400
    ];

    protected override async Task OnInitializedAsync()
    {
        // Scan ALL sessions on computer (same source as dashboard)
        _dashStats = await GamificationService.GetDashboardStatsAsync();

        // Refresh stats cache from session files if stale (lastComputedDate != today)
        await StatsCacheService.RefreshIfStaleAsync();

        await LoadStats();
    }

    private async Task OnRangeChanged(string range)
    {
        _selectedRange = range;
        await LoadStats();
    }

    private async Task OnRefreshClick()
    {
        _refreshing = true;
        StateHasChanged();

        await StatsCacheService.ForceRefreshAsync();
        _dashStats = await GamificationService.GetDashboardStatsAsync();
        await LoadStats();

        _refreshing = false;
        StateHasChanged();
    }

    private async Task LoadStats()
    {
        _loading = true;
        StateHasChanged();

        int? days = _selectedRange == "all" ? null : int.Parse(_selectedRange);
        _stats = await StatsCacheService.GetMergedStatsAsync(days);

        _loading = false;
        StateHasChanged();
    }

    // ── Formatting helpers ──

    private static string FormatNumber(int n)
    {
        return n switch
        {
            >= 1_000_000 => $"{n / 1_000_000.0:F1}M",
            >= 1_000 => $"{n / 1_000.0:F1}K",
            _ => n.ToString("N0")
        };
    }

    private static string FormatTokens(long tokens)
    {
        return tokens switch
        {
            >= 1_000_000 => $"{tokens / 1_000_000.0:F1}M",
            >= 1_000 => $"{tokens / 1_000.0:F1}K",
            _ => tokens.ToString()
        };
    }

    private static string FormatDuration(long ms)
    {
        if (ms <= 0) return "—";
        var ts = TimeSpan.FromMilliseconds(ms);
        if (ts.TotalHours >= 1)
            return $"{(int)ts.TotalHours}h {ts.Minutes}m";
        return $"{ts.Minutes}m";
    }

    private static string FormatActiveSince(DateTime? date)
    {
        if (date == null) return "—";
        return date.Value.ToString("yyyy/MM");
    }

    private static string FormatDaysAgo(DateTime? date)
    {
        if (date == null) return "";
        var days = (int)(DateTime.UtcNow - date.Value).TotalDays;
        return $"{days}일 전";
    }

    private static string FormatChartDate(string date)
    {
        if (DateTime.TryParse(date, out var dt))
            return dt.ToString("MMM d");
        return date.Length > 5 ? date[5..] : date;
    }

    private static string GetPercent(long part, long total)
    {
        if (total == 0) return "0";
        return (part * 100.0 / total).ToString("F1");
    }

    private string GetModelColor(string model)
    {
        if (_stats == null) return _modelColors[0];
        var idx = _stats.ByModel.FindIndex(m => m.Model == model);
        return _modelColors[idx >= 0 ? idx % _modelColors.Length : 0];
    }

    // ── Computed properties ──

    private long TotalCacheTokens =>
        (_stats?.TotalCacheCreationTokens ?? 0) + (_stats?.TotalCacheReadTokens ?? 0);

    private double CacheEfficiencyRate
    {
        get
        {
            var total = TotalCacheTokens;
            return total > 0 ? (double)(_stats?.TotalCacheReadTokens ?? 0) / total * 100 : 0;
        }
    }

    private decimal CostPerMessage
    {
        get
        {
            var filteredMessages = GetFilteredActivitySummary().Messages;
            return filteredMessages > 0 ? _stats!.TotalCost / filteredMessages : 0;
        }
    }

    private long AvgDailyTokens
    {
        get
        {
            if (_stats?.DailyTokenTrend is not { Count: > 0 } trend) return 0;
            return trend.Sum(d => d.TotalTokens) / trend.Count;
        }
    }

    private decimal EstimatedCacheSavings
    {
        get
        {
            if (_stats == null) return 0;
            decimal savings = 0;
            foreach (var model in _stats.ByModel)
            {
                var pricing = ModelDefinitions.GetPricing(model.Model);
                if (pricing == null) continue;
                var fullInputPrice = pricing.Input;
                var cacheReadPrice = pricing.CacheRead;
                savings += (decimal)model.CacheReadTokens / 1_000_000m * (fullInputPrice - cacheReadPrice);
            }

            return savings;
        }
    }

    private List<DailyActivityEntry> GetFilteredDailyActivity()
    {
        var days = _selectedRange == "all" ? (int?)null : int.Parse(_selectedRange);
        if (!days.HasValue) return _dashStats.DailyActivity;
        var cutoff = DateTime.Today.AddDays(-(days.Value - 1)).ToString("yyyy-MM-dd");
        return _dashStats.DailyActivity
            .Where(d => string.Compare(d.Date, cutoff, StringComparison.Ordinal) >= 0)
            .ToList();
    }

    private static List<DailyActivityEntry> PadDailyActivity(List<DailyActivityEntry> raw, int days)
    {
        var lookup = raw.ToDictionary(d => d.Date, d => d);
        var result = new List<DailyActivityEntry>(days);
        var endDate = DateTime.Today;
        var startDate = endDate.AddDays(-(days - 1));
        for (var d = startDate; d <= endDate; d = d.AddDays(1))
        {
            var key = d.ToString("yyyy-MM-dd");
            result.Add(lookup.TryGetValue(key, out var e) ? e : new DailyActivityEntry { Date = key });
        }

        return result;
    }

    private (int Sessions, int Messages, int ToolCalls, int ActiveDays) GetFilteredActivitySummary()
    {
        var filtered = GetFilteredDailyActivity();
        return (
            Sessions: filtered.Sum(d => d.SessionCount),
            Messages: filtered.Sum(d => d.MessageCount),
            ToolCalls: filtered.Sum(d => d.ToolCallCount),
            ActiveDays: filtered.Count(d => d.MessageCount > 0 || d.SessionCount > 0)
        );
    }

    private int AvgDailyMessages
    {
        get
        {
            var activity = GetFilteredDailyActivity();
            if (activity.Count == 0) return 0;
            return activity.Sum(d => d.MessageCount) / activity.Count;
        }
    }

    // ── Export ──

    private async Task ExportCsv()
    {
        _exporting = true;
        StateHasChanged();

        try
        {
            if (_stats == null) return;
            var sb = new StringBuilder();
            sb.AppendLine("Model,InputTokens,OutputTokens,CacheCreation,CacheRead,TotalTokens,Cost");
            foreach (var m in _stats.ByModel)
                sb.AppendLine($"{m.Model},{m.InputTokens},{m.OutputTokens},{m.CacheCreationTokens},{m.CacheReadTokens},{m.TotalTokens},{m.TotalCost:F6}");

            var fileName = $"usage-export-{DateTime.Now:yyyyMMdd-HHmmss}.csv";
            var bytes = Encoding.UTF8.GetBytes(sb.ToString());
            var base64 = Convert.ToBase64String(bytes);
            await JS.InvokeVoidAsync("eval",
                $"var a=document.createElement('a');a.href='data:text/csv;base64,{base64}';a.download='{fileName}';document.body.appendChild(a);a.click();a.remove();");
        }
        catch
        {
        }
        finally
        {
            _exporting = false;
            StateHasChanged();
        }
    }

    private async Task ExportJson()
    {
        _exporting = true;
        StateHasChanged();

        try
        {
            if (_stats == null) return;
            var json = JsonSerializer.Serialize(_stats, new JsonSerializerOptions { WriteIndented = true });
            var fileName = $"usage-export-{DateTime.Now:yyyyMMdd-HHmmss}.json";
            var bytes = Encoding.UTF8.GetBytes(json);
            var base64 = Convert.ToBase64String(bytes);
            await JS.InvokeVoidAsync("eval",
                $"var a=document.createElement('a');a.href='data:application/json;base64,{base64}';a.download='{fileName}';document.body.appendChild(a);a.click();a.remove();");
        }
        catch
        {
        }
        finally
        {
            _exporting = false;
            StateHasChanged();
        }
    }

}

