<div class="settings-section-title">AI 모델</div>
<div class="settings-section-desc">AI 모델 및 동작 방식을 설정합니다.</div>

<div class="stack gap-3">
    <MudSelect T="string" @bind-Value="Settings.DefaultModel" Label="기본 모델"
               Variant="Variant.Outlined" Margin="Margin.Dense"
               MaxHeight="400"
               HelperText="전역 기본값입니다. 워크스페이스별로 다른 모델을 지정할 수 있습니다.">
        @foreach (var model in ModelDefinitions.All)
        {
            <MudSelectItem T="string" Value="@model.Id">
                <div class="model-select-option">
                    <div class="model-select-name">
                        <span>@model.DisplayName</span>
                        @if (model.Pricing != null)
                        {
                            <span class="model-select-price">$@model.Pricing.Input/$@model.Pricing.Output</span>
                        }
                        else if (model.IsAlias)
                        {
                            <span class="model-select-price" style="opacity: 0.5;">alias</span>
                        }
                    </div>
                    @if (!string.IsNullOrEmpty(model.Description))
                    {
                        <span class="model-select-desc" title="@model.Description">@model.Description</span>
                    }
                </div>
            </MudSelectItem>
        }
    </MudSelect>

    <div>
        <div class="settings-field-label">기본 Effort 레벨</div>
        <div class="settings-segmented">
            <button class="settings-seg-item @(Settings.DefaultEffortLevel == "auto" ? "active" : "")"
                    @onclick="@(() => Settings.DefaultEffortLevel = "auto")">Auto</button>
            <button class="settings-seg-item @(Settings.DefaultEffortLevel == "low" ? "active" : "")"
                    @onclick="@(() => Settings.DefaultEffortLevel = "low")">Low</button>
            <button class="settings-seg-item @(Settings.DefaultEffortLevel == "medium" ? "active" : "")"
                    @onclick="@(() => Settings.DefaultEffortLevel = "medium")">Medium</button>
            <button class="settings-seg-item @(Settings.DefaultEffortLevel == "high" ? "active" : "")"
                    @onclick="@(() => Settings.DefaultEffortLevel = "high")">High</button>
            <button class="settings-seg-item @(Settings.DefaultEffortLevel == "max" ? "active" : "")"
                    @onclick="@(() => Settings.DefaultEffortLevel = "max")">Max</button>
        </div>
        <div class="settings-field-hint">auto: 모델 기본값, high: 높은 사고 수준, max: 확장 사고 모드 (Opus 전용)</div>
    </div>

    <div>
        <div class="settings-field-label">기본 권한 모드</div>
        <div class="settings-segmented">
            <button class="settings-seg-item @(Settings.DefaultPermissionMode == "bypassAll" ? "active" : "")"
                    @onclick="@(() => Settings.DefaultPermissionMode = "bypassAll")">일반 모드</button>
            <button class="settings-seg-item @(Settings.DefaultPermissionMode == "plan" ? "active" : "")"
                    @onclick="@(() => Settings.DefaultPermissionMode = "plan")">플랜 모드</button>
        </div>
        <div class="settings-field-hint">Cominomi에서 Claude CLI 실행 시 적용되는 권한 모드입니다.</div>
    </div>

    <MudTextField @bind-Value="Settings.FallbackModel" Label="Fallback 모델"
                  Variant="Variant.Outlined" Margin="Margin.Dense"
                  Placeholder="sonnet"
                  HelperText="기본 모델 과부하 시 대체 모델 (비워두면 미사용)"/>

    <MudTextField @bind-Value="Settings.McpConfigPath" Label="MCP 설정 파일 경로"
                  Variant="Variant.Outlined" Margin="Margin.Dense"
                  Placeholder="./mcp.json"
                  HelperText="MCP 서버 설정 JSON 파일 경로 (비워두면 미사용)"/>
</div>

@code {
    [Parameter][EditorRequired] public AppSettings Settings { get; set; } = null!;
}
