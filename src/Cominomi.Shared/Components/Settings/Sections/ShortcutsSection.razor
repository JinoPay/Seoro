@using System.Runtime.InteropServices

<div class="settings-section-title">단축키</div>
<div class="settings-section-desc">사용 가능한 키보드 단축키 목록입니다.</div>

<MudSimpleTable Dense="true" Hover="true" Bordered="false" Style="max-width: 500px;">
    <thead>
        <tr>
            <th>동작</th>
            <th>단축키</th>
        </tr>
    </thead>
    <tbody>
        <tr><td>세션 1~5 전환</td><td><code>@_mod+1</code> ~ <code>@_mod+5</code></td></tr>
        <tr><td>현재 세션 삭제</td><td><code>@_mod+D</code></td></tr>
        <tr><td>모든 프로젝트 펼치기</td><td><code>@_mod+Shift+E</code></td></tr>
        <tr><td>모든 프로젝트 접기</td><td><code>@_mod+Shift+W</code></td></tr>
        <tr><td>사이드바 토글</td><td><code>@_mod+B</code></td></tr>
        <tr><td>입력창 포커스</td><td><code>@_mod+Shift+L</code></td></tr>
        <tr><td>테마 전환 (라이트/다크)</td><td><code>@_mod+Shift+T</code></td></tr>
        <tr><td>플랜 모드 전환</td><td><code>@_mod+Shift+P</code></td></tr>
        <tr><td>Effort 레벨 전환</td><td><code>@_mod+Shift+M</code></td></tr>
        <tr><td>메시지 전송</td><td><code>Enter</code></td></tr>
        <tr><td>줄바꿈</td><td><code>Shift+Enter</code></td></tr>
        <tr><td>오버레이 닫기</td><td><code>Esc</code></td></tr>
        <tr><td>터미널 복사</td><td><code>@_mod+C</code></td></tr>
        <tr><td>터미널 붙여넣기</td><td><code>@_mod+V</code></td></tr>
    </tbody>
</MudSimpleTable>

@code {
    private string _mod = RuntimeInformation.IsOSPlatform(OSPlatform.OSX) ? "\u2318" : "Ctrl";
}
