@using System.Runtime.InteropServices
@inject IClaudeService ClaudeService
@inject IDependencyCheckService DependencyCheckService

<div class="settings-section-title">연동</div>
<div class="settings-section-desc">외부 서비스 연결 상태를 확인합니다.</div>

<div class="settings-group">
    <div class="settings-group-title">Claude CLI</div>
    <div class="integration-status">
        @if (_claudeCliChecking)
        {
            <MudProgressCircular Size="Size.Small" Indeterminate="true"
                                 Style="width: 18px; height: 18px;" />
            <span class="status-text">감지 중...</span>
        }
        else if (_claudeCliFound)
        {
            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small"
                     Class="status-ok" />
            <span class="status-text">감지됨</span>
            @if (!string.IsNullOrEmpty(_claudeCliResolvedPath))
            {
                <span class="status-path">@_claudeCliResolvedPath</span>
            }
        }
        else
        {
            <MudIcon Icon="@Icons.Material.Filled.Warning" Size="Size.Small"
                     Class="status-warn" />
            <span class="status-text">감지되지 않음</span>
        }
        <MudIconButton Icon="@Icons.Material.Filled.Refresh" Size="Size.Small"
                       OnClick="CheckClaudeCli" title="다시 확인" />
    </div>

    @if (_claudeCliFound && !string.IsNullOrEmpty(_claudeCliVersion))
    {
        <div class="stack gap-1 mt-2">
            <div class="stack-row items-center gap-2">
                <span class="typo-body2">버전:</span>
                <MudChip T="string" Size="Size.Small"
                         Color="@(_claudeVersionOutdated ? Color.Warning : Color.Success)"
                         Variant="Variant.Text">
                    @_claudeCliVersion
                </MudChip>
                @if (_claudeVersionOutdated)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Warning"
                             Variant="Variant.Outlined">
                        업데이트 필요 (v@(CominomiConstants.RequiredClaudeVersion))
                    </MudChip>
                }
            </div>

            @if (_claudeVersionOutdated)
            {
                <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined"
                          Class="mt-2" Dense="true">
                    <div class="stack gap-1">
                        <span class="typo-body2">업데이트 방법:</span>
                        @foreach (var method in (_isMac ? ClaudeInstallMethods.Mac : ClaudeInstallMethods.Windows))
                        {
                            <div class="stack-row items-center gap-2">
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                         Style="min-width: 80px; justify-content: center;">
                                    @method.Label
                                </MudChip>
                                <code style="flex: 1;">@method.UpdateCommand</code>
                            </div>
                        }
                    </div>
                </MudAlert>
            }
        </div>
    }

    <MudTextField @bind-Value="Settings.ClaudePath" Label="Claude CLI 경로"
                  Variant="Variant.Outlined" Margin="Margin.Dense"
                  Placeholder="자동 감지" Class="mt-3"
                  HelperText="비워두면 자동으로 감지합니다" />
</div>

<div class="settings-group">
    <div class="settings-group-title">Git</div>
    <div class="integration-status">
        @if (_gitChecking)
        {
            <MudProgressCircular Size="Size.Small" Indeterminate="true"
                                 Style="width: 18px; height: 18px;" />
            <span class="status-text">감지 중...</span>
        }
        else if (_gitFound)
        {
            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small"
                     Class="status-ok" />
            <span class="status-text">감지됨</span>
            @if (!string.IsNullOrEmpty(_gitResolvedPath))
            {
                <span class="status-path">@_gitResolvedPath</span>
            }
        }
        else
        {
            <MudIcon Icon="@Icons.Material.Filled.Warning" Size="Size.Small"
                     Class="status-warn" />
            <span class="status-text">감지되지 않음</span>
        }
        <MudIconButton Icon="@Icons.Material.Filled.Refresh" Size="Size.Small"
                       OnClick="CheckGit" title="다시 확인" />
    </div>

    @if (_gitFound && !string.IsNullOrEmpty(_gitVersion))
    {
        <div class="stack gap-1 mt-2">
            <div class="stack-row items-center gap-2">
                <span class="typo-body2">버전:</span>
                <MudChip T="string" Size="Size.Small" Color="Color.Success"
                         Variant="Variant.Text">
                    @_gitVersion
                </MudChip>
            </div>
        </div>
    }

    @if (!_gitChecking && !_gitFound)
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined"
                  Class="mt-2" Dense="true">
            <div class="stack gap-1">
                <span class="typo-body2">설치 방법:</span>
                @if (_isMac)
                {
                    <code>brew install git</code>
                }
                else
                {
                    <code>winget install Git.Git</code>
                }
            </div>
        </MudAlert>
    }

    <MudTextField @bind-Value="Settings.GitPath" Label="Git 경로"
                  Variant="Variant.Outlined" Margin="Margin.Dense"
                  Placeholder="자동 감지" Class="mt-3"
                  HelperText="비워두면 자동으로 감지합니다" />
</div>

<div class="settings-group">
    <div class="settings-group-title">GitHub CLI</div>
    <div class="integration-status">
        @if (_ghChecking)
        {
            <MudProgressCircular Size="Size.Small" Indeterminate="true"
                                 Style="width: 18px; height: 18px;" />
            <span class="status-text">감지 중...</span>
        }
        else if (_ghFound)
        {
            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small"
                     Class="status-ok" />
            <span class="status-text">감지됨</span>
            @if (!string.IsNullOrEmpty(_ghResolvedPath))
            {
                <span class="status-path">@_ghResolvedPath</span>
            }
        }
        else
        {
            <MudIcon Icon="@Icons.Material.Filled.Warning" Size="Size.Small"
                     Class="status-warn" />
            <span class="status-text">감지되지 않음</span>
        }
        <MudIconButton Icon="@Icons.Material.Filled.Refresh" Size="Size.Small"
                       OnClick="CheckGh" title="다시 확인" />
    </div>

    @if (_ghFound && !string.IsNullOrEmpty(_ghVersion))
    {
        <div class="stack gap-1 mt-2">
            <div class="stack-row items-center gap-2">
                <span class="typo-body2">버전:</span>
                <MudChip T="string" Size="Size.Small" Color="Color.Success"
                         Variant="Variant.Text">
                    @_ghVersion
                </MudChip>
            </div>
        </div>
    }

    @if (!_ghChecking && !_ghFound)
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined"
                  Class="mt-2" Dense="true">
            <div class="stack gap-1">
                <span class="typo-body2">설치 방법:</span>
                @if (_isMac)
                {
                    <code>brew install gh</code>
                }
                else
                {
                    <code>winget install GitHub.cli</code>
                }
            </div>
        </MudAlert>
    }

    <MudTextField @bind-Value="Settings.GhPath" Label="GitHub CLI 경로"
                  Variant="Variant.Outlined" Margin="Margin.Dense"
                  Placeholder="자동 감지" Class="mt-3"
                  HelperText="비워두면 자동으로 감지합니다" />
</div>

@code {
    [Parameter, EditorRequired] public AppSettings Settings { get; set; } = null!;

    private bool _claudeCliChecking;
    private bool _claudeCliFound;
    private string? _claudeCliResolvedPath;
    private string? _claudeCliVersion;
    private bool _claudeVersionOutdated;
    private bool _gitChecking;
    private bool _gitFound;
    private string? _gitResolvedPath;
    private string? _gitVersion;
    private bool _ghChecking;
    private bool _ghFound;
    private string? _ghResolvedPath;
    private string? _ghVersion;
    private bool _isMac = !RuntimeInformation.IsOSPlatform(OSPlatform.Windows);

    protected override async Task OnInitializedAsync()
    {
        await CheckIntegrations();
    }

    private async Task CheckIntegrations()
    {
        _gitChecking = true;
        _ghChecking = true;
        StateHasChanged();

        var depsTask = DependencyCheckService.CheckAllAsync();
        var cliTask = CheckClaudeCli();

        var deps = await depsTask;
        ApplyDepResult(deps, "git", ref _gitFound, ref _gitResolvedPath, ref _gitVersion);
        _gitChecking = false;
        ApplyDepResult(deps, "gh", ref _ghFound, ref _ghResolvedPath, ref _ghVersion);
        _ghChecking = false;

        await cliTask;
        StateHasChanged();
    }

    private static void ApplyDepResult(List<DependencyResult> deps, string name,
        ref bool found, ref string? resolvedPath, ref string? version)
    {
        var dep = deps.FirstOrDefault(d => d.Name == name);
        if (dep != null)
        {
            found = dep.IsInstalled;
            resolvedPath = dep.ResolvedPath;
            version = dep.Version;
        }
    }

    private async Task CheckGit()
    {
        _gitChecking = true;
        StateHasChanged();

        var deps = await DependencyCheckService.CheckAllAsync();
        ApplyDepResult(deps, "git", ref _gitFound, ref _gitResolvedPath, ref _gitVersion);

        _gitChecking = false;
        StateHasChanged();
    }

    private async Task CheckGh()
    {
        _ghChecking = true;
        StateHasChanged();

        var deps = await DependencyCheckService.CheckAllAsync();
        ApplyDepResult(deps, "gh", ref _ghFound, ref _ghResolvedPath, ref _ghVersion);

        _ghChecking = false;
        StateHasChanged();
    }

    private async Task CheckClaudeCli()
    {
        _claudeCliChecking = true;
        StateHasChanged();
        var (found, path) = await ClaudeService.DetectCliAsync();
        _claudeCliFound = found;
        _claudeCliResolvedPath = path;

        if (found)
        {
            _claudeCliVersion = await ClaudeService.GetDetectedVersionAsync();
            _claudeVersionOutdated = VersionComparer.IsOutdated(
                _claudeCliVersion, CominomiConstants.RequiredClaudeVersion);
        }
        else
        {
            _claudeCliVersion = null;
            _claudeVersionOutdated = false;
        }

        _claudeCliChecking = false;
        StateHasChanged();
    }
}
