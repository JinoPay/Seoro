@using System.Runtime.InteropServices
@inject INotificationService NotificationService
@inject ISnackbar Snackbar

<div class="settings-section-title">알림</div>
<div class="settings-section-desc">작업 완료, 응답 대기, 플랜 리뷰 시 OS 알림을 발송합니다.</div>

<div class="stack gap-3">
    <MudSwitch T="bool" @bind-Value="Settings.NotificationsEnabled" Label="데스크톱 알림"
               Color="Color.Primary" UncheckedColor="Color.Default"/>

    <MudSwitch T="bool" @bind-Value="Settings.NotificationSound" Label="알림 사운드"
               Color="Color.Primary" UncheckedColor="Color.Default"
               Disabled="@(!Settings.NotificationsEnabled)"/>

    @if (RuntimeInformation.IsOSPlatform(OSPlatform.OSX))
    {
        <MudSelect T="string" @bind-Value="Settings.NotificationSoundName"
                   Label="사운드 종류" Variant="Variant.Outlined" Margin="Margin.Dense"
                   Disabled="@(!Settings.NotificationsEnabled || !Settings.NotificationSound)">
            <MudSelectItem T="string" Value="@("default")">기본 (Default)</MudSelectItem>
            <MudSelectItem T="string" Value="@("Glass")">Glass</MudSelectItem>
            <MudSelectItem T="string" Value="@("Ping")">Ping</MudSelectItem>
            <MudSelectItem T="string" Value="@("Pop")">Pop</MudSelectItem>
            <MudSelectItem T="string" Value="@("Purr")">Purr</MudSelectItem>
            <MudSelectItem T="string" Value="@("Tink")">Tink</MudSelectItem>
            <MudSelectItem T="string" Value="@("Basso")">Basso</MudSelectItem>
            <MudSelectItem T="string" Value="@("Blow")">Blow</MudSelectItem>
            <MudSelectItem T="string" Value="@("Bottle")">Bottle</MudSelectItem>
            <MudSelectItem T="string" Value="@("Frog")">Frog</MudSelectItem>
            <MudSelectItem T="string" Value="@("Funk")">Funk</MudSelectItem>
            <MudSelectItem T="string" Value="@("Hero")">Hero</MudSelectItem>
            <MudSelectItem T="string" Value="@("Morse")">Morse</MudSelectItem>
            <MudSelectItem T="string" Value="@("Submarine")">Submarine</MudSelectItem>
            <MudSelectItem T="string" Value="@("Sosumi")">Sosumi</MudSelectItem>
        </MudSelect>
    }

    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
               OnClick="SendTestNotification" StartIcon="@Icons.Material.Filled.NotificationsActive"
               Disabled="@(!Settings.NotificationsEnabled)"
               Style="text-transform: none; align-self: flex-start;">
        테스트 알림 보내기
    </MudButton>

    @if (RuntimeInformation.IsOSPlatform(OSPlatform.OSX))
    {
        <MudAlert Severity="Severity.Info" Dense="true" NoIcon="false" Class="mt-2">
            알림이 보이지 않으면 시스템 설정 > 알림 > Cominomi가 허용되어 있는지 확인하세요.
        </MudAlert>
    }
</div>

@code {
    [Parameter][EditorRequired] public AppSettings Settings { get; set; } = null!;
    [Parameter] public EventCallback OnSave { get; set; }

    private async Task SendTestNotification()
    {
        await OnSave.InvokeAsync();
        await NotificationService.SendAsync("Cominomi", "테스트 알림입니다!", NotificationType.Info);
        Snackbar.Add("테스트 알림을 발송했습니다.", Severity.Success);
    }

}
