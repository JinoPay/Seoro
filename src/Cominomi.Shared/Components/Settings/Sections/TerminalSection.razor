@inject IShellService ShellSvc

<div class="settings-section-title">터미널</div>
<div class="settings-section-desc">내장 터미널의 기본 셸을 설정합니다.</div>

<div class="stack gap-3">
    <MudSelect T="string" Value="Settings.TerminalShell"
               ValueChanged="@((string v) => HandleTerminalShellChanged(v))"
               Label="기본 셸"
               Variant="Variant.Outlined" Margin="Margin.Dense">
        <MudSelectItem T="string" Value="@((string?)null)">자동 감지 (@_detectedShellLabel)</MudSelectItem>
        @foreach (var shell in _availableShells)
        {
            <MudSelectItem T="string" Value="@(ShellService.ShellTypeToKey(shell.Type))">
                @ShellService.GetShellDisplayName(shell)
            </MudSelectItem>
        }
    </MudSelect>
    <small class="typo-caption text-secondary">
        터미널 패널에서 사용할 셸입니다. "자동 감지"는 시스템 기본 셸을 사용합니다.
    </small>
</div>

@code {
    [Parameter, EditorRequired] public AppSettings Settings { get; set; } = null!;
    [Parameter] public EventCallback OnSave { get; set; }

    private List<ShellInfo> _availableShells = [];
    private string _detectedShellLabel = "";

    protected override async Task OnInitializedAsync()
    {
        _availableShells = await ShellSvc.GetAvailableShellsAsync();
        var detected = await ShellSvc.GetShellAsync();
        _detectedShellLabel = ShellService.GetShellDisplayName(detected);
    }

    private async Task HandleTerminalShellChanged(string value)
    {
        Settings.TerminalShell = value;
        await OnSave.InvokeAsync();
    }
}
