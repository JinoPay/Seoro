@using Cominomi.Shared.Models
@inject ISessionReplayService ReplayService
@inject IChatState ChatState
@implements IDisposable

<div class="replay-page">
    <div class="replay-page-header">
        <span class="typo-h6">세션 히스토리</span>
        <MudChip T="string" Size="Size.Small" Variant="Variant.Text">@_totalCount 세션</MudChip>
        <button class="replay-nav-link" @onclick="@(() => ChatState.SetSettingsSection("usage"))">
            <MudIcon Icon="@Icons.Material.Filled.Analytics" Size="Size.Small" />
            사용량 분석 →
        </button>
    </div>
    <div class="replay-layout">
            @* === Left: Session list === *@
            <div class="replay-sidebar">
                <div class="replay-search-row">
                    <MudTextField T="string" @bind-Value="_search" Placeholder="전체 세션 검색..."
                                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" Immediate="true"
                                  OnKeyDown="HandleSearchKeyDown" Class="mb-2" />
                </div>

                @* Live sessions *@
                @if (_liveSessions.Count > 0 && !_searchMode)
                {
                    <div class="replay-live-section">
                        <div class="replay-live-header">
                            <span class="replay-live-dot"></span>
                            실시간 (@_liveSessions.Count)
                        </div>
                        @foreach (var live in _liveSessions)
                        {
                            <div class="replay-live-item">
                                <span class="replay-live-dot-sm"></span>
                                <span class="typo-caption text-truncate">@GetProjectDisplayName(live.ProjectPath)</span>
                                <span class="typo-caption text-secondary ml-auto">@(live.ModifiedSecondsAgo)초 전</span>
                            </div>
                        }
                    </div>
                }

                @* Search results *@
                @if (_searchMode)
                {
                    <div class="replay-search-status">
                        <span class="typo-caption text-secondary">
                            @if (_searching) { <text>검색 중...</text> }
                            else { <text>@_searchResults.Count 결과</text> }
                        </span>
                        <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Primary"
                                   OnClick="ClearSearch" Style="text-transform: none; min-width: auto;">
                            초기화
                        </MudButton>
                    </div>

                    @foreach (var result in _searchResults)
                    {
                        <div class="replay-item" @onclick="@(() => SelectSearchResult(result))">
                            <div class="d-flex align-center gap-2">
                                <MudIcon Icon="@Icons.Material.Filled.Search" Size="Size.Small"
                                         Style="width: 12px; height: 12px; color: var(--mud-palette-primary);" />
                                <span class="typo-caption text-truncate">@GetProjectDisplayName(result.ProjectPath)</span>
                            </div>
                            <div class="typo-caption text-secondary" style="margin-left: 18px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                @result.Snippet
                            </div>
                        </div>
                    }
                }
                else if (_loading)
                {
                    <div style="display: flex; justify-content: center; padding: 20px;">
                        <MudProgressCircular Indeterminate="true" Size="Size.Small" />
                    </div>
                }
                else if (_sessions.Count == 0)
                {
                    <div class="typo-caption text-secondary text-center pa-4">
                        Claude CLI 세션 히스토리가 없습니다
                    </div>
                }
                else
                {
                    @foreach (var s in FilteredSessions)
                    {
                        var tags = GetSessionTags(s.Id);
                        <div class="@($"replay-item {(_selected?.Id == s.Id ? "active" : "")}")"
                             @onclick="@(() => SelectSession(s))">
                            <div class="d-flex align-center gap-2 mb-1">
                                @if (s.IsLive)
                                {
                                    <span class="replay-live-dot-sm"></span>
                                }
                                else
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Small"
                                             Style="width: 14px; height: 14px; color: var(--mud-palette-primary);" />
                                }
                                <span class="typo-caption" style="font-weight: 500;">
                                    @GetProjectDisplayName(s.ProjectPath)
                                </span>
                                <span class="typo-caption text-secondary ml-auto" style="font-size: 10px;">
                                    @FormatTime(s.FirstTimestamp)
                                </span>
                            </div>
                            @if (s.FirstMessage != null)
                            {
                                <div class="typo-body2 text-truncate" style="margin-left: 20px; font-size: 12px;">
                                    "@s.FirstMessage"
                                </div>
                            }
                            @if (tags.Count > 0)
                            {
                                <div class="d-flex gap-1 mt-1" style="margin-left: 20px;">
                                    @foreach (var tag in tags)
                                    {
                                        <span class="replay-tag">@tag</span>
                                    }
                                </div>
                            }
                            <div class="d-flex gap-3 mt-1" style="margin-left: 20px; font-size: 10px; opacity: 0.5;">
                                <span>@s.MessageCount 메시지</span>
                                <span>@s.ToolCallCount 도구</span>
                                <span>@s.EntryCount 이벤트</span>
                                <span>@FormatDuration(s.FirstTimestamp, s.LastTimestamp)</span>
                            </div>
                        </div>
                    }

                    @if (_hasMoreSessions)
                    {
                        <div style="padding: 8px;">
                            <MudButton Variant="Variant.Outlined" Size="Size.Small" FullWidth="true"
                                       OnClick="LoadMoreSessions" Disabled="_loadingMore"
                                       Style="text-transform: none;">
                                @if (_loadingMore)
                                {
                                    <MudProgressCircular Indeterminate="true" Size="Size.Small" Class="mr-1" />
                                }
                                더 보기 (@_sessions.Count/@_totalCount)
                            </MudButton>
                        </div>
                    }
                }
            </div>

            @* === Right: Event stream === *@
            <div class="replay-timeline">
                @if (_selected == null)
                {
                    <div class="d-flex flex-column align-center justify-center" style="height: 300px; opacity: 0.5;">
                        <MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Large" />
                        <div class="typo-body2 mt-2">왼쪽에서 세션을 선택하세요</div>
                        <div class="typo-caption mt-1">Claude Code 세션을 단계별로 재생합니다</div>
                    </div>
                }
                else if (_loadingEvents)
                {
                    <div class="d-flex align-center justify-center" style="height: 200px;">
                        <MudProgressCircular Indeterminate="true" Size="Size.Small" />
                        <span class="typo-body2 ml-2">세션 로딩 중...</span>
                    </div>
                }
                else
                {
                    @* Session header *@
                    <div class="replay-session-header">
                        <div>
                            <div class="d-flex align-center gap-2">
                                <span class="typo-body1" style="font-weight: 600;">@GetProjectDisplayName(_selected.ProjectPath)</span>
                                <span class="typo-caption text-secondary">@FormatTime(_selected.FirstTimestamp)</span>
                            </div>
                            @if (_selected.FirstMessage != null)
                            {
                                <div class="typo-caption text-secondary mt-1">"@_selected.FirstMessage"</div>
                            }
                        </div>
                        <div class="d-flex align-center gap-2">
                            <div class="d-flex align-center gap-3" style="font-size: 11px; opacity: 0.5;">
                                <span>@_selected.MessageCount 메시지</span>
                                <span>@_selected.ToolCallCount 도구</span>
                                <span>@FormatDuration(_selected.FirstTimestamp, _selected.LastTimestamp)</span>
                                <span>@_totalEvents 이벤트</span>
                            </div>
                            <MudIconButton Icon="@Icons.Material.Filled.ContentCopy" Size="Size.Small"
                                           OnClick="ExportSession" title="마크다운 내보내기"
                                           Style="width: 28px; height: 28px;" />
                            <MudIconButton Icon="@Icons.Material.Filled.Label" Size="Size.Small"
                                           OnClick="@(() => _showTagEditor = !_showTagEditor)" title="태그"
                                           Style="width: 28px; height: 28px;" />
                            @if (!_playing)
                            {
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                           StartIcon="@Icons.Material.Filled.PlayArrow"
                                           OnClick="StartReplay" Style="text-transform: none;">
                                    재생
                                </MudButton>
                            }
                            else
                            {
                                <MudButton Variant="Variant.Outlined" Size="Size.Small"
                                           StartIcon="@Icons.Material.Filled.Pause"
                                           OnClick="StopReplay" Style="text-transform: none;">
                                    중지 (@_visibleCount/@_displayEvents.Count)
                                </MudButton>
                            }
                        </div>
                    </div>

                    @* Tag editor *@
                    @if (_showTagEditor && _selected != null)
                    {
                        var currentTags = GetSessionTags(_selected.Id);
                        <div class="replay-tag-editor">
                            @foreach (var tag in currentTags)
                            {
                                <span class="replay-tag">
                                    @tag
                                    <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                                   OnClick="@(() => RemoveTag(tag))"
                                                   Style="width: 14px; height: 14px; margin-left: 2px;" />
                                </span>
                            }
                            <MudTextField T="string" @bind-Value="_tagInput" Placeholder="태그 추가..."
                                          Variant="Variant.Outlined" Margin="Margin.Dense"
                                          OnKeyDown="HandleTagKeyDown"
                                          Style="max-width: 100px; font-size: 11px;" />
                            @foreach (var preset in _tagPresets)
                            {
                                if (!currentTags.Contains(preset))
                                {
                                    <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="@(() => AddTag(preset))"
                                               Style="text-transform: none; min-width: auto; font-size: 10px; padding: 2px 6px;">
                                        @preset
                                    </MudButton>
                                }
                            }
                        </div>
                    }

                    @* Event stream *@
                    <div class="replay-events-container">
                        @foreach (var (evt, idx) in VisibleEvents.Select((e, i) => (e, i)))
                        {
                            @if (evt.Type is "human" or "user")
                            {
                                <div class="replay-evt replay-evt-user">
                                    <div class="replay-evt-avatar replay-evt-avatar-user">
                                        <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small"
                                                 Style="width: 14px; height: 14px;" />
                                    </div>
                                    <div class="replay-evt-body">
                                        <span class="replay-evt-label">사용자 · @FormatEventTime(evt.Timestamp)</span>
                                        <div class="replay-evt-card replay-evt-card-user">
                                            <div class="typo-body2" style="white-space: pre-wrap; word-break: break-word;">@evt.Content</div>
                                        </div>
                                    </div>
                                </div>
                            }
                            else if (evt.Type == "assistant")
                            {
                                <div class="replay-evt replay-evt-assistant">
                                    <div class="replay-evt-avatar replay-evt-avatar-assistant">
                                        <MudIcon Icon="@Icons.Material.Filled.SmartToy" Size="Size.Small"
                                                 Style="width: 14px; height: 14px;" />
                                    </div>
                                    <div class="replay-evt-body">
                                        <span class="replay-evt-label">Claude · @FormatEventTime(evt.Timestamp)</span>

                                        @if (evt.ToolCalls?.Count > 0)
                                        {
                                            @foreach (var tc in evt.ToolCalls)
                                            {
                                                <div class="replay-tool-pill">
                                                    <MudIcon Icon="@GetToolIcon(tc.Name)" Size="Size.Small"
                                                             Style="width: 12px; height: 12px; color: var(--mud-palette-warning);" />
                                                    <span class="replay-tool-name">@tc.Name</span>
                                                    <span class="replay-tool-input">@tc.InputPreview</span>
                                                </div>
                                            }
                                        }

                                        @if (!string.IsNullOrEmpty(evt.Content))
                                        {
                                            <div class="replay-evt-card replay-evt-card-assistant">
                                                @if (evt.Content.Length > 300 && !_expandedEvents.Contains(idx))
                                                {
                                                    <div class="typo-body2" style="white-space: pre-wrap; word-break: break-word;">@(evt.Content[..300])...</div>
                                                    <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Primary"
                                                               OnClick="@(() => ToggleExpand(idx))"
                                                               Style="text-transform: none; padding: 0; min-width: auto; font-size: 11px;">
                                                        더 보기
                                                    </MudButton>
                                                }
                                                else
                                                {
                                                    <div class="typo-body2" style="white-space: pre-wrap; word-break: break-word;">@evt.Content</div>
                                                    @if (evt.Content.Length > 300)
                                                    {
                                                        <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Primary"
                                                                   OnClick="@(() => ToggleExpand(idx))"
                                                                   Style="text-transform: none; padding: 0; min-width: auto; font-size: 11px;">
                                                            접기
                                                        </MudButton>
                                                    }
                                                }
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                            else if (evt.Type == "tool_result" && !string.IsNullOrEmpty(evt.Content))
                            {
                                <div class="replay-evt-tool-result">
                                    <button class="replay-tool-result-toggle" @onclick="@(() => ToggleExpand(idx))">
                                        <MudIcon Icon="@(_expandedEvents.Contains(idx)
                                            ? Icons.Material.Filled.ExpandMore
                                            : Icons.Material.Filled.ChevronRight)"
                                                 Size="Size.Small" Style="width: 12px; height: 12px;" />
                                        도구 출력 (@(evt.Content.Length)자)
                                        @if (evt.IsError)
                                        {
                                            <span style="color: var(--mud-palette-error);">오류</span>
                                        }
                                    </button>
                                    @if (_expandedEvents.Contains(idx))
                                    {
                                        <pre class="replay-tool-result-content">@evt.Content</pre>
                                    }
                                </div>
                            }
                        }

                        @if (_playing && _visibleCount < _displayEvents.Count)
                        {
                            <div class="d-flex justify-center pa-4">
                                <span class="replay-live-dot"></span>
                            </div>
                        }

                        @if (_hasMoreEvents && !_playing)
                        {
                            <div style="padding: 12px 0;">
                                <MudButton Variant="Variant.Outlined" Size="Size.Small" FullWidth="true"
                                           OnClick="LoadMoreEvents" Disabled="_loadingMoreEvents"
                                           Style="text-transform: none;">
                                    @if (_loadingMoreEvents)
                                    {
                                        <MudProgressCircular Indeterminate="true" Size="Size.Small" Class="mr-1" />
                                    }
                                    이벤트 더 보기 (@_events.Count/@_totalEvents)
                                </MudButton>
                            </div>
                        }
                    </div>
                }
            </div> @* replay-timeline *@
        </div> @* replay-layout *@
</div> @* replay-page *@

@code {
    // Session list state
    private List<SessionReplaySummary> _sessions = [];
    private int _totalCount;
    private bool _hasMoreSessions;
    private bool _loading = true;
    private bool _loadingMore;
    private SessionReplaySummary? _selected;

    // Event state
    private List<SessionReplayEvent> _events = [];
    private List<SessionReplayEvent> _displayEvents = [];
    private int _totalEvents;
    private bool _hasMoreEvents;
    private bool _loadingEvents;
    private bool _loadingMoreEvents;

    // Search
    private string _search = "";
    private bool _searchMode;
    private bool _searching;
    private List<SessionSearchResult> _searchResults = [];

    // Tags
    private SessionTagsData _tagsData = new();
    private bool _showTagEditor;
    private string _tagInput = "";
    private static readonly string[] _tagPresets = ["버그수정", "기능", "리팩터"];

    // Live sessions
    private List<LiveSessionInfo> _liveSessions = [];
    private Timer? _liveTimer;

    // Replay
    private bool _playing;
    private int _visibleCount;
    private Timer? _replayTimer;

    // UI state
    private HashSet<int> _expandedEvents = [];
    private bool _exportCopied;

    private List<SessionReplaySummary> FilteredSessions => string.IsNullOrWhiteSpace(_search) || _searchMode
        ? _sessions
        : _sessions.Where(s =>
            (s.FirstMessage?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false) ||
            s.ProjectPath.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
            s.Id.Contains(_search, StringComparison.OrdinalIgnoreCase)).ToList();

    private List<SessionReplayEvent> VisibleEvents => _playing
        ? _displayEvents.Take(_visibleCount).ToList()
        : _displayEvents;

    protected override async Task OnInitializedAsync()
    {
        var listTask = ReplayService.ListSessionsAsync(10, 0);
        var tagsTask = ReplayService.GetTagsAsync();
        var liveTask = ReplayService.DetectLiveSessionsAsync();

        await Task.WhenAll(listTask, tagsTask, liveTask);

        var result = listTask.Result;
        _sessions = result.Sessions;
        _totalCount = result.Total;
        _hasMoreSessions = result.HasMore;
        _tagsData = tagsTask.Result;
        _liveSessions = liveTask.Result;

        // Mark live sessions in the list
        MarkLiveSessions();

        _loading = false;

        // Poll for live sessions every 30s
        _liveTimer = new Timer(async _ =>
        {
            try
            {
                _liveSessions = await ReplayService.DetectLiveSessionsAsync();
                MarkLiveSessions();
                await InvokeAsync(StateHasChanged);
            }
            catch { /* silent */ }
        }, null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));
    }

    private void MarkLiveSessions()
    {
        var livePaths = _liveSessions.Select(l => l.FilePath).ToHashSet();
        foreach (var s in _sessions)
            s.IsLive = livePaths.Contains(s.FilePath);
    }

    private async Task LoadMoreSessions()
    {
        _loadingMore = true;
        StateHasChanged();

        try
        {
            var result = await ReplayService.ListSessionsAsync(10, _sessions.Count);
            _sessions.AddRange(result.Sessions);
            _hasMoreSessions = result.HasMore;
            _totalCount = result.Total;
            MarkLiveSessions();
        }
        catch { /* silent */ }
        finally
        {
            _loadingMore = false;
            StateHasChanged();
        }
    }

    private async Task SelectSession(SessionReplaySummary session)
    {
        _selected = session;
        _events = [];
        _displayEvents = [];
        _loadingEvents = true;
        _playing = false;
        _visibleCount = 0;
        _expandedEvents = [];
        StopReplayTimer();
        StateHasChanged();

        try
        {
            var result = await ReplayService.LoadSessionAsync(session.FilePath, 50, 0);
            _events = result.Events;
            _displayEvents = _events;
            _hasMoreEvents = result.HasMore;
            _totalEvents = result.Total;
        }
        catch
        {
            _events = [];
            _displayEvents = [];
        }
        finally
        {
            _loadingEvents = false;
            StateHasChanged();
        }
    }

    private async Task LoadMoreEvents()
    {
        if (_selected == null || _loadingMoreEvents) return;
        _loadingMoreEvents = true;
        StateHasChanged();

        try
        {
            var result = await ReplayService.LoadSessionAsync(_selected.FilePath, 50, _events.Count);
            _events.AddRange(result.Events);
            _displayEvents = _events;
            _hasMoreEvents = result.HasMore;
            _totalEvents = result.Total;
        }
        catch { /* silent */ }
        finally
        {
            _loadingMoreEvents = false;
            StateHasChanged();
        }
    }

    // ===== Search =====

    private async Task HandleSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key != "Enter" || string.IsNullOrWhiteSpace(_search)) return;
        _searching = true;
        _searchMode = true;
        StateHasChanged();

        try
        {
            _searchResults = await ReplayService.SearchAsync(_search, 20);
        }
        catch { _searchResults = []; }
        finally
        {
            _searching = false;
            StateHasChanged();
        }
    }

    private void ClearSearch()
    {
        _search = "";
        _searchMode = false;
        _searchResults = [];
        StateHasChanged();
    }

    private async Task SelectSearchResult(SessionSearchResult result)
    {
        // Find matching session or load it
        var session = _sessions.FirstOrDefault(s => s.FilePath == result.FilePath);
        if (session != null)
        {
            await SelectSession(session);
        }
        else
        {
            // Create a minimal summary for display
            await SelectSession(new SessionReplaySummary
            {
                Id = result.SessionId,
                FilePath = result.FilePath,
                ProjectPath = result.ProjectPath
            });
        }
    }

    // ===== Tags =====

    private List<string> GetSessionTags(string sessionId)
        => _tagsData.Tags.TryGetValue(sessionId, out var tags) ? tags : [];

    private async Task HandleTagKeyDown(KeyboardEventArgs e)
    {
        if (e.Key != "Enter" || string.IsNullOrWhiteSpace(_tagInput)) return;
        await AddTag(_tagInput.Trim());
        _tagInput = "";
    }

    private async Task AddTag(string tag)
    {
        if (_selected == null || string.IsNullOrWhiteSpace(tag)) return;
        var current = GetSessionTags(_selected.Id);
        if (current.Contains(tag)) return;
        var newTags = new List<string>(current) { tag };
        await ReplayService.SetTagAsync(_selected.Id, newTags);
        _tagsData = await ReplayService.GetTagsAsync();
        StateHasChanged();
    }

    private async Task RemoveTag(string tag)
    {
        if (_selected == null) return;
        var current = GetSessionTags(_selected.Id).Where(t => t != tag).ToList();
        await ReplayService.SetTagAsync(_selected.Id, current);
        _tagsData = await ReplayService.GetTagsAsync();
        StateHasChanged();
    }

    // ===== Export =====

    private async Task ExportSession()
    {
        if (_selected == null) return;
        try
        {
            var md = await ReplayService.ExportToMarkdownAsync(_selected.FilePath);
            // Copy to clipboard via JS interop would be ideal, but for now just store it
            _exportCopied = true;
            StateHasChanged();
            await Task.Delay(2000);
            _exportCopied = false;
            StateHasChanged();
        }
        catch { /* silent */ }
    }

    // ===== Replay =====

    private void StartReplay()
    {
        _playing = true;
        _visibleCount = 0;
        _replayTimer = new Timer(_ =>
        {
            if (_visibleCount >= _displayEvents.Count)
            {
                StopReplay();
                return;
            }
            _visibleCount++;
            _ = InvokeAsync(StateHasChanged);
        }, null, TimeSpan.Zero, TimeSpan.FromMilliseconds(300));
    }

    private void StopReplay()
    {
        _playing = false;
        StopReplayTimer();
        _visibleCount = _displayEvents.Count;
        _ = InvokeAsync(StateHasChanged);
    }

    private void StopReplayTimer()
    {
        _replayTimer?.Dispose();
        _replayTimer = null;
    }

    // ===== UI Helpers =====

    private void ToggleExpand(int idx)
    {
        if (!_expandedEvents.Remove(idx))
            _expandedEvents.Add(idx);
    }

    private static string GetProjectDisplayName(string projectPath)
    {
        if (string.IsNullOrEmpty(projectPath)) return "알 수 없음";
        var parts = projectPath.Split('/', '\\');
        return parts[^1];
    }

    private static string FormatTime(DateTime? ts)
    {
        if (ts == null) return "";
        return ts.Value.ToLocalTime().ToString("M/d HH:mm");
    }

    private static string FormatEventTime(DateTime? ts)
    {
        if (ts == null) return "";
        return ts.Value.ToLocalTime().ToString("HH:mm:ss");
    }

    private static string FormatDuration(DateTime? start, DateTime? end)
    {
        if (start == null || end == null) return "";
        var diff = end.Value - start.Value;
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m";
        return $"{(int)diff.TotalHours}h {diff.Minutes}m";
    }

    private static string GetToolIcon(string toolName) => toolName switch
    {
        "Bash" => Icons.Material.Filled.Terminal,
        "Read" => Icons.Material.Filled.Visibility,
        "Write" => Icons.Material.Filled.Edit,
        "Edit" => Icons.Material.Filled.Edit,
        "Glob" => Icons.Material.Filled.Folder,
        "Grep" => Icons.Material.Filled.Search,
        "Agent" => Icons.Material.Filled.SmartToy,
        "WebFetch" or "WebSearch" => Icons.Material.Filled.Language,
        "ToolSearch" => Icons.Material.Filled.Build,
        _ => Icons.Material.Filled.Code
    };

    public void Dispose()
    {
        _liveTimer?.Dispose();
        _replayTimer?.Dispose();
    }
}

