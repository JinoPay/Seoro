@using Cominomi.Shared.Models
@inject IJSRuntime JS

<div class="filediff-view">
    <div class="filediff-header">
        <MudIcon Icon="@GetFileIcon(Diff.ChangeType)" Size="Size.Small"
                 Style="@($"width: 16px; height: 16px; {GetFileIconStyle(Diff.ChangeType)}")" />
        <span class="filediff-path">@Diff.FilePath</span>
        <div class="diff-stats" style="margin-left: auto;">
            @if (Diff.Additions > 0) { <span class="additions">+@Diff.Additions</span> }
            @if (Diff.Deletions > 0) { <span class="deletions">-@Diff.Deletions</span> }
        </div>
    </div>

    <div id="@_elementId" class="filediff-content">
        @if (string.IsNullOrWhiteSpace(Diff.UnifiedDiff))
        {
            <div class="filediff-empty">
                <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Style="opacity: 0.3;" />
                <span>No diff available</span>
            </div>
        }
        else
        {
            @foreach (var line in Diff.UnifiedDiff.Split('\n'))
            {
                var cls = GetLineClass(line);
                var prefix = GetPrefix(line);
                var codeText = GetCodeText(line);
                <div class="diff-line @cls"><span class="diff-prefix">@prefix</span><span class="diff-code">@codeText</span></div>
            }
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public FileDiff Diff { get; set; } = default!;

    private string _elementId = "";
    private string _hljsLang = "";
    private bool _needsHighlight;
    private string? _lastFilePath;

    protected override void OnParametersSet()
    {
        var filePath = Diff.FilePath;
        if (_lastFilePath == filePath) return;
        _lastFilePath = filePath;

        _elementId = $"diff-{filePath.GetHashCode():x8}";
        _hljsLang = GetHljsLanguage(filePath);
        _needsHighlight = !string.IsNullOrWhiteSpace(Diff.UnifiedDiff) && _hljsLang.Length > 0;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_needsHighlight)
        {
            _needsHighlight = false;
            try
            {
                await JS.InvokeVoidAsync("highlightDiffBlock", _elementId, _hljsLang);
            }
            catch
            {
                // JS interop may fail during disposal
            }
        }
    }

    private static string GetFileIcon(FileChangeType type) => type switch
    {
        FileChangeType.Added => Icons.Material.Filled.NoteAdd,
        FileChangeType.Deleted => Icons.Material.Filled.Delete,
        FileChangeType.Renamed => Icons.Material.Filled.DriveFileRenameOutline,
        _ => Icons.Material.Filled.EditNote
    };

    private static string GetFileIconStyle(FileChangeType type) => type switch
    {
        FileChangeType.Added => "color: var(--color-success);",
        FileChangeType.Deleted => "color: var(--color-error);",
        FileChangeType.Renamed => "color: var(--color-warning);",
        _ => "color: var(--color-info);"
    };

    private static string GetLineClass(string line)
    {
        if (line.StartsWith("@@")) return "hunk";
        if (line.StartsWith('+') && !line.StartsWith("+++")) return "addition";
        if (line.StartsWith('-') && !line.StartsWith("---")) return "deletion";
        return "";
    }

    private static string GetPrefix(string line)
    {
        if (line.Length == 0) return "";
        if (line.StartsWith("@@")) return "";
        if (line.StartsWith('+') || line.StartsWith('-') || line.StartsWith(' '))
            return line[..1];
        return "";
    }

    private static string GetCodeText(string line)
    {
        if (line.Length == 0) return "";
        if (line.StartsWith("@@")) return line;
        if (line.StartsWith('+') || line.StartsWith('-') || line.StartsWith(' '))
            return line[1..];
        return line;
    }

    private static string GetHljsLanguage(string filePath)
    {
        var ext = Path.GetExtension(filePath).ToLowerInvariant();
        return ext switch
        {
            ".cs" => "csharp",
            ".js" or ".jsx" => "javascript",
            ".ts" or ".tsx" => "typescript",
            ".py" => "python",
            ".rs" => "rust",
            ".go" => "go",
            ".java" => "java",
            ".html" or ".razor" => "xml",
            ".css" or ".scss" => "css",
            ".json" => "json",
            ".yaml" or ".yml" => "yaml",
            ".xml" or ".csproj" or ".sln" => "xml",
            ".sh" or ".bash" or ".zsh" => "bash",
            ".sql" => "sql",
            ".rb" => "ruby",
            ".swift" => "swift",
            ".kt" => "kotlin",
            ".dart" => "dart",
            ".php" => "php",
            ".dockerfile" => "dockerfile",
            ".toml" or ".ini" or ".cfg" => "ini",
            ".c" or ".cpp" or ".h" or ".hpp" => "cpp",
            ".m" or ".mm" => "objectivec",
            ".r" => "r",
            ".lua" => "lua",
            ".pl" => "perl",
            ".makefile" => "makefile",
            ".graphql" => "graphql",
            ".proto" => "protobuf",
            _ => ""
        };
    }
}
