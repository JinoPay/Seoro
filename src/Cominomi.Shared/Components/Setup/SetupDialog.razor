@using System.Runtime.InteropServices
@inject IDependencyCheckService DependencyCheckService

<MudDialog Visible="IsOpen" VisibleChanged="OnVisibleChanged" Options="_dialogOptions">
    <TitleContent>
        <div class="typo-h6">
            <MudIcon Icon="@Icons.Material.Filled.Build" Class="mr-2" />
            초기 설정
        </div>
    </TitleContent>
    <DialogContent>
        <div class="stack gap-3 pa-2" style="min-width: 440px;">
            <p class="typo-body2 text-secondary">
                Cominomi를 사용하려면 다음 도구들이 설치되어 있어야 합니다.
            </p>

            @if (_loading)
            {
                <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
            }
            else if (_results != null)
            {
                @foreach (var dep in _results)
                {
                    <MudPaper Class="pa-3" Elevation="0" Outlined="true">
                        <div class="stack-row items-center gap-2">
                            @if (dep.IsInstalled)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" />
                            }
                            else
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Warning" />
                            }
                            <div class="stack flex-1">
                                <div class="typo-subtitle2">@dep.Name</div>
                                <small class="typo-caption text-secondary">@dep.Description</small>
                            </div>
                            @if (dep.IsInstalled)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Text">
                                    @(dep.Version ?? "설치됨")
                                </MudChip>
                            }
                        </div>

                        @if (!dep.IsInstalled)
                        {
                            <MudDivider Class="my-2" />
                            <div class="stack gap-1">
                                <small class="typo-caption text-secondary">설치 방법:</small>
                                @if (_isMac)
                                {
                                    <p class="typo-body2">
                                        <code>@dep.MacInstallHint</code>
                                    </p>
                                }
                                else
                                {
                                    <p class="typo-body2">
                                        <code>@dep.WindowsInstallHint</code>
                                    </p>
                                }
                                <MudLink Href="@dep.InstallUrl" Target="_blank" Typo="Typo.caption">
                                    @dep.InstallUrl
                                </MudLink>
                            </div>
                        }
                    </MudPaper>
                }
            }
        </div>
    </DialogContent>
    <DialogActions>
        @if (_allInstalled)
        {
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Close">
                시작
            </MudButton>
        }
        else
        {
            <MudButton OnClick="Close">건너뛰기</MudButton>
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Recheck"
                       Disabled="_loading">
                다시 확인
            </MudButton>
        }
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback<bool> IsOpenChanged { get; set; }

    private List<DependencyResult>? _results;
    private bool _loading;
    private bool _allInstalled;
    private bool _isMac = !RuntimeInformation.IsOSPlatform(OSPlatform.Windows);

    private readonly DialogOptions _dialogOptions = new()
    {
        MaxWidth = MaxWidth.Small,
        FullWidth = true,
        BackdropClick = false
    };

    protected override async Task OnParametersSetAsync()
    {
        if (IsOpen && _results == null)
        {
            await RunCheck();
        }
    }

    private async Task RunCheck()
    {
        _loading = true;
        StateHasChanged();

        _results = await DependencyCheckService.CheckAllAsync();
        _allInstalled = _results.All(r => r.IsInstalled);
        _loading = false;

        if (_allInstalled)
        {
            await Close();
        }
    }

    private async Task Recheck()
    {
        _results = null;
        await RunCheck();
    }

    private async Task OnVisibleChanged(bool visible)
    {
        if (IsOpen != visible)
        {
            IsOpen = visible;
            await IsOpenChanged.InvokeAsync(visible);
        }
    }

    private async Task Close()
    {
        IsOpen = false;
        await IsOpenChanged.InvokeAsync(false);
    }
}
