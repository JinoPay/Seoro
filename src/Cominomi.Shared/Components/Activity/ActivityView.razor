@inject IActivityService ActivityService
@inject IWorkspaceService WorkspaceService
@inject ISessionService SessionService
@inject IChatState ChatState
@implements IDisposable

<div class="overlay-page">
    <div class="overlay-page-header">
        <button class="overlay-back-btn" @onclick="Close">
            <MudIcon Icon="@Icons.Material.Filled.ArrowBack" Size="Size.Small" />
            앱으로 돌아가기
        </button>
    </div>
    <div class="overlay-page-content">
<div class="activity-view">
    <div class="activity-header">
        <span class="activity-header-title">Activity</span>
        <MudIconButton Icon="@Icons.Material.Filled.Refresh" Size="Size.Small"
                       Style="width: 24px; height: 24px; opacity: 0.5;"
                       OnClick="@(() => LoadTimeline())" Disabled="_loading" />
    </div>

    @* Filters *@
    <div class="activity-filters">
        <div class="activity-filter-row">
            <MudChipSet T="string" SelectedValue="_selectedRange" SelectedValueChanged="OnRangeChanged"
                        SelectionMode="SelectionMode.SingleSelection" CheckMark="false"
                        Variant="Variant.Outlined" Color="Color.Primary">
                <MudChip T="string" Value="@("7")">7일</MudChip>
                <MudChip T="string" Value="@("30")">30일</MudChip>
                <MudChip T="string" Value="@("all")">전체</MudChip>
            </MudChipSet>

            <MudSelect T="string" Value="_selectedWorkspaceId" ValueChanged="OnWorkspaceChanged"
                       Variant="Variant.Outlined" Dense="true" Margin="Margin.Dense"
                       Style="max-width: 200px; font-size: var(--text-sm);"
                       AnchorOrigin="Origin.BottomLeft">
                <MudSelectItem T="string" Value="@((string?)null)">모든 프로젝트</MudSelectItem>
                @foreach (var ws in _workspaces)
                {
                    <MudSelectItem T="string" Value="@ws.Id">@ws.Name</MudSelectItem>
                }
            </MudSelect>

            <MudSelect T="string" Value="_selectedSessionId" ValueChanged="OnSessionChanged"
                       Variant="Variant.Outlined" Dense="true" Margin="Margin.Dense"
                       Style="max-width: 200px; font-size: var(--text-sm);"
                       AnchorOrigin="Origin.BottomLeft">
                <MudSelectItem T="string" Value="@((string?)null)">모든 세션</MudSelectItem>
                @foreach (var s in _filteredSessions)
                {
                    <MudSelectItem T="string" Value="@s.Id">@s.Title</MudSelectItem>
                }
            </MudSelect>
        </div>
    </div>

    @* Content *@
    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Style="margin: var(--space-4) 0;" />
    }
    else if (_allGroups.Count == 0)
    {
        <div class="activity-empty">
            <MudIcon Icon="@Icons.Material.Filled.Timeline" Size="Size.Large" Style="opacity: 0.15;" />
            <p class="typo-body2" style="opacity: 0.4;">아직 활동이 없습니다</p>
        </div>
    }
    else
    {
        <div class="activity-list">
            @foreach (var group in _allGroups)
            {
                <div class="activity-date-header">@group.Label</div>

                @foreach (var entry in group.Entries)
                {
                    <div class="activity-entry" @key="entry.ToolCallId">
                        <MudIcon Icon="@ToolDisplayHelper.GetToolIcon(entry.ToolName)"
                                 Size="Size.Small"
                                 Color="@(entry.IsError ? Color.Error : Color.Default)"
                                 Style="width: 16px; height: 16px; margin-top: 2px; flex-shrink: 0;" />

                        <div class="activity-entry-content">
                            <span class="activity-message">@entry.HeaderLabel</span>
                            @if (!string.IsNullOrEmpty(entry.ResultHint))
                            {
                                <span class="activity-result-hint">@entry.ResultHint</span>
                            }
                            <div class="activity-meta">
                                <span class="activity-session-badge">@entry.SessionTitle</span>
                                @if (string.IsNullOrEmpty(_selectedWorkspaceId) && !string.IsNullOrEmpty(entry.WorkspaceName))
                                {
                                    <span class="activity-workspace-badge">@entry.WorkspaceName</span>
                                }
                                <span class="activity-time">@FormatRelativeTime(entry.Timestamp)</span>
                            </div>
                        </div>

                        @if (entry.IsError)
                        {
                            <div class="activity-error-dot"></div>
                        }
                    </div>
                }
            }

            @if (_hasMore)
            {
                <div class="activity-load-more">
                    <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small"
                               OnClick="@LoadMore" Disabled="_loadingMore">
                        @if (_loadingMore)
                        {
                            <MudProgressCircular Indeterminate="true" Size="Size.Small" Class="mr-2" />
                        }
                        더 불러오기
                    </MudButton>
                </div>
            }
        </div>
    }
</div>
    </div>
</div>

@code {
    private List<ActionDateGroup> _allGroups = [];
    private bool _loading;
    private bool _loadingMore;
    private bool _hasMore;
    private DateTime? _oldestTimestamp;

    // Filters
    private string _selectedRange = "7";
    private string? _selectedWorkspaceId;
    private string? _selectedSessionId;

    // Filter dropdown data
    private List<Workspace> _workspaces = [];
    private List<Session> _filteredSessions = [];
    private List<Session> _allSessions = [];

    protected override async Task OnInitializedAsync()
    {
        ChatState.OnChange += HandleStateChanged;

        _workspaces = await WorkspaceService.GetWorkspacesAsync();
        _allSessions = await SessionService.GetSessionsAsync();
        _filteredSessions = _allSessions.OrderByDescending(s => s.UpdatedAt).ToList();

        await LoadTimeline();
    }

    private async Task LoadTimeline()
    {
        _loading = true;
        _allGroups = [];
        _hasMore = false;
        _oldestTimestamp = null;
        StateHasChanged();

        try
        {
            var filter = BuildFilter();
            var result = await ActivityService.GetActionTimelineAsync(filter);
            _allGroups = result.Groups;
            _hasMore = result.HasMore;
            _oldestTimestamp = result.OldestTimestamp;
        }
        catch
        {
            _allGroups = [];
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task LoadMore()
    {
        if (!_hasMore || _oldestTimestamp == null) return;

        _loadingMore = true;
        StateHasChanged();

        try
        {
            var filter = BuildFilter() with { Before = _oldestTimestamp };
            var result = await ActivityService.GetActionTimelineAsync(filter);

            MergeGroups(result.Groups);
            _hasMore = result.HasMore;
            _oldestTimestamp = result.OldestTimestamp;
        }
        catch { /* keep existing data */ }
        finally
        {
            _loadingMore = false;
            StateHasChanged();
        }
    }

    private void MergeGroups(List<ActionDateGroup> newGroups)
    {
        foreach (var newGroup in newGroups)
        {
            var existing = _allGroups.FirstOrDefault(g => g.Label == newGroup.Label);
            if (existing != null)
            {
                // Append entries to existing date group
                var merged = existing.Entries.Concat(newGroup.Entries).ToList();
                var idx = _allGroups.IndexOf(existing);
                _allGroups[idx] = new ActionDateGroup { Label = existing.Label, Entries = merged };
            }
            else
            {
                _allGroups.Add(newGroup);
            }
        }
    }

    private ActionTimelineFilter BuildFilter() => new()
    {
        WorkspaceId = _selectedWorkspaceId,
        SessionId = _selectedSessionId,
        DaysBack = _selectedRange == "all" ? 0 : int.Parse(_selectedRange)
    };

    private async Task OnRangeChanged(string value)
    {
        _selectedRange = value ?? "7";
        await LoadTimeline();
    }

    private async Task OnWorkspaceChanged(string? value)
    {
        _selectedWorkspaceId = value;
        _selectedSessionId = null;

        _filteredSessions = string.IsNullOrEmpty(value)
            ? _allSessions.OrderByDescending(s => s.UpdatedAt).ToList()
            : _allSessions.Where(s => s.WorkspaceId == value).OrderByDescending(s => s.UpdatedAt).ToList();

        await LoadTimeline();
    }

    private async Task OnSessionChanged(string? value)
    {
        _selectedSessionId = value;
        await LoadTimeline();
    }

    private static string FormatRelativeTime(DateTime utcTime)
    {
        var diff = DateTime.UtcNow - utcTime;

        if (diff.TotalMinutes < 1) return "방금 전";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}분 전";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}시간 전";
        if (diff.TotalDays < 7) return $"{(int)diff.TotalDays}일 전";
        return utcTime.ToLocalTime().ToString("M월 d일");
    }

    private void Close() => ChatState.CloseActivity();

    private void HandleStateChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        ChatState.OnChange -= HandleStateChanged;
    }
}
