@inject IActivityService ActivityService
@inject IChatState ChatState
@implements IDisposable

<div class="activity-view">
    <div class="activity-header">
        <span class="activity-header-title">Activity</span>
        <MudIconButton Icon="@Icons.Material.Filled.Refresh" Size="Size.Small"
                       Style="width: 24px; height: 24px; opacity: 0.5;"
                       OnClick="@LoadActivity" Disabled="_loading" />
    </div>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Style="margin: var(--space-4) 0;" />
    }
    else if (_groups.Count == 0)
    {
        <div class="activity-empty">
            <MudIcon Icon="@Icons.Material.Filled.Timeline" Size="Size.Large" Style="opacity: 0.15;" />
            <MudText Typo="Typo.body2" Style="opacity: 0.4;">아직 커밋이 없습니다</MudText>
        </div>
    }
    else
    {
        <div class="activity-list">
            @foreach (var group in _groups)
            {
                <div class="activity-date-header">@group.Label</div>

                @foreach (var entry in group.Entries)
                {
                    <div class="activity-entry" @key="entry.CommitHash">
                        <MudIcon Icon="@GetStatusIcon(entry.SessionStatus)"
                                 Size="Size.Small"
                                 Color="@GetStatusColor(entry.SessionStatus)"
                                 Style="width: 16px; height: 16px; margin-top: 2px; flex-shrink: 0;" />

                        <div class="activity-entry-content">
                            <span class="activity-message">@entry.Message</span>
                            <div class="activity-meta">
                                <span class="activity-session-badge">@entry.SessionTitle</span>
                                <span class="activity-hash">@entry.ShortHash</span>
                                <span class="activity-time">@FormatRelativeTime(entry.Timestamp)</span>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    }
</div>

@code {
    private List<ActivityDateGroup> _groups = [];
    private bool _loading;

    protected override async Task OnInitializedAsync()
    {
        ChatState.OnChange += HandleStateChanged;
        await LoadActivity();
    }

    private async Task LoadActivity()
    {
        var workspace = ChatState.CurrentWorkspace;
        if (workspace == null) return;

        _loading = true;
        StateHasChanged();

        try
        {
            _groups = await ActivityService.GetWorkspaceActivityAsync(workspace.Id);
        }
        catch
        {
            _groups = [];
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private static string GetStatusIcon(SessionStatus status) => status switch
    {
        SessionStatus.Merged => Icons.Material.Filled.CheckCircle,
        SessionStatus.PrOpen => Icons.Material.Filled.OpenInNew,
        SessionStatus.Pushed => Icons.Material.Filled.CloudUpload,
        SessionStatus.ConflictDetected => Icons.Material.Filled.Warning,
        SessionStatus.Error => Icons.Material.Filled.Error,
        SessionStatus.Archived => Icons.Material.Filled.Archive,
        _ => Icons.Material.Filled.Commit
    };

    private static Color GetStatusColor(SessionStatus status) => status switch
    {
        SessionStatus.Merged => Color.Success,
        SessionStatus.PrOpen => Color.Info,
        SessionStatus.ConflictDetected => Color.Warning,
        SessionStatus.Error => Color.Error,
        SessionStatus.Archived => Color.Default,
        _ => Color.Default
    };

    private static string FormatRelativeTime(DateTime utcTime)
    {
        var diff = DateTime.UtcNow - utcTime;

        if (diff.TotalMinutes < 1) return "방금 전";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}분 전";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}시간 전";
        if (diff.TotalDays < 7) return $"{(int)diff.TotalDays}일 전";
        return utcTime.ToLocalTime().ToString("M월 d일");
    }

    private void HandleStateChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        ChatState.OnChange -= HandleStateChanged;
    }
}
