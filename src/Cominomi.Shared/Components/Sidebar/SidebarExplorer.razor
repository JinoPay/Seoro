@using Cominomi.Shared.Models
@inject IChatState ChatState
@inject IGitService GitService
@implements IDisposable

<div class="sidebar-explorer">
    <div class="tree-header">
        <span class="tree-header-label">Explorer</span>
        <div class="tree-header-actions">
            <MudIconButton Icon="@Icons.Material.Filled.Refresh" Size="Size.Small"
                           Style="width: 22px; height: 22px; opacity: 0.5;"
                           OnClick="LoadFilesAsync" Disabled="_loading" />
        </div>
    </div>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="my-2" />
    }
    else if (_error != null)
    {
        <MudAlert Severity="Severity.Error" Dense="true" Class="my-2">@_error</MudAlert>
    }
    else if (_tree.Count == 0)
    {
        <div class="sidebar-explorer-empty">
            <MudIcon Icon="@Icons.Material.Filled.FolderOff" Size="Size.Large" Style="opacity: 0.15;" />
            <span>No files found</span>
        </div>
    }
    else
    {
        <div class="sidebar-explorer-tree">
            <FileTreeNode Nodes="_tree"
                          ExpandedDirs="_expandedDirs"
                          Diff="_diff"
                          OnToggleDir="ToggleDir"
                          OnOpenFile="OpenFile" />
        </div>
    }
</div>

@code {
    private List<FileNode> _tree = new();
    private bool _loading;
    private string? _error;
    private DiffSummary? _diff;
    private string? _lastSessionId;

    // Per-session expanded dirs state
    private Dictionary<string, HashSet<string>> _sessionExpandedDirs = new();
    private HashSet<string> _expandedDirs = new();

    // FileSystemWatcher for throttled change detection
    private FileSystemWatcher? _watcher;
    private System.Timers.Timer? _debounceTimer;
    private readonly object _debounceLock = new();

    protected override async Task OnInitializedAsync()
    {
        ChatState.OnChange += HandleStateChanged;
        await LoadFilesAsync();
        StartWatching();
    }

    protected override async Task OnParametersSetAsync()
    {
        var sessionId = ChatState.CurrentSession?.Id;
        if (sessionId != _lastSessionId)
        {
            // Save current session's expanded state
            if (_lastSessionId != null)
                _sessionExpandedDirs[_lastSessionId] = _expandedDirs;

            _lastSessionId = sessionId;

            // Restore or initialize expanded state for this session
            if (sessionId != null && _sessionExpandedDirs.TryGetValue(sessionId, out var saved))
            {
                _expandedDirs = saved;
            }
            else
            {
                _expandedDirs = new HashSet<string>();
            }

            await LoadFilesAsync();
            StartWatching();

            // Save initial (collapsed) state for this session
            if (sessionId != null && !_sessionExpandedDirs.ContainsKey(sessionId))
            {
                _sessionExpandedDirs[sessionId] = _expandedDirs;
            }
        }
    }

    private void StartWatching()
    {
        StopWatching();

        var path = ChatState.CurrentSession?.Git.WorktreePath;
        if (string.IsNullOrEmpty(path) || !Directory.Exists(path))
            return;

        _watcher = new FileSystemWatcher(path)
        {
            IncludeSubdirectories = true,
            NotifyFilter = NotifyFilters.FileName | NotifyFilters.LastWrite | NotifyFilters.Size,
            EnableRaisingEvents = true
        };

        _debounceTimer = new System.Timers.Timer(2000) { AutoReset = false };
        _debounceTimer.Elapsed += async (_, _) =>
        {
            try
            {
                await InvokeAsync(async () =>
                {
                    var prevDiffFiles = _diff?.Files.Select(f => f.FilePath).ToHashSet() ?? new HashSet<string>();
                    await LoadFilesAsync(preserveExpanded: true);
                    var newDiffFiles = _diff?.Files.Select(f => f.FilePath).ToHashSet() ?? new HashSet<string>();

                    // Auto-expand directories of newly changed files
                    var newlyChanged = newDiffFiles.Except(prevDiffFiles).ToList();
                    if (newlyChanged.Count > 0)
                    {
                        foreach (var filePath in newlyChanged)
                            ExpandParentDirs(filePath);
                        StateHasChanged();
                    }
                });
            }
            catch { /* component may be disposed */ }
        };

        void OnChange(object sender, FileSystemEventArgs e)
        {
            if (e.FullPath.Contains(Path.DirectorySeparatorChar + ".git" + Path.DirectorySeparatorChar) ||
                e.FullPath.EndsWith(Path.DirectorySeparatorChar + ".git"))
                return;

            lock (_debounceLock)
            {
                _debounceTimer?.Stop();
                _debounceTimer?.Start();
            }
        }

        _watcher.Changed += OnChange;
        _watcher.Created += OnChange;
        _watcher.Deleted += OnChange;
        _watcher.Renamed += (s, e) => OnChange(s, e);
    }

    private void StopWatching()
    {
        if (_watcher != null)
        {
            _watcher.EnableRaisingEvents = false;
            _watcher.Dispose();
            _watcher = null;
        }
        lock (_debounceLock)
        {
            _debounceTimer?.Dispose();
            _debounceTimer = null;
        }
    }

    private async Task LoadFilesAsync(bool preserveExpanded = false)
    {
        var session = ChatState.CurrentSession;
        if (session == null || string.IsNullOrEmpty(session.Git.WorktreePath)) return;

        _loading = true;
        _error = null;
        StateHasChanged();

        try
        {
            var files = await GitService.ListTrackedFilesAsync(session.Git.WorktreePath);

            try
            {
                var diffBase = !string.IsNullOrEmpty(session.Git.BaseBranch) ? session.Git.BaseBranch : "HEAD";
                _diff = await GitService.GetDiffSummaryAsync(session.Git.WorktreePath, diffBase);
            }
            catch { _diff = null; }

            _tree = BuildTree(files);

            // No auto-expand: tree starts collapsed by default

            // Always ensure diff file parents are expanded
            if (_diff != null)
            {
                foreach (var file in _diff.Files)
                    ExpandParentDirs(file.FilePath);
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    // Parameterless overload for button click
    private Task LoadFilesAsync() => LoadFilesAsync(preserveExpanded: false);

    private async Task OpenFile(string filePath)
    {
        var session = ChatState.CurrentSession;
        if (session == null || string.IsNullOrEmpty(session.Git.WorktreePath)) return;

        try
        {
            var content = await GitService.ReadFileAsync(session.Git.WorktreePath, filePath);
            ChatState.Tabs.OpenFileContentTab(filePath, content);
        }
        catch (Exception ex)
        {
            ChatState.Tabs.OpenFileContentTab(filePath, $"Error reading file: {ex.Message}");
        }
    }

    private void ToggleDir(string path)
    {
        if (!_expandedDirs.Remove(path))
            _expandedDirs.Add(path);
    }

    private void ExpandParentDirs(string filePath)
    {
        var parts = filePath.Split('/');
        var currentPath = "";
        for (int i = 0; i < parts.Length - 1; i++)
        {
            currentPath = i == 0 ? parts[i] : $"{currentPath}/{parts[i]}";
            _expandedDirs.Add(currentPath);
        }
    }

    private void ExpandAllDirs(List<FileNode> nodes)
    {
        foreach (var node in nodes)
        {
            if (node.IsDirectory)
            {
                _expandedDirs.Add(node.FullPath);
                ExpandAllDirs(node.Children);
            }
        }
    }

    private static List<FileNode> BuildTree(List<string> files)
    {
        var root = new List<FileNode>();
        var dirMap = new Dictionary<string, FileNode>();

        foreach (var file in files.OrderBy(f => f))
        {
            var parts = file.Split('/');
            var currentList = root;
            var currentPath = "";

            for (int i = 0; i < parts.Length; i++)
            {
                currentPath = i == 0 ? parts[i] : $"{currentPath}/{parts[i]}";
                bool isLast = i == parts.Length - 1;

                if (isLast)
                {
                    currentList.Add(new FileNode { Name = parts[i], FullPath = file, IsDirectory = false });
                }
                else
                {
                    if (!dirMap.TryGetValue(currentPath, out var dirNode))
                    {
                        dirNode = new FileNode { Name = parts[i], FullPath = currentPath, IsDirectory = true };
                        dirMap[currentPath] = dirNode;
                        currentList.Add(dirNode);
                    }
                    currentList = dirNode.Children;
                }
            }
        }

        return root;
    }

    private void HandleStateChanged()
    {
        _ = InvokeAsync(async () =>
        {
            var sessionId = ChatState.CurrentSession?.Id;
            if (sessionId != _lastSessionId)
            {
                // Save current session's expanded state
                if (_lastSessionId != null)
                    _sessionExpandedDirs[_lastSessionId] = _expandedDirs;

                _lastSessionId = sessionId;

                if (sessionId != null)
                {
                    // Restore or initialize expanded state for this session
                    if (_sessionExpandedDirs.TryGetValue(sessionId, out var saved))
                        _expandedDirs = saved;
                    else
                        _expandedDirs = new HashSet<string>();

                    await LoadFilesAsync();
                    StartWatching();

                    if (!_sessionExpandedDirs.ContainsKey(sessionId))
                        _sessionExpandedDirs[sessionId] = _expandedDirs;
                }
                else
                {
                    _tree = new();
                    _diff = null;
                    _error = null;
                    _expandedDirs = new HashSet<string>();
                    StopWatching();
                    StateHasChanged();
                }
                return;
            }
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        ChatState.OnChange -= HandleStateChanged;
        StopWatching();

        // Save current session state before dispose
        if (_lastSessionId != null)
            _sessionExpandedDirs[_lastSessionId] = _expandedDirs;
    }

}
