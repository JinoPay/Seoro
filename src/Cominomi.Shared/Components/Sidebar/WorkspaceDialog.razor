@inject IWorkspaceService WorkspaceService
@inject ISessionService SessionService
@inject IGitService GitService
@inject IFolderPickerService FolderPickerService
@inject ChatState ChatState

<MudDialog Visible="IsOpen" VisibleChanged="OnVisibleChanged" Options="_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Workspaces" Class="mr-2" />
            Workspaces
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="2" Class="pa-2" Style="min-width: 450px; max-height: 600px; overflow-y: auto;">
            @if (_step == WizardStep.List)
            {
                @foreach (var ws in _workspaces)
                {
                    var isActive = ChatState.CurrentWorkspace?.Id == ws.Id;
                    <MudPaper Class="pa-2" Outlined="true"
                              Style="@($"border-radius: 8px; {(isActive ? "border-color: var(--mud-palette-primary);" : "")}")">
                        <MudStack Row="true" AlignItems="AlignItems.Center">
                            <MudStack Spacing="0" Style="flex: 1; min-width: 0;">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                    <MudText Typo="Typo.body2" Style="font-weight: 600;">@ws.Name</MudText>
                                    @if (!string.IsNullOrEmpty(ws.BranchName))
                                    {
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                                 Color="Color.Primary" Style="font-size: 0.7rem;">
                                            @ws.BranchName
                                        </MudChip>
                                    }
                                    @if (ws.Status == WorkspaceStatus.Initializing)
                                    {
                                        <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                                    }
                                    else if (ws.Status == WorkspaceStatus.Error)
                                    {
                                        <MudIcon Icon="@Icons.Material.Filled.Error" Size="Size.Small" Color="Color.Error" />
                                    }
                                </MudStack>
                                @if (!string.IsNullOrEmpty(ws.RepoUrl))
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Secondary"
                                             Style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                        @ws.RepoUrl
                                    </MudText>
                                }
                                else if (!string.IsNullOrEmpty(ws.RepoLocalPath))
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Secondary"
                                             Style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                        @ShortenPath(ws.RepoLocalPath)
                                    </MudText>
                                }
                                @if (ws.Status == WorkspaceStatus.Error && !string.IsNullOrEmpty(ws.ErrorMessage))
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Error">@ws.ErrorMessage</MudText>
                                }
                            </MudStack>
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                           OnClick="@(() => StartEdit(ws))" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                           Color="Color.Error"
                                           OnClick="@(() => DeleteWorkspace(ws))" />
                        </MudStack>
                    </MudPaper>
                }

                <MudStack Row="true" Spacing="2">
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Style="flex: 1;"
                               StartIcon="@Icons.Material.Filled.Cloud" OnClick="@(() => StartCreate(WizardStep.GitHubForm))">
                        Clone from URL
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Style="flex: 1;"
                               StartIcon="@Icons.Material.Filled.Folder" OnClick="@(() => StartCreate(WizardStep.LocalForm))">
                        Local Repository
                    </MudButton>
                </MudStack>
            }
            else if (_step == WizardStep.EditForm)
            {
                <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">Edit Workspace</MudText>
                <MudTextField @bind-Value="_editName" Label="Name" Variant="Variant.Outlined"
                              Margin="Margin.Dense" />
                <MudSelect T="string" @bind-Value="_editModel" Label="Default Model"
                           Variant="Variant.Outlined" Margin="Margin.Dense">
                    @foreach (var model in ModelDefinitions.All)
                    {
                        <MudSelectItem T="string" Value="@model.Id">@model.DisplayName</MudSelectItem>
                    }
                </MudSelect>
                <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="1">
                    <MudButton Size="Size.Small" OnClick="BackToList">Cancel</MudButton>
                    <MudButton Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled"
                               OnClick="SaveEdit">Save</MudButton>
                </MudStack>
            }
            else if (_step == WizardStep.GitHubForm)
            {
                <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">Clone from URL</MudText>
                <MudTextField @bind-Value="_repoUrl" Label="Repository URL" Variant="Variant.Outlined"
                              Margin="Margin.Dense" Placeholder="https://github.com/org/repo"
                              Immediate="true" TextChanged="OnUrlChanged" />
                <MudTextField @bind-Value="_editName" Label="Workspace Name" Variant="Variant.Outlined"
                              Margin="Margin.Dense" />
                <MudTextField @bind-Value="_branchName" Label="Branch Name" Variant="Variant.Outlined"
                              Margin="Margin.Dense" />
                <MudTextField @bind-Value="_baseBranch" Label="Base Branch" Variant="Variant.Outlined"
                              Margin="Margin.Dense" Placeholder="main" />
                <MudSelect T="string" @bind-Value="_editModel" Label="Default Model"
                           Variant="Variant.Outlined" Margin="Margin.Dense">
                    @foreach (var model in ModelDefinitions.All)
                    {
                        <MudSelectItem T="string" Value="@model.Id">@model.DisplayName</MudSelectItem>
                    }
                </MudSelect>
                <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="1">
                    <MudButton Size="Size.Small" OnClick="BackToList">Cancel</MudButton>
                    <MudButton Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled"
                               OnClick="CreateFromUrl"
                               Disabled="@(string.IsNullOrWhiteSpace(_repoUrl) || string.IsNullOrWhiteSpace(_editName) || string.IsNullOrWhiteSpace(_branchName))">
                        Create
                    </MudButton>
                </MudStack>
            }
            else if (_step == WizardStep.LocalForm)
            {
                <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">Local Repository</MudText>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <MudTextField @bind-Value="_localPath" Label="Repository Path" Variant="Variant.Outlined"
                                  Margin="Margin.Dense" Placeholder="/path/to/repo" Style="flex: 1;" />
                    <MudIconButton Icon="@Icons.Material.Filled.FolderOpen" Color="Color.Primary"
                                   OnClick="BrowseLocalFolder" Title="Browse..." />
                </MudStack>
                @if (_localPathValidation != null)
                {
                    <MudAlert Severity="@(_isLocalPathGitRepo ? Severity.Success : Severity.Warning)" Dense="true">
                        @_localPathValidation
                    </MudAlert>
                }
                <MudTextField @bind-Value="_editName" Label="Workspace Name" Variant="Variant.Outlined"
                              Margin="Margin.Dense" />
                <MudTextField @bind-Value="_branchName" Label="Branch Name" Variant="Variant.Outlined"
                              Margin="Margin.Dense" />
                <MudTextField @bind-Value="_baseBranch" Label="Base Branch" Variant="Variant.Outlined"
                              Margin="Margin.Dense" Placeholder="main" />
                <MudSelect T="string" @bind-Value="_editModel" Label="Default Model"
                           Variant="Variant.Outlined" Margin="Margin.Dense">
                    @foreach (var model in ModelDefinitions.All)
                    {
                        <MudSelectItem T="string" Value="@model.Id">@model.DisplayName</MudSelectItem>
                    }
                </MudSelect>
                <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="1">
                    <MudButton Size="Size.Small" OnClick="BackToList">Cancel</MudButton>
                    <MudButton Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled"
                               OnClick="CreateFromLocal"
                               Disabled="@(string.IsNullOrWhiteSpace(_localPath) || string.IsNullOrWhiteSpace(_editName) || string.IsNullOrWhiteSpace(_branchName))">
                        Create
                    </MudButton>
                </MudStack>
            }
            else if (_step == WizardStep.Creating)
            {
                <MudStack AlignItems="AlignItems.Center" Spacing="2" Class="pa-4">
                    <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                    <MudText Typo="Typo.body2" Align="Align.Center">@_progressMessage</MudText>
                </MudStack>
            }

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <MudAlert Severity="Severity.Error" Dense="true">@_errorMessage</MudAlert>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback<bool> IsOpenChanged { get; set; }
    [Parameter] public EventCallback OnWorkspacesChanged { get; set; }

    private enum WizardStep { List, GitHubForm, LocalForm, EditForm, Creating }

    private List<Workspace> _workspaces = [];
    private WizardStep _step = WizardStep.List;
    private Workspace? _editingWorkspace;

    // Form fields
    private string _editName = "";
    private string _editModel = ModelDefinitions.Default.Id;
    private string _repoUrl = "";
    private string _localPath = "";
    private string _branchName = "";
    private string _baseBranch = "main";
    private string _progressMessage = "";
    private string? _errorMessage;
    private string? _localPathValidation;
    private bool _isLocalPathGitRepo;

    private readonly DialogOptions _dialogOptions = new()
    {
        MaxWidth = MaxWidth.Small,
        FullWidth = true
    };

    protected override async Task OnParametersSetAsync()
    {
        if (IsOpen)
        {
            _workspaces = await WorkspaceService.GetWorkspacesAsync();
            _step = WizardStep.List;
            _errorMessage = null;
        }
    }

    private void StartCreate(WizardStep step)
    {
        _editName = "";
        _repoUrl = "";
        _localPath = "";
        _branchName = $"cominomi/{DateTime.Now:yyyyMMdd-HHmm}";
        _baseBranch = "main";
        _editModel = ModelDefinitions.Default.Id;
        _errorMessage = null;
        _localPathValidation = null;
        _isLocalPathGitRepo = false;
        _step = step;
    }

    private void StartEdit(Workspace ws)
    {
        _editingWorkspace = ws;
        _editName = ws.Name;
        _editModel = ws.DefaultModel;
        _errorMessage = null;
        _step = WizardStep.EditForm;
    }

    private void BackToList()
    {
        _step = WizardStep.List;
        _editingWorkspace = null;
        _errorMessage = null;
    }

    private async Task BrowseLocalFolder()
    {
        var path = await FolderPickerService.PickFolderAsync();
        if (string.IsNullOrEmpty(path))
            return;

        _localPath = path;
        _localPathValidation = null;
        _isLocalPathGitRepo = false;

        var isGitRepo = await GitService.IsGitRepoAsync(path);
        if (!isGitRepo)
        {
            _localPathValidation = "This folder is not a git repository.";
            _isLocalPathGitRepo = false;
            return;
        }

        _isLocalPathGitRepo = true;
        _localPathValidation = "Valid git repository";

        // Auto-fill workspace name from folder name
        if (string.IsNullOrEmpty(_editName))
        {
            _editName = Path.GetFileName(path.TrimEnd(Path.DirectorySeparatorChar, Path.AltDirectorySeparatorChar)) ?? "";
        }

        // Auto-detect base branch
        var detectedBranch = await GitService.DetectDefaultBranchAsync(path);
        if (detectedBranch != null)
        {
            _baseBranch = detectedBranch;
        }
    }

    private void OnUrlChanged(string url)
    {
        _repoUrl = url;
        if (!string.IsNullOrWhiteSpace(url) && string.IsNullOrEmpty(_editName))
        {
            _editName = ExtractRepoName(url);
        }
    }

    private async Task SaveEdit()
    {
        if (string.IsNullOrWhiteSpace(_editName) || _editingWorkspace == null)
            return;

        _editingWorkspace.Name = _editName.Trim();
        _editingWorkspace.DefaultModel = _editModel;
        await WorkspaceService.SaveWorkspaceAsync(_editingWorkspace);

        _workspaces = await WorkspaceService.GetWorkspacesAsync();
        await OnWorkspacesChanged.InvokeAsync();
        BackToList();
    }

    private async Task CreateFromUrl()
    {
        _errorMessage = null;
        _step = WizardStep.Creating;
        _progressMessage = "Starting...";
        StateHasChanged();

        var progress = new Progress<string>(msg =>
        {
            _progressMessage = msg;
            InvokeAsync(StateHasChanged);
        });

        try
        {
            var ws = await WorkspaceService.CreateFromUrlAsync(
                _repoUrl.Trim(), _editName.Trim(), _branchName.Trim(),
                _baseBranch.Trim(), _editModel, progress);

            if (ws.Status == WorkspaceStatus.Error)
            {
                _errorMessage = ws.ErrorMessage ?? "Failed to create workspace.";
                _step = WizardStep.GitHubForm;
            }
            else
            {
                _workspaces = await WorkspaceService.GetWorkspacesAsync();
                await OnWorkspacesChanged.InvokeAsync();
                BackToList();
            }
        }
        catch (OperationCanceledException)
        {
            _errorMessage = "Operation cancelled.";
            _step = WizardStep.GitHubForm;
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
            _step = WizardStep.GitHubForm;
        }
    }

    private async Task CreateFromLocal()
    {
        _errorMessage = null;
        _step = WizardStep.Creating;
        _progressMessage = "Setting up workspace...";
        StateHasChanged();

        try
        {
            var ws = await WorkspaceService.CreateFromLocalAsync(
                _localPath.Trim(), _editName.Trim(), _branchName.Trim(),
                _baseBranch.Trim(), _editModel);

            if (ws.Status == WorkspaceStatus.Error)
            {
                _errorMessage = ws.ErrorMessage ?? "Failed to create workspace.";
                _step = WizardStep.LocalForm;
            }
            else
            {
                _workspaces = await WorkspaceService.GetWorkspacesAsync();
                await OnWorkspacesChanged.InvokeAsync();
                BackToList();
            }
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
            _step = WizardStep.LocalForm;
        }
    }

    private async Task DeleteWorkspace(Workspace ws)
    {
        // Move sessions to... nowhere. Just delete them since no default workspace.
        var sessions = await SessionService.GetSessionsByWorkspaceAsync(ws.Id);
        foreach (var session in sessions)
        {
            await SessionService.DeleteSessionAsync(session.Id);
        }

        await WorkspaceService.DeleteWorkspaceAsync(ws.Id);
        _workspaces.Remove(ws);

        if (ChatState.CurrentWorkspace?.Id == ws.Id)
        {
            var firstWs = _workspaces.FirstOrDefault();
            if (firstWs != null)
                ChatState.SetWorkspace(firstWs);
            else
                ChatState.SetWorkspace(null!);
        }

        await OnWorkspacesChanged.InvokeAsync();
    }

    private async Task OnVisibleChanged(bool visible)
    {
        if (IsOpen != visible)
        {
            IsOpen = visible;
            await IsOpenChanged.InvokeAsync(visible);
        }
    }

    private async Task Close()
    {
        IsOpen = false;
        await IsOpenChanged.InvokeAsync(false);
    }

    private static string ExtractRepoName(string url)
    {
        var cleaned = url.Trim().TrimEnd('/');
        if (cleaned.EndsWith(".git", StringComparison.OrdinalIgnoreCase))
            cleaned = cleaned[..^4];
        var lastSlash = cleaned.LastIndexOfAny(['/', ':']);
        return lastSlash >= 0 ? cleaned[(lastSlash + 1)..] : cleaned;
    }

    private static string ShortenPath(string path)
    {
        var home = Environment.GetFolderPath(Environment.SpecialFolder.UserProfile);
        if (path.StartsWith(home))
            return "~" + path[home.Length..];
        return path;
    }
}
