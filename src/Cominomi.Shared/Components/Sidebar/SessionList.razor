@inject ChatState ChatState
@inject ISessionService SessionService
@inject ISettingsService SettingsService
@inject IWorkspaceService WorkspaceService
@inject IDialogService DialogService
@implements IDisposable

<div style="display: flex; flex-direction: column; height: 100%; min-height: 0;">
    @if (_workspaces.Count > 0)
    {
        @* Workspace selector *@
        <div class="workspace-selector">
            <MudSelect T="string" Value="@_expandedWorkspaceId" ValueChanged="OnWorkspaceSelected"
                       Variant="Variant.Text" Dense="true" Margin="Margin.Dense"
                       Style="font-size: var(--text-sm);"
                       AnchorOrigin="Origin.BottomLeft" TransformOrigin="Origin.TopLeft">
                @foreach (var ws in _workspaces)
                {
                    <MudSelectItem T="string" Value="@ws.Id">
                        @ws.Name
                        @if (ws.Status == WorkspaceStatus.Error)
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Error" Size="Size.Small" Color="Color.Error"
                                     Style="width: 12px; height: 12px; margin-left: 4px;" />
                        }
                    </MudSelectItem>
                }
            </MudSelect>
        </div>

        @* New chat button *@
        @if (_expandedWorkspaceId != null)
        {
            var ws = _workspaces.FirstOrDefault(w => w.Id == _expandedWorkspaceId);
            @if (ws != null)
            {
                <div class="new-chat-btn" @onclick="@(() => CreateNewChat(ws))"
                     style="@(ws.Status != WorkspaceStatus.Ready || _isCreatingSession ? "opacity: 0.4; pointer-events: none;" : "")">
                    <MudIcon Icon="@Icons.Material.Filled.Add" Size="Size.Small" Style="width: 14px; height: 14px;" />
                    <span>새 대화</span>
                </div>
            }
        }

        @* Session list *@
        <div style="overflow-y: auto; flex: 1; min-height: 0; padding: var(--space-1) 0;">
            @if (_expandedWorkspaceId != null && _sessionCache.TryGetValue(_expandedWorkspaceId, out var sessions))
            {
                @foreach (var session in sessions)
                {
                    var isActive = ChatState.CurrentSession?.Id == session.Id;
                    var isArchived = session.Status == SessionStatus.Archived;

                    <div class="session-item @(isActive ? "active" : "") @(isArchived ? "archived" : "")"
                         style="@(isArchived ? "opacity: 0.35;" : "")"
                         @onclick="@(() => SelectSession(session))">

                        <div class="session-actions">
                            @if (session.Status == SessionStatus.Merged)
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.CleaningServices" Size="Size.Small"
                                               Color="Color.Success" Style="width: 20px; height: 20px;"
                                               OnClick="@(() => CleanupSession(session))"
                                               OnClickStopPropagation="true" />
                            }
                            <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                           Style="width: 20px; height: 20px; opacity: 0.4;"
                                           OnClick="@(() => DeleteSession(session))"
                                           OnClickStopPropagation="true" />
                        </div>

                        <div style="display: flex; align-items: center; gap: 6px;">
                            <span class="status-dot @GetStatusDotClass(session.Status)"></span>
                            @if (ChatState.IsSessionStreaming(session.Id))
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true"
                                                     Style="width: 10px; height: 10px;" Color="Color.Primary" />
                            }
                            <span class="session-title">@session.Title</span>
                        </div>

                        <div class="session-meta">
                            @if (!string.IsNullOrEmpty(session.BranchName))
                            {
                                <span class="session-branch">@session.BranchName</span>
                            }
                            <span style="margin-left: auto;">@session.UpdatedAt.ToLocalTime().ToString("MM/dd HH:mm")</span>
                        </div>
                    </div>
                }

                @if (sessions.Count == 0)
                {
                    <div style="padding: var(--space-4); font-size: var(--text-sm); opacity: 0.3; text-align: center;">
                        대화가 없습니다
                    </div>
                }
            }
        </div>

        @* Bottom actions *@
        <div style="padding: var(--space-2); flex-shrink: 0; border-top: 1px solid var(--border-subtle);">
            <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" FullWidth="true"
                       StartIcon="@Icons.Material.Filled.Add"
                       OnClick="@(() => _workspaceDialogOpen = true)"
                       Style="text-transform: none; font-size: var(--text-sm); border-radius: var(--radius-sm);">
                워크스페이스 추가
            </MudButton>
        </div>
    }
    else
    {
        <div class="welcome-container" style="padding: var(--space-6);">
            <MudIcon Icon="@Icons.Material.Filled.Workspaces" Size="Size.Large" Style="opacity: 0.2;" />
            <MudText Typo="Typo.body2" Color="Color.Secondary" Style="opacity: 0.4;">
                워크스페이스를 만들어 시작하세요
            </MudText>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Add"
                       OnClick="@(() => _workspaceDialogOpen = true)"
                       Style="text-transform: none; border-radius: var(--radius-full);">
                새 워크스페이스
            </MudButton>
        </div>
    }
</div>

<WorkspaceDialog @bind-IsOpen="_workspaceDialogOpen" OnWorkspacesChanged="ReloadWorkspaces" />

@code {
    private List<Workspace> _workspaces = [];
    private string? _expandedWorkspaceId;
    private Dictionary<string, List<Session>> _sessionCache = new();
    private bool _workspaceDialogOpen;
    private bool _isCreatingSession;

    protected override async Task OnInitializedAsync()
    {
        ChatState.OnChange += OnStateChanged;

        _workspaces = await WorkspaceService.GetWorkspacesAsync();

        var settings = await SettingsService.LoadAsync();
        var lastId = settings.LastWorkspaceId;

        var currentWs = _workspaces.FirstOrDefault(w => w.Id == lastId)
                        ?? _workspaces.FirstOrDefault();
        if (currentWs != null)
        {
            await ExpandWorkspace(currentWs);
        }
    }

    private async Task OnWorkspaceSelected(string wsId)
    {
        var ws = _workspaces.FirstOrDefault(w => w.Id == wsId);
        if (ws != null)
            await ExpandWorkspace(ws);
    }

    private async Task ExpandWorkspace(Workspace ws)
    {
        _expandedWorkspaceId = ws.Id;
        ChatState.SetWorkspace(ws);

        if (!_sessionCache.ContainsKey(ws.Id))
        {
            var sessions = await SessionService.GetSessionsByWorkspaceAsync(ws.Id);
            _sessionCache[ws.Id] = sessions;
            _ = CheckMergeStatuses(ws.Id);
        }

        var settings = await SettingsService.LoadAsync();
        settings.LastWorkspaceId = ws.Id;
        await SettingsService.SaveAsync(settings);
    }

    private async Task CheckMergeStatuses(string workspaceId)
    {
        if (!_sessionCache.TryGetValue(workspaceId, out var sessions)) return;

        var readySessions = sessions.Where(s => s.Status == SessionStatus.Ready).ToList();
        foreach (var session in readySessions)
        {
            try
            {
                var merged = await SessionService.CheckMergeStatusAsync(session.Id);
                if (merged)
                {
                    session.Status = SessionStatus.Merged;
                    await InvokeAsync(StateHasChanged);
                }
            }
            catch { }
        }
    }

    private async Task ReloadWorkspaces()
    {
        _workspaces = await WorkspaceService.GetWorkspacesAsync();

        if (_expandedWorkspaceId != null && !_workspaces.Any(w => w.Id == _expandedWorkspaceId))
        {
            _sessionCache.Remove(_expandedWorkspaceId);
            var firstWs = _workspaces.FirstOrDefault();
            if (firstWs != null)
                await ExpandWorkspace(firstWs);
            else
                _expandedWorkspaceId = null;
        }
        else if (_expandedWorkspaceId != null)
        {
            var sessions = await SessionService.GetSessionsByWorkspaceAsync(_expandedWorkspaceId);
            _sessionCache[_expandedWorkspaceId] = sessions;
        }
    }

    private async Task CreateNewChat(Workspace ws)
    {
        if (ws.Status != WorkspaceStatus.Ready) return;

        _isCreatingSession = true;
        StateHasChanged();

        try
        {
            var session = await SessionService.CreatePendingSessionAsync(ws.DefaultModel, ws.Id);
            ChatState.SetSession(session);

            if (_sessionCache.TryGetValue(ws.Id, out var sessions))
                sessions.Insert(0, session);
        }
        finally
        {
            _isCreatingSession = false;
            StateHasChanged();
        }
    }

    private async Task SelectSession(Session session)
    {
        var fullSess = await SessionService.LoadSessionAsync(session.Id);
        if (fullSess != null)
            ChatState.SetSession(fullSess);
        else
            ChatState.SetSession(session);
    }

    private async Task CleanupSession(Session session)
    {
        await SessionService.CleanupSessionAsync(session.Id);
        session.Status = SessionStatus.Archived;
        StateHasChanged();
    }

    private async Task DeleteSession(Session session)
    {
        await SessionService.DeleteSessionAsync(session.Id);

        if (_sessionCache.TryGetValue(session.WorkspaceId, out var sessions))
            sessions.Remove(session);

        if (ChatState.CurrentSession?.Id == session.Id)
            ChatState.SetSession(null!);
    }

    private static string GetStatusDotClass(SessionStatus status) => status switch
    {
        SessionStatus.Ready => "ready",
        SessionStatus.Pushed => "pushed",
        SessionStatus.PrOpen => "pr-open",
        SessionStatus.Merged => "merged",
        SessionStatus.ConflictDetected => "conflict",
        SessionStatus.Error => "error",
        SessionStatus.Pending => "pending",
        SessionStatus.Archived => "archived",
        _ => "pending"
    };

    private string? _lastSessionId;
    private bool _lastHasStreaming;

    private async void OnStateChanged()
    {
        var currentId = ChatState.CurrentSession?.Id;
        var hasStreaming = ChatState.HasAnyStreaming();
        if (currentId == _lastSessionId && hasStreaming == _lastHasStreaming)
            return;
        _lastSessionId = currentId;
        _lastHasStreaming = hasStreaming;
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        ChatState.OnChange -= OnStateChanged;
    }
}
