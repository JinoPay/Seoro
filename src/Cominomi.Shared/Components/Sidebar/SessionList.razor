@using Microsoft.Extensions.Logging
@inject IChatState ChatState
@inject SessionListDataService DataService
@inject ISessionListFacade Facade
@inject ISkillRegistry SkillRegistry
@inject IJSRuntime JS
@inject ILauncherService Launcher
@inject ILogger<SessionList> Logger
@inject IWorktreeSyncService SyncService
@implements IDisposable

<div class="sidebar-tree">
    @if (DataService.Workspaces.Count > 0)
    {
        <SessionListToolbar FilterVisible="_filterVisible"
                            FilterText="@_filterText"
                            OnToggleFilter="ToggleFilter"
                            OnCreateWorkspace="@(() => _createDialogOpen = true)"
                            FilterTextChanged="@(v => { _filterText = v; RebuildFlatRows(); })" />

        @* Tree body — single Virtualize over flat list *@
        <div class="tree-body">
            <Virtualize Items="_flatRows" Context="row" ItemSize="36" OverscanCount="5">
                @switch (row.Kind)
                {
                    case SidebarRowKind.ProjectHeader:
                        var isExpanded = _expandedProjects.Contains(row.ProjectName!);
                        <div @key="@($"ph-{row.ProjectName}")"
                             class="project-header @(row.HasStreamingSession && !isExpanded ? "has-streaming" : "")"
                             @onclick="@(() => ToggleProject(row.ProjectName!))">
                            <MudIcon Icon="@(isExpanded ? Icons.Material.Filled.ExpandMore : Icons.Material.Filled.ChevronRight)"
                                     Size="Size.Small" Class="project-chevron" />
                            <span class="project-letter">@row.ProjectName![0]</span>
                            <span class="project-name">@row.ProjectName</span>
                            @if (!isExpanded && row.SessionCount > 0)
                            {
                                <span class="project-session-count">@row.SessionCount</span>
                            }
                            @if (!isExpanded && row.HasStreamingSession)
                            {
                                <span class="project-streaming-dot"></span>
                            }
                            <div class="project-actions" @onclick:stopPropagation="true">
                                @{
                                    var readyWs = row.WorkspacesInGroup!.FirstOrDefault(w => w.Status == WorkspaceStatus.Ready);
                                }
                                @if (readyWs != null)
                                {
                                    <AddSessionMenu WorkspaceId="@readyWs.Id"
                                                    OnNewChat="@(() => CreateNewChat(readyWs))"
                                                    OnAddLocalDir="@(() => CreateLocalDirChat(readyWs))"
                                                    Style="width: 20px; height: 20px; opacity: 0.5;" />
                                }
                                <MudMenu Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small"
                                         Dense="true"
                                         AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight"
                                         Style="width: 20px; height: 20px; opacity: 0.5;"
                                         ActivationEvent="@MouseEvent.LeftClick">
                                    <MudMenuItem OnClick="@(() => ChatState.OpenSettings("ws-general", row.WorkspacesInGroup!.First().Id))"
                                                 Icon="@Icons.Material.Filled.Settings">
                                        워크스페이스 설정
                                    </MudMenuItem>
                                    <MudDivider />
                                    <MudMenuItem OnClick="@(() => DeleteWorkspace(row.WorkspacesInGroup!.First()))"
                                                 Icon="@Icons.Material.Filled.Delete"
                                                 IconColor="Color.Error">
                                        워크스페이스 삭제
                                    </MudMenuItem>
                                </MudMenu>
                            </div>
                        </div>
                        break;

                    case SidebarRowKind.WorkspaceSubheader:
                        <div @key="@($"ws-{row.Workspace!.Id}")" class="workspace-subheader">
                            <span>@row.Workspace!.Name</span>
                            @if (row.Workspace.Status == WorkspaceStatus.Error)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Error" Size="Size.Small" Color="Color.Error"
                                         Style="width: 12px; height: 12px;" />
                            }
                            @if (row.Workspace.Status == WorkspaceStatus.Ready && !_isCreatingSession)
                            {
                                <AddSessionMenu WorkspaceId="@row.Workspace.Id"
                                                OnNewChat="@(() => CreateNewChat(row.Workspace))"
                                                OnAddLocalDir="@(() => CreateLocalDirChat(row.Workspace))"
                                                Style="width: 16px; height: 16px; opacity: 0.4;" />
                            }
                        </div>
                        break;

                    case SidebarRowKind.Session:
                        var isStreaming = ChatState.IsSessionStreaming(row.Session!.Id);
                        var isCompleted = ChatState.IsSessionCompleted(row.Session!.Id);
                        var hasDiffStats = DataService.DiffStatsCache.TryGetValue(row.Session!.Id, out var stats);
                        <SessionItem Session="row.Session!"
                                     IsActive="@(ChatState.CurrentSession?.Id == row.Session!.Id)"
                                     IsStreaming="isStreaming"
                                     IsCompleted="isCompleted"
                                     IsSynced="@(SyncService.IsSessionSynced(row.Session!.Id))"
                                     StreamingStatusText="@(isStreaming ? GetStreamingStatusText(row.Session!) : null)"
                                     DiffAdditions="@(hasDiffStats ? stats.Additions : 0)"
                                     DiffDeletions="@(hasDiffStats ? stats.Deletions : 0)"
                                     ShortcutLabel="@(row.SessionIndex < 5 ? GetShortcutLabel(row.SessionIndex) : null)"
                                     DeleteShortcutLabel="@(ChatState.CurrentSession?.Id == row.Session!.Id ? GetDeleteShortcutLabel() : null)"
                                     ShowShortcuts="@_ctrlHeld"
                                     AvailableIdes="_availableIdes"
                                     OnClick="@(() => SelectSession(row.Session!, row.Workspace))"
                                     OnDelete="@(() => DeleteSession(row.Session!))"
                                     OnOpenFolder="@(() => OpenSessionFolder(row.Session!, row.Workspace))"
                                     OnOpenInIde="@(cmd => OpenSessionInIde(row.Session!, row.Workspace, cmd))" />
                        break;
                }
            </Virtualize>
        </div>
    }
    else
    {
        <div class="welcome-container" style="padding: var(--space-6);">
            <MudIcon Icon="@Icons.Material.Filled.Workspaces" Size="Size.Large" Style="opacity: 0.2;" />
            <p class="typo-body2 text-secondary" style="opacity: 0.4;">
                워크스페이스를 만들어 시작하세요
            </p>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Add"
                       OnClick="@(() => _createDialogOpen = true)"
                       Style="text-transform: none; border-radius: var(--radius-full);">
                새 워크스페이스
            </MudButton>
        </div>
    }
</div>

<CreateWorkspaceDialog @bind-IsOpen="_createDialogOpen" OnWorkspaceCreated="ReloadWorkspaces" />

@code {
    private HashSet<string> _expandedProjects = new();
    private bool _createDialogOpen;
    private bool _isCreatingSession;
    private bool _filterVisible;
    private bool _ctrlHeld;
    private string? _filterText;
    private DotNetObjectReference<SessionList>? _dotNetRef;
    private List<SidebarRow> _flatRows = new();
    private List<(Session Session, Workspace Workspace)> _visibleSessions = new();
    private List<IdeInfo> _availableIdes = [];

    private enum SidebarRowKind { ProjectHeader, WorkspaceSubheader, Session }

    private sealed record SidebarRow(
        SidebarRowKind Kind,
        string? ProjectName = null,
        List<Workspace>? WorkspacesInGroup = null,
        Workspace? Workspace = null,
        Session? Session = null,
        int SessionIndex = 0,
        int SessionCount = 0,
        bool HasStreamingSession = false);

    private void RebuildFlatRows()
    {
        var rows = new List<SidebarRow>();
        var visibleSessions = new List<(Session, Workspace)>();
        var sessionIndex = 0;

        foreach (var group in DataService.GetFilteredWorkspaces(_filterText)
                     .GroupBy(SessionListDataService.GetProjectName))
        {
            var projectName = group.Key;
            var workspacesInGroup = group.OrderByDescending(w => w.UpdatedAt).ToList();

            var sessionCount = 0;
            var hasStreaming = false;
            foreach (var ws in workspacesInGroup)
            {
                if (DataService.SessionCache.TryGetValue(ws.Id, out var cachedSessions))
                {
                    sessionCount += cachedSessions.Count;
                    if (!hasStreaming)
                        hasStreaming = cachedSessions.Any(s => ChatState.IsSessionStreaming(s.Id));
                }
            }

            rows.Add(new SidebarRow(SidebarRowKind.ProjectHeader,
                ProjectName: projectName, WorkspacesInGroup: workspacesInGroup,
                SessionCount: sessionCount, HasStreamingSession: hasStreaming));

            if (!_expandedProjects.Contains(projectName)) continue;

            var showSubheaders = workspacesInGroup.Count > 1;

            foreach (var ws in workspacesInGroup)
            {
                if (showSubheaders)
                    rows.Add(new SidebarRow(SidebarRowKind.WorkspaceSubheader, Workspace: ws));

                if (DataService.SessionCache.TryGetValue(ws.Id, out var sessions))
                {
                    foreach (var session in SessionListDataService.FilterSessions(sessions, _filterText))
                    {
                        rows.Add(new SidebarRow(SidebarRowKind.Session,
                            Session: session, Workspace: ws, SessionIndex: sessionIndex));
                        visibleSessions.Add((session, ws));
                        sessionIndex++;
                    }
                }
            }
        }

        _flatRows = rows;
        _visibleSessions = visibleSessions;
    }

    protected override async Task OnInitializedAsync()
    {
        ChatState.OnChange += OnStateChanged;
        ChatState.OnRequestCreateWorkspace += HandleCreateWorkspaceRequest;
        DataService.OnDataChanged += OnDataServiceChanged;

        try
        {
            _availableIdes = await Launcher.GetAvailableIdesAsync();
            await DataService.LoadWorkspacesAsync();

            // 1차: 워크스페이스와 프로젝트명 결정 (세션 캐시 아직 비어있음)
            var (ws, _, projectName) = await Facade.RestoreLastSelectionAsync(
                DataService.Workspaces, DataService.SessionCache);

            if (ws != null)
            {
                _expandedProjects.Add(projectName!);
                await DataService.LoadSessionsForProjectAsync(projectName!);

                // 2차: 세션 캐시 채워진 후 마지막 세션 조회
                var (_, lastSession, _) = await Facade.RestoreLastSelectionAsync(
                    DataService.Workspaces, DataService.SessionCache);

                ChatState.SetWorkspace(ws);
                // Load custom skills for the initial workspace
                await SkillRegistry.LoadCustomCommandsAsync(ws.RepoLocalPath);

                if (lastSession != null)
                    await SelectSession(lastSession, ws);
            }

            // 접힌 프로젝트도 세션 수 배지를 표시할 수 있도록 백그라운드 사전 로딩
            _ = DataService.LoadAllSessionCountsAsync();

            DataService.RebuildOrderedSessions();
            RebuildFlatRows();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "SessionList initialization failed");
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("registerSessionShortcuts", _dotNetRef);
            await JS.InvokeVoidAsync("registerCtrlWatcher", _dotNetRef);
        }
    }

    [JSInvokable]
    public void OnCtrlStateChanged(bool pressed)
    {
        _ctrlHeld = pressed;
        InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public async Task OnSessionShortcut(int index)
    {
        if (index >= 0 && index < _visibleSessions.Count)
        {
            var (session, ws) = _visibleSessions[index];
            await SelectSession(session, ws);
            await InvokeAsync(StateHasChanged);
        }
    }

    [JSInvokable]
    public async Task OnDeleteCurrentSessionShortcut()
    {
        var current = ChatState.CurrentSession;
        if (current != null)
        {
            await DeleteSession(current);
            await InvokeAsync(StateHasChanged);
        }
    }

    [JSInvokable]
    public async Task OnExpandAllProjects()
    {
        foreach (var name in DataService.Workspaces
            .Select(SessionListDataService.GetProjectName).Distinct())
        {
            if (_expandedProjects.Add(name))
                await DataService.LoadSessionsForProjectAsync(name);
        }
        RebuildFlatRows();
        await InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public void OnCollapseAllProjects()
    {
        _expandedProjects.Clear();
        RebuildFlatRows();
        InvokeAsync(StateHasChanged);
    }

    private static string GetShortcutLabel(int index)
    {
        // Use platform-appropriate modifier
        return OperatingSystem.IsMacCatalyst() || OperatingSystem.IsMacOS()
            ? $"\u2318{index + 1}"
            : $"Ctrl+{index + 1}";
    }

    private static string GetDeleteShortcutLabel()
    {
        return OperatingSystem.IsMacCatalyst() || OperatingSystem.IsMacOS()
            ? "\u2318D"
            : "Ctrl+D";
    }

    private string GetStreamingStatusText(Session session)
    {
        var phase = ChatState.GetSessionPhase(session.Id);

        if (session.PermissionMode == "plan")
        {
            return phase switch
            {
                StreamingPhase.Preparing or StreamingPhase.Sending => "준비 중...",
                StreamingPhase.Thinking => "생각 중...",
                StreamingPhase.WritingText => "작성 중...",
                StreamingPhase.UsingTool => GetSidebarToolLabel(ChatState.GetSessionToolName(session.Id)),
                _ => "계획 중..."
            };
        }

        return phase switch
        {
            StreamingPhase.Preparing or StreamingPhase.Sending => "준비 중...",
            StreamingPhase.Thinking => "생각 중...",
            StreamingPhase.WritingText => "작성 중...",
            StreamingPhase.UsingTool => GetSidebarToolLabel(ChatState.GetSessionToolName(session.Id)),
            _ => "작업 중..."
        };
    }

    private static string GetSidebarToolLabel(string? toolName) => (toolName?.ToLowerInvariant()) switch
    {
        "bash" or "execute_bash" => "명령 실행 중...",
        "read" or "read_file" => "파일 읽는 중...",
        "write" or "write_file" => "파일 작성 중...",
        "edit" or "edit_file" => "파일 수정 중...",
        "glob" => "파일 검색 중...",
        "grep" => "내용 검색 중...",
        "agent" => "에이전트...",
        _ => "도구 사용 중..."
    };

    private void ToggleFilter()
    {
        _filterVisible = !_filterVisible;
        if (!_filterVisible)
            _filterText = "";
        RebuildFlatRows();
    }

    private async Task ToggleProject(string projectName)
    {
        if (_expandedProjects.Contains(projectName))
        {
            _expandedProjects.Remove(projectName);
        }
        else
        {
            _expandedProjects.Add(projectName);
            await DataService.LoadSessionsForProjectAsync(projectName);
        }
        RebuildFlatRows();
    }

    private async Task ReloadWorkspaces()
    {
        var invalidProjects = _expandedProjects
            .Where(p => !DataService.Workspaces.Any(w => SessionListDataService.GetProjectName(w) == p))
            .ToList();
        foreach (var p in invalidProjects) _expandedProjects.Remove(p);

        await DataService.ReloadWorkspacesAsync(_expandedProjects);
        RebuildFlatRows();
    }

    private async Task CreateNewChat(Workspace ws) => await CreateSession(ws, localDir: false);
    private async Task CreateLocalDirChat(Workspace ws) => await CreateSession(ws, localDir: true);

    private async Task CreateSession(Workspace ws, bool localDir)
    {
        if (ws.Status != WorkspaceStatus.Ready) return;

        _isCreatingSession = true;
        StateHasChanged();

        try
        {
            await Facade.CreateSessionAsync(ws, localDir);
            RebuildFlatRows();
        }
        finally
        {
            _isCreatingSession = false;
            StateHasChanged();
        }
    }

    private async Task SelectSession(Session session, Workspace? ws = null)
    {
        await Facade.SelectSessionAsync(session, ws, DataService.Workspaces);
    }

    private async Task DeleteSession(Session session)
    {
        if (await Facade.DeleteSessionAsync(session))
            RebuildFlatRows();
        StateHasChanged();
    }

    private async Task DeleteWorkspace(Workspace workspace)
    {
        if (await Facade.DeleteWorkspaceAsync(workspace))
            RebuildFlatRows();
        StateHasChanged();
    }

    private string? _lastSessionId;
    private string? _lastBranchName;
    private string? _lastSessionTitle;
    private bool _lastHasStreaming;
    private int _lastStreamingHash;
    private int _lastCompletedHash;

    private void OnStateChanged()
    {
        _ = InvokeAsync(() =>
        {
            var currentId = ChatState.CurrentSession?.Id;
            var hasStreaming = ChatState.HasAnyStreaming();

            // Compute a hash of streaming phases to detect phase changes
            var streamingHash = 0;
            foreach (var sid in ChatState.GetStreamingSessionIds())
            {
                streamingHash ^= sid.GetHashCode()
                    ^ ChatState.GetSessionPhase(sid).GetHashCode()
                    ^ (ChatState.GetSessionToolName(sid)?.GetHashCode() ?? 0);
            }

            // Compute a hash of completed sessions
            var completedHash = 0;
            foreach (var row in _flatRows)
            {
                if (row.Session != null && ChatState.IsSessionCompleted(row.Session.Id))
                    completedHash ^= row.Session.Id.GetHashCode();
            }

            var branchName = ChatState.CurrentSession?.Git.BranchName;
            var sessionTitle = ChatState.CurrentSession?.Title;
            if (currentId == _lastSessionId && branchName == _lastBranchName
                && sessionTitle == _lastSessionTitle
                && hasStreaming == _lastHasStreaming
                && streamingHash == _lastStreamingHash && completedHash == _lastCompletedHash)
                return;

            // If streaming state changed, rebuild flat rows to update collapsed indicators
            if (hasStreaming != _lastHasStreaming || streamingHash != _lastStreamingHash)
            {
                RebuildFlatRows();
            }

            // If a session stopped streaming, refresh its diff stats
            if (_lastHasStreaming && !hasStreaming)
            {
                foreach (var ordered in DataService.OrderedSessions)
                {
                    _ = DataService.RefreshDiffStatsAsync(ordered.Session.Id);
                }
            }

            _lastSessionId = currentId;
            _lastBranchName = branchName;
            _lastSessionTitle = sessionTitle;
            _lastHasStreaming = hasStreaming;
            _lastStreamingHash = streamingHash;
            _lastCompletedHash = completedHash;
            StateHasChanged();
        });
    }

    private void HandleCreateWorkspaceRequest()
    {
        _createDialogOpen = true;
        InvokeAsync(StateHasChanged);
    }

    private void OnDataServiceChanged()
    {
        _ = InvokeAsync(() =>
        {
            RebuildFlatRows();
            StateHasChanged();
        });
    }

    private string? GetSessionPath(Session session, Workspace? ws)
    {
        if (!string.IsNullOrEmpty(session.Git.WorktreePath))
            return session.Git.WorktreePath;
        return ws?.RepoLocalPath;
    }

    private async Task OpenSessionFolder(Session session, Workspace? ws)
    {
        var path = GetSessionPath(session, ws);
        if (path != null)
            await Launcher.OpenFolderAsync(path);
    }

    private async Task OpenSessionInIde(Session session, Workspace? ws, string ideCommand)
    {
        var path = GetSessionPath(session, ws);
        if (path != null)
            await Launcher.OpenInIdeAsync(path, ideCommand);
    }

    public void Dispose()
    {
        ChatState.OnChange -= OnStateChanged;
        ChatState.OnRequestCreateWorkspace -= HandleCreateWorkspaceRequest;
        DataService.OnDataChanged -= OnDataServiceChanged;
        _ = JS.InvokeVoidAsync("unregisterSessionShortcuts");
        _ = JS.InvokeVoidAsync("unregisterCtrlWatcher");
        _dotNetRef?.Dispose();
    }
}
