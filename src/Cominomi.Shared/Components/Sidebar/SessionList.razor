@inject ChatState ChatState
@inject ISessionService SessionService
@inject ISessionGitWorkflowService GitWorkflow
@inject ISettingsService SettingsService
@inject IWorkspaceService WorkspaceService
@inject IGitService GitService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@implements IDisposable

<div class="sidebar-tree">
    @if (_workspaces.Count > 0)
    {
        @* Header *@
        <div class="tree-header">
            <span class="tree-header-label">Workspaces</span>
            <div class="tree-header-actions">
                <MudIconButton Icon="@(_filterVisible ? Icons.Material.Filled.FilterListOff : Icons.Material.Filled.FilterList)"
                               Size="Size.Small"
                               Style="width: 24px; height: 24px; opacity: 0.5;"
                               OnClick="@(() => ToggleFilter())" />
                <MudIconButton Icon="@Icons.Material.Filled.Add" Size="Size.Small"
                               Style="width: 24px; height: 24px; opacity: 0.5;"
                               OnClick="@(() => _createDialogOpen = true)" />
            </div>
        </div>

        @if (_filterVisible)
        {
            <div class="tree-filter">
                <MudTextField @bind-Value="_filterText" Placeholder="검색..."
                              Variant="Variant.Outlined" Margin="Margin.Dense"
                              Adornment="Adornment.End"
                              AdornmentIcon="@(_filterText?.Length > 0 ? Icons.Material.Filled.Close : "")"
                              OnAdornmentClick="@(() => _filterText = "")"
                              Immediate="true"
                              Style="font-size: var(--text-xs);" />
            </div>
        }

        @* Tree body *@
        <div class="tree-body">
            @{ var sessionIndex = 0; }
            @foreach (var group in GetFilteredWorkspaces().GroupBy(GetProjectName))
            {
                var projectName = group.Key;
                var isExpanded = _expandedProjects.Contains(projectName);
                var workspacesInGroup = group.OrderByDescending(w => w.UpdatedAt).ToList();

                <div @key="projectName">
                    @* Project header *@
                    <div class="project-header" @onclick="@(() => ToggleProject(projectName))">
                        <span class="project-letter">@projectName[0]</span>
                        <span class="project-name">@projectName</span>
                        @if (isExpanded)
                        {
                            <div class="project-actions">
                                @{
                                    var readyWs = workspacesInGroup.FirstOrDefault(w => w.Status == WorkspaceStatus.Ready);
                                }
                                @if (readyWs != null)
                                {
                                    <MudMenu Icon="@Icons.Material.Filled.Add" Size="Size.Small"
                                             Dense="true" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter"
                                             Style="width: 20px; height: 20px; opacity: 0.5;"
                                             ActivationEvent="@MouseEvent.LeftClick">
                                        <MudMenuItem OnClick="@(() => CreateNewChat(readyWs))"
                                                     Icon="@Icons.Material.Filled.AccountTree">새 세션</MudMenuItem>
                                        <MudMenuItem OnClick="@(() => CreateLocalDirChat(readyWs))"
                                                     Icon="@Icons.Material.Filled.Folder">로컬 디렉토리</MudMenuItem>
                                    </MudMenu>
                                }
                                <MudMenu Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small"
                                         Dense="true"
                                         AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight"
                                         Style="width: 20px; height: 20px; opacity: 0.5;"
                                         ActivationEvent="@MouseEvent.LeftClick">
                                    <MudMenuItem OnClick="@(() => ChatState.OpenSettings("ws-general", workspacesInGroup.First().Id))"
                                                 Icon="@Icons.Material.Filled.Settings">
                                        워크스페이스 설정
                                    </MudMenuItem>
                                </MudMenu>
                            </div>
                        }
                    </div>

                    @* Expanded content *@
                    @if (isExpanded)
                    {
                        var showSubheaders = workspacesInGroup.Count > 1;

                        @foreach (var ws in workspacesInGroup)
                        {
                            @if (showSubheaders)
                            {
                                <div class="workspace-subheader">
                                    <span>@ws.Name</span>
                                    @if (ws.Status == WorkspaceStatus.Error)
                                    {
                                        <MudIcon Icon="@Icons.Material.Filled.Error" Size="Size.Small" Color="Color.Error"
                                                 Style="width: 12px; height: 12px;" />
                                    }
                                    @if (ws.Status == WorkspaceStatus.Ready && !_isCreatingSession)
                                    {
                                        <MudMenu Icon="@Icons.Material.Filled.Add" Size="Size.Small"
                                                 Dense="true" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter"
                                                 Style="width: 16px; height: 16px; opacity: 0.4;"
                                                 ActivationEvent="@MouseEvent.LeftClick">
                                            <MudMenuItem OnClick="@(() => CreateNewChat(ws))"
                                                         Icon="@Icons.Material.Filled.AccountTree">새 세션</MudMenuItem>
                                            <MudMenuItem OnClick="@(() => CreateLocalDirChat(ws))"
                                                         Icon="@Icons.Material.Filled.Folder">로컬 디렉토리</MudMenuItem>
                                        </MudMenu>
                                    }
                                </div>
                            }

                            @if (_sessionCache.TryGetValue(ws.Id, out var sessions))
                            {
                                @foreach (var session in FilterSessions(sessions))
                                {
                                    var isActive = ChatState.CurrentSession?.Id == session.Id;
                                    var isArchived = session.Status == SessionStatus.Archived;
                                    var isStreaming = ChatState.IsSessionStreaming(session.Id);
                                    var currentIndex = sessionIndex;
                                    sessionIndex++;

                                    <div @key="session.Id"
                                         class="tree-session @(isActive ? "active" : "") @(isArchived ? "archived" : "")"
                                         @onclick="@(() => SelectSession(session, ws))">

                                        <div class="tree-session-actions">
                                            @if (session.Status == SessionStatus.Merged)
                                            {
                                                <MudIconButton Icon="@Icons.Material.Filled.CleaningServices" Size="Size.Small"
                                                               Color="Color.Success" Style="width: 20px; height: 20px;"
                                                               OnClick="@(() => CleanupSession(session))"
                                                               OnClickStopPropagation="true" />
                                            }
                                            <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                                           Style="width: 20px; height: 20px; opacity: 0.4;"
                                                           OnClick="@(() => DeleteSession(session))"
                                                           OnClickStopPropagation="true" />
                                        </div>

                                        <span class="status-dot @GetStatusDotClass(session.Status) @(isStreaming ? "streaming" : "")"></span>

                                        <div class="tree-session-info">
                                            <span class="tree-session-title">@session.Title</span>
                                            <div class="tree-session-meta">
                                                @if (session.IsLocalDir)
                                                {
                                                    <span class="tree-session-branch" style="opacity: 0.5;">로컬</span>
                                                }
                                                else if (!string.IsNullOrEmpty(session.BranchName))
                                                {
                                                    <span class="tree-session-branch">@session.BranchName</span>
                                                }

                                                @if (session.IssueNumber != null)
                                                {
                                                    <span style="opacity: 0.6; font-size: 0.65rem;">#@session.IssueNumber</span>
                                                }

                                                @if (_diffStatsCache.TryGetValue(session.Id, out var stats) && (stats.Additions > 0 || stats.Deletions > 0))
                                                {
                                                    <span class="tree-session-diff-stats">
                                                        @if (stats.Additions > 0)
                                                        {
                                                            <span class="diff-add">+@stats.Additions</span>
                                                        }
                                                        @if (stats.Deletions > 0)
                                                        {
                                                            <span class="diff-del">-@stats.Deletions</span>
                                                        }
                                                    </span>
                                                }
                                            </div>

                                            @if (isStreaming)
                                            {
                                                <span class="tree-session-status">@GetStreamingStatusText(session)</span>
                                            }
                                        </div>

                                        @if (currentIndex < 5)
                                        {
                                            <span class="tree-session-shortcut">@GetShortcutLabel(currentIndex)</span>
                                        }
                                    </div>
                                }
                            }
                        }
                    }
                </div>
            }
        </div>
    }
    else
    {
        <div class="welcome-container" style="padding: var(--space-6);">
            <MudIcon Icon="@Icons.Material.Filled.Workspaces" Size="Size.Large" Style="opacity: 0.2;" />
            <MudText Typo="Typo.body2" Color="Color.Secondary" Style="opacity: 0.4;">
                워크스페이스를 만들어 시작하세요
            </MudText>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Add"
                       OnClick="@(() => _createDialogOpen = true)"
                       Style="text-transform: none; border-radius: var(--radius-full);">
                새 워크스페이스
            </MudButton>
        </div>
    }
</div>

<CreateWorkspaceDialog @bind-IsOpen="_createDialogOpen" OnWorkspaceCreated="ReloadWorkspaces" />

@code {
    private List<Workspace> _workspaces = [];
    private HashSet<string> _expandedProjects = new();
    private Dictionary<string, List<Session>> _sessionCache = new();
    private Dictionary<string, (int Additions, int Deletions)> _diffStatsCache = new();
    private bool _createDialogOpen;
    private bool _isCreatingSession;
    private bool _filterVisible;
    private string? _filterText;
    private DotNetObjectReference<SessionList>? _dotNetRef;

    // Ordered list of session IDs for keyboard shortcuts
    private List<(Session Session, Workspace Workspace)> _orderedSessions = [];

    protected override async Task OnInitializedAsync()
    {
        ChatState.OnChange += OnStateChanged;
        ChatState.OnRequestCreateWorkspace += HandleCreateWorkspaceRequest;

        _workspaces = await WorkspaceService.GetWorkspacesAsync();

        var settings = await SettingsService.LoadAsync();
        var lastId = settings.LastWorkspaceId;

        var currentWs = _workspaces.FirstOrDefault(w => w.Id == lastId)
                        ?? _workspaces.FirstOrDefault();
        if (currentWs != null)
        {
            var projectName = GetProjectName(currentWs);
            _expandedProjects.Add(projectName);
            await LoadSessionsForProject(projectName);

            ChatState.SetWorkspace(currentWs);

            // Auto-restore last active session
            if (!string.IsNullOrEmpty(settings.LastSessionId)
                && _sessionCache.TryGetValue(currentWs.Id, out var cached))
            {
                var lastSession = cached.FirstOrDefault(s => s.Id == settings.LastSessionId);
                if (lastSession != null)
                    await SelectSession(lastSession, currentWs);
            }
        }

        RebuildOrderedSessions();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("registerSessionShortcuts", _dotNetRef);
        }
    }

    [JSInvokable]
    public async Task OnSessionShortcut(int index)
    {
        if (index >= 0 && index < _orderedSessions.Count)
        {
            var (session, ws) = _orderedSessions[index];
            await SelectSession(session, ws);
            await InvokeAsync(StateHasChanged);
        }
    }

    private void RebuildOrderedSessions()
    {
        _orderedSessions.Clear();
        foreach (var group in _workspaces.GroupBy(GetProjectName))
        {
            var workspacesInGroup = group.OrderByDescending(w => w.UpdatedAt).ToList();
            foreach (var ws in workspacesInGroup)
            {
                if (_sessionCache.TryGetValue(ws.Id, out var sessions))
                {
                    foreach (var s in sessions)
                    {
                        _orderedSessions.Add((s, ws));
                    }
                }
            }
        }
    }

    private static string GetShortcutLabel(int index)
    {
        // Use platform-appropriate modifier
        return OperatingSystem.IsMacCatalyst() || OperatingSystem.IsMacOS()
            ? $"\u2318{index + 1}"
            : $"Ctrl+{index + 1}";
    }

    private string GetStreamingStatusText(Session session)
    {
        if (session.PermissionMode == "plan")
            return "Planning...";

        var phase = ChatState.GetSessionPhase(session.Id);
        return phase switch
        {
            StreamingPhase.Preparing or StreamingPhase.Sending => "Starting...",
            StreamingPhase.Thinking => "Thinking...",
            StreamingPhase.WritingText => "Writing...",
            StreamingPhase.UsingTool => ChatState.GetSessionToolName(session.Id) ?? "Working...",
            _ => "Working..."
        };
    }

    private IEnumerable<Workspace> GetFilteredWorkspaces()
    {
        if (string.IsNullOrWhiteSpace(_filterText))
            return _workspaces;

        var filter = _filterText.Trim();
        return _workspaces.Where(w =>
        {
            if (GetProjectName(w).Contains(filter, StringComparison.OrdinalIgnoreCase))
                return true;
            if (w.Name.Contains(filter, StringComparison.OrdinalIgnoreCase))
                return true;
            if (_sessionCache.TryGetValue(w.Id, out var sessions))
                return sessions.Any(s => s.Title.Contains(filter, StringComparison.OrdinalIgnoreCase)
                    || s.BranchName.Contains(filter, StringComparison.OrdinalIgnoreCase)
                    || s.CityName.Contains(filter, StringComparison.OrdinalIgnoreCase));
            return false;
        });
    }

    private IEnumerable<Session> FilterSessions(List<Session> sessions)
    {
        if (string.IsNullOrWhiteSpace(_filterText))
            return sessions;

        var filter = _filterText.Trim();
        return sessions.Where(s =>
            s.Title.Contains(filter, StringComparison.OrdinalIgnoreCase)
            || s.BranchName.Contains(filter, StringComparison.OrdinalIgnoreCase)
            || s.CityName.Contains(filter, StringComparison.OrdinalIgnoreCase));
    }

    private void ToggleFilter()
    {
        _filterVisible = !_filterVisible;
        if (!_filterVisible)
            _filterText = "";
    }

    private static string GetProjectName(Workspace ws)
    {
        if (!string.IsNullOrEmpty(ws.RepoUrl))
        {
            var url = ws.RepoUrl.TrimEnd('/');
            if (url.EndsWith(".git"))
                url = url[..^4];

            // SSH: git@github.com:org/repo
            var colonIdx = url.LastIndexOf(':');
            var slashIdx = url.LastIndexOf('/');
            if (slashIdx >= 0)
                return url[(slashIdx + 1)..];
            if (colonIdx >= 0)
                return url[(colonIdx + 1)..];
        }

        if (!string.IsNullOrEmpty(ws.RepoLocalPath))
        {
            return Path.GetFileName(ws.RepoLocalPath.TrimEnd(Path.DirectorySeparatorChar, '/'));
        }

        return ws.Name;
    }

    private async Task ToggleProject(string projectName)
    {
        if (_expandedProjects.Contains(projectName))
        {
            _expandedProjects.Remove(projectName);
        }
        else
        {
            _expandedProjects.Add(projectName);
            await LoadSessionsForProject(projectName);
        }
    }

    private async Task LoadSessionsForProject(string projectName)
    {
        var workspacesInGroup = _workspaces.Where(w => GetProjectName(w) == projectName);
        foreach (var ws in workspacesInGroup)
        {
            if (!_sessionCache.ContainsKey(ws.Id))
            {
                var sessions = await SessionService.GetSessionsByWorkspaceAsync(ws.Id);
                _sessionCache[ws.Id] = sessions;
                _ = CheckMergeStatuses(ws.Id);
                _ = LoadDiffStatsForWorkspace(ws, sessions);
            }
        }
        RebuildOrderedSessions();
    }

    private async Task LoadDiffStatsForWorkspace(Workspace ws, List<Session> sessions)
    {
        foreach (var session in sessions)
        {
            if (session.Status == SessionStatus.Pending || session.IsLocalDir
                || string.IsNullOrEmpty(session.WorktreePath) || string.IsNullOrEmpty(session.BaseBranch))
                continue;

            try
            {
                var stats = await GitService.GetDiffStatAsync(session.WorktreePath, session.BaseBranch);
                if (stats.Additions > 0 || stats.Deletions > 0)
                {
                    _diffStatsCache[session.Id] = stats;
                    await InvokeAsync(StateHasChanged);
                }
            }
            catch { }
        }
    }

    private async Task RefreshDiffStats(string sessionId)
    {
        var session = _orderedSessions.FirstOrDefault(o => o.Session.Id == sessionId).Session;
        if (session == null || session.IsLocalDir
            || string.IsNullOrEmpty(session.WorktreePath) || string.IsNullOrEmpty(session.BaseBranch))
            return;

        try
        {
            var stats = await GitService.GetDiffStatAsync(session.WorktreePath, session.BaseBranch);
            _diffStatsCache[sessionId] = stats;
            await InvokeAsync(StateHasChanged);
        }
        catch { }
    }

    private async Task CheckMergeStatuses(string workspaceId)
    {
        if (!_sessionCache.TryGetValue(workspaceId, out var sessions)) return;

        var readySessions = sessions.Where(s => s.Status == SessionStatus.Ready).ToList();
        foreach (var session in readySessions)
        {
            try
            {
                var merged = await GitWorkflow.CheckMergeStatusAsync(session.Id);
                if (merged)
                {
                    session.Status = SessionStatus.Merged;
                    await InvokeAsync(StateHasChanged);
                }
            }
            catch { }
        }
    }

    private async Task ReloadWorkspaces()
    {
        _workspaces = await WorkspaceService.GetWorkspacesAsync();

        // Reload sessions for expanded projects
        foreach (var projectName in _expandedProjects.ToList())
        {
            var workspacesInGroup = _workspaces.Where(w => GetProjectName(w) == projectName).ToList();
            if (workspacesInGroup.Count == 0)
            {
                _expandedProjects.Remove(projectName);
                continue;
            }
            foreach (var ws in workspacesInGroup)
            {
                var sessions = await SessionService.GetSessionsByWorkspaceAsync(ws.Id);
                _sessionCache[ws.Id] = sessions;
            }
        }
        RebuildOrderedSessions();
    }

    private async Task CreateNewChat(Workspace ws)
    {
        if (ws.Status != WorkspaceStatus.Ready) return;

        _isCreatingSession = true;
        StateHasChanged();

        try
        {
            var session = await SessionService.CreatePendingSessionAsync(ws.DefaultModel, ws.Id);
            ChatState.SetWorkspace(ws);
            ChatState.SetSession(session);

            if (_sessionCache.TryGetValue(ws.Id, out var sessions))
                sessions.Insert(0, session);

            var settings = await SettingsService.LoadAsync();
            settings.LastWorkspaceId = ws.Id;
            settings.LastSessionId = session.Id;
            await SettingsService.SaveAsync(settings);

            RebuildOrderedSessions();
        }
        finally
        {
            _isCreatingSession = false;
            StateHasChanged();
        }
    }

    private async Task CreateLocalDirChat(Workspace ws)
    {
        if (ws.Status != WorkspaceStatus.Ready) return;

        _isCreatingSession = true;
        StateHasChanged();

        try
        {
            var session = await SessionService.CreateLocalDirSessionAsync(ws.DefaultModel, ws.Id);
            ChatState.SetWorkspace(ws);
            ChatState.SetSession(session);

            if (_sessionCache.TryGetValue(ws.Id, out var sessions))
                sessions.Insert(0, session);

            var settings = await SettingsService.LoadAsync();
            settings.LastWorkspaceId = ws.Id;
            settings.LastSessionId = session.Id;
            await SettingsService.SaveAsync(settings);

            RebuildOrderedSessions();
        }
        finally
        {
            _isCreatingSession = false;
            StateHasChanged();
        }
    }

    private async Task SelectSession(Session session, Workspace? ws = null)
    {
        ws ??= _workspaces.FirstOrDefault(w => w.Id == session.WorkspaceId);
        if (ws != null)
            ChatState.SetWorkspace(ws);

        var activeSession = ChatState.GetActiveSession(session.Id);
        if (activeSession != null)
        {
            ChatState.SetSession(activeSession);
        }
        else
        {
            var fullSess = await SessionService.LoadSessionAsync(session.Id);
            if (fullSess != null)
                ChatState.SetSession(fullSess);
            else
                ChatState.SetSession(session);
        }

        var settings = await SettingsService.LoadAsync();
        settings.LastWorkspaceId = session.WorkspaceId;
        settings.LastSessionId = session.Id;
        await SettingsService.SaveAsync(settings);
    }

    private async Task CleanupSession(Session session)
    {
        await SessionService.CleanupSessionAsync(session.Id);
        session.Status = SessionStatus.Archived;
        StateHasChanged();
    }

    private async Task DeleteSession(Session session)
    {
        var result = await DialogService.ShowMessageBoxAsync(
            "세션 삭제",
            $"'{session.Title}' 세션을 삭제하시겠습니까?",
            yesText: "삭제", cancelText: "취소");

        if (result != true) return;

        try
        {
            await SessionService.DeleteSessionAsync(session.Id);

            if (_sessionCache.TryGetValue(session.WorkspaceId, out var sessions))
                sessions.Remove(session);

            if (ChatState.CurrentSession?.Id == session.Id)
                ChatState.SetSession(null!);

            _diffStatsCache.Remove(session.Id);
            RebuildOrderedSessions();
            Snackbar.SessionDeleted();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"세션 삭제 실패: {ex.Message}", Severity.Error);
        }
        finally
        {
            StateHasChanged();
        }
    }

    private static string GetStatusDotClass(SessionStatus status) => status switch
    {
        SessionStatus.Ready => "ready",
        SessionStatus.Pushed => "pushed",
        SessionStatus.PrOpen => "pr-open",
        SessionStatus.Merged => "merged",
        SessionStatus.ConflictDetected => "conflict",
        SessionStatus.Error => "error",
        SessionStatus.Pending => "pending",
        SessionStatus.Archived => "archived",
        _ => "pending"
    };

    private string? _lastSessionId;
    private bool _lastHasStreaming;
    private int _lastStreamingHash;

    private async void OnStateChanged()
    {
        var currentId = ChatState.CurrentSession?.Id;
        var hasStreaming = ChatState.HasAnyStreaming();

        // Compute a hash of streaming phases to detect phase changes
        var streamingHash = 0;
        foreach (var sid in ChatState.GetStreamingSessionIds())
        {
            streamingHash ^= sid.GetHashCode() ^ ChatState.GetSessionPhase(sid).GetHashCode();
        }

        if (currentId == _lastSessionId && hasStreaming == _lastHasStreaming && streamingHash == _lastStreamingHash)
            return;

        // If a session stopped streaming, refresh its diff stats
        if (_lastHasStreaming && !hasStreaming)
        {
            foreach (var ordered in _orderedSessions)
            {
                _ = RefreshDiffStats(ordered.Session.Id);
            }
        }

        _lastSessionId = currentId;
        _lastHasStreaming = hasStreaming;
        _lastStreamingHash = streamingHash;
        await InvokeAsync(StateHasChanged);
    }

    private void HandleCreateWorkspaceRequest()
    {
        _createDialogOpen = true;
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        ChatState.OnChange -= OnStateChanged;
        ChatState.OnRequestCreateWorkspace -= HandleCreateWorkspaceRequest;
        _ = JS.InvokeVoidAsync("unregisterSessionShortcuts");
        _dotNetRef?.Dispose();
    }
}
