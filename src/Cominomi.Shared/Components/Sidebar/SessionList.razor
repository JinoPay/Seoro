@inject ChatState ChatState
@inject ISessionService SessionService
@inject ISettingsService SettingsService
@inject IWorkspaceService WorkspaceService
@inject IGitService GitService
@implements IDisposable

<MudStack Class="pa-2" Spacing="1" Style="height: 100%; min-height: 0;">
    @if (_workspaces.Count > 0)
    {
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
            <MudSelect T="string" Value="_selectedWorkspaceId" ValueChanged="OnWorkspaceChanged"
                       Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true"
                       Style="flex: 1;">
                @foreach (var ws in _workspaces)
                {
                    <MudSelectItem T="string" Value="@ws.Id">
                        @ws.Name
                    </MudSelectItem>
                }
            </MudSelect>
            <MudIconButton Icon="@Icons.Material.Filled.Settings" Size="Size.Small"
                           OnClick="@(() => _workspaceDialogOpen = true)" />
        </MudStack>

        @if (_showBranchPicker)
        {
            <MudPaper Class="pa-2" Outlined="true" Style="border-radius: 8px;">
                <MudStack Spacing="1">
                    <MudSelect T="string" @bind-Value="_selectedBranch" Label="Base Branch"
                               Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true">
                        @foreach (var branch in _branches)
                        {
                            <MudSelectItem T="string" Value="@branch">@branch</MudSelectItem>
                        }
                    </MudSelect>
                    <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="1">
                        <MudButton Size="Size.Small" OnClick="CancelBranchPicker">Cancel</MudButton>
                        <MudButton Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled"
                                   OnClick="ConfirmCreateSession"
                                   Disabled="@(string.IsNullOrEmpty(_selectedBranch) || _isCreatingSession)">
                            @if (_isCreatingSession)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" />
                                <span>Creating...</span>
                            }
                            else
                            {
                                <span>Create</span>
                            }
                        </MudButton>
                    </MudStack>
                </MudStack>
            </MudPaper>
        }
        else
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                       StartIcon="@Icons.Material.Filled.Add" OnClick="ShowBranchPicker"
                       Disabled="@(ChatState.CurrentWorkspace?.Status != WorkspaceStatus.Ready)">
                New Chat
            </MudButton>
        }

        <MudDivider Class="my-2" />

        <MudStack Style="overflow-y: auto; flex: 1; min-height: 0;">
            @foreach (var session in _sessions)
            {
                var isActive = ChatState.CurrentSession?.Id == session.Id;
                var isArchived = session.Status == SessionStatus.Archived;
                <MudPaper Class="pa-2 mb-1" Outlined="true"
                          Style="@($"cursor: pointer; border-radius: 8px; {(isActive ? "border-color: var(--mud-palette-primary);" : "")} {(isArchived ? "opacity: 0.5;" : "")}")"
                          @onclick="@(() => SelectSession(session))">
                    <MudStack Spacing="0">
                        <MudStack Row="true" AlignItems="AlignItems.Center">
                            <MudText Typo="Typo.body2"
                                     Style="@($"flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; {(isActive ? "font-weight: 600;" : "")}")">
                                @session.Title
                            </MudText>
                            @if (session.Status == SessionStatus.Merged)
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.CleaningServices" Size="Size.Small"
                                               Color="Color.Success" OnClick="@(() => CleanupSession(session))"
                                               OnClickStopPropagation="true" />
                            }
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                           Color="Color.Error" OnClick="@(() => DeleteSession(session))"
                                           OnClickStopPropagation="true" />
                        </MudStack>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            @if (!string.IsNullOrEmpty(session.BranchName))
                            {
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                         Color="@GetBranchChipColor(session.Status)"
                                         Style="font-size: 0.65rem; height: 18px;">
                                    @session.BranchName
                                </MudChip>
                            }
                            @if (session.Status == SessionStatus.Merged)
                            {
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Filled"
                                         Color="Color.Success"
                                         Style="font-size: 0.6rem; height: 16px;">
                                    Merged
                                </MudChip>
                            }
                            else if (session.Status == SessionStatus.Error)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Error" Size="Size.Small" Color="Color.Error" />
                            }
                            <MudSpacer />
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                @session.UpdatedAt.ToLocalTime().ToString("MM/dd HH:mm")
                            </MudText>
                        </MudStack>
                    </MudStack>
                </MudPaper>
            }
        </MudStack>
    }
    else
    {
        <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="flex: 1;" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.Workspaces" Size="Size.Large" Color="Color.Secondary" />
            <MudText Typo="Typo.body2" Align="Align.Center" Color="Color.Secondary">
                Create a workspace to start
            </MudText>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add"
                       OnClick="@(() => _workspaceDialogOpen = true)">
                New Workspace
            </MudButton>
        </MudStack>
    }
</MudStack>

<WorkspaceDialog @bind-IsOpen="_workspaceDialogOpen" OnWorkspacesChanged="ReloadWorkspaces" />

@code {
    private List<Session> _sessions = [];
    private List<Workspace> _workspaces = [];
    private string _selectedWorkspaceId = "";
    private bool _workspaceDialogOpen;
    private bool _isCreatingSession;
    private bool _showBranchPicker;
    private List<string> _branches = [];
    private string _selectedBranch = "";

    protected override async Task OnInitializedAsync()
    {
        ChatState.OnChange += async () => await InvokeAsync(StateHasChanged);

        var settings = await SettingsService.LoadAsync();
        _selectedWorkspaceId = settings.LastWorkspaceId;

        _workspaces = await WorkspaceService.GetWorkspacesAsync();

        var currentWs = _workspaces.FirstOrDefault(w => w.Id == _selectedWorkspaceId)
                        ?? _workspaces.FirstOrDefault();
        if (currentWs != null)
        {
            ChatState.SetWorkspace(currentWs);
            _selectedWorkspaceId = currentWs.Id;
        }

        await LoadSessions();
    }

    private async Task LoadSessions()
    {
        if (!string.IsNullOrEmpty(_selectedWorkspaceId))
        {
            _sessions = await SessionService.GetSessionsByWorkspaceAsync(_selectedWorkspaceId);
            // Check merge status for ready sessions
            _ = CheckMergeStatuses();
        }
        else
            _sessions = [];
    }

    private async Task CheckMergeStatuses()
    {
        var readySessions = _sessions.Where(s => s.Status == SessionStatus.Ready).ToList();
        foreach (var session in readySessions)
        {
            try
            {
                var merged = await SessionService.CheckMergeStatusAsync(session.Id);
                if (merged)
                {
                    session.Status = SessionStatus.Merged;
                    await InvokeAsync(StateHasChanged);
                }
            }
            catch { }
        }
    }

    private async Task OnWorkspaceChanged(string workspaceId)
    {
        _selectedWorkspaceId = workspaceId;
        var ws = _workspaces.FirstOrDefault(w => w.Id == workspaceId);
        if (ws != null)
            ChatState.SetWorkspace(ws);

        await LoadSessions();

        var settings = await SettingsService.LoadAsync();
        settings.LastWorkspaceId = workspaceId;
        await SettingsService.SaveAsync(settings);
    }

    private async Task ReloadWorkspaces()
    {
        _workspaces = await WorkspaceService.GetWorkspacesAsync();

        // If current workspace was deleted, select the first available
        if (!_workspaces.Any(w => w.Id == _selectedWorkspaceId))
        {
            var firstWs = _workspaces.FirstOrDefault();
            if (firstWs != null)
            {
                _selectedWorkspaceId = firstWs.Id;
                ChatState.SetWorkspace(firstWs);
            }
            else
            {
                _selectedWorkspaceId = "";
            }
        }

        await LoadSessions();
    }

    private async Task ShowBranchPicker()
    {
        var ws = ChatState.CurrentWorkspace;
        if (ws == null || string.IsNullOrEmpty(ws.RepoLocalPath)) return;

        _branches = await GitService.ListBranchesAsync(ws.RepoLocalPath);
        var defaultBranch = await GitService.DetectDefaultBranchAsync(ws.RepoLocalPath);
        _selectedBranch = defaultBranch ?? _branches.FirstOrDefault() ?? "";
        _showBranchPicker = true;
    }

    private void CancelBranchPicker()
    {
        _showBranchPicker = false;
        _selectedBranch = "";
    }

    private async Task ConfirmCreateSession()
    {
        var ws = ChatState.CurrentWorkspace;
        if (ws == null || ws.Status != WorkspaceStatus.Ready || string.IsNullOrEmpty(_selectedBranch)) return;

        _isCreatingSession = true;
        StateHasChanged();

        try
        {
            var model = ws.DefaultModel;
            var session = await SessionService.CreateSessionAsync(model, _selectedWorkspaceId, _selectedBranch);

            if (session.Status == SessionStatus.Error)
            {
                _sessions.Insert(0, session);
                await SessionService.SaveSessionAsync(session);
            }
            else
            {
                ChatState.SetSession(session);
                _sessions.Insert(0, session);
            }
        }
        finally
        {
            _isCreatingSession = false;
            _showBranchPicker = false;
            StateHasChanged();
        }
    }

    private async Task SelectSession(Session session)
    {
        if (session.Status == SessionStatus.Archived)
        {
            // Load for viewing history only
            var fullSession = await SessionService.LoadSessionAsync(session.Id);
            if (fullSession != null)
                ChatState.SetSession(fullSession);
            return;
        }

        var fullSess = await SessionService.LoadSessionAsync(session.Id);
        if (fullSess != null)
            ChatState.SetSession(fullSess);
        else
            ChatState.SetSession(session);
    }

    private async Task CleanupSession(Session session)
    {
        await SessionService.CleanupSessionAsync(session.Id);
        session.Status = SessionStatus.Archived;
        StateHasChanged();
    }

    private async Task DeleteSession(Session session)
    {
        await SessionService.DeleteSessionAsync(session.Id);
        _sessions.Remove(session);
        if (ChatState.CurrentSession?.Id == session.Id)
            ChatState.SetSession(null!);
    }

    private static Color GetBranchChipColor(SessionStatus status) => status switch
    {
        SessionStatus.Merged => Color.Success,
        SessionStatus.Error => Color.Error,
        SessionStatus.Archived => Color.Default,
        _ => Color.Primary
    };

    public void Dispose()
    {
        ChatState.OnChange -= async () => await InvokeAsync(StateHasChanged);
    }
}
