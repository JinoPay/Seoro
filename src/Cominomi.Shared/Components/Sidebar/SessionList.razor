@inject ChatState ChatState
@inject ISessionService SessionService
@inject ISettingsService SettingsService
@inject IWorkspaceService WorkspaceService
@implements IDisposable

<MudStack Class="pa-2" Spacing="1" Style="height: 100%; min-height: 0;">
    @if (_workspaces.Count > 0)
    {
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
            <MudSelect T="string" Value="_selectedWorkspaceId" ValueChanged="OnWorkspaceChanged"
                       Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true"
                       Style="flex: 1;">
                @foreach (var ws in _workspaces)
                {
                    <MudSelectItem T="string" Value="@ws.Id">
                        @ws.Name @(string.IsNullOrEmpty(ws.BranchName) ? "" : $"({ws.BranchName})")
                    </MudSelectItem>
                }
            </MudSelect>
            <MudIconButton Icon="@Icons.Material.Filled.Settings" Size="Size.Small"
                           OnClick="@(() => _workspaceDialogOpen = true)" />
        </MudStack>

        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                   StartIcon="@Icons.Material.Filled.Add" OnClick="CreateNewSession"
                   Disabled="@(ChatState.CurrentWorkspace?.Status != WorkspaceStatus.Ready)">
            New Chat
        </MudButton>

        <MudDivider Class="my-2" />

        <MudStack Style="overflow-y: auto; flex: 1; min-height: 0;">
            @foreach (var session in _sessions)
            {
                var isActive = ChatState.CurrentSession?.Id == session.Id;
                <MudPaper Class="pa-2 mb-1" Outlined="true"
                          Style="@($"cursor: pointer; border-radius: 8px; {(isActive ? "border-color: var(--mud-palette-primary);" : "")}")"
                          @onclick="@(() => SelectSession(session))">
                    <MudStack Spacing="0">
                        <MudStack Row="true" AlignItems="AlignItems.Center">
                            <MudText Typo="Typo.body2"
                                     Style="@($"flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; {(isActive ? "font-weight: 600;" : "")}")">
                                @session.Title
                            </MudText>
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                           Color="Color.Error" OnClick="@(() => DeleteSession(session))"
                                           OnClickStopPropagation="true" />
                        </MudStack>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @session.UpdatedAt.ToLocalTime().ToString("MM/dd HH:mm")
                        </MudText>
                    </MudStack>
                </MudPaper>
            }
        </MudStack>
    }
    else
    {
        <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="flex: 1;" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.Workspaces" Size="Size.Large" Color="Color.Secondary" />
            <MudText Typo="Typo.body2" Align="Align.Center" Color="Color.Secondary">
                Create a workspace to start
            </MudText>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add"
                       OnClick="@(() => _workspaceDialogOpen = true)">
                New Workspace
            </MudButton>
        </MudStack>
    }
</MudStack>

<WorkspaceDialog @bind-IsOpen="_workspaceDialogOpen" OnWorkspacesChanged="ReloadWorkspaces" />

@code {
    private List<Session> _sessions = [];
    private List<Workspace> _workspaces = [];
    private string _selectedWorkspaceId = "";
    private bool _workspaceDialogOpen;

    protected override async Task OnInitializedAsync()
    {
        ChatState.OnChange += async () => await InvokeAsync(StateHasChanged);

        var settings = await SettingsService.LoadAsync();
        _selectedWorkspaceId = settings.LastWorkspaceId;

        _workspaces = await WorkspaceService.GetWorkspacesAsync();

        var currentWs = _workspaces.FirstOrDefault(w => w.Id == _selectedWorkspaceId)
                        ?? _workspaces.FirstOrDefault();
        if (currentWs != null)
        {
            ChatState.SetWorkspace(currentWs);
            _selectedWorkspaceId = currentWs.Id;
        }

        await LoadSessions();
    }

    private async Task LoadSessions()
    {
        if (!string.IsNullOrEmpty(_selectedWorkspaceId))
            _sessions = await SessionService.GetSessionsByWorkspaceAsync(_selectedWorkspaceId);
        else
            _sessions = [];
    }

    private async Task OnWorkspaceChanged(string workspaceId)
    {
        _selectedWorkspaceId = workspaceId;
        var ws = _workspaces.FirstOrDefault(w => w.Id == workspaceId);
        if (ws != null)
            ChatState.SetWorkspace(ws);

        await LoadSessions();

        var settings = await SettingsService.LoadAsync();
        settings.LastWorkspaceId = workspaceId;
        await SettingsService.SaveAsync(settings);
    }

    private async Task ReloadWorkspaces()
    {
        _workspaces = await WorkspaceService.GetWorkspacesAsync();

        // If current workspace was deleted, select the first available
        if (!_workspaces.Any(w => w.Id == _selectedWorkspaceId))
        {
            var firstWs = _workspaces.FirstOrDefault();
            if (firstWs != null)
            {
                _selectedWorkspaceId = firstWs.Id;
                ChatState.SetWorkspace(firstWs);
            }
            else
            {
                _selectedWorkspaceId = "";
            }
        }

        await LoadSessions();
    }

    private async Task CreateNewSession()
    {
        var ws = ChatState.CurrentWorkspace;
        if (ws == null || ws.Status != WorkspaceStatus.Ready) return;

        var workDir = ws.WorktreePath;
        var model = ws.DefaultModel;
        var session = await SessionService.CreateSessionAsync(workDir, model, _selectedWorkspaceId);
        ChatState.SetSession(session);
        _sessions.Insert(0, session);
    }

    private async Task SelectSession(Session session)
    {
        var fullSession = await SessionService.LoadSessionAsync(session.Id);
        if (fullSession != null)
            ChatState.SetSession(fullSession);
        else
            ChatState.SetSession(session);
    }

    private async Task DeleteSession(Session session)
    {
        await SessionService.DeleteSessionAsync(session.Id);
        _sessions.Remove(session);
        if (ChatState.CurrentSession?.Id == session.Id)
            ChatState.SetSession(null!);
    }

    public void Dispose()
    {
        ChatState.OnChange -= async () => await InvokeAsync(StateHasChanged);
    }
}
