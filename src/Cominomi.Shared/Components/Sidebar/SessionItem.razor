@using Cominomi.Shared.Models

<div @key="Session.Id"
     class="tree-session @(IsActive ? "active" : "") @(IsStreaming ? "is-streaming" : "") @(Session.Status == SessionStatus.Archived ? "archived" : "")"
     @onclick="@OnClick"
     @oncontextmenu="OpenContextMenu"
     @oncontextmenu:preventDefault="true">

    <div class="tree-session-actions">
        <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                       Style="width: 20px; height: 20px; opacity: 0.4;"
                       OnClick="@OnDelete"
                       OnClickStopPropagation="true" />
    </div>

    @if (IsStreaming)
    {
        <span class="status-badge streaming">
            <span class="status-badge-dot"></span>
        </span>
    }
    else
    {
        <span class="status-badge @GetStatusBadgeClass(Session.Status)">@GetStatusLabel(Session.Status)</span>
    }

    <div class="tree-session-info">
        <span class="tree-session-title">@Session.Title</span>
        <div class="tree-session-meta">
            @if (Session.Git.IsLocalDir)
            {
                <span class="tree-session-branch" style="opacity: 0.5;">로컬</span>
            }
            else if (!string.IsNullOrEmpty(Session.Git.BranchName))
            {
                <span class="tree-session-branch">@Session.Git.BranchName</span>
            }

            @if (DiffAdditions > 0 || DiffDeletions > 0)
            {
                <span class="tree-session-diff-stats">
                    @if (DiffAdditions > 0)
                    {
                        <span class="diff-add">+@DiffAdditions</span>
                    }
                    @if (DiffDeletions > 0)
                    {
                        <span class="diff-del">-@DiffDeletions</span>
                    }
                </span>
            }
        </div>

        @if (IsStreaming)
        {
            <span class="tree-session-status">@StreamingStatusText</span>
        }
    </div>

    @if (ShortcutLabel != null)
    {
        <span class="tree-session-shortcut @(ShowShortcuts ? "visible" : "")">@ShortcutLabel</span>
    }
</div>

<MudMenu @ref="_contextMenu"
         ActivationEvent="@MouseEvent.RightClick"
         PositionAtCursor="true"
         Dense="true"
         Style="position: absolute; visibility: hidden; width: 0; height: 0;">
    <MudMenuItem OnClick="@HandleOpenFolder"
                 Icon="@Icons.Material.Outlined.FolderOpen">
        폴더 열기
    </MudMenuItem>
    @if (AvailableIdes?.Count > 0)
    {
        @foreach (var ide in AvailableIdes)
        {
            <MudMenuItem OnClick="@(() => OnOpenInIde.InvokeAsync(ide.Command))"
                         Icon="@Icons.Material.Outlined.Code">
                @ide.Name 에서 열기
            </MudMenuItem>
        }
    }
    <MudDivider />
    <MudMenuItem OnClick="@(() => OnDelete.InvokeAsync())"
                 Icon="@Icons.Material.Filled.Close">
        삭제
    </MudMenuItem>
</MudMenu>

@code {
    [Parameter, EditorRequired] public Session Session { get; set; } = default!;
    [Parameter] public bool IsActive { get; set; }
    [Parameter] public bool IsStreaming { get; set; }
    [Parameter] public string? StreamingStatusText { get; set; }
    [Parameter] public int DiffAdditions { get; set; }
    [Parameter] public int DiffDeletions { get; set; }
    [Parameter] public string? ShortcutLabel { get; set; }
    [Parameter] public bool ShowShortcuts { get; set; }
    [Parameter] public EventCallback OnClick { get; set; }
    [Parameter] public EventCallback OnDelete { get; set; }
    [Parameter] public EventCallback OnOpenFolder { get; set; }
    [Parameter] public EventCallback<string> OnOpenInIde { get; set; }
    [Parameter] public List<IdeInfo>? AvailableIdes { get; set; }

    private MudMenu? _contextMenu;

    private async Task OpenContextMenu()
    {
        if (_contextMenu != null)
            await _contextMenu.OpenMenuAsync(EventArgs.Empty);
    }

    private async Task HandleOpenFolder()
    {
        await OnOpenFolder.InvokeAsync();
    }

    private static string GetStatusBadgeClass(SessionStatus status) => status switch
    {
        SessionStatus.Ready => "ready",
        SessionStatus.Error => "error",
        SessionStatus.Pending => "pending",
        SessionStatus.Archived => "archived",
        _ => "pending"
    };

    private static string GetStatusLabel(SessionStatus status) => status switch
    {
        SessionStatus.Initializing => "초기화",
        SessionStatus.Pending => "대기",
        SessionStatus.Ready => "준비",
        SessionStatus.Error => "오류",
        SessionStatus.Archived => "보관",
        _ => ""
    };
}
