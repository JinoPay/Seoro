@inject INotificationHistoryService NotificationHistory
@implements IDisposable

<div class="sidebar-toolbar">
    <span class="sidebar-brand">
        <svg width="20" height="20" viewBox="0 0 456 456" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="68" y="78" width="320" height="240" rx="40" ry="40" fill="currentColor" opacity="0.8" />
            <polygon points="108,318 68,378 168,318" fill="currentColor" opacity="0.8" />
            <polyline points="148,158 208,198 148,238" fill="none" stroke="var(--mud-palette-surface)" stroke-width="30" stroke-linecap="round" stroke-linejoin="round" />
            <line x1="228" y1="238" x2="308" y2="238" stroke="var(--mud-palette-surface)" stroke-width="30" stroke-linecap="round" />
        </svg>
        <span class="sidebar-brand-text">Cominomi</span>
    </span>
    @if (SidebarOpen)
    {
        <div style="display: flex; align-items: center; gap: 6px;">
            <MudIconButton Icon="@Icons.Material.Filled.Timeline" Color="Color.Inherit"
                           Size="Size.Small" OnClick="@OnOpenActivity"
                           Style="width: 28px; height: 28px; opacity: 0.5;"
                           Title="Activity" />
            <MudBadge Content="@_unreadCount" Visible="@(_unreadCount > 0)" Color="Color.Error"
                      Overlap="true" Dot="@(_unreadCount <= 0)" Class="notification-badge">
                <MudIconButton Icon="@Icons.Material.Filled.Notifications" Color="Color.Inherit"
                               Size="Size.Small" OnClick="@OnOpenNotifications"
                               Style="width: 28px; height: 28px; opacity: 0.5;"
                               Title="알림 히스토리" />
            </MudBadge>
            <button class="sidebar-collapse-btn" @onclick="@OnToggleSidebar" title="사이드바 접기">
                <MudIcon Icon="@Icons.Material.Filled.ChevronLeft" Size="Size.Small"
                         Style="width: 18px; height: 18px;" />
            </button>
        </div>
    }
    else
    {
        <button class="sidebar-collapse-btn" @onclick="@OnToggleSidebar" title="사이드바 펼치기">
            <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small"
                     Style="width: 18px; height: 18px;" />
        </button>
    }
</div>

@code {
    [Parameter] public bool SidebarOpen { get; set; }
    [Parameter] public EventCallback OnToggleSidebar { get; set; }
    [Parameter] public EventCallback OnOpenActivity { get; set; }
    [Parameter] public EventCallback OnOpenNotifications { get; set; }

    private int _unreadCount;

    protected override void OnInitialized()
    {
        NotificationHistory.OnChange += HandleNotificationChange;
        _unreadCount = NotificationHistory.UnreadCount;
    }

    private void HandleNotificationChange()
    {
        _ = InvokeAsync(() =>
        {
            _unreadCount = NotificationHistory.UnreadCount;
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        NotificationHistory.OnChange -= HandleNotificationChange;
    }
}
