@inherits LayoutComponentBase
@inject ChatState ChatState
@inject IJSRuntime JS
@implements IDisposable

<MudThemeProvider @bind-IsDarkMode="@_isDarkMode" Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<div class="cominomi-shell @(ChatState.RightPanel != RightPanelMode.None ? "detail-open" : "") @(!_sidebarOpen ? "sidebar-collapsed" : "")">
    @* === Left Panel: Sidebar === *@
    <aside class="cominomi-sidebar">
        <div class="sidebar-toolbar">
            <span class="sidebar-brand">
                <svg width="20" height="20" viewBox="0 0 456 456" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect x="68" y="78" width="320" height="240" rx="40" ry="40" fill="currentColor" opacity="0.8" />
                    <polygon points="108,318 68,378 168,318" fill="currentColor" opacity="0.8" />
                    <polyline points="148,158 208,198 148,238" fill="none" stroke="var(--mud-palette-surface)" stroke-width="30" stroke-linecap="round" stroke-linejoin="round" />
                    <line x1="228" y1="238" x2="308" y2="238" stroke="var(--mud-palette-surface)" stroke-width="30" stroke-linecap="round" />
                </svg>
                Cominomi
            </span>
            <div style="display: flex; align-items: center; gap: 2px;">
                <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                               Color="Color.Inherit" Size="Size.Small" OnClick="@ToggleDarkMode"
                               Style="width: 28px; height: 28px; opacity: 0.5;" />
                <MudIconButton Icon="@Icons.Material.Filled.Analytics" Color="Color.Inherit"
                               Size="Size.Small" OnClick="@OpenUsageDashboard"
                               Style="width: 28px; height: 28px; opacity: 0.5;"
                               Title="사용량 대시보드" />
                <MudIconButton Icon="@Icons.Material.Filled.Settings" Color="Color.Inherit"
                               Size="Size.Small" OnClick="@OpenSettings"
                               Style="width: 28px; height: 28px; opacity: 0.5;" />
            </div>
        </div>
        <SessionList />
    </aside>

    @* === Center Panel: Chat === *@
    <main class="cominomi-main">
        <div class="main-toolbar">
            <MudIconButton Icon="@(_sidebarOpen ? Icons.Material.Filled.MenuOpen : Icons.Material.Filled.Menu)"
                           Color="Color.Inherit" Size="Size.Small" OnClick="@ToggleSidebar"
                           Style="width: 28px; height: 28px; opacity: 0.6;" />

            @if (ChatState.CurrentSession != null)
            {
                <span class="toolbar-title">@(ChatState.CurrentSession.Title ?? "새 대화")</span>

                @if (!string.IsNullOrEmpty(ChatState.CurrentSession.BranchName))
                {
                    <span class="toolbar-branch-badge">
                        <MudIcon Icon="@Icons.Material.Filled.AccountTree" Size="Size.Small"
                                 Style="width: 12px; height: 12px; opacity: 0.6;" />
                        @ChatState.CurrentSession.BranchName
                    </span>
                }

                @if (ChatState.CurrentSession.PermissionMode == "plan")
                {
                    <span class="toolbar-mode-badge plan">플랜</span>
                }
            }
            else
            {
                <span class="toolbar-title" style="opacity: 0.4;">대화를 선택하세요</span>
            }

            <div style="flex: 1;"></div>

            <StatusBar />

            @if (ChatState.CurrentSession != null && ChatState.CurrentSession.Status != SessionStatus.Pending)
            {
                <MudTooltip Text="파일 탐색기">
                    <MudIconButton Icon="@Icons.Material.Filled.FolderOpen"
                                   Color="@(ChatState.RightPanel == RightPanelMode.Explorer ? Color.Primary : Color.Inherit)"
                                   Size="Size.Small"
                                   Style="width: 28px; height: 28px;"
                                   OnClick="@(() => ChatState.ToggleRightPanel(RightPanelMode.Explorer))" />
                </MudTooltip>
                <MudTooltip Text="변경사항">
                    <MudIconButton Icon="@Icons.Material.Filled.Difference"
                                   Color="@(ChatState.RightPanel == RightPanelMode.Changes ? Color.Primary : Color.Inherit)"
                                   Size="Size.Small"
                                   Style="width: 28px; height: 28px;"
                                   OnClick="@(() => ChatState.ToggleRightPanel(RightPanelMode.Changes))" />
                </MudTooltip>
                <MudTooltip Text="컨텍스트">
                    <MudIconButton Icon="@Icons.Material.Filled.Folder"
                                   Color="@(ChatState.RightPanel == RightPanelMode.Context ? Color.Primary : Color.Inherit)"
                                   Size="Size.Small"
                                   Style="width: 28px; height: 28px;"
                                   OnClick="@(() => ChatState.ToggleRightPanel(RightPanelMode.Context))" />
                </MudTooltip>
            }
        </div>

        @if (ChatState.OpenTabs.Count > 1)
        {
            <MainTabBar />
        }

        <div class="main-content">
            @if (ChatState.ActiveTab?.Type == MainTabType.FileContent && ChatState.ActiveTab.FilePath != null)
            {
                <FileContentView FilePath="ChatState.ActiveTab.FilePath"
                                 Content="@(ChatState.ActiveTab.FileContent ?? "")" />
            }
            else if (ChatState.ActiveTab?.Type == MainTabType.FileDiff && ChatState.ActiveTab.DiffData != null)
            {
                <FileDiffView Diff="ChatState.ActiveTab.DiffData" />
            }
            else
            {
                @Body
            }
        </div>
    </main>

    @* === Right Panel: Detail (Context) === *@
    @if (ChatState.RightPanel != RightPanelMode.None)
    {
        <aside class="cominomi-detail">
            <DetailPanel />
        </aside>
    }
</div>

<SettingsDialog @bind-IsOpen="_settingsOpen" />
<SetupDialog @bind-IsOpen="_setupOpen" />
<UsageDashboard @bind-IsOpen="_usageDashboardOpen" />

@code {
    private bool _sidebarOpen = true;
    private bool _isDarkMode = true;
    private bool _settingsOpen;
    private bool _setupOpen;
    private bool _usageDashboardOpen;

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#7c3aed",
            AppbarBackground = "#f5f5f5",
            AppbarText = "#333333",
            Background = "#ffffff",
            Surface = "#f5f5f5",
            DrawerBackground = "#fafafa",
        },
        PaletteDark = new PaletteDark
        {
            Primary = "#a78bfa",
            AppbarBackground = "#1e1e2e",
            AppbarText = "#cdd6f4",
            Background = "#1e1e2e",
            Surface = "#313244",
            DrawerBackground = "#11111b",
            TextPrimary = "#cdd6f4",
            TextSecondary = "#a6adc8",
            LinesDefault = "rgba(166,173,200,0.12)",
        }
    };

    [Inject] private ISettingsService SettingsService { get; set; } = default!;
    [Inject] private IDependencyCheckService DependencyCheckService { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        ChatState.OnChange += HandleStateChanged;
        SettingsService.OnSettingsChanged += HandleSettingsChanged;

        var settings = await SettingsService.LoadAsync();
        _isDarkMode = settings.Theme != "light";

        var deps = await DependencyCheckService.CheckAllAsync();
        if (deps.Any(d => !d.IsInstalled))
        {
            _setupOpen = true;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var settings = await SettingsService.LoadAsync();
            await ApplyTheme(settings.Theme);
        }
    }

    private async Task ApplyTheme(string theme)
    {
        var effectiveTheme = theme == "light" ? "light" : "dark";
        _isDarkMode = effectiveTheme == "dark";
        await JS.InvokeVoidAsync("setTheme", effectiveTheme);
    }

    private async void HandleSettingsChanged(AppSettings settings)
    {
        await InvokeAsync(async () =>
        {
            await ApplyTheme(settings.Theme);
            StateHasChanged();
        });
    }

    private void HandleStateChanged() => InvokeAsync(StateHasChanged);

    private void ToggleSidebar() => _sidebarOpen = !_sidebarOpen;

    private async Task ToggleDarkMode()
    {
        _isDarkMode = !_isDarkMode;
        var settings = await SettingsService.LoadAsync();
        settings.Theme = _isDarkMode ? "dark" : "light";
        await SettingsService.SaveAsync(settings);
        await ApplyTheme(settings.Theme);
    }

    private void OpenSettings() => _settingsOpen = true;
    private void OpenUsageDashboard() => _usageDashboardOpen = true;

    public void Dispose()
    {
        ChatState.OnChange -= HandleStateChanged;
        SettingsService.OnSettingsChanged -= HandleSettingsChanged;
    }
}
