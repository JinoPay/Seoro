@using Microsoft.Extensions.Logging
@inherits LayoutComponentBase
@inject IChatState ChatState
@inject IGitService GitService
@inject IJSRuntime JS
@inject IThemeService ThemeService
@inject ISettingsService SettingsService
@inject IDependencyCheckService DependencyCheckService
@inject IClaudeService ClaudeService
@inject ISnackbar Snackbar
@inject ILogger<MainLayout> Logger
@implements IAsyncDisposable

<MudThemeProvider @bind-IsDarkMode="@_isDarkMode" Theme="ThemeService.Theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<Cominomi.Shared.Components.Chat.ImageLightbox />

@if (ChatState.ShowSettings)
{
    <SettingsPage />
}
@if (ChatState.ShowActivity)
{
    <ActivityView />
}
@if (ChatState.ShowNotifications)
{
    <NotificationHistoryView />
}

@{
    var anyOverlay = ChatState.ShowSettings || ChatState.ShowActivity || ChatState.ShowNotifications;
}
<div class="cominomi-shell @(!_sidebarOpen ? "sidebar-collapsed" : "")"
     style="@(anyOverlay ? "display:none;height:0;overflow:hidden" : "")">
        @* === Left Panel: Sidebar === *@
        <aside class="cominomi-sidebar">
            <SidebarToolbar SidebarOpen="_sidebarOpen"
                            OnToggleSidebar="@(() => _sidebarOpen = !_sidebarOpen)"
                            OnOpenActivity="OpenActivity"
                            OnOpenNotifications="OpenNotifications" />
            <SessionList />
            <SidebarFooter OnOpenUsageDashboard="@(() => _usageDashboardOpen = true)"
                           OnOpenSettings="@(() => ChatState.OpenSettings())" />
        </aside>

        @* === Sidebar ↔ Main Resizer === *@
        @if (_sidebarOpen)
        {
            <PanelResizer PanelId="sidebar" CurrentSize="_sidebarWidth" MinSize="180" MaxSize="480"
                          OnResize="HandleSidebarResize" />
        }

        @* === Center Panel: Chat + Right Panel === *@
        @{
            bool showRightPanel = ChatState.CurrentSession != null
                                  && ChatState.CurrentSession.Status != SessionStatus.Pending;
        }
        <main class="cominomi-main">
            <div class="main-left-col">
                <MainToolbar />

                @if (ChatState.Tabs.OpenTabs.Count > 1)
                {
                    <MainTabBar />
                }

                <div class="main-content">
                    @{
                        var activeType = ChatState.Tabs.ActiveTab?.Type;
                        var isChatTab = activeType is null or MainTabType.Chat;
                    }

                    @* ChatView는 항상 렌더링 — 탭 전환 시에도 프로세스가 유지되도록 display로 토글 *@
                    <div style="@(isChatTab ? "flex:1;min-height:0;display:flex;flex-direction:column" : "display:none;height:0;overflow:hidden")">
                        @Body
                    </div>

                    @if (activeType == MainTabType.FileContent && ChatState.Tabs.ActiveTab?.FilePath != null)
                    {
                        @if (ChatState.Tabs.ActiveTab.ContentEvicted)
                        {
                            <div style="display: flex; align-items: center; justify-content: center; flex:1; opacity: 0.5;">
                                <MudProgressCircular Indeterminate="true" Size="Size.Small" Class="mr-2" />
                                <span>Reloading…</span>
                            </div>
                        }
                        else
                        {
                            <FileContentView @key="ChatState.Tabs.ActiveTab.Id"
                                             FilePath="@ChatState.Tabs.ActiveTab.FilePath"
                                             Content="@(ChatState.Tabs.ActiveTab.FileContent ?? "")" />
                        }
                    }
                    else if (activeType == MainTabType.FileDiff && ChatState.Tabs.ActiveTab?.DiffData != null)
                    {
                        <FileDiffView @key="ChatState.Tabs.ActiveTab.Id" Diff="ChatState.Tabs.ActiveTab.DiffData" />
                    }
                </div>
            </div>

            @if (showRightPanel)
            {
                <PanelResizer PanelId="rightpanel" CurrentSize="_rightPanelWidth"
                              MinSize="280" MaxSize="600" Reverse="true"
                              OnResize="HandleRightPanelResize" />

                <div class="main-right-col" style="width: @(_rightPanelWidth)px;">
                    <div class="right-panel-spacer"></div>
                    <EmbeddedDiffPanel />
                </div>
            }
        </main>

    </div>

<SetupDialog @bind-IsOpen="_setupOpen" />
<UsageDashboard @bind-IsOpen="_usageDashboardOpen" />

@code {
    private bool _sidebarOpen = true;
    private bool _isDarkMode = true;
    private bool _setupOpen;
    private bool _usageDashboardOpen;
    private int _sidebarWidth = 260;
    private int _rightPanelWidth = 400;
    private DotNetObjectReference<MainLayout>? _panelShortcutRef;

    protected override async Task OnInitializedAsync()
    {
        ChatState.OnChange += HandleStateChanged;
        ThemeService.OnThemeChanged += HandleThemeChanged;
        SettingsService.OnSettingsChanged += HandleUiScaleChanged;

        try
        {
            await ThemeService.InitializeAsync();
            _isDarkMode = ThemeService.IsDarkMode;

            var deps = await DependencyCheckService.CheckAllAsync();
            if (deps.Any(d => !d.IsInstalled))
            {
                _setupOpen = true;
            }
            else
            {
                _ = CheckClaudeVersionAsync();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "MainLayout initialization failed");
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var effectiveTheme = _isDarkMode ? "dark" : "light";
            await JS.InvokeVoidAsync("setTheme", effectiveTheme);

            _panelShortcutRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("registerPanelShortcuts", _panelShortcutRef);

            // Apply UI scale from persisted settings
            var settings = await SettingsService.LoadAsync();
            double scale = settings.UiScale;
            if (scale == 0)
                scale = await JS.InvokeAsync<double>("getDefaultUiScale");
            await JS.InvokeVoidAsync("setUiScale", scale);
        }
    }

    private void HandleSidebarResize(int newWidth) => _sidebarWidth = newWidth;
    private void HandleRightPanelResize(int newWidth) => _rightPanelWidth = newWidth;

    [JSInvokable]
    public void OnToggleSidebarShortcut()
    {
        _sidebarOpen = !_sidebarOpen;
        InvokeAsync(StateHasChanged);
    }

    private void HandleThemeChanged()
    {
        _ = InvokeAsync(() =>
        {
            try
            {
                _isDarkMode = ThemeService.IsDarkMode;
                _ = JS.InvokeVoidAsync("setTheme", _isDarkMode ? "dark" : "light");
                StateHasChanged();
            }
            catch (Exception ex)
            {
                System.Diagnostics.Debug.WriteLine($"HandleThemeChanged failed: {ex}");
            }
        });
    }

    private void HandleUiScaleChanged(AppSettings settings)
    {
        _ = InvokeAsync(async () =>
        {
            try
            {
                double scale = settings.UiScale;
                if (scale == 0)
                    scale = await JS.InvokeAsync<double>("getDefaultUiScale");
                await JS.InvokeVoidAsync("setUiScale", scale);
            }
            catch (Exception ex)
            {
                System.Diagnostics.Debug.WriteLine($"HandleUiScaleChanged failed: {ex}");
            }
        });
    }

    private async Task CheckClaudeVersionAsync()
    {
        try
        {
            var version = await ClaudeService.GetDetectedVersionAsync();
            if (VersionComparer.IsOutdated(version, CominomiConstants.RequiredClaudeVersion))
            {
                await InvokeAsync(() =>
                {
                    Snackbar.ClaudeUpdateRequired(
                        version ?? "알 수 없음",
                        CominomiConstants.RequiredClaudeVersion);
                });
            }
        }
        catch (Exception ex)
        {
            Logger.LogDebug(ex, "Version check failed silently");
        }
    }

    private void HandleStateChanged()
    {
        _ = InvokeAsync(async () =>
        {
            StateHasChanged();
            var active = ChatState.Tabs.ActiveTab;
            if (active is { Type: MainTabType.FileContent, ContentEvicted: true })
                await ReloadEvictedContent(active);
        });
    }

    private void OpenActivity() => ChatState.OpenActivity();
    private void OpenNotifications() => ChatState.OpenNotifications();

    private HashSet<string> _reloadingTabs = new();

    private async Task ReloadEvictedContent(MainTab tab)
    {
        if (!_reloadingTabs.Add(tab.Id)) return;
        try
        {
            var session = ChatState.CurrentSession;
            if (session == null || string.IsNullOrEmpty(session.Git.WorktreePath) || tab.FilePath == null) return;

            var content = await GitService.ReadFileAsync(session.Git.WorktreePath, tab.FilePath);
            ChatState.Tabs.OpenFileContentTab(tab.FilePath, content);
        }
        catch (Exception ex)
        {
            tab.FileContent = $"Error reloading file: {ex.Message}";
            tab.ContentEvicted = false;
        }
        finally
        {
            _reloadingTabs.Remove(tab.Id);
            await InvokeAsync(StateHasChanged);
        }
    }

    public async ValueTask DisposeAsync()
    {
        ChatState.OnChange -= HandleStateChanged;
        ThemeService.OnThemeChanged -= HandleThemeChanged;
        SettingsService.OnSettingsChanged -= HandleUiScaleChanged;
        try
        {
            await JS.InvokeVoidAsync("unregisterPanelShortcuts");
        }
        catch { /* May already be disposed */ }
        _panelShortcutRef?.Dispose();
    }
}
