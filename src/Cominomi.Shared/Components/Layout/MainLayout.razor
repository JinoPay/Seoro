@inherits LayoutComponentBase
@inject IChatState ChatState
@inject IJSRuntime JS
@inject IThemeService ThemeService
@inject IDependencyCheckService DependencyCheckService
@implements IAsyncDisposable

<MudThemeProvider @bind-IsDarkMode="@_isDarkMode" Theme="ThemeService.Theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

@if (ChatState.ShowSettings)
{
    <SettingsPage />
}
else
{
    <div class="cominomi-shell @(ChatState.RightPanel != RightPanelMode.None ? "detail-open" : "") @(!_sidebarOpen ? "sidebar-collapsed" : "")">
        @* === Left Panel: Sidebar === *@
        <aside class="cominomi-sidebar">
            <SidebarToolbar OnOpenActivity="OpenActivity"
                            OnOpenUsageDashboard="@(() => _usageDashboardOpen = true)"
                            OnOpenSettings="@(() => ChatState.OpenSettings())" />
            <SessionList />
        </aside>

        @* === Sidebar ↔ Main Resizer === *@
        @if (_sidebarOpen)
        {
            <PanelResizer PanelId="sidebar" CurrentSize="_sidebarWidth" MinSize="180" MaxSize="480"
                          OnResize="HandleSidebarResize" />
        }

        @* === Center Panel: Chat === *@
        <main class="cominomi-main">
            <MainToolbar SidebarOpen="_sidebarOpen" OnToggleSidebar="@(() => _sidebarOpen = !_sidebarOpen)" />

            @if (ChatState.Tabs.OpenTabs.Count > 1)
            {
                <MainTabBar />
            }

            <div class="main-content">
                @if (ChatState.Tabs.ActiveTab?.Type == MainTabType.Activity)
                {
                    <ActivityView />
                }
                else if (ChatState.Tabs.ActiveTab?.Type == MainTabType.FileContent && ChatState.Tabs.ActiveTab.FilePath != null)
                {
                    <FileContentView FilePath="ChatState.Tabs.ActiveTab.FilePath"
                                     Content="@(ChatState.Tabs.ActiveTab.FileContent ?? "")" />
                }
                else if (ChatState.Tabs.ActiveTab?.Type == MainTabType.FileDiff && ChatState.Tabs.ActiveTab.DiffData != null)
                {
                    <FileDiffView Diff="ChatState.Tabs.ActiveTab.DiffData" />
                }
                else
                {
                    @Body
                }
            </div>
        </main>

        @* === Main ↔ Detail Resizer === *@
        @if (ChatState.RightPanel != RightPanelMode.None)
        {
            <PanelResizer PanelId="detail" CurrentSize="_detailWidth" MinSize="280" MaxSize="700"
                          Reverse="true" OnResize="HandleDetailResize" />

            @* === Right Panel: Detail (Context) === *@
            <aside class="cominomi-detail">
                <DetailPanel />
            </aside>
        }
    </div>
}

<SetupDialog @bind-IsOpen="_setupOpen" />
<UsageDashboard @bind-IsOpen="_usageDashboardOpen" />

@code {
    private bool _sidebarOpen = true;
    private bool _isDarkMode = true;
    private bool _setupOpen;
    private bool _usageDashboardOpen;
    private int _sidebarWidth = 260;
    private int _detailWidth = 400;
    private DotNetObjectReference<MainLayout>? _panelShortcutRef;

    protected override async Task OnInitializedAsync()
    {
        ChatState.OnChange += HandleStateChanged;
        ThemeService.OnThemeChanged += HandleThemeChanged;

        await ThemeService.InitializeAsync();
        _isDarkMode = ThemeService.IsDarkMode;

        var deps = await DependencyCheckService.CheckAllAsync();
        if (deps.Any(d => !d.IsInstalled))
        {
            _setupOpen = true;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var effectiveTheme = _isDarkMode ? "dark" : "light";
            await JS.InvokeVoidAsync("setTheme", effectiveTheme);

            _panelShortcutRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("registerPanelShortcuts", _panelShortcutRef);
        }
    }

    private void HandleSidebarResize(int newWidth)
    {
        _sidebarWidth = newWidth;
    }

    private void HandleDetailResize(int newWidth)
    {
        _detailWidth = newWidth;
    }

    [JSInvokable]
    public void OnToggleSidebarShortcut()
    {
        _sidebarOpen = !_sidebarOpen;
        InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public void OnToggleDetailShortcut()
    {
        var current = ChatState.RightPanel != RightPanelMode.None ? ChatState.RightPanel : RightPanelMode.Explorer;
        ChatState.ToggleRightPanel(current);
    }

    private void HandleThemeChanged()
    {
        _ = InvokeAsync(() =>
        {
            try
            {
                _isDarkMode = ThemeService.IsDarkMode;
                _ = JS.InvokeVoidAsync("setTheme", _isDarkMode ? "dark" : "light");
                StateHasChanged();
            }
            catch (Exception ex)
            {
                System.Diagnostics.Debug.WriteLine($"HandleThemeChanged failed: {ex}");
            }
        });
    }

    private void HandleStateChanged() => InvokeAsync(StateHasChanged);

    private void OpenActivity() => ChatState.Tabs.OpenActivityTab();

    public async ValueTask DisposeAsync()
    {
        ChatState.OnChange -= HandleStateChanged;
        ThemeService.OnThemeChanged -= HandleThemeChanged;
        try
        {
            await JS.InvokeVoidAsync("unregisterPanelShortcuts");
        }
        catch { /* May already be disposed */ }
        _panelShortcutRef?.Dispose();
    }
}
