@inject IChatState ChatState
@inject ILauncherService Launcher
@inject IWorktreeSyncService SyncService
@inject IWorkspaceService WorkspaceService
@inject IChatEventBus EventBus
@inject ISnackbar Snackbar
@implements IDisposable

<div class="main-toolbar">
    @if (ChatState.CurrentSession != null)
    {
        <span class="toolbar-title">@(ChatState.CurrentSession.Title ?? "새 대화")</span>

        @if (!string.IsNullOrEmpty(ChatState.CurrentSession.Git.BranchName))
        {
            <span class="toolbar-branch-badge">
                <MudIcon Icon="@Icons.Material.Filled.AccountTree" Size="Size.Small"
                         Style="width: 12px; height: 12px; opacity: 0.6;" />
                @ChatState.CurrentSession.Git.BranchName
            </span>
        }

        @if (IsSynced)
        {
            <span class="toolbar-sync-badge">동기화</span>
        }

        @if (ChatState.CurrentSession.PermissionMode == "plan")
        {
            <span class="toolbar-mode-badge plan">플랜</span>
        }

        @if (ChatState.CurrentSession.EffortLevel is not (null or "" or "auto"))
        {
            <span class="toolbar-effort-badge @ChatState.CurrentSession.EffortLevel">
                @ChatState.CurrentSession.EffortLevel
            </span>
        }
    }
    else
    {
        <span class="toolbar-title" style="opacity: 0.4;">대화를 선택하세요</span>
    }

    <div style="flex: 1;"></div>

    @if (ChatState.CurrentSession != null && !string.IsNullOrEmpty(GetEffectivePath()))
    {
        <div class="toolbar-actions">
            @if (ShowSyncButton)
            {
                <MudTooltip Text="@SyncTooltip" Placement="Placement.Bottom">
                    <MudIconButton Icon="@(IsSynced ? Icons.Material.Filled.SyncDisabled : Icons.Material.Filled.Sync)"
                                   Color="@(IsSynced ? Color.Success : Color.Default)"
                                   Size="Size.Small"
                                   OnClick="ToggleSync"
                                   Disabled="_syncBusy || IsSyncBlockedByOther"
                                   Style="width: 28px; height: 28px;" />
                </MudTooltip>
            }

            <MudTooltip Text="폴더 열기" Placement="Placement.Bottom">
                <MudIconButton Icon="@Icons.Material.Outlined.FolderOpen" Size="Size.Small"
                               OnClick="OpenFolder"
                               Style="width: 28px; height: 28px; opacity: 0.5;" />
            </MudTooltip>

            @if (_availableIdes.Count == 1)
            {
                <MudTooltip Text="@($"{_availableIdes[0].Name}에서 열기")" Placement="Placement.Bottom">
                    <MudIconButton Icon="@Icons.Material.Outlined.Code" Size="Size.Small"
                                   OnClick="@(() => OpenInIde(_availableIdes[0].Command))"
                                   Style="width: 28px; height: 28px; opacity: 0.5;" />
                </MudTooltip>
            }
            else if (_availableIdes.Count > 1)
            {
                <MudMenu Icon="@Icons.Material.Outlined.Code" Size="Size.Small"
                         Dense="true"
                         AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight"
                         Style="width: 28px; height: 28px; opacity: 0.5;"
                         ActivationEvent="@MouseEvent.LeftClick">
                    @foreach (var ide in _availableIdes)
                    {
                        <MudMenuItem OnClick="@(() => OpenInIde(ide.Command))"
                                     Icon="@Icons.Material.Outlined.Code">
                            @ide.Name
                        </MudMenuItem>
                    }
                </MudMenu>
            }
        </div>
    }

    <StatusBar />
</div>

@code {
    private List<IdeInfo> _availableIdes = [];
    private bool _syncBusy;
    private IDisposable? _syncStartSub;
    private IDisposable? _syncStopSub;

    private bool IsSynced => SyncService.IsSessionSynced(ChatState.CurrentSession?.Id ?? "");
    private bool IsSyncBlockedByOther => SyncService.IsSyncActive && !IsSynced;

    private string SyncTooltip => IsSynced
        ? "로컬 동기화 해제"
        : IsSyncBlockedByOther
            ? "다른 세션이 동기화 중입니다"
            : "로컬 디렉터리에 동기화";

    private bool ShowSyncButton
    {
        get
        {
            var session = ChatState.CurrentSession;
            return session != null &&
                   !session.Git.IsLocalDir &&
                   !string.IsNullOrEmpty(session.Git.WorktreePath);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        ChatState.OnChange += HandleStateChanged;
        _syncStartSub = EventBus.Subscribe<WorktreeSyncStartedEvent>(_ => InvokeAsync(StateHasChanged));
        _syncStopSub = EventBus.Subscribe<WorktreeSyncStoppedEvent>(_ => InvokeAsync(StateHasChanged));
        _availableIdes = await Launcher.GetAvailableIdesAsync();
    }

    private string? GetEffectivePath()
    {
        var session = ChatState.CurrentSession;
        if (session == null) return null;

        if (!string.IsNullOrEmpty(session.Git.WorktreePath))
            return session.Git.WorktreePath;

        return ChatState.CurrentWorkspace?.RepoLocalPath;
    }

    private async Task ToggleSync()
    {
        var session = ChatState.CurrentSession;
        if (session == null) return;

        _syncBusy = true;
        StateHasChanged();

        try
        {
            if (IsSynced)
            {
                await SyncService.StopSyncAsync();
                Snackbar.Add("동기화 해제됨", Severity.Info);
            }
            else
            {
                var workspace = ChatState.CurrentWorkspace;
                if (workspace == null) return;
                var success = await SyncService.StartSyncAsync(session, workspace);
                Snackbar.Add(success ? "로컬 디렉터리에 동기화됨" : "동기화 실패 — 이미 다른 세션이 동기화 중이거나 세션 상태가 유효하지 않습니다", success ? Severity.Success : Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"동기화 오류: {ex.Message}", Severity.Error);
        }
        finally
        {
            _syncBusy = false;
            StateHasChanged();
        }
    }

    private async Task OpenFolder()
    {
        var path = GetEffectivePath();
        if (path != null)
            await Launcher.OpenFolderAsync(path);
    }

    private async Task OpenInIde(string ideCommand)
    {
        var path = GetEffectivePath();
        if (path != null)
            await Launcher.OpenInIdeAsync(path, ideCommand);
    }

    private void HandleStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        ChatState.OnChange -= HandleStateChanged;
        _syncStartSub?.Dispose();
        _syncStopSub?.Dispose();
    }
}

<style>
    .toolbar-sync-badge {
        font-size: 0.65rem;
        font-weight: 600;
        padding: 1px 6px;
        border-radius: 4px;
        background: var(--color-success);
        color: white;
        line-height: 1.4;
    }
</style>
