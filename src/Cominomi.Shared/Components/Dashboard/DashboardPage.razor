@inject IGamificationService GamificationService
@inject IStatsCacheService StatsCacheService
@inject ISessionReplayService ReplayService
@inject IChatState ChatState

<div class="settings-content-area wide">
    <div class="settings-content-header">
        <span class="typo-h6">대시보드</span>
        <div style="display: flex; align-items: center; gap: 8px; margin-left: auto;">
            @if (_refreshing)
            {
                <MudProgressCircular Indeterminate="true" Size="Size.Small" Style="width: 20px; height: 20px;"/>
            }
            <MudIconButton Icon="@Icons.Material.Filled.Refresh" Size="Size.Small"
                           Disabled="_refreshing || _loading"
                           OnClick="OnRefreshClick"
                           Title="통계 새로고침"/>
        </div>
    </div>
    <div class="settings-content-body">
        @if (_loading)
        {
            <div style="display: flex; justify-content: center; padding: 40px;">
                <MudProgressCircular Indeterminate="true"/>
            </div>
        }
        else
        {
            @* Level Banner *@
            <div class="dashboard-level-banner">
                <div class="d-flex justify-space-between align-center mb-1">
                    <div>
                        <span class="typo-h5" style="font-weight: 700;">Lv.@_stats.Level.Level</span>
                        <span class="typo-subtitle1 ml-2">@_stats.Level.Name</span>
                    </div>
                    <div style="text-align: right;">
                        <span
                            class="typo-caption">@_stats.Level.Xp.ToString("N0") / @_stats.Level.XpForNext.ToString("N0") XP</span>
                        @if (_stats.Level.Level < UserLevel.Names.Length)
                        {
                            <div class="typo-caption" style="opacity: 0.7;">
                                다음: @UserLevel.Names[_stats.Level.Level]
                            </div>
                        }
                    </div>
                </div>
                <MudProgressLinear Value="@(_stats.Level.Progress * 100)" Color="Color.Primary"
                                   Rounded="true" Size="Size.Medium"
                                   Style="height: 8px;"/>
                <div class="d-flex gap-4 mt-2" style="font-size: 0.7rem; opacity: 0.8;">
                    <span>@_stats.TotalProjects 프로젝트</span>
                    <span>@_stats.Achievements.Count(a => a.Unlocked)/@_stats.Achievements.Count 업적</span>
                    <span>@(_stats.Streak.CurrentStreak)일 연속</span>
                </div>
            </div>

            @* Stats Overview *@
            <StatsOverview TotalSessions="@_stats.TotalSessions"
                           TotalMessages="@_stats.TotalMessages"
                           TotalToolCalls="@_stats.TotalToolCalls"
                           DaysActive="@_stats.DaysActive"/>

            @* Middle Row: Streak + Config + Cost *@
            <div class="dashboard-middle-row">
                <StreakCard Current="@_stats.Streak.CurrentStreak"
                            Longest="@_stats.Streak.LongestStreak"
                            LastActiveDate="@_stats.Streak.LastActiveDate"/>

                @* Config Completeness *@
                <div class="dashboard-config-card">
                    <div class="dashboard-config-title">설정 완성도</div>
                    <div class="d-flex align-center gap-4">
                        <div style="position: relative; flex-shrink: 0;">
                            <MudProgressCircular Value="@(_stats.ConfigCompleteness * 100)"
                                                 Color="Color.Primary" Size="Size.Large"
                                                 StrokeWidth="6"/>
                            <span
                                class="dashboard-config-pct">@((_stats.ConfigCompleteness * 100).ToString("F0"))%</span>
                        </div>
                        <div class="dashboard-config-items">
                            @foreach (var item in _stats.ConfigItems)
                            {
                                <div class="dashboard-config-item @(item.IsConfigured ? "configured" : "")">
                                    <MudIcon
                                        Icon="@(item.IsConfigured ? Icons.Material.Filled.CheckCircle : Icons.Material.Outlined.RadioButtonUnchecked)"
                                        Size="Size.Small"/>
                                    <span>@item.Name</span>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <CostOverviewCard Cost="@_stats.Cost"
                                  OnNavigateToUsage="@(() => ChatState.SetSettingsSection("usage"))"/>
            </div>

            @* Activity Heatmap *@
            <ActivityHeatmap DailyActivity="@_stats.DailyActivity"/>

            @* Bottom Row: Session Monitor + Achievements *@
            <div class="dashboard-bottom-row">
                <SessionMonitor/>
                <AchievementGrid Achievements="@_stats.Achievements"/>
            </div>
        }
    </div>
</div>

@code {
    private DashboardStats _stats = new();
    private bool _loading = true;
    private bool _refreshing;

    protected override async Task OnInitializedAsync()
    {
        // Parallel: refresh stats cache if stale + ensure session index loaded
        var t1 = StatsCacheService.RefreshIfStaleAsync();
        var t2 = ReplayService.RefreshSessionIndexAsync();
        await Task.WhenAll(t1, t2);

        _stats = await GamificationService.GetDashboardStatsAsync();
        _loading = false;
    }

    private async Task OnRefreshClick()
    {
        _refreshing = true;
        StateHasChanged();

        await StatsCacheService.ForceRefreshAsync();
        await ReplayService.RefreshSessionIndexAsync(true);
        _stats = await GamificationService.ForceRefreshDashboardAsync();

        _refreshing = false;
        StateHasChanged();
    }

}

<style>
    .dashboard-level-banner {
        background: linear-gradient(135deg, var(--mud-palette-primary-darken) 0%, var(--mud-palette-primary) 100%);
        border-radius: 12px;
        padding: 20px;
        color: white;
        margin-bottom: 16px;
    }

    .dashboard-middle-row {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
        margin-bottom: 16px;
    }

    .dashboard-middle-row > *,
    .dashboard-bottom-row > * {
        min-width: 0;
    }

    .dashboard-config-card {
        border: 1px solid var(--mud-palette-lines-default);
        border-radius: 12px;
        padding: 16px;
    }

    .dashboard-config-title {
        font-size: 0.85rem;
        font-weight: 500;
        color: var(--mud-palette-text-secondary);
        margin-bottom: 12px;
    }

    .dashboard-config-pct {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        font-weight: 700;
    }

    .dashboard-config-items {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4px 12px;
        min-width: 0;
    }

    .dashboard-config-item {
        display: flex;
        align-items: center;
        gap: 4px;
        font-size: 0.7rem;
        color: var(--mud-palette-text-disabled);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .dashboard-config-item.configured {
        color: var(--mud-palette-text-primary);
    }

    .dashboard-bottom-row {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 16px;
    }
</style>
