<MudPaper Class="pa-3" Elevation="3" Style="border-top: 1px solid var(--mud-palette-lines-default);">
    <MudSelect T="string" Value="Model" ValueChanged="HandleModelChanged"
               Variant="Variant.Text" Dense="true" Margin="Margin.Dense"
               Disabled="Disabled || IsStreaming"
               Style="max-width: 240px; margin-bottom: 4px;"
               AnchorOrigin="Origin.TopLeft" TransformOrigin="Origin.BottomLeft">
        @foreach (var model in ModelDefinitions.All)
        {
            <MudSelectItem T="string" Value="@model.Id">@model.DisplayName</MudSelectItem>
        }
    </MudSelect>
    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.End">
        <MudTooltip Text="@(IsPlanMode ? "Plan Mode (read-only)" : "Code Mode")">
            <MudToggleIconButton Toggled="@_planToggled"
                                 ToggledChanged="OnPlanToggled"
                                 Icon="@Icons.Material.Filled.EditNote"
                                 ToggledIcon="@Icons.Material.Filled.Description"
                                 Color="Color.Default"
                                 ToggledColor="Color.Warning"
                                 Size="Size.Medium"
                                 Disabled="Disabled || IsStreaming" />
        </MudTooltip>

        <MudTextField @bind-Value="_inputText"
                      Placeholder="@GetPlaceholder()"
                      Variant="Variant.Outlined"
                      Lines="1"
                      AutoGrow="true"
                      MaxLines="8"
                      Immediate="true"
                      Disabled="Disabled || IsStreaming"
                      OnKeyDown="HandleKeyDown"
                      Class="flex-grow-1" />

        @if (IsStreaming)
        {
            <MudIconButton Icon="@Icons.Material.Filled.Stop"
                           Color="Color.Error"
                           Variant="Variant.Filled"
                           OnClick="@(() => OnCancel.InvokeAsync())"
                           Size="Size.Medium" />
        }
        else
        {
            <MudIconButton Icon="@Icons.Material.Filled.Send"
                           Color="Color.Primary"
                           Variant="Variant.Filled"
                           OnClick="Send"
                           Disabled="Disabled || string.IsNullOrWhiteSpace(_inputText)"
                           Size="Size.Medium" />
        }
    </MudStack>
</MudPaper>

@code {
    [Parameter] public EventCallback<string> OnSend { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public bool IsStreaming { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool IsPlanMode { get; set; }
    [Parameter] public EventCallback<bool> IsPlanModeChanged { get; set; }
    [Parameter] public string Model { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> OnModelChanged { get; set; }

    private string _inputText = string.Empty;
    private bool _planToggled;

    protected override void OnParametersSet()
    {
        _planToggled = IsPlanMode;
    }

    private string GetPlaceholder()
    {
        if (Disabled) return "Select or create a session first...";
        return IsPlanMode ? "Plan mode: Claude will read and research only..." : "Type a message...";
    }

    private async Task OnPlanToggled(bool toggled)
    {
        _planToggled = toggled;
        await IsPlanModeChanged.InvokeAsync(toggled);
    }

    private async Task HandleModelChanged(string value)
    {
        Model = value;
        await OnModelChanged.InvokeAsync(value);
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await Send();
        }
    }

    private async Task Send()
    {
        if (string.IsNullOrWhiteSpace(_inputText) || Disabled)
            return;

        var text = _inputText.Trim();
        _inputText = string.Empty;
        await OnSend.InvokeAsync(text);
    }
}
