@using Cominomi.Shared.Models
@using Cominomi.Shared.Services
@inject IFilePickerService FilePickerService
@inject ISkillRegistry SkillRegistry
@inject IJSRuntime JSRuntime
@implements IAsyncDisposable

<div class="input-area-container" id="input-area">
    <div class="input-area-float">
        @if (_pendingAttachments.Count > 0)
        {
            <div class="attachment-chips">
                @foreach (var attachment in _pendingAttachments)
                {
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                             Icon="@(attachment.IsImage ? Icons.Material.Filled.Image : Icons.Material.Filled.InsertDriveFile)"
                             OnClose="@(() => RemoveAttachment(attachment))"
                             Style="font-size: 0.75rem;">
                        @if (attachment.IsImage && attachment.PreviewDataUrl != null)
                        {
                            <img src="@attachment.PreviewDataUrl" alt="@attachment.FileName"
                                 style="max-height: 28px; max-width: 40px; border-radius: 4px; margin-right: 4px; vertical-align: middle;" />
                        }
                        @TruncateFileName(attachment.FileName)
                    </MudChip>
                }
            </div>
        }

        <MudTextField T="string" Value="@_inputText" ValueChanged="@HandleInputValueChanged"
                      Placeholder="@GetPlaceholder()"
                      Variant="Variant.Text"
                      Lines="1"
                      AutoGrow="true"
                      MaxLines="8"
                      Immediate="true"
                      Disabled="Disabled"
                      ReadOnly="IsStreaming"
                      Class="input-textarea-full"
                      Style="font-size: var(--text-base);" />

        <div class="input-toolbar">
            <div class="input-toolbar-left">
                <MudTooltip Text="@GetPermissionModeTooltip()">
                    <MudIconButton Icon="@GetPermissionModeIcon()"
                                   Color="@GetPermissionModeColor()"
                                   Size="Size.Small"
                                   OnClick="CyclePermissionMode"
                                   Disabled="Disabled || IsStreaming" />
                </MudTooltip>

                <MudTooltip Text="@GetEffortLevelTooltip()">
                    <MudIconButton Icon="@Icons.Material.Filled.Psychology"
                                   Color="@GetEffortLevelColor()"
                                   Size="Size.Small"
                                   OnClick="CycleEffortLevel"
                                   Disabled="Disabled || IsStreaming" />
                </MudTooltip>

                <MudTooltip Text="파일 첨부">
                    <MudIconButton Icon="@Icons.Material.Filled.AttachFile"
                                   Color="Color.Default"
                                   Size="Size.Small"
                                   OnClick="PickFiles"
                                   Disabled="Disabled || IsStreaming" />
                </MudTooltip>
            </div>

            <div class="input-toolbar-right">
                <MudTooltip Text="@(ResolvedModel ?? GetModelDisplayName())">
                    <button class="model-selector-pill" type="button"
                            @onclick="ToggleModelMenu"
                            disabled="@(Disabled || IsStreaming)">
                        <span class="model-selector-label">@GetModelDisplayName()</span>
                        <MudIcon Icon="@Icons.Material.Filled.UnfoldMore" Size="Size.Small" />
                    </button>
                </MudTooltip>

                <MudPopover Open="@_modelMenuOpen" AnchorOrigin="Origin.TopRight"
                            TransformOrigin="Origin.BottomRight" Class="model-popover">
                    <MudList T="string" Dense="true" Class="model-list">
                        @foreach (var model in ModelDefinitions.All)
                        {
                            <MudListItem T="string" OnClick="@(() => SelectModel(model.Id))"
                                         Class="@(Model == model.Id ? "model-item-active" : "")">
                                @model.DisplayName
                            </MudListItem>
                        }
                        <MudDivider />
                        <MudListItem T="string" OnClick="@(() => _customModelInput = true)"
                                     Class="@(_isCustomModel ? "model-item-active" : "")">
                            @if (_customModelInput)
                            {
                                <MudTextField T="string" @bind-Value="_customModelId"
                                              Placeholder="claude-sonnet-4-6..."
                                              Variant="Variant.Text" Margin="Margin.Dense"
                                              Immediate="true" AutoFocus="true"
                                              OnKeyDown="HandleCustomModelKeyDown"
                                              Style="font-size: 0.8rem;" />
                            }
                            else
                            {
                                <span style="opacity: 0.7;">커스텀 모델...</span>
                            }
                        </MudListItem>
                    </MudList>
                </MudPopover>

                @if (_modelMenuOpen)
                {
                    <MudOverlay Visible="true" OnClick="CloseModelMenu"
                                DarkBackground="false" ZIndex="1" />
                }

                @if (IsStreaming)
                {
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Error"
                               Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.Stop"
                               OnClick="@(() => OnCancel.InvokeAsync())"
                               Class="stop-button-glow"
                               Style="border-radius: 20px; text-transform: none; min-width: 72px;">
                        중지
                    </MudButton>
                }
                else
                {
                    <MudIconButton Icon="@Icons.Material.Filled.ArrowUpward"
                                   Color="Color.Primary"
                                   Variant="Variant.Filled"
                                   OnClick="Send"
                                   Disabled="@(Disabled || (string.IsNullOrWhiteSpace(_inputText) && _pendingAttachments.Count == 0))"
                                   Size="Size.Small"
                                   Style="border-radius: 50%;" />
                }
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public EventCallback<ChatInputMessage> OnSend { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public bool IsStreaming { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string PermissionMode { get; set; } = "bypassAll";
    [Parameter] public EventCallback<string> PermissionModeChanged { get; set; }
    [Parameter] public string Model { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> OnModelChanged { get; set; }
    [Parameter] public string? ResolvedModel { get; set; }
    [Parameter] public string EffortLevel { get; set; } = "auto";
    [Parameter] public EventCallback<string> EffortLevelChanged { get; set; }

    private static readonly string[] PermissionModes = ["bypassAll", "plan"];
    private static readonly string[] EffortLevels = ["auto", "max"];

    private string _inputText = string.Empty;
    private List<PendingAttachment> _pendingAttachments = [];
    private DotNetObjectReference<InputArea>? _dotNetRef;
    private bool _handlersRegistered;
    private bool _suppressInputUpdates;
    private bool _modelMenuOpen;
    private bool _customModelInput;
    private string _customModelId = "";
    private bool _isCustomModel => !ModelDefinitions.All.Any(m => m.Id == Model) && !string.IsNullOrEmpty(Model);

    // Parameter tracking to prevent unnecessary re-renders (cursor jumping fix)
    private bool _prevIsStreaming;
    private bool _prevDisabled;
    private string _prevPermissionMode = "bypassAll";
    private string _prevModel = string.Empty;
    private string? _prevResolvedModel;
    private string _prevEffortLevel = "auto";
    private bool _forceRender;
    private bool _isComposing;

    private string GetPermissionModeTooltip() => PermissionMode switch
    {
        "plan" => "플랜 모드 (읽기 전용)",
        _ => "일반 모드 (모든 권한 우회)"
    };

    private string GetPermissionModeIcon() => PermissionMode switch
    {
        "plan" => Icons.Material.Filled.Description,
        _ => Icons.Material.Filled.EditNote
    };

    private Color GetPermissionModeColor() => PermissionMode switch
    {
        "plan" => Color.Warning,
        _ => Color.Default
    };

    private async Task CyclePermissionMode()
    {
        _forceRender = true;
        var idx = Array.IndexOf(PermissionModes, PermissionMode);
        var next = PermissionModes[(idx + 1) % PermissionModes.Length];
        await PermissionModeChanged.InvokeAsync(next);
    }

    private string GetEffortLevelTooltip() => EffortLevel switch
    {
        "max" => "Effort: Max (Thinking)",
        _ => "Effort: Auto"
    };

    private Color GetEffortLevelColor() => EffortLevel switch
    {
        "max" => Color.Secondary,
        _ => Color.Default
    };

    private async Task CycleEffortLevel()
    {
        _forceRender = true;
        var idx = Array.IndexOf(EffortLevels, EffortLevel);
        var next = EffortLevels[(idx + 1) % EffortLevels.Length];
        await EffortLevelChanged.InvokeAsync(next);
    }

    protected override void OnParametersSet()
    {
        if (_prevIsStreaming != IsStreaming ||
            _prevDisabled != Disabled ||
            _prevPermissionMode != PermissionMode ||
            _prevModel != Model ||
            _prevResolvedModel != ResolvedModel ||
            _prevEffortLevel != EffortLevel)
        {
            _prevIsStreaming = IsStreaming;
            _prevDisabled = Disabled;
            _prevPermissionMode = PermissionMode;
            _prevModel = Model;
            _prevResolvedModel = ResolvedModel;
            _prevEffortLevel = EffortLevel;
            _forceRender = true;
        }
    }

    protected override bool ShouldRender()
    {
        if (_forceRender)
        {
            _forceRender = false;
            return true;
        }
        return false;
    }

    private void HandleInputValueChanged(string value)
    {
        if (_suppressInputUpdates) return;
        var wasEmpty = string.IsNullOrWhiteSpace(_inputText);
        _inputText = value;
        var isEmpty = string.IsNullOrWhiteSpace(_inputText);
        if (wasEmpty != isEmpty && !_isComposing)
        {
            _forceRender = true;
            StateHasChanged();
        }
    }

    [JSInvokable]
    public void OnCompositionStart() => _isComposing = true;

    [JSInvokable]
    public void OnCompositionEnd()
    {
        _isComposing = false;
        // Catch up on any deferred render (e.g. send button enable/disable)
        _forceRender = true;
        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JSRuntime.InvokeVoidAsync("registerInputHandlers", "input-area", _dotNetRef);
            _handlersRegistered = true;
        }
    }

    [JSInvokable]
    public async Task OnFilePasted(string fileName, string contentType, byte[] data)
    {
        await AddPendingAttachment(fileName, contentType, data);
    }

    [JSInvokable]
    public async Task OnFileDropped(string fileName, string contentType, byte[] data)
    {
        await AddPendingAttachment(fileName, contentType, data);
    }

    private Task AddPendingAttachment(string fileName, string contentType, byte[] data)
    {
        var attachment = new PendingAttachment
        {
            FileName = fileName,
            ContentType = contentType,
            Data = data
        };

        if (attachment.IsImage)
        {
            attachment.PreviewDataUrl = $"data:{contentType};base64,{Convert.ToBase64String(data)}";
        }

        _pendingAttachments.Add(attachment);
        _forceRender = true;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private async Task PickFiles()
    {
        var files = await FilePickerService.PickFilesAsync();
        if (files == null || files.Count == 0) return;

        _pendingAttachments.AddRange(files);
        _forceRender = true;
        StateHasChanged();
    }

    private void RemoveAttachment(PendingAttachment attachment)
    {
        _pendingAttachments.Remove(attachment);
        _forceRender = true;
    }

    private string GetPlaceholder()
    {
        if (Disabled) return "먼저 세션을 선택하거나 만드세요...";
        if (IsStreaming) return "Claude가 응답 중...";
        return PermissionMode switch
        {
            "plan" => "플랜 모드: Claude가 읽기와 조사만 합니다...",
            "acceptEdits" => "편집 허용 모드: 파일 편집은 허용, 명령 실행은 확인...",
            _ => "메시지를 입력하세요..."
        };
    }

    private string GetModelDisplayName()
    {
        var model = ModelDefinitions.All.FirstOrDefault(m => m.Id == Model);
        return model?.DisplayName ?? Model;
    }

    private void ToggleModelMenu()
    {
        _modelMenuOpen = !_modelMenuOpen;
        _forceRender = true;
        StateHasChanged();
    }

    private void CloseModelMenu()
    {
        _modelMenuOpen = false;
        _customModelInput = false;
        _forceRender = true;
        StateHasChanged();
    }

    private async Task HandleCustomModelKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_customModelId))
        {
            await SelectModel(_customModelId.Trim());
            _customModelInput = false;
            _customModelId = "";
        }
        else if (e.Key == "Escape")
        {
            _customModelInput = false;
            _forceRender = true;
            StateHasChanged();
        }
    }

    private async Task SelectModel(string modelId)
    {
        _modelMenuOpen = false;
        _forceRender = true;
        Model = modelId;
        await OnModelChanged.InvokeAsync(modelId);
    }

    [JSInvokable]
    public async Task SendFromJs()
    {
        await Send();
    }

    [Parameter] public Session? CurrentSession { get; set; }

    private async Task Send()
    {
        _forceRender = true;
        if (Disabled || (string.IsNullOrWhiteSpace(_inputText) && _pendingAttachments.Count == 0))
            return;

        var text = _inputText.Trim();

        // Try to expand slash commands
        var skillName = SkillRegistry.TryParseSkillCommand(text, out var skillArgs);
        if (skillName != null)
        {
            var skill = SkillRegistry.Find(skillName);
            if (skill != null && CurrentSession != null)
            {
                text = SkillRegistry.ExpandSkill(skill, skillArgs, CurrentSession);
            }
        }

        var input = new ChatInputMessage
        {
            Text = text,
            Attachments = new List<PendingAttachment>(_pendingAttachments)
        };

        _suppressInputUpdates = true;   // Block oninput from reinserting newline
        _inputText = string.Empty;
        _pendingAttachments.Clear();
        StateHasChanged();
        await OnSend.InvokeAsync(input);

        // JS safety net: clear textarea DOM directly
        try { await JSRuntime.InvokeVoidAsync("clearInputArea", "input-area"); }
        catch { }

        _suppressInputUpdates = false;  // Unblock
    }

    private static string TruncateFileName(string name)
    {
        return name.Length > 20 ? string.Concat(name.AsSpan(0, 17), "...") : name;
    }

    public async ValueTask DisposeAsync()
    {
        if (_handlersRegistered)
        {
            try { await JSRuntime.InvokeVoidAsync("unregisterInputHandlers", "input-area"); }
            catch { }
        }
        _dotNetRef?.Dispose();
    }
}
