@using Cominomi.Shared.Models
@using Cominomi.Shared.Services
@inject IFilePickerService FilePickerService
@inject ISkillRegistry SkillRegistry
@inject IJSRuntime JSRuntime
@implements IAsyncDisposable

<div class="input-area-container" id="input-area">
    <div class="input-area-float" style="position: relative;">
        <SlashCommandPopup IsOpen="_slashPopupOpen"
                           FilteredCommands="_filteredCommands"
                           SelectedIndex="_slashSelectedIndex"
                           OnCommandSelected="SelectSlashCommand"
                           OnDismiss="DismissSlashPopup"
                           OnHover="@(i => { _slashSelectedIndex = i; StateHasChanged(); })" />

        <AttachmentChips Attachments="_pendingAttachments" OnRemove="RemoveAttachment" />

        <MudTextField T="string" Value="@_inputText" ValueChanged="@HandleInputValueChanged"
                      Placeholder="@GetPlaceholder()"
                      Variant="Variant.Text"
                      Lines="2"
                      AutoGrow="true"
                      MaxLines="8"
                      Immediate="true"
                      Disabled="Disabled"
                      ReadOnly="IsStreaming"
                      Class="input-textarea-full"
                      Style="font-size: var(--text-base);" />

        <InputToolbar PermissionMode="@_currentPermissionMode"
                      OnPermissionModeChanged="HandlePermissionModeChangedLocal"
                      EffortLevel="@_currentEffortLevel"
                      OnEffortLevelChanged="HandleEffortLevelChangedLocal"
                      Model="@_currentModel"
                      OnModelChanged="HandleModelChangedLocal"
                      ResolvedModel="ResolvedModel"
                      IsStreaming="IsStreaming"
                      Disabled="Disabled"
                      HasInput="@(!string.IsNullOrWhiteSpace(_inputText))"
                      HasAttachments="@(_pendingAttachments.Count > 0)"
                      OnSend="Send"
                      OnCancel="@(() => OnCancel.InvokeAsync())"
                      OnPickFiles="PickFiles"
                      OnModelMenuClosed="RefocusTextarea"
                      PlanFilePath="@PlanFilePath"
                      PlanContent="@PlanContent" />
    </div>
</div>

@code {
    [Parameter] public EventCallback<ChatInputMessage> OnSend { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public bool IsStreaming { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string PermissionMode { get; set; } = "bypassAll";
    [Parameter] public EventCallback<string> PermissionModeChanged { get; set; }
    [Parameter] public string Model { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> OnModelChanged { get; set; }
    [Parameter] public string? ResolvedModel { get; set; }
    [Parameter] public string EffortLevel { get; set; } = "auto";
    [Parameter] public EventCallback<string> EffortLevelChanged { get; set; }
    [Parameter] public Session? CurrentSession { get; set; }
    [Parameter] public string? PlanFilePath { get; set; }
    [Parameter] public string? PlanContent { get; set; }
    [Parameter] public bool IsPlanReviewVisible { get; set; }

    private string _inputText = string.Empty;
    private List<PendingAttachment> _pendingAttachments = [];
    private DotNetObjectReference<InputArea>? _dotNetRef;
    private bool _handlersRegistered;
    private bool _suppressInputUpdates;

    // Local copies of toolbar state — updated both from parent parameters AND from
    // user clicks (optimistic update). This decouples toolbar rendering from the
    // parent re-render cycle, preventing ShouldRender from swallowing updates.
    private string _currentPermissionMode = "bypassAll";
    private string _currentEffortLevel = "auto";
    private string _currentModel = string.Empty;

    // Parameter tracking to prevent unnecessary re-renders (cursor jumping fix)
    private bool _prevIsStreaming;
    private bool _prevDisabled;
    private string _prevPermissionMode = "bypassAll";
    private string _prevModel = string.Empty;
    private string? _prevResolvedModel;
    private string _prevEffortLevel = "auto";
    private string? _prevPlanFilePath;
    private string? _prevPlanContent;
    private bool _prevIsPlanReviewVisible;
    private bool _forceRender;
    private bool _isComposing;

    // Slash command autocomplete state
    private bool _slashPopupOpen;
    private IReadOnlyList<SkillDefinition> _filteredCommands = Array.Empty<SkillDefinition>();
    private int _slashSelectedIndex;

    protected override void OnParametersSet()
    {
        // Sync local copies from parent parameters
        if (_prevPermissionMode != PermissionMode)
            _currentPermissionMode = PermissionMode;
        if (_prevModel != Model)
            _currentModel = Model;
        if (_prevEffortLevel != EffortLevel)
            _currentEffortLevel = EffortLevel;

        if (_prevIsStreaming != IsStreaming ||
            _prevDisabled != Disabled ||
            _prevPermissionMode != PermissionMode ||
            _prevModel != Model ||
            _prevResolvedModel != ResolvedModel ||
            _prevEffortLevel != EffortLevel ||
            _prevPlanFilePath != PlanFilePath ||
            _prevPlanContent != PlanContent ||
            _prevIsPlanReviewVisible != IsPlanReviewVisible)
        {
            _prevIsStreaming = IsStreaming;
            _prevDisabled = Disabled;
            _prevPermissionMode = PermissionMode;
            _prevModel = Model;
            _prevResolvedModel = ResolvedModel;
            _prevEffortLevel = EffortLevel;
            _prevPlanFilePath = PlanFilePath;
            _prevPlanContent = PlanContent;
            _prevIsPlanReviewVisible = IsPlanReviewVisible;
            _forceRender = true;
        }
    }

    private async Task RefocusTextarea()
    {
        try { await JSRuntime.InvokeVoidAsync("focusInputArea", "input-area"); }
        catch (JSDisconnectedException) { }
    }

    private async Task HandlePermissionModeChangedLocal(string mode)
    {
        _currentPermissionMode = mode;
        _forceRender = true;
        StateHasChanged();
        await PermissionModeChanged.InvokeAsync(mode);
        await RefocusTextarea();
    }

    private async Task HandleEffortLevelChangedLocal(string level)
    {
        _currentEffortLevel = level;
        _forceRender = true;
        StateHasChanged();
        await EffortLevelChanged.InvokeAsync(level);
        await RefocusTextarea();
    }

    private async Task HandleModelChangedLocal(string model)
    {
        _currentModel = model;
        _forceRender = true;
        StateHasChanged();
        await OnModelChanged.InvokeAsync(model);
        await RefocusTextarea();
    }

    protected override bool ShouldRender()
    {
        if (_forceRender)
        {
            _forceRender = false;
            return true;
        }
        return false;
    }

    private void HandleInputValueChanged(string value)
    {
        if (_suppressInputUpdates) return;
        var wasEmpty = string.IsNullOrWhiteSpace(_inputText);
        _inputText = value;
        var isEmpty = string.IsNullOrWhiteSpace(_inputText);

        UpdateSlashPopupState();

        if (wasEmpty != isEmpty && !_isComposing)
        {
            _forceRender = true;
            StateHasChanged();
        }
    }

    [JSInvokable]
    public void OnCompositionStart() => _isComposing = true;

    [JSInvokable]
    public void OnCompositionEnd()
    {
        _isComposing = false;
        _forceRender = true;
        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JSRuntime.InvokeVoidAsync("registerInputHandlers", "input-area", _dotNetRef);
            _handlersRegistered = true;
        }
    }

    [JSInvokable]
    public void OnFilePasted(string fileName, string contentType, string base64Data)
    {
        AddPendingAttachmentFromBase64(fileName, contentType, base64Data);
    }

    [JSInvokable]
    public void OnFileDropped(string fileName, string contentType, string base64Data)
    {
        AddPendingAttachmentFromBase64(fileName, contentType, base64Data);
    }

    private void AddPendingAttachmentFromBase64(string fileName, string contentType, string base64Data)
    {
        var data = Convert.FromBase64String(base64Data);
        var attachment = new PendingAttachment
        {
            FileName = fileName,
            ContentType = contentType,
            Data = data
        };

        if (attachment.IsImage)
        {
            attachment.PreviewDataUrl = $"data:{contentType};base64,{base64Data}";
        }

        _pendingAttachments.Add(attachment);
        _forceRender = true;
        StateHasChanged();
    }

    private async Task PickFiles()
    {
        var files = await FilePickerService.PickFilesAsync();
        if (files == null || files.Count == 0)
        {
            await RefocusTextarea();
            return;
        }

        _pendingAttachments.AddRange(files);
        _forceRender = true;
        StateHasChanged();
        await RefocusTextarea();
    }

    private async Task RemoveAttachment(PendingAttachment attachment)
    {
        _pendingAttachments.Remove(attachment);
        _forceRender = true;
        await RefocusTextarea();
    }

    private string GetPlaceholder()
    {
        if (Disabled) return "먼저 세션을 선택하거나 만드세요...";
        if (IsStreaming) return "Claude가 응답 중...";
        if (IsPlanReviewVisible) return "플랜에 대한 피드백을 입력하세요...";
        return _currentPermissionMode switch
        {
            "plan" => "플랜 모드: Claude가 읽기와 조사만 합니다...",
            "acceptEdits" => "편집 허용 모드: 파일 편집은 허용, 명령 실행은 확인...",
            _ => "메시지를 입력하세요..."
        };
    }

    [JSInvokable]
    public void OnNewlineInserted(string value)
    {
        _inputText = value;
        _forceRender = true;
        StateHasChanged();
    }

    // --- Slash command autocomplete ---

    private void UpdateSlashPopupState()
    {
        if (_isComposing) return;

        var wasOpen = _slashPopupOpen;

        if (_inputText.StartsWith('/') && !_inputText.Contains(' '))
        {
            var filter = _inputText[1..];
            var all = SkillRegistry.GetAll();
            _filteredCommands = string.IsNullOrEmpty(filter)
                ? all
                : all.Where(s => s.Name.Contains(filter, StringComparison.OrdinalIgnoreCase)).ToList();

            _slashPopupOpen = _filteredCommands.Count > 0;
            _slashSelectedIndex = Math.Clamp(_slashSelectedIndex, 0, Math.Max(0, _filteredCommands.Count - 1));
        }
        else
        {
            _slashPopupOpen = false;
            _filteredCommands = Array.Empty<SkillDefinition>();
            _slashSelectedIndex = 0;
        }

        if (wasOpen != _slashPopupOpen)
        {
            _ = JSRuntime.InvokeVoidAsync("setSlashPopupState", "input-area", _slashPopupOpen);
            _forceRender = true;
            StateHasChanged();
        }
        else if (_slashPopupOpen)
        {
            _forceRender = true;
            StateHasChanged();
        }
    }

    [JSInvokable]
    public void OnSlashArrowDown()
    {
        if (_filteredCommands.Count == 0) return;
        _slashSelectedIndex = (_slashSelectedIndex + 1) % _filteredCommands.Count;
        _forceRender = true;
        StateHasChanged();
    }

    [JSInvokable]
    public void OnSlashArrowUp()
    {
        if (_filteredCommands.Count == 0) return;
        _slashSelectedIndex = (_slashSelectedIndex - 1 + _filteredCommands.Count) % _filteredCommands.Count;
        _forceRender = true;
        StateHasChanged();
    }

    [JSInvokable]
    public async Task OnSlashEnterSelect()
    {
        if (_slashSelectedIndex >= 0 && _slashSelectedIndex < _filteredCommands.Count)
            await SelectSlashCommand(_filteredCommands[_slashSelectedIndex]);
    }

    [JSInvokable]
    public void OnSlashDismiss()
    {
        DismissSlashPopup();
    }

    private void DismissSlashPopup()
    {
        _slashPopupOpen = false;
        _forceRender = true;
        StateHasChanged();
        _ = JSRuntime.InvokeVoidAsync("setSlashPopupState", "input-area", false);
    }

    private async Task SelectSlashCommand(SkillDefinition command)
    {
        _slashPopupOpen = false;
        _slashSelectedIndex = 0;

        var newText = $"/{command.Name} ";
        _inputText = newText;

        _forceRender = true;
        StateHasChanged();

        await JSRuntime.InvokeVoidAsync("setSlashPopupState", "input-area", false);
        await JSRuntime.InvokeVoidAsync("replaceSlashCommand", "input-area", newText);
    }

    [JSInvokable]
    public async Task SendFromJs()
    {
        await Send();
    }

    private async Task Send()
    {
        _forceRender = true;
        if (Disabled || (string.IsNullOrWhiteSpace(_inputText) && _pendingAttachments.Count == 0))
            return;

        var text = _inputText.Trim();
        List<SkillChainStep>? pendingChain = null;

        // Try skill chaining first (pipe syntax or definition chain)
        if (CurrentSession != null && SkillRegistry.TryParseSkillChain(text, CurrentSession, out var chainSteps))
        {
            text = chainSteps[0].ExpandedText;
            pendingChain = chainSteps.Count > 1 ? chainSteps.GetRange(1, chainSteps.Count - 1) : null;
        }
        else
        {
            // Single slash command (no chain)
            var skillName = SkillRegistry.TryParseSkillCommand(text, out var skillArgs);
            if (skillName != null)
            {
                var skill = SkillRegistry.Find(skillName);
                if (skill != null && CurrentSession != null)
                {
                    text = SkillRegistry.ExpandSkill(skill, skillArgs, CurrentSession);
                }
            }
        }

        var input = new ChatInputMessage
        {
            Text = text,
            Attachments = new List<PendingAttachment>(_pendingAttachments),
            PendingChain = pendingChain
        };

        _suppressInputUpdates = true;   // Block oninput from reinserting newline
        _inputText = string.Empty;
        _pendingAttachments.Clear();
        StateHasChanged();
        await OnSend.InvokeAsync(input);

        // JS safety net: clear textarea DOM directly
        try { await JSRuntime.InvokeVoidAsync("clearInputArea", "input-area"); }
        catch (JSDisconnectedException) { /* expected during circuit disposal */ }

        _suppressInputUpdates = false;  // Unblock
    }

    public async ValueTask DisposeAsync()
    {
        if (_handlersRegistered)
        {
            try { await JSRuntime.InvokeVoidAsync("unregisterInputHandlers", "input-area"); }
            catch (JSDisconnectedException) { /* expected during circuit disposal */ }
        }
        _dotNetRef?.Dispose();
    }
}
