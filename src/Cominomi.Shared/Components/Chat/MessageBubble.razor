@using Markdig
@inject IChatState ChatState
@inject LightboxService Lightbox
@inject FilePreviewService FilePreview
@inject IJSRuntime JS

@if (Message.Role == MessageRole.System)
{
    <div class="system-message">
        <div class="system-message-content">
            <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small"
                     Style="width: 14px; height: 14px; opacity: 0.5;"/>
            <span>@Message.Text</span>
            <span class="message-time">@Message.Timestamp.ToLocalTime().ToString("HH:mm")</span>
        </div>
    </div>
    return;
}

<div class="message-bubble @(Message.Role == MessageRole.User ? "user-message" : "assistant-message")">
    <div class="message-layout">
        <div class="message-avatar">
            @if (Message.Role == MessageRole.User)
            {
                <MudAvatar Color="Color.Primary" Variant="Variant.Filled"
                           Style="width: 22px; height: 22px; font-size: 12px; background: rgba(167, 139, 250, 0.2); color: var(--accent);">
                    <MudIcon Icon="@Icons.Material.Filled.Person" Style="width: 13px; height: 13px;"/>
                </MudAvatar>
            }
            else
            {
                <MudAvatar Variant="Variant.Filled"
                           Style="width: 22px; height: 22px; font-size: 12px; background: var(--color-info-bg); color: var(--color-info);">
                    <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Style="width: 13px; height: 13px;"/>
                </MudAvatar>
            }
        </div>
        <div class="message-content">
            <div class="message-header">
                <span class="role-name">@(Message.Role == MessageRole.User ? "나" : "Claude")</span>
                <span class="message-time">@Message.Timestamp.ToLocalTime().ToString("HH:mm")</span>
                @if (Message.Role == MessageRole.Assistant && Message.Duration.HasValue && !HasActivitySummary())
                {
                    <span class="message-duration">@FormatDuration(Message.Duration.Value)</span>
                }
            </div>

            @if (Message.Attachments.Count > 0)
            {
                <div class="stack-column gap-1" style="margin-bottom: 8px;">
                    @foreach (var attachment in Message.Attachments)
                    {
                        @if (attachment.IsImage)
                        {
                            <div style="margin: 4px 0; cursor: pointer;"
                                 @onclick="@(() => Lightbox.Open(GetImageSrc(attachment), attachment.OriginalFileName))">
                                <img src="@GetImageSrc(attachment)"
                                     alt="@attachment.OriginalFileName"
                                     style="max-width: 300px; max-height: 200px; border-radius: 8px; object-fit: contain;"/>
                                <div
                                    style="font-size: 0.7rem; opacity: 0.4; margin-top: 2px;">@attachment.OriginalFileName</div>
                            </div>
                        }
                        else if (IsPreviewableFile(attachment) && attachment.SizeBytes <= 100_000)
                        {
                            var content = GetFileContent(attachment);
                            @if (content != null)
                            {
                                var isExpanded = _expandedFiles.Contains(attachment.Id);
                                <div class="file-attachment-card">
                                    <div class="file-attachment-card-header"
                                         @onclick="@(() => ToggleFileExpand(attachment.Id))">
                                        <MudIcon Icon="@GetAttachmentIcon(attachment)" Size="Size.Small"
                                                 Style="width: 14px; height: 14px; opacity: 0.6; flex-shrink: 0;"/>
                                        <span class="file-attachment-card-name">@attachment.OriginalFileName</span>
                                        <span
                                            class="file-attachment-card-size">@FormatFileSize(attachment.SizeBytes)</span>
                                        <MudIconButton Icon="@Icons.Material.Filled.OpenInNew" Size="Size.Small"
                                                       Style="width: 22px; height: 22px; padding: 0;"
                                                       OnClick="@(() => OpenFilePreviewDialog(attachment, content))"
                                                       title="전체 보기"/>
                                        <MudIcon
                                            Icon="@(isExpanded ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                                            Size="Size.Small"
                                            Style="opacity: 0.4; width: 14px; height: 14px; flex-shrink: 0;"/>
                                    </div>
                                    @if (isExpanded)
                                    {
                                        var viewMode = GetFileViewMode(attachment.OriginalFileName);
                                        <div class="file-attachment-card-body" id="@GetFileBlockId(attachment)">
                                            @if (viewMode == FileViewMode.Markdown)
                                            {
                                                <div class="filecontent-markdown markdown-body">
                                                    @((MarkupString)Markdown.ToHtml(content, _previewPipeline))
                                                </div>
                                            }
                                            else if (viewMode == FileViewMode.Code)
                                            {
                                                <div class="filecontent-code-container">
                                                    <pre class="filecontent-pre"><code
                                                            class="@GetFileLanguageClass(attachment.OriginalFileName)">@content</code></pre>
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="filecontent-body">
                                                    @{
                                                        var lines = content.Split('\n');
                                                        var displayLines = lines.Length > 50 ? lines.Take(50).ToArray() : lines;
                                                    }
                                                    @for (var i = 0; i < displayLines.Length; i++)
                                                    {
                                                        <div class="filecontent-line">
                                                            <span class="filecontent-linenum">@(i + 1)</span>
                                                            <span class="filecontent-text">@displayLines[i]</span>
                                                        </div>
                                                    }
                                                    @if (lines.Length > 50)
                                                    {
                                                        <div
                                                            style="padding: 4px 12px; opacity: 0.4; font-size: 0.7rem;">
                                                            ... @(lines.Length - 50)줄 더
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <MudChip T="string" Icon="@Icons.Material.Filled.InsertDriveFile"
                                         Size="Size.Small" Variant="Variant.Outlined"
                                         OnClick="@(() => OpenFileInTab(attachment))"
                                         Style="font-size: 0.75rem; cursor: pointer;">
                                    @attachment.OriginalFileName @($"({FormatFileSize(attachment.SizeBytes)})")
                                </MudChip>
                            }
                        }
                        else
                        {
                            <MudChip T="string" Icon="@Icons.Material.Filled.InsertDriveFile"
                                     Size="Size.Small" Variant="Variant.Outlined"
                                     OnClick="@(() => OpenFileInTab(attachment))"
                                     Style="font-size: 0.75rem; cursor: pointer;">
                                @attachment.OriginalFileName @($"({FormatFileSize(attachment.SizeBytes)})")
                            </MudChip>
                        }
                    }
                </div>
            }

            @if (Message.Parts.Count > 0)
            {
                var groups = ContentGrouper.Group(Message.Parts, Message.IsStreaming);
                <CascadingValue Value="Message.Parts" Name="MessageParts">

                    @if (Message.IsStreaming)
                    {
                        @* === STREAMING: show live updates === *@
                        var lastToolGroupIndex = groups.FindLastIndex(g => g.Type == ContentGroupType.ToolGroup);

                        @foreach (var (group, idx) in groups.Select((g, i) => (g, i)))
                        {
                            @if (group.Type == ContentGroupType.Thinking)
                            {
                                var thinkingText = group.Parts[0].Text ?? "";

                                <div
                                    class="thinking-block @(_thinkingExpanded.Contains(idx) ? "expanded" : "") streaming"
                                    @onclick="@(() => ToggleThinkingBlock(idx))">
                                    <div class="thinking-header">
                                        <MudIcon Icon="@Icons.Material.Filled.Psychology" Size="Size.Small"
                                                 Style="width: 14px; height: 14px; opacity: 0.6; flex-shrink: 0;"/>
                                        <span
                                            style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap; min-width: 0;">@GetThinkingHeaderText(thinkingText, _thinkingExpanded.Contains(idx))</span>
                                        <MudIcon
                                            Icon="@(_thinkingExpanded.Contains(idx) ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                                            Size="Size.Small"
                                            Style="opacity: 0.4; width: 14px; height: 14px; margin-left: auto; flex-shrink: 0;"/>
                                    </div>
                                    @if (_thinkingExpanded.Contains(idx))
                                    {
                                        <div class="thinking-content">
                                            @((MarkupString)Markdown.ToHtml(thinkingText, _pipeline))
                                        </div>
                                    }
                                </div>
                            }
                            else if (group.Type == ContentGroupType.ToolGroup)
                            {
                                var isLastToolGroup = idx == lastToolGroupIndex;
                                <ToolGroupCard Group="group" IsActive="@isLastToolGroup"/>
                            }
                            else if (group.Type == ContentGroupType.FinalText)
                            {
                                var text = group.Parts[0].Text ?? "";
                                <div class="markdown-body">
                                    @((MarkupString)Markdown.ToHtml(text, _pipeline))
                                </div>
                            }
                            else if (group.Type == ContentGroupType.Text)
                            {
                                var text = group.Parts[0].Text ?? "";
                                @if (group.IsIntermediate)
                                {
                                    <div class="intermediate-text">
                                        @((MarkupString)Markdown.ToHtml(text, _pipeline))
                                    </div>
                                }
                                else
                                {
                                    <div class="markdown-body">
                                        @((MarkupString)Markdown.ToHtml(text, _pipeline))
                                    </div>
                                }
                            }
                        }
                    }
                    else
                    {
                        @* === COMPLETED: collapsed activity summary + final text === *@
                        var activityGroups = groups.Where(g => g.Type != ContentGroupType.FinalText).ToList();
                        var finalText = groups.FirstOrDefault(g => g.Type == ContentGroupType.FinalText);

                        @* Safeguard: if no FinalText exists, promote the last text group *@
                        if (finalText == null)
                        {
                            var lastTextInActivity = activityGroups.LastOrDefault(g => g.Type == ContentGroupType.Text);
                            if (lastTextInActivity != null)
                            {
                                lastTextInActivity.Type = ContentGroupType.FinalText;
                                lastTextInActivity.IsIntermediate = false;
                                activityGroups.Remove(lastTextInActivity);
                                finalText = lastTextInActivity;
                            }
                        }

                        @if (activityGroups.Count > 0 && activityGroups.Any(g => g.Type == ContentGroupType.ToolGroup))
                        {
                            var summaryInfo = ContentGrouper.BuildActivitySummary(activityGroups);
                            <ActivitySummary ActivityGroups="activityGroups"
                                             SummaryInfo="summaryInfo"
                                             Duration="Message.Duration"/>
                        }

                        @if (finalText != null)
                        {
                            var text = finalText.Parts[0].Text ?? "";
                            <div class="markdown-body">
                                @((MarkupString)Markdown.ToHtml(text, _pipeline))
                            </div>
                        }
                    }
                </CascadingValue>
            }
            else
            {
                @* Fallback for old messages without Parts *@
                @if (Message.ToolCalls.Count > 0)
                {
                    @foreach (var tool in Message.ToolCalls)
                    {
                        <ToolCallCard Tool="tool"/>
                    }
                }

                @if (!string.IsNullOrEmpty(Message.Text))
                {
                    <div class="markdown-body">
                        @((MarkupString)Markdown.ToHtml(Message.Text, _pipeline))
                    </div>
                }
            }

            @if (Message.IsStreaming)
            {
                <StreamingIndicator Phase="ChatState.Phase" ActiveToolName="@ChatState.ActiveToolName"
                                    StartedAt="Message.StreamingStartedAt"/>
            }
        </div>
    </div>
</div>

@code {
    [Parameter][EditorRequired] public ChatMessage Message { get; set; } = default!;

    private static readonly MarkdownPipeline _pipeline = new MarkdownPipelineBuilder()
        .UseAdvancedExtensions()
        .UseSoftlineBreakAsHardlineBreak()
        .DisableHtml()
        .Build();

    private static readonly MarkdownPipeline _previewPipeline = new MarkdownPipelineBuilder()
        .UseAdvancedExtensions()
        .Build();

    private enum FileViewMode
    {
        Code,
        Markdown,
        PlainText
    }

    private readonly Dictionary<string, string> _imageCache = new();
    private readonly Dictionary<string, string?> _fileContentCache = new();
    private readonly HashSet<string> _expandedFiles = [];
    private readonly HashSet<int> _thinkingExpanded = [];
    private int _lastThinkingGroupCount;
    private bool _needsFileHighlight;

    private bool _fileExpandInitialized;

    protected override void OnParametersSet()
    {
        // Auto-expand previewable file attachments on first render
        if (!_fileExpandInitialized && Message.Attachments.Count > 0)
        {
            _fileExpandInitialized = true;
            foreach (var att in Message.Attachments)
            {
                if (!att.IsImage && IsPreviewableFile(att) && att.SizeBytes <= 100_000)
                    _expandedFiles.Add(att.Id);
            }

            if (_expandedFiles.Count > 0)
                _needsFileHighlight = true;
        }

        if (!Message.IsStreaming) return;

        var groups = ContentGrouper.Group(Message.Parts, true);
        var thinkingCount = groups.Count(g => g.Type == ContentGroupType.Thinking);

        if (thinkingCount > _lastThinkingGroupCount)
        {
            _thinkingExpanded.Clear();
            _lastThinkingGroupCount = thinkingCount;
        }
    }

    private bool HasActivitySummary()
    {
        if (Message.IsStreaming || Message.Parts.Count == 0) return false;
        var groups = ContentGrouper.Group(Message.Parts, false);
        return groups.Any(g => g.Type == ContentGroupType.ToolGroup);
    }

    private void ToggleThinkingBlock(int index)
    {
        if (!_thinkingExpanded.Remove(index))
            _thinkingExpanded.Add(index);
    }


    private static string GetThinkingHeaderText(string thinkingText, bool isExpanded)
    {
        if (isExpanded || string.IsNullOrWhiteSpace(thinkingText))
            return "생각 중...";

        var preview = thinkingText.Trim().ReplaceLineEndings(" ");
        return preview.Length <= 80 ? preview : preview[..80] + "...";
    }

    private static string FormatDuration(TimeSpan duration)
    {
        if (duration.TotalSeconds < 60)
            return $"{(int)duration.TotalSeconds}초";
        return $"{(int)duration.TotalMinutes}분 {duration.Seconds}초";
    }

    private static readonly HashSet<string> TextContentTypes = new(StringComparer.OrdinalIgnoreCase)
    {
        "text/plain", "text/markdown", "text/csv", "text/html", "text/css",
        "application/json", "application/xml", "application/javascript",
        "application/x-yaml", "text/yaml", "text/x-log"
    };

    private void OpenFileInTab(FileAttachment attachment)
    {
        if (attachment.IsImage)
        {
            Lightbox.Open(GetImageSrc(attachment), attachment.OriginalFileName);
            return;
        }

        // Only open text-based files in tab
        if (!TextContentTypes.Contains(attachment.ContentType)
            && !attachment.OriginalFileName.EndsWith(".md", StringComparison.OrdinalIgnoreCase)
            && !attachment.OriginalFileName.EndsWith(".txt", StringComparison.OrdinalIgnoreCase)
            && !attachment.OriginalFileName.EndsWith(".json", StringComparison.OrdinalIgnoreCase)
            && !attachment.OriginalFileName.EndsWith(".csv", StringComparison.OrdinalIgnoreCase)
            && !attachment.OriginalFileName.EndsWith(".log", StringComparison.OrdinalIgnoreCase))
            return;

        var worktreePath = ChatState.CurrentSession?.Git.WorktreePath;
        if (string.IsNullOrEmpty(worktreePath)) return;

        var filePath = Path.Combine(worktreePath, ".cominomi-attachments", attachment.StoredFileName);
        if (!File.Exists(filePath)) return;

        var content = File.ReadAllText(filePath);
        ChatState.Tabs.OpenFileContentTab(filePath, content);
    }

    private string GetImageSrc(FileAttachment attachment)
    {
        if (_imageCache.TryGetValue(attachment.Id, out var cached))
            return cached;

        var worktreePath = ChatState.CurrentSession?.Git.WorktreePath;
        if (string.IsNullOrEmpty(worktreePath))
            return string.Empty;

        var filePath = Path.Combine(worktreePath, ".cominomi-attachments", attachment.StoredFileName);
        if (!File.Exists(filePath))
            return string.Empty;

        var bytes = File.ReadAllBytes(filePath);
        var dataUrl = $"data:{attachment.ContentType};base64,{Convert.ToBase64String(bytes)}";
        _imageCache[attachment.Id] = dataUrl;
        return dataUrl;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_needsFileHighlight)
        {
            _needsFileHighlight = false;
            foreach (var attachment in Message.Attachments)
            {
                if (!attachment.IsImage && IsPreviewableFile(attachment)
                                        && _expandedFiles.Contains(attachment.Id)
                                        && GetFileViewMode(attachment.OriginalFileName) == FileViewMode.Code)
                {
                    try
                    {
                        await JS.InvokeVoidAsync("highlightCodeBlock", GetFileBlockId(attachment));
                    }
                    catch
                    {
                    }
                }
            }
        }
    }

    private static bool IsPreviewableFile(FileAttachment attachment)
    {
        var ext = Path.GetExtension(attachment.OriginalFileName).ToLowerInvariant();
        return ext is ".md" or ".mdx" or ".txt" or ".log" or ".csv"
            or ".json" or ".yaml" or ".yml" or ".xml" or ".toml" or ".ini" or ".cfg"
            or ".cs" or ".js" or ".jsx" or ".ts" or ".tsx" or ".py" or ".rs" or ".go"
            or ".java" or ".html" or ".razor" or ".css" or ".scss" or ".sql"
            or ".sh" or ".bash" or ".zsh" or ".ps1" or ".dockerfile"
            or ".rb" or ".swift" or ".kt" or ".dart" or ".php"
            or ".c" or ".cpp" or ".h" or ".hpp" or ".vue" or ".svelte"
            or ".lua" or ".pl" or ".r" or ".graphql" or ".proto"
            or ".csproj" or ".sln" or ".makefile" or ".gradle";
    }

    private string? GetFileContent(FileAttachment attachment)
    {
        if (_fileContentCache.TryGetValue(attachment.Id, out var cached))
            return cached;

        var worktreePath = ChatState.CurrentSession?.Git.WorktreePath;
        if (string.IsNullOrEmpty(worktreePath))
            return null;

        var filePath = Path.Combine(worktreePath, ".cominomi-attachments", attachment.StoredFileName);
        if (!File.Exists(filePath))
            return null;

        try
        {
            var content = File.ReadAllText(filePath);
            _fileContentCache[attachment.Id] = content;
            return content;
        }
        catch
        {
            _fileContentCache[attachment.Id] = null;
            return null;
        }
    }

    private void ToggleFileExpand(string attachmentId)
    {
        if (!_expandedFiles.Remove(attachmentId))
        {
            _expandedFiles.Add(attachmentId);
            _needsFileHighlight = true;
        }
    }

    private void OpenFilePreviewDialog(FileAttachment attachment, string content)
    {
        FilePreview.Open(attachment.OriginalFileName, content);
    }

    private static string GetFileBlockId(FileAttachment attachment)
    {
        return $"fa-hljs-{attachment.Id[..8]}";
    }

    private static string GetAttachmentIcon(FileAttachment attachment)
    {
        var ext = Path.GetExtension(attachment.OriginalFileName).ToLowerInvariant();
        return ext switch
        {
            ".md" or ".mdx" => Icons.Material.Filled.Description,
            ".json" or ".yaml" or ".yml" or ".xml" or ".toml" or ".ini" or ".cfg"
                => Icons.Material.Filled.DataObject,
            ".cs" or ".js" or ".ts" or ".py" or ".rs" or ".go" or ".java" or ".html"
                or ".css" or ".sql" or ".sh" or ".bash" or ".ps1"
                => Icons.Material.Filled.Code,
            _ => Icons.Material.Filled.InsertDriveFile
        };
    }

    private static FileViewMode GetFileViewMode(string fileName)
    {
        var ext = Path.GetExtension(fileName).ToLowerInvariant();
        return ext switch
        {
            ".md" or ".mdx" => FileViewMode.Markdown,
            ".cs" or ".js" or ".jsx" or ".ts" or ".tsx" or ".py" or ".rs" or ".go"
                or ".java" or ".html" or ".razor" or ".css" or ".scss" or ".json"
                or ".yaml" or ".yml" or ".xml" or ".csproj" or ".sln" or ".rb"
                or ".swift" or ".kt" or ".dart" or ".php" or ".sql" or ".sh"
                or ".bash" or ".zsh" or ".ps1" or ".dockerfile" or ".toml"
                or ".ini" or ".cfg" or ".vue" or ".svelte" or ".c" or ".cpp"
                or ".h" or ".hpp" or ".m" or ".mm" or ".r" or ".lua" or ".pl"
                or ".makefile" or ".gradle" or ".graphql" or ".proto"
                => FileViewMode.Code,
            _ => FileViewMode.PlainText
        };
    }

    private static string GetFileLanguageClass(string fileName)
    {
        var ext = Path.GetExtension(fileName).ToLowerInvariant();
        return ext switch
        {
            ".cs" => "language-csharp",
            ".js" or ".jsx" => "language-javascript",
            ".ts" or ".tsx" => "language-typescript",
            ".py" => "language-python",
            ".rs" => "language-rust",
            ".go" => "language-go",
            ".java" => "language-java",
            ".html" or ".razor" => "language-xml",
            ".css" or ".scss" => "language-css",
            ".json" => "language-json",
            ".yaml" or ".yml" => "language-yaml",
            ".xml" or ".csproj" or ".sln" => "language-xml",
            ".sh" or ".bash" or ".zsh" => "language-bash",
            ".sql" => "language-sql",
            ".rb" => "language-ruby",
            ".swift" => "language-swift",
            ".kt" => "language-kotlin",
            ".dart" => "language-dart",
            ".php" => "language-php",
            ".dockerfile" => "language-dockerfile",
            ".toml" or ".ini" or ".cfg" => "language-ini",
            ".c" or ".cpp" or ".h" or ".hpp" => "language-cpp",
            ".m" or ".mm" => "language-objectivec",
            ".r" => "language-r",
            ".lua" => "language-lua",
            ".pl" => "language-perl",
            ".makefile" => "language-makefile",
            ".graphql" => "language-graphql",
            ".proto" => "language-protobuf",
            _ => ""
        };
    }

    private static string FormatFileSize(long sizeBytes)
    {
        if (sizeBytes >= 1024 * 1024)
            return $"{sizeBytes / (1024.0 * 1024.0):F1} MB";
        if (sizeBytes >= 1024)
            return $"{sizeBytes / 1024.0:F1} KB";
        return $"{sizeBytes} B";
    }

}
