@using Cominomi.Shared.Services
@implements IDisposable

@switch (Phase)
{
    case StreamingPhase.Preparing:
        <div class="streaming-pill">
            <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Default"
                                 Style="width: 14px; height: 14px;" />
            <span style="font-size: 0.78rem; opacity: 0.7;">준비 중...</span>
        </div>
        break;

    case StreamingPhase.Sending:
        <div class="streaming-pill">
            <span class="pulse-dot"></span>
            <span style="font-size: 0.78rem; opacity: 0.7;">전송 중...</span>
            @if (!string.IsNullOrEmpty(_elapsed))
            {
                <span class="streaming-elapsed">@_elapsed</span>
            }
        </div>
        break;

    case StreamingPhase.Thinking:
        <div class="streaming-pill thinking">
            <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Primary"
                                 Style="width: 14px; height: 14px;" />
            <span style="font-size: 0.78rem; opacity: 0.7;">생각 중...</span>
            @if (!string.IsNullOrEmpty(_elapsed))
            {
                <span class="streaming-elapsed">@_elapsed</span>
            }
        </div>
        break;

    case StreamingPhase.UsingTool:
        <div class="streaming-pill using-tool">
            <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Warning"
                                 Style="width: 14px; height: 14px;" />
            <MudIcon Icon="@ToolDisplayHelper.GetToolIcon(ActiveToolName)" Size="Size.Small" Style="opacity: 0.7; width: 16px; height: 16px;" />
            <span class="tool-badge">@ToolDisplayHelper.GetStreamingLabel(ActiveToolName)</span>
            @if (!string.IsNullOrEmpty(_elapsed))
            {
                <span class="streaming-elapsed">@_elapsed</span>
            }
        </div>
        break;

    case StreamingPhase.WritingText:
        <div class="streaming-pill" style="background: rgba(166, 227, 161, 0.06); border-color: rgba(166, 227, 161, 0.1);">
            <span class="typing-dots">
                <span></span><span></span><span></span>
            </span>
            @if (!string.IsNullOrEmpty(_elapsed))
            {
                <span class="streaming-elapsed">@_elapsed</span>
            }
        </div>
        break;

    default:
        break;
}

@code {
    [Parameter] public StreamingPhase Phase { get; set; }
    [Parameter] public string? ActiveToolName { get; set; }
    [Parameter] public DateTime? StartedAt { get; set; }

    private Timer? _timer;
    private string _elapsed = "";

    protected override void OnInitialized()
    {
        _timer = new Timer(_ =>
        {
            if (StartedAt.HasValue)
            {
                var elapsed = DateTime.UtcNow - StartedAt.Value;
                var newElapsed = elapsed.TotalSeconds < 60
                    ? $"{(int)elapsed.TotalSeconds}초"
                    : $"{(int)elapsed.TotalMinutes}분 {elapsed.Seconds}초";
                if (newElapsed != _elapsed)
                {
                    _elapsed = newElapsed;
                    InvokeAsync(StateHasChanged);
                }
            }
        }, null, 1000, 1000);
    }

    public void Dispose()
    {
        _timer?.Dispose();
        _timer = null;
    }
}
