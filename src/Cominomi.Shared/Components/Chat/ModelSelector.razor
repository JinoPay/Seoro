@inject IChatState ChatState
@implements IDisposable

<MudTooltip Text="@GetTooltip()">
    <button class="model-selector-pill" type="button"
            @onclick="ToggleModelMenu"
            disabled="@(Disabled || IsStreaming)">
        <span class="model-selector-label">@GetModelDisplayName()</span>
        <MudIcon Icon="@Icons.Material.Filled.UnfoldMore" Size="Size.Small"/>
    </button>
</MudTooltip>

<MudPopover Open="@_modelMenuOpen" AnchorOrigin="Origin.TopRight"
            TransformOrigin="Origin.BottomRight" Class="model-popover">
    <MudList T="string" Dense="true" Class="model-list">
        @foreach (var model in ModelDefinitions.All)
        {
            <MudListItem T="string" OnClick="@(() => SelectModel(model.Id))"
                         Class="@(IsModelActive(model.Id) ? "model-item-active" : "")">
                @model.DisplayName
            </MudListItem>
        }
        <MudDivider/>
        <MudListItem T="string" OnClick="@(() => _customModelInput = true)"
                     Class="@(_isCustomModel ? "model-item-active" : "")">
            @if (_customModelInput)
            {
                <MudTextField T="string" @bind-Value="_customModelId"
                              Placeholder="claude-sonnet-4-6..."
                              Variant="Variant.Text" Margin="Margin.Dense"
                              Immediate="true" AutoFocus="true"
                              OnKeyDown="HandleCustomModelKeyDown"
                              Style="font-size: 0.8rem;"/>
            }
            else
            {
                <span style="opacity: 0.7;">커스텀 모델...</span>
            }
        </MudListItem>
    </MudList>
</MudPopover>

@if (_modelMenuOpen)
{
    <MudOverlay Visible="true" OnClick="CloseModelMenu"
                DarkBackground="false" ZIndex="1"/>
}

@code {
    [Parameter] public string Model { get; set; } = string.Empty;
    [Parameter] public string? ResolvedModel { get; set; }
    [Parameter] public EventCallback<string> OnModelChanged { get; set; }
    [Parameter] public EventCallback OnMenuClosed { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool IsStreaming { get; set; }

    private bool _modelMenuOpen;
    private bool _customModelInput;

    private string _customModelId = "";

    // Optimistic model — set only during user selection, before parent confirms.
    // Cleared as soon as parent delivers the matching Model parameter.
    private string? _pendingModel;

    private string EffectiveModel => _pendingModel ?? ChatState.CurrentSession?.Model ?? Model;

    private bool _isCustomModel => !string.IsNullOrEmpty(EffectiveModel)
                                   && !ModelDefinitions.All.Any(m => m.Id == EffectiveModel)
                                   && ModelDefinitions.NormalizeModelId(EffectiveModel) == EffectiveModel;

    protected override void OnInitialized()
    {
        ChatState.OnChange += SyncFromState;
    }

    protected override void OnParametersSet()
    {
        // Parent confirmed the pending selection (or sent a new model via session switch)
        _pendingModel = null;
    }

    private void SyncFromState()
    {
        InvokeAsync(() =>
        {
            var sessionModel = ChatState.CurrentSession?.Model ?? string.Empty;
            if (EffectiveModel != sessionModel)
            {
                // Parameter chain hasn't delivered the new model yet — force re-render.
                // EffectiveModel will resolve via Model parameter or next OnParametersSet.
                _pendingModel = null;
                StateHasChanged();
            }
        });
    }

    public void Dispose()
    {
        ChatState.OnChange -= SyncFromState;
    }

    private string GetModelDisplayName()
    {
        if (string.IsNullOrEmpty(EffectiveModel))
            return ModelDefinitions.Default.DisplayName;

        var model = ModelDefinitions.All.FirstOrDefault(m => m.Id == EffectiveModel);
        if (model != null) return model.DisplayName;

        // Try keyword normalization for non-standard IDs (e.g. "claude-opus-4-6-...")
        var normalized = ModelDefinitions.NormalizeModelId(EffectiveModel);
        var normalizedModel = ModelDefinitions.All.FirstOrDefault(m => m.Id == normalized);
        if (normalizedModel != null) return normalizedModel.DisplayName;

        // Custom model IDs that look like API model IDs (e.g. "claude-...") — show as-is
        if (EffectiveModel.StartsWith("claude-", StringComparison.OrdinalIgnoreCase))
            return EffectiveModel;

        // Unknown short strings (e.g. "Model") — fall back to default display name
        return ModelDefinitions.Default.DisplayName;
    }

    private string GetTooltip()
    {
        var displayName = GetModelDisplayName();
        if (!string.IsNullOrEmpty(ResolvedModel) && ResolvedModel != EffectiveModel)
            return $"{displayName} ({ResolvedModel})";
        return displayName;
    }

    private bool IsModelActive(string modelId)
    {
        if (EffectiveModel == modelId) return true;
        // Handle non-standard IDs — normalize and compare
        if (!string.IsNullOrEmpty(EffectiveModel) && ModelDefinitions.NormalizeModelId(EffectiveModel) == modelId)
            return true;
        return false;
    }

    private void ToggleModelMenu()
    {
        _modelMenuOpen = !_modelMenuOpen;
    }

    private async Task CloseModelMenu()
    {
        _modelMenuOpen = false;
        _customModelInput = false;
        await OnMenuClosed.InvokeAsync();
    }

    private async Task HandleCustomModelKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_customModelId))
        {
            await SelectModel(_customModelId.Trim());
            _customModelInput = false;
            _customModelId = "";
        }
        else if (e.Key == "Escape")
        {
            _customModelInput = false;
        }
    }

    private async Task SelectModel(string modelId)
    {
        _modelMenuOpen = false;
        _pendingModel = modelId;
        await OnModelChanged.InvokeAsync(modelId);
        await OnMenuClosed.InvokeAsync();
    }

}
