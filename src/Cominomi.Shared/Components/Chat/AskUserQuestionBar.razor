@using System.Text.Json

@if (IsVisible && _questions.Count > 0)
{
    <div class="askbar-panel">
        @* Header *@
        <div class="askbar-header">
            <div class="askbar-header-left">
                <div class="askbar-icon-badge">
                    <MudIcon Icon="@Icons.Material.Filled.QuestionAnswer" Size="Size.Small"
                             Style="width: 18px; height: 18px;" />
                </div>
                <span class="askbar-title">응답 필요</span>
                @if (_questions.Count > 1)
                {
                    <span class="askbar-progress">@(_currentPage + 1) / @_questions.Count</span>
                }
            </div>
        </div>

        @* Current question (paginated for 2+) *@
        @{
            var q = _questions[_currentPage];
            var selectedForThis = _selections[_currentPage];
        }

        <div class="askbar-body">
            @if (!string.IsNullOrEmpty(q.Header))
            {
                <div class="askbar-question-header">@q.Header</div>
            }
            <div class="askbar-question-text">@q.Question</div>

            @{
                var customActive = !string.IsNullOrWhiteSpace(_customTexts[_currentPage]);
                var anyOptionSelected = selectedForThis != null;
            }

            <div class="askbar-options">
                @foreach (var opt in q.Options)
                {
                    var isSelected = selectedForThis == opt.Label;
                    var isOther = (anyOptionSelected && !isSelected) || customActive;

                    <button class="askbar-option @(isSelected ? "selected" : "") @(isOther ? "dimmed" : "")"
                            @onclick="@(() => SelectOption(_currentPage, opt.Label))"
                            @onclick:stopPropagation="true">
                        <span class="askbar-option-label">
                            @if (isSelected)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small"
                                         Style="width: 14px; height: 14px; color: var(--accent);" />
                            }
                            @opt.Label
                        </span>
                        @if (!string.IsNullOrEmpty(opt.Description))
                        {
                            <span class="askbar-option-desc">@opt.Description</span>
                        }
                    </button>
                }

                <div class="askbar-option askbar-custom-option @(customActive ? "selected" : "") @(anyOptionSelected ? "dimmed" : "")">
                    <MudTextField Value="@_customTexts[_currentPage]"
                                  ValueChanged="@((string v) => OnCustomTextChanged(_currentPage, v))"
                                  Placeholder="의견을 직접 입력하세요..."
                                  Variant="Variant.Text"
                                  Lines="1"
                                  Immediate="true"
                                  Underline="false"
                                  Class="askbar-inline-textfield"
                                  OnKeyDown="HandleInputKeyDown" />
                </div>
            </div>
        </div>

        @* Navigation / Submit *@
        <div class="askbar-actions">
            @if (!IsFirstPage)
            {
                <MudButton Size="Size.Small" Variant="Variant.Text"
                           StartIcon="@Icons.Material.Filled.ArrowBack"
                           OnClick="GoPrevious"
                           Class="askbar-nav-btn">
                    이전
                </MudButton>
            }
            <div class="askbar-actions-spacer"></div>
            @if (IsLastPage)
            {
                <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Send"
                           Disabled="@(!CanSubmit || _submitted)"
                           OnClick="Submit"
                           Class="askbar-submit-btn">
                    응답 보내기
                </MudButton>
            }
            else
            {
                <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary"
                           EndIcon="@Icons.Material.Filled.ArrowForward"
                           Disabled="@(!CurrentAnswered)"
                           OnClick="GoNext"
                           Class="askbar-submit-btn">
                    다음
                </MudButton>
            }
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public string? QuestionInput { get; set; }
    [Parameter] public EventCallback<string> OnResponse { get; set; }

    private record AskOption(string Label, string? Description);
    private record AskQuestion(string? Header, string Question, List<AskOption> Options);

    private List<AskQuestion> _questions = [];
    private string?[] _selections = [];
    private string[] _customTexts = [];
    private bool _submitted;
    private string? _lastInput;
    private int _currentPage;

    private bool IsQuestionAnswered(int i) =>
        _selections[i] != null || !string.IsNullOrWhiteSpace(_customTexts[i]);
    private bool AllAnswered => _selections.Length > 0 && Enumerable.Range(0, _selections.Length).All(IsQuestionAnswered);
    private bool CurrentAnswered => _selections.Length > 0 && IsQuestionAnswered(_currentPage);
    private bool CanSubmit => AllAnswered;
    private bool IsFirstPage => _currentPage == 0;
    private bool IsLastPage => _currentPage >= _questions.Count - 1;

    protected override void OnParametersSet()
    {
        if (ReferenceEquals(_lastInput, QuestionInput))
            return;

        _lastInput = QuestionInput;
        _questions = ParseQuestions(QuestionInput);
        _selections = new string?[_questions.Count];
        _customTexts = new string[_questions.Count];
        Array.Fill(_customTexts, "");
        _submitted = false;
        _currentPage = 0;
    }

    private void GoNext()
    {
        if (_currentPage < _questions.Count - 1 && CurrentAnswered)
            _currentPage++;
    }

    private void GoPrevious()
    {
        if (_currentPage > 0)
            _currentPage--;
    }

    private void SelectOption(int questionIndex, string label)
    {
        if (_submitted) return;

        // Toggle: clicking the same option deselects it
        _selections[questionIndex] = _selections[questionIndex] == label ? null : label;

        // Mutual exclusion: clear custom text for THIS question only
        if (_selections[questionIndex] != null)
            _customTexts[questionIndex] = "";
    }

    private async Task Submit()
    {
        if (!CanSubmit || _submitted) return;
        _submitted = true;

        if (OnResponse.HasDelegate)
        {
            string GetAnswer(int i) =>
                !string.IsNullOrWhiteSpace(_customTexts[i]) ? _customTexts[i].Trim() : _selections[i]!;

            var response = _questions.Count == 1
                ? GetAnswer(0)
                : string.Join("\n", _questions.Select((q, i) =>
                    $"{q.Header ?? q.Question}: {GetAnswer(i)}"));

            await OnResponse.InvokeAsync(response);
        }
    }

    private void OnCustomTextChanged(int questionIndex, string value)
    {
        _customTexts[questionIndex] = value;

        // Mutual exclusion: clear selection for THIS question only
        if (!string.IsNullOrWhiteSpace(value))
            _selections[questionIndex] = null;
    }

    private async Task HandleInputKeyDown(KeyboardEventArgs e)
    {
        if (e.Key != "Enter" || e.ShiftKey || _submitted) return;

        if (IsLastPage && CanSubmit)
            await Submit();
        else if (!IsLastPage && CurrentAnswered)
            GoNext();
    }

    private static List<AskQuestion> ParseQuestions(string? input)
    {
        if (string.IsNullOrEmpty(input))
            return [];

        try
        {
            using var doc = JsonDocument.Parse(input);
            var root = doc.RootElement;

            if (!root.TryGetProperty("questions", out var questionsArr) ||
                questionsArr.ValueKind != JsonValueKind.Array)
                return [];

            var result = new List<AskQuestion>();
            foreach (var q in questionsArr.EnumerateArray())
            {
                var question = q.TryGetProperty("question", out var qProp) ? qProp.GetString() ?? "" : "";
                var header = q.TryGetProperty("header", out var hProp) ? hProp.GetString() : null;

                var options = new List<AskOption>();
                if (q.TryGetProperty("options", out var optsArr) && optsArr.ValueKind == JsonValueKind.Array)
                {
                    foreach (var opt in optsArr.EnumerateArray())
                    {
                        var label = opt.TryGetProperty("label", out var lProp) ? lProp.GetString() ?? "" : "";
                        var desc = opt.TryGetProperty("description", out var dProp) ? dProp.GetString() : null;
                        if (!string.IsNullOrEmpty(label))
                            options.Add(new AskOption(label, desc));
                    }
                }

                if (!string.IsNullOrEmpty(question) || options.Count > 0)
                    result.Add(new AskQuestion(header, question, options));
            }

            return result;
        }
        catch (JsonException)
        {
            return [];
        }
    }
}
