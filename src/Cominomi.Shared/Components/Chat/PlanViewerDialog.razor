@using Markdig

<MudDialog Visible="IsOpen" VisibleChanged="OnVisibleChanged" Options="_dialogOptions">
    <TitleContent>
        <div style="display: flex; align-items: center; gap: 8px;">
            <MudIcon Icon="@Icons.Material.Filled.Map" Size="Size.Small" />
            <span class="typo-h6">플랜 파일</span>
            @if (!string.IsNullOrEmpty(PlanFilePath))
            {
                <span style="font-size: 12px; opacity: 0.5; font-family: var(--font-mono);">
                    @System.IO.Path.GetFileName(PlanFilePath)
                </span>
            }
        </div>
    </TitleContent>
    <DialogContent>
        <div style="max-height: 70vh; overflow-y: auto;">
            @if (!string.IsNullOrEmpty(PlanContent))
            {
                <div class="markdown-body">
                    @((MarkupString)Markdown.ToHtml(PlanContent, _pipeline))
                </div>
            }
            else
            {
                <div style="opacity: 0.5; padding: 16px;">플랜 내용이 없습니다.</div>
            }
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => OnVisibleChanged.InvokeAsync(false))">닫기</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback<bool> OnVisibleChanged { get; set; }
    [Parameter] public string? PlanContent { get; set; }
    [Parameter] public string? PlanFilePath { get; set; }

    private static readonly MarkdownPipeline _pipeline = new MarkdownPipelineBuilder()
        .UseAdvancedExtensions()
        .Build();

    private readonly DialogOptions _dialogOptions = new()
    {
        MaxWidth = MaxWidth.Medium,
        FullWidth = true,
        CloseOnEscapeKey = true,
        BackdropClick = true,
    };
}
