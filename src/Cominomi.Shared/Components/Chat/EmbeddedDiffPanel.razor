@using Cominomi.Shared.Models
@inject IChatState ChatState
@implements IDisposable

<div class="embedded-diff-panel">
    <div class="embedded-diff-toolbar">
        <div class="embedded-diff-tabs">
            <span class="embedded-diff-tab @(_activeTab == DiffPanelTab.Explorer ? "active" : "")"
                  @onclick="@(() => _activeTab = DiffPanelTab.Explorer)">
                Explorer
            </span>
            <span class="embedded-diff-tab @(_activeTab == DiffPanelTab.Changes ? "active" : "")"
                  @onclick="@(() => _activeTab = DiffPanelTab.Changes)">
                Changes
            </span>
        </div>
    </div>

    <div class="embedded-diff-content">
        <div style="@(_activeTab == DiffPanelTab.Explorer
            ? "flex:1;min-height:0;display:flex;flex-direction:column"
            : "display:none;height:0;overflow:hidden")">
            <SidebarExplorer />
        </div>

        <div style="@(_activeTab == DiffPanelTab.Changes
            ? "flex:1;min-height:0;display:flex;flex-direction:column"
            : "display:none;height:0;overflow:hidden")">
            <div class="embedded-diff-file-list">
                <SidebarChanges OnFileSelected="HandleFileSelected"
                                SelectedFilePath="@_selectedFile?.FilePath"
                                OnChangesDetected="HandleChangesDetected" />
            </div>

            @if (_selectedFile != null)
            {
                <div class="embedded-diff-viewer">
                    <FileDiffView Diff="_selectedFile" />
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public EventCallback OnLinkIssueRequested { get; set; }
    [Parameter] public EventCallback<ChatInputMessage> OnSendMessage { get; set; }

    private DiffPanelTab _activeTab = DiffPanelTab.Explorer;
    private FileDiff? _selectedFile;
    private string? _lastSessionId;
    private bool _hasAutoSwitched;

    protected override void OnInitialized()
    {
        _lastSessionId = ChatState.CurrentSession?.Id;
        ChatState.OnChange += HandleStateChanged;
    }

    private void HandleFileSelected(FileDiff file)
    {
        _selectedFile = _selectedFile?.FilePath == file.FilePath ? null : file;
        StateHasChanged();
    }

    private void HandleStateChanged()
    {
        _ = InvokeAsync(() =>
        {
            var sessionId = ChatState.CurrentSession?.Id;
            if (sessionId != _lastSessionId)
            {
                _lastSessionId = sessionId;
                _selectedFile = null;
                _hasAutoSwitched = false;
                _activeTab = DiffPanelTab.Explorer;
            }
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        ChatState.OnChange -= HandleStateChanged;
    }

    private void HandleChangesDetected()
    {
        if (_activeTab != DiffPanelTab.Changes && !_hasAutoSwitched)
        {
            _hasAutoSwitched = true;
            _activeTab = DiffPanelTab.Changes;
            StateHasChanged();
        }
    }

    private enum DiffPanelTab { Changes, Explorer }
}
