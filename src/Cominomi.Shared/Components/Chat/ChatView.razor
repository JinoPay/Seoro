@using Cominomi.Shared.Models
@using Microsoft.Extensions.Logging
@inject IChatState ChatState
@inject IChatMessageOrchestrator Orchestrator
@inject IClaudeService ClaudeService
@inject ISessionService SessionService
@inject ISessionInitializer SessionInitializer
@inject IJSRuntime JSRuntime
@inject ILogger<ChatView> Logger
@inject ISnackbar Snackbar
@inject INotificationService NotificationService
@inject INotificationHistoryService NotificationHistory
@implements IDisposable

@ChatContentFragment

@code {
    private RenderFragment ChatContentFragment => __builder =>
    {
        <div class="chat-container">
            @* Message area *@
            <CascadingValue Value="_askUserResponseCallback" Name="OnAskUserResponse">
            <div class="message-area" id="message-list">
                @if (ChatState.CurrentSession == null)
                {
                    <LandingPage @ref="_landingPage" />
                }
                else if (ChatState.CurrentSession.Messages.Count == 0)
                {
                    <div class="welcome-container">
                        <MudIcon Icon="@Icons.Material.Filled.Terminal" Size="Size.Large" Color="Color.Primary" Style="opacity: 0.4;" />
                        <span class="welcome-title">무엇을 도와드릴까요?</span>
                        @if (ChatState.CurrentSession.Status == SessionStatus.Pending)
                        {
                            <BranchSelector BranchGroups="_branchGroups"
                                            SelectedBranch="@_selectedBranch"
                                            SelectedBranchChanged="@(b => _selectedBranch = b)"
                                            IsLoading="_isLoadingBranches" />
                        }
                    </div>
                }
                else
                {
                    <div class="message-container">
                        @foreach (var message in ChatState.CurrentSession.Messages.ToList())
                        {
                            <MessageBubble @key="message.Id" Message="message" />
                        }
                    </div>
                }
            </div>
            @if (!_isAtBottom && ChatState.CurrentSession?.Messages.Count > 0)
            {
                <div class="scroll-to-bottom-btn @(_askUserBarVisible ? "askbar-active" : "")" @onclick="ScrollToBottom">
                    <MudIcon Icon="@Icons.Material.Filled.KeyboardArrowDown" Size="Size.Small" />
                </div>
            }
            </CascadingValue>

            @* Quick response bar *@
            <QuickResponseBar IsVisible="@(_quickResponseVisible && !_planReviewVisible && !_askUserBarVisible)"
                              Options="_quickResponseOptions"
                              OnResponse="HandleQuickResponse" />

            @* AskUserQuestion bar *@
            <AskUserQuestionBar IsVisible="@(_askUserBarVisible && !_planReviewVisible)"
                                QuestionInput="@_askUserQuestionInput"
                                OnResponse="HandleAskUserBarResponse" />

            @* Plan review bar *@
            <PlanReviewBar IsVisible="_planReviewVisible"
                           PlanContent="@_planContent"
                           PlanFilePath="@_planFilePath"
                           OnAction="HandlePlanReviewAction" />

            @* Input area *@
            @if (ChatState.CurrentSession != null)
            {
                <InputArea OnSend="HandleSend" OnCancel="HandleCancel"
                           IsStreaming="ChatState.IsStreaming"
                           Disabled="@(ChatState.CurrentSession.Status == SessionStatus.Archived)"
                           PermissionMode="@(ChatState.CurrentSession.PermissionMode ?? "bypassAll")"
                           PermissionModeChanged="HandlePermissionModeChanged"
                           EffortLevel="@(ChatState.CurrentSession.EffortLevel ?? "auto")"
                           EffortLevelChanged="HandleEffortLevelChanged"
                           Model="@(ChatState.CurrentSession.Model ?? "")"
                           OnModelChanged="HandleModelChanged"
                           ResolvedModel="@(ChatState.CurrentSession.ResolvedModel)"
                           CurrentSession="@ChatState.CurrentSession"
                           PlanFilePath="@_lastPlanFilePath"
                           PlanContent="@_lastPlanContent"
                           IsPlanReviewVisible="_planReviewVisible" />
            }
        </div>
    };

    private List<BranchGroup> _branchGroups = [];
    private string _selectedBranch = "";
    private bool _quickResponseVisible;
    private List<string> _quickResponseOptions = [];
    private EventCallback<string> _askUserResponseCallback;
    private bool _askUserBarVisible;
    private string? _askUserQuestionInput;
    private bool _planReviewVisible;
    private string? _planFilePath;
    private string? _planContent;
    private string? _planSessionId;
    private string? _lastPlanFilePath;
    private string? _lastPlanContent;
    private bool _shouldAutoScroll;
    private bool _isAtBottom = true;
    private DotNetObjectReference<ChatView>? _selfRef;
    private bool _isLoadingBranches;
    private string? _branchesForSessionId;
    private LandingPage? _landingPage;
    private readonly Dictionary<string, (CancellationTokenSource Cts, Task Task)> _sessionTasks = new();
    private List<SkillChainStep>? _pendingChain;
    protected override void OnInitialized()
    {
        ChatState.OnChange += HandleStateChanged;
        _askUserResponseCallback = EventCallback.Factory.Create<string>(this, HandleQuickResponse);
    }

    private void HandleStateChanged()
    {
        _ = InvokeAsync(() =>
        {
            try
            {
                bool needsBranches = ChatState.CurrentSession?.Status == SessionStatus.Pending
                                     && ChatState.CurrentSession?.Id != _branchesForSessionId
                                     && !_isLoadingBranches;

                var pendingMsg = ChatState.ConsumePendingMessage();
                if (pendingMsg != null && ChatState.CurrentSession != null && !ChatState.IsStreaming)
                {
                    StateHasChanged();
                    _ = HandleSend(new ChatInputMessage { Text = pendingMsg });
                    return;
                }

                // Restore AskUserQuestion bar state from session (survives session switches)
                var currentId = ChatState.CurrentSession?.Id;
                var pendingAskInput = ChatState.CurrentSession?.PendingAskUserQuestionInput;
                if (!ChatState.IsStreaming && pendingAskInput != null)
                {
                    _askUserBarVisible = true;
                    _askUserQuestionInput = pendingAskInput;
                    // AskUserQuestion supersedes plan review
                    _planReviewVisible = false;
                }
                else
                {
                    // Only clear bar if session switched (not just any state change)
                    if (pendingAskInput == null)
                    {
                        _askUserBarVisible = false;
                        _askUserQuestionInput = null;
                    }
                }

                // Restore plan review state scoped to the current session (only if no AskUserQuestion)
                if (!_askUserBarVisible
                    && ChatState.CurrentSession is { PlanCompleted: true, PermissionMode: "plan" }
                    && !ChatState.IsStreaming)
                {
                    _planReviewVisible = true;

                    // Only restore content if we don't already have content for THIS session
                    if (_planSessionId != currentId || _planContent == null)
                    {
                        _planSessionId = currentId;
                        _planContent = null;
                        _planFilePath = ChatState.CurrentSession.PlanFilePath;

                        if (!string.IsNullOrEmpty(ChatState.CurrentSession.Git.WorktreePath))
                            _ = RestorePlanContentAsync(ChatState.CurrentSession.Git.WorktreePath, ChatState.CurrentSession.PlanFilePath);
                    }
                }
                else if (!_askUserBarVisible)
                {
                    _planReviewVisible = false;

                    if (_planSessionId != currentId)
                    {
                        _planContent = null;
                        _planFilePath = null;
                        _planSessionId = currentId;
                        _lastPlanFilePath = null;
                        _lastPlanContent = null;
                    }
                }

                if (ChatState.IsStreaming)
                    _shouldAutoScroll = true;

                if (needsBranches)
                {
                    _isLoadingBranches = true;
                    _branchGroups = [];
                    _selectedBranch = "";
                }

                StateHasChanged();

                if (needsBranches)
                    _ = LoadBranchesInBackground();

                if (ChatState.CurrentSession == null)
                    _ = _landingPage?.RefreshAsync();
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "HandleStateChanged failed");
            }
        });
    }

    private async Task RestorePlanContentAsync(string worktreePath, string? savedPlanFilePath = null)
    {
        // Capture session ID at call time to detect switches during async I/O
        var targetSessionId = ChatState.CurrentSession?.Id;

        string? filePath = null;
        string? content = null;

        if (!string.IsNullOrEmpty(savedPlanFilePath) && File.Exists(savedPlanFilePath))
        {
            filePath = savedPlanFilePath;
            content = await File.ReadAllTextAsync(savedPlanFilePath);
        }
        else
        {
            // Check both ~/.claude/plans/ (where CLI saves) and worktree .claude/plans/
            var dirs = new List<string>();

            var homePlansDir = Path.Combine(
                Environment.GetFolderPath(Environment.SpecialFolder.UserProfile),
                ".claude", "plans");
            if (Directory.Exists(homePlansDir))
                dirs.Add(homePlansDir);

            var worktreePlansDir = Path.Combine(worktreePath, ".claude", "plans");
            if (Directory.Exists(worktreePlansDir))
                dirs.Add(worktreePlansDir);

            var planFile = dirs
                .SelectMany(d => Directory.GetFiles(d, "*.md"))
                .OrderByDescending(f => File.GetLastWriteTimeUtc(f))
                .FirstOrDefault();
            if (planFile != null)
            {
                filePath = planFile;
                content = await File.ReadAllTextAsync(planFile);
            }
        }

        // Guard: only apply if user hasn't switched sessions during async read
        if (content != null && ChatState.CurrentSession?.Id == targetSessionId)
        {
            _planFilePath = filePath;
            _planContent = content;
            _planSessionId = targetSessionId;
            _lastPlanFilePath = filePath;
            _lastPlanContent = content;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadBranchesInBackground()
    {
        try
        {
            var ws = ChatState.CurrentWorkspace;
            if (ws == null || string.IsNullOrEmpty(ws.RepoLocalPath)) return;

            var (groups, defaultBranch) = await SessionInitializer.LoadBranchesAsync(ws.RepoLocalPath);
            _branchGroups = groups;
            _selectedBranch = defaultBranch;
            _branchesForSessionId = ChatState.CurrentSession?.Id;
        }
        finally
        {
            _isLoadingBranches = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _selfRef = DotNetObjectReference.Create(this);
            await JSRuntime.InvokeVoidAsync("registerScrollWatcher", "message-list", _selfRef);
        }

        if (_shouldAutoScroll)
        {
            _shouldAutoScroll = false;
            if (_isAtBottom)
                await JSRuntime.InvokeVoidAsync("scrollToBottom", "message-list");
        }
    }

    [JSInvokable]
    public void OnScrollPositionChanged(bool isAtBottom)
    {
        var changed = _isAtBottom != isAtBottom;
        _isAtBottom = isAtBottom;
        if (changed) InvokeAsync(StateHasChanged);
    }

    private async Task ScrollToBottom()
    {
        _isAtBottom = true;
        await JSRuntime.InvokeVoidAsync("scrollToBottom", "message-list");
    }

    private async Task HandlePermissionModeChanged(string mode)
    {
        if (ChatState.CurrentSession == null) return;
        ChatState.CurrentSession.PermissionMode = mode;
        ChatState.NotifyStateChanged();
        await SessionService.SaveSessionAsync(ChatState.CurrentSession);
    }

    private Task HandleQuickResponse(string response)
    {
        _quickResponseVisible = false;
        _quickResponseOptions = [];
        return HandleSend(new ChatInputMessage { Text = response });
    }

    private Task HandleAskUserBarResponse(string response)
    {
        _askUserBarVisible = false;
        _askUserQuestionInput = null;
        // Clear persisted state so bar doesn't reappear on session switch
        if (ChatState.CurrentSession != null)
            ChatState.CurrentSession.PendingAskUserQuestionInput = null;
        return HandleSend(new ChatInputMessage { Text = response });
    }

    private async Task HandlePlanReviewAction(PlanReviewAction action)
    {
        _planReviewVisible = false;

        switch (action)
        {
            case PlanReviewAction.Approve:
                await HandlePermissionModeChanged("bypassAll");
                var planRef = !string.IsNullOrEmpty(_planFilePath)
                    ? ".claude/plans/ 에 저장된 플랜 파일을 참고하여 "
                    : "";
                await HandleSend(new ChatInputMessage
                {
                    Text = $"플랜을 승인합니다. {planRef}구현을 진행해주세요. 플랜의 각 단계를 순서대로 실행하세요."
                });
                if (ChatState.CurrentSession != null)
                {
                    ChatState.CurrentSession.PlanCompleted = false;
                    ChatState.CurrentSession.PlanFilePath = null;
                }
                _planFilePath = null;
                _planContent = null;
                _planSessionId = null;
                break;

            case PlanReviewAction.Advice:
                break;

            case PlanReviewAction.Reject:
                await HandleSend(new ChatInputMessage
                {
                    Text = "플랜을 거절합니다. 다른 접근 방식을 제안해주세요."
                });
                break;
        }
    }


    private Task HandleSend(ChatInputMessage input)
    {
        if (ChatState.CurrentSession == null || ChatState.IsStreaming
            || (string.IsNullOrWhiteSpace(input.Text) && input.Attachments.Count == 0))
            return Task.CompletedTask;

        // Capture plan review state before clearing
        bool wasPlanReviewVisible = _planReviewVisible;

        _quickResponseVisible = false;
        _quickResponseOptions = [];
        _askUserBarVisible = false;
        _askUserQuestionInput = null;
        _planReviewVisible = false;
        _planSessionId = null;
        // Clear persisted AskUserQuestion state
        if (ChatState.CurrentSession != null)
            ChatState.CurrentSession.PendingAskUserQuestionInput = null;

        // If plan review was visible, treat user input as plan feedback
        if (wasPlanReviewVisible && !string.IsNullOrWhiteSpace(input.Text))
        {
            input.Text = $"플랜에 대한 피드백: {input.Text}\n\n이 피드백을 반영하여 플랜을 수정해주세요.";
        }

        // Extract chain state from input
        if (input.PendingChain is { Count: > 0 })
        {
            _pendingChain = input.PendingChain;
            input.PendingChain = null;
        }

        var session = ChatState.CurrentSession;
        var workspace = ChatState.CurrentWorkspace;
        var branch = _selectedBranch;
        var sessionId = session.Id;

        // Cancel previous task only for the SAME session
        if (_sessionTasks.TryGetValue(sessionId, out var prev))
        {
            prev.Cts.Cancel();
            prev.Cts.Dispose();
            _sessionTasks.Remove(sessionId);
        }

        var cts = new CancellationTokenSource();
        var ct = cts.Token;

        var task = Task.Run(async () =>
        {
            try
            {
                var result = await Orchestrator.SendAsync(session, input, branch, workspace, ct);
                await ApplyResultAsync(result, session);
            }
            catch (OperationCanceledException) { }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Unhandled exception in SendAsync for session {SessionId}", sessionId);
            }
            finally
            {
                _sessionTasks.Remove(sessionId);
            }
        });

        _sessionTasks[sessionId] = (cts, task);
        return Task.CompletedTask;
    }

    private async Task ApplyResultAsync(StreamResult result, Session session)
    {
        var isCurrentSession = ChatState.CurrentSession?.Id == session.Id;

        // Plan state: always store data (for later session switch), but only show UI for current session
        if (result.PlanReviewVisible)
        {
            _planFilePath = result.PlanFilePath;
            _planContent = result.PlanContent;
            _planSessionId = session.Id;
            _planReviewVisible = isCurrentSession;
            _lastPlanFilePath = result.PlanFilePath;
            _lastPlanContent = result.PlanContent;
        }
        else if (isCurrentSession)
        {
            _planFilePath = result.PlanFilePath;
            _planContent = result.PlanContent;
            _planReviewVisible = false;
        }

        if (isCurrentSession)
        {
            _quickResponseVisible = result.QuickResponseVisible;
            _quickResponseOptions = result.QuickResponseOptions;
            _askUserBarVisible = result.AskUserQuestionInput != null;
            _askUserQuestionInput = result.AskUserQuestionInput;
            _shouldAutoScroll = true;
        }

        if (result.ErrorMessage != null)
            await InvokeAsync(() => Snackbar.StreamingError(result.ErrorMessage));

        if (result.PlanReviewVisible)
            _ = SendNotificationIfNeeded(session, "계획 완료", NotificationType.PlanReview);
        else if (result.AskUserQuestionInput != null)
            _ = SendNotificationIfNeeded(session, "응답 필요", NotificationType.Question);
        else if (result.QuickResponseVisible)
            _ = SendNotificationIfNeeded(session, "응답 필요", NotificationType.Question);
        else
            _ = SendNotificationIfNeeded(session, "작업 완료", NotificationType.Success);

        await InvokeAsync(StateHasChanged);

        // Skill chaining: auto-send next step if not cancelled/errored/paused
        if (_pendingChain is { Count: > 0 }
            && !result.WasCancelled
            && result.ErrorMessage == null
            && !result.PlanReviewVisible
            && !result.QuickResponseVisible
            && result.AskUserQuestionInput == null)
        {
            var nextStep = _pendingChain[0];
            _pendingChain.RemoveAt(0);
            var remainingChain = _pendingChain.Count > 0 ? _pendingChain : null;
            _pendingChain = null;

            ChatState.AddSystemMessage(session, $"체이닝: /{nextStep.SkillName} 실행 중...");
            await InvokeAsync(StateHasChanged);

            await InvokeAsync(() => HandleSend(new ChatInputMessage
            {
                Text = nextStep.ExpandedText,
                PendingChain = remainingChain
            }));
        }
    }

    private async Task HandleEffortLevelChanged(string level)
    {
        if (ChatState.CurrentSession == null) return;
        ChatState.CurrentSession.EffortLevel = level;
        ChatState.NotifyStateChanged();
        await SessionService.SaveSessionAsync(ChatState.CurrentSession);
    }

    private async Task HandleModelChanged(string model)
    {
        if (ChatState.CurrentSession != null)
        {
            ChatState.CurrentSession.Model = model;
            ChatState.NotifyStateChanged();
            await SessionService.SaveSessionAsync(ChatState.CurrentSession);
        }
    }

    private async Task SendNotificationIfNeeded(Session session, string body, NotificationType type)
    {
        try
        {
            NotificationHistory.Record(session.Title, body, type, session.Id);

            var isFocused = await JSRuntime.InvokeAsync<bool>("isWindowFocused");
            var isCurrentSession = ChatState.CurrentSession?.Id == session.Id;

            if (!isFocused || !isCurrentSession)
                await NotificationService.SendAsync(session.Title, body, type);
        }
        catch (Exception ex)
        {
            Logger.LogDebug(ex, "Failed to send notification for session {SessionId}", session.Id);
        }
    }

    private void HandleCancel()
    {
        _pendingChain = null;
        var sessionId = ChatState.CurrentSession?.Id;
        ClaudeService.Cancel(sessionId);
        if (sessionId != null && _sessionTasks.TryGetValue(sessionId, out var entry))
        {
            entry.Cts.Cancel();
        }
    }

    public void Dispose()
    {
        ChatState.OnChange -= HandleStateChanged;
        _selfRef?.Dispose();

        foreach (var (_, (cts, task)) in _sessionTasks)
        {
            cts.Cancel();
            // Observe the task to prevent UnobservedTaskException
            if (task is { IsCompleted: false })
                task.ContinueWith(static t => { _ = t.Exception; }, TaskContinuationOptions.OnlyOnFaulted);
            cts.Dispose();
        }
        _sessionTasks.Clear();
    }
}
