@using Cominomi.Shared.Models
@using Microsoft.Extensions.Logging
@using System.Text.Json
@inject ChatState ChatState
@inject IClaudeService ClaudeService
@inject ISessionService SessionService
@inject IChatPrWorkflowService PrWorkflow
@inject IAttachmentService AttachmentService
@inject ISystemPromptBuilder SystemPromptBuilder
@inject ISessionInitializer SessionInitializer
@inject IHooksEngine HooksEngine
@inject IJSRuntime JSRuntime
@inject ILogger<ChatView> Logger
@inject ISnackbar Snackbar
@inject IUsageService UsageService
@inject INotificationService NotificationService
@inject IStreamEventProcessor StreamProcessor
@implements IDisposable

<div class="chat-container">
    @* Workflow actions bar (Merge all) *@
    @if (ChatState.CurrentSession != null && !ChatState.CurrentSession.IsLocalDir
         && ChatState.CurrentSession.Status is SessionStatus.Ready
         or SessionStatus.Pushed or SessionStatus.PrOpen or SessionStatus.ConflictDetected)
    {
        <div class="session-workflow" style="padding: var(--space-1) var(--space-4); border-bottom: 1px solid var(--border-subtle); justify-content: flex-end;">
            @if (ChatState.CurrentSession.IssueNumber != null)
            {
                <MudLink Href="@ChatState.CurrentSession.IssueUrl" Target="_blank" Typo="Typo.caption"
                         Style="font-size: var(--text-xs); margin-right: auto;">
                    Issue #@ChatState.CurrentSession.IssueNumber
                </MudLink>
            }
            else
            {
                <MudIconButton Icon="@Icons.Material.Filled.BugReport" Size="Size.Small"
                               OnClick="@(() => _linkIssueDialogOpen = true)"
                               Style="width: 24px; height: 24px; opacity: 0.5; margin-right: auto;"
                               Title="이슈 연결" />
            }
            @if (_operatingSessionId == ChatState.CurrentSession.Id)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Style="width: 12px; height: 12px;" />
                <span style="font-size: var(--text-xs); opacity: 0.6;">처리 중...</span>
            }
            else
            {
                @switch (ChatState.CurrentSession.Status)
                {
                    case SessionStatus.Ready:
                    case SessionStatus.Pushed:
                        @if (!ChatState.IsStreaming)
                        {
                            <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.RocketLaunch"
                                       OnClick="@(() => CreatePr(ChatState.CurrentSession))"
                                       Style="text-transform: none; font-size: var(--text-xs); min-width: 0; padding: 0 var(--space-2); height: 24px;">
                                PR 생성
                            </MudButton>
                        }
                        break;
                    case SessionStatus.PrOpen:
                        <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Warning"
                                   StartIcon="@Icons.Material.Filled.MergeType"
                                   OnClick="@(() => MergePr(ChatState.CurrentSession))"
                                   Style="text-transform: none; font-size: var(--text-xs); min-width: 0; padding: 0 var(--space-2); height: 24px;">
                            병합
                        </MudButton>
                        @if (!string.IsNullOrEmpty(ChatState.CurrentSession.PrUrl))
                        {
                            <MudLink Href="@ChatState.CurrentSession.PrUrl" Target="_blank" Typo="Typo.caption"
                                     Style="font-size: var(--text-xs);">
                                #@ChatState.CurrentSession.PrNumber
                            </MudLink>
                        }
                        break;
                    case SessionStatus.ConflictDetected:
                        <span style="font-size: var(--text-xs); color: #f38ba8; font-weight: 600;">충돌</span>
                        <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Error"
                                   OnClick="@(() => ResolveConflicts(ChatState.CurrentSession))"
                                   Style="text-transform: none; font-size: var(--text-xs); min-width: 0; padding: 0 var(--space-2); height: 24px;">
                            해결
                        </MudButton>
                        break;
                }

                @if (!string.IsNullOrEmpty(ChatState.CurrentSession.ErrorMessage))
                {
                    <MudTooltip Text="@ChatState.CurrentSession.ErrorMessage">
                        <MudIcon Icon="@Icons.Material.Filled.Warning" Size="Size.Small" Color="Color.Error"
                                 Style="width: 14px; height: 14px;" />
                    </MudTooltip>
                    @if (ChatState.CurrentSession.ErrorMessage.Contains("rejected", StringComparison.OrdinalIgnoreCase))
                    {
                        <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Warning"
                                   OnClick="@(() => ForcePushAndMerge(ChatState.CurrentSession))"
                                   Style="text-transform: none; font-size: var(--text-xs); min-width: 0; padding: 0 var(--space-1); height: 24px;">
                            강제 푸시
                        </MudButton>
                    }
                }
            }
        </div>
    }

    @* Message area *@
    <div class="message-area" id="message-list">
        @if (ChatState.CurrentSession == null)
        {
            <div class="landing-container">
                <div class="landing-logo">
                    <svg width="48" height="48" viewBox="0 0 456 456" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <rect x="68" y="78" width="320" height="240" rx="40" ry="40" fill="currentColor" opacity="0.8" />
                        <polygon points="108,318 68,378 168,318" fill="currentColor" opacity="0.8" />
                        <polyline points="148,158 208,198 148,238" fill="none" stroke="var(--bg-base)" stroke-width="30" stroke-linecap="round" stroke-linejoin="round" />
                        <line x1="228" y1="238" x2="308" y2="238" stroke="var(--bg-base)" stroke-width="30" stroke-linecap="round" />
                    </svg>
                </div>
                <h2 class="landing-heading">Cominomi</h2>
                <p class="landing-subtitle">AI 코딩 어시스턴트</p>

                <div class="landing-actions">
                    <button class="landing-action-card" @onclick="LandingCreateWorkspace">
                        <MudIcon Icon="@Icons.Material.Filled.CreateNewFolder" Style="font-size: 20px;" />
                        <div class="landing-action-text">
                            <span class="landing-action-title">워크스페이스 만들기</span>
                        </div>
                    </button>
                </div>

                @if (_recentSessions.Count > 0)
                {
                    <div class="landing-recents">
                        <span class="landing-recents-label">최근 대화</span>
                        @foreach (var recent in _recentSessions)
                        {
                            <button class="landing-recent-item" @onclick="@(() => ResumeRecentSession(recent))">
                                <span class="status-dot @GetStatusDotClass(recent.Status)"></span>
                                <span class="landing-recent-title">@recent.Title</span>
                            </button>
                        }
                    </div>
                }
            </div>
        }
        else if (ChatState.CurrentSession.Messages.Count == 0)
        {
            <div class="welcome-container">
                <MudIcon Icon="@Icons.Material.Filled.Terminal" Size="Size.Large" Color="Color.Primary" Style="opacity: 0.4;" />
                <span class="welcome-title">무엇을 도와드릴까요?</span>
                @if (ChatState.CurrentSession.Status == SessionStatus.Pending)
                {
                    @if (_isLoadingBranches)
                    {
                        <div class="branch-selector-loading">
                            <MudProgressCircular Size="Size.Small" Indeterminate="true"
                                                 Style="width: 14px; height: 14px; color: var(--accent);" />
                            <span>브랜치 불러오는 중...</span>
                        </div>
                    }
                    else if (_branchGroups.Count > 0)
                    {
                        <div class="branch-selector-wrapper">
                            <button class="branch-selector-pill" type="button" @onclick="ToggleBranchMenu">
                                <MudIcon Icon="@Icons.Material.Filled.AccountTree"
                                         Style="font-size: 16px; opacity: 0.7;" />
                                <span class="branch-selector-name">@_selectedBranch</span>
                                <MudIcon Icon="@Icons.Material.Filled.UnfoldMore"
                                         Style="font-size: 16px; opacity: 0.4;" />
                            </button>

                            <MudPopover Open="@_branchMenuOpen" AnchorOrigin="Origin.BottomCenter"
                                        TransformOrigin="Origin.TopCenter" Class="branch-popover">
                                <div class="branch-search-container">
                                    <MudTextField T="string" @bind-Value="_branchSearchText"
                                                  Placeholder="브랜치 검색..."
                                                  Variant="Variant.Text"
                                                  Immediate="true"
                                                  Adornment="Adornment.Start"
                                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                                  Style="font-size: var(--text-sm);" />
                                </div>
                                <MudList T="string" Dense="true" Class="branch-list">
                                    @foreach (var group in FilteredBranchGroups)
                                    {
                                        <div class="branch-group-header">@group.Name</div>
                                        @foreach (var branch in group.Branches)
                                        {
                                            <MudListItem T="string" OnClick="@(() => SelectBranch(branch))"
                                                         Class="@(branch == _selectedBranch ? "branch-item-active" : "")">
                                                <div class="branch-item-content">
                                                    <MudIcon Icon="@Icons.Material.Filled.AccountTree"
                                                             Style="font-size: 14px; opacity: 0.5;" />
                                                    <span class="branch-item-name">@branch</span>
                                                    @if (branch == _selectedBranch)
                                                    {
                                                        <MudIcon Icon="@Icons.Material.Filled.Check"
                                                                 Style="font-size: 14px; color: var(--accent);" />
                                                    }
                                                </div>
                                            </MudListItem>
                                        }
                                    }
                                    @if (!FilteredBranchGroups.Any())
                                    {
                                        <div class="branch-no-results">일치하는 브랜치 없음</div>
                                    }
                                </MudList>
                            </MudPopover>

                            @if (_branchMenuOpen)
                            {
                                <MudOverlay Visible="true" OnClick="CloseBranchMenu"
                                            DarkBackground="false" ZIndex="1" />
                            }
                        </div>
                    }
                }
            </div>
        }
        else
        {
            <div class="message-container">
                @foreach (var message in ChatState.CurrentSession.Messages)
                {
                    <MessageBubble Message="message" />
                }
            </div>
        }
    </div>

    @* Quick response bar *@
    <QuickResponseBar IsVisible="@(_quickResponseVisible && !_planReviewVisible)"
                      Options="_quickResponseOptions"
                      OnResponse="HandleQuickResponse" />

    @* Plan review bar *@
    <PlanReviewBar IsVisible="_planReviewVisible"
                   PlanContent="@_planContent"
                   PlanFilePath="@_planFilePath"
                   OnAction="HandlePlanReviewAction"
                   OnAdvice="HandlePlanAdvice" />

    @* Input area *@
    @if (ChatState.CurrentSession != null)
    {
        <InputArea OnSend="HandleSend" OnCancel="HandleCancel" IsStreaming="ChatState.IsStreaming"
                   Disabled="@(ChatState.CurrentSession.Status == SessionStatus.Archived || _isInitializingWorktree)"
                   PermissionMode="@(ChatState.CurrentSession.PermissionMode ?? "bypassAll")"
                   PermissionModeChanged="HandlePermissionModeChanged"
                   EffortLevel="@(ChatState.CurrentSession.EffortLevel ?? "auto")"
                   EffortLevelChanged="HandleEffortLevelChanged"
                   Model="@(ChatState.CurrentSession.Model ?? "")"
                   OnModelChanged="HandleModelChanged"
                   ResolvedModel="@(ChatState.CurrentSession.ResolvedModel)"
                   CurrentSession="@ChatState.CurrentSession" />
    }
</div>

<LinkIssueDialog @bind-IsOpen="_linkIssueDialogOpen" OnIssueLinked="HandleIssueLinked" />

@code {
    private List<BranchGroup> _branchGroups = [];
    private string _selectedBranch = "";
    private bool _isInitializingWorktree;
    private string? _operatingSessionId;
    private bool _linkIssueDialogOpen;
    private bool _quickResponseVisible;
    private List<string> _quickResponseOptions = [];
    private bool _planReviewVisible;
    private string? _planFilePath;
    private string? _planContent;
    private DateTime _streamStartTime;
    private string? _lastPrCheckedSessionId;

    private List<Session> _recentSessions = [];


    protected override async Task OnInitializedAsync()
    {
        ChatState.OnChange += HandleStateChanged;
        await LoadRecentSessions();
    }

    private bool _isLoadingBranches;
    private bool _branchMenuOpen;
    private string _branchSearchText = "";

    private IEnumerable<BranchGroup> FilteredBranchGroups =>
        string.IsNullOrWhiteSpace(_branchSearchText)
            ? _branchGroups
            : _branchGroups
                .Select(g => new BranchGroup(g.Name,
                    g.Branches.Where(b => b.Contains(_branchSearchText, StringComparison.OrdinalIgnoreCase)).ToList()))
                .Where(g => g.Branches.Count > 0)
                .ToList();

    private void ToggleBranchMenu()
    {
        _branchMenuOpen = !_branchMenuOpen;
        if (!_branchMenuOpen) _branchSearchText = "";
    }

    private void CloseBranchMenu()
    {
        _branchMenuOpen = false;
        _branchSearchText = "";
    }

    private void SelectBranch(string branch)
    {
        _selectedBranch = branch;
        _branchMenuOpen = false;
        _branchSearchText = "";
    }

    private void HandleStateChanged()
    {
        _ = InvokeAsync(() =>
        {
            try
            {
                bool needsBranches = ChatState.CurrentSession?.Status == SessionStatus.Pending
                                     && _branchGroups.Count == 0 && !_isLoadingBranches;

                var pendingMsg = ChatState.ConsumePendingMessage();
                if (pendingMsg != null && ChatState.CurrentSession != null && !ChatState.IsStreaming)
                {
                    StateHasChanged();
                    _ = HandleSend(new ChatInputMessage { Text = pendingMsg });
                    return;
                }

                // Restore plan review state when switching to a session with completed plan
                if (ChatState.CurrentSession is { PlanCompleted: true, PermissionMode: "plan" } && !ChatState.IsStreaming)
                {
                    _planReviewVisible = true;
                    if (_planContent == null && !string.IsNullOrEmpty(ChatState.CurrentSession.WorktreePath))
                        _ = RestorePlanContentAsync(ChatState.CurrentSession.WorktreePath, ChatState.CurrentSession.PlanFilePath);
                }
                else if (ChatState.CurrentSession?.PermissionMode != "plan" || ChatState.IsStreaming)
                {
                    if (!ChatState.IsStreaming)
                        _planReviewVisible = false;
                }

                if (ChatState.IsStreaming)
                    _shouldAutoScroll = true;

                if (needsBranches)
                    _isLoadingBranches = true;

                StateHasChanged();

                if (needsBranches)
                    _ = LoadBranchesInBackground();

                if (ChatState.CurrentSession == null)
                    _ = LoadRecentSessions().ContinueWith(_ => InvokeAsync(StateHasChanged));

                // 세션 전환 시 GitHub PR 상태 자동 확인
                if (ChatState.CurrentSession != null
                    && !ChatState.CurrentSession.IsLocalDir
                    && ChatState.CurrentSession.Id != _lastPrCheckedSessionId
                    && ChatState.CurrentSession.Status is SessionStatus.Ready or SessionStatus.Pushed
                    && ChatState.CurrentSession.PrNumber == null
                    && !string.IsNullOrEmpty(ChatState.CurrentSession.BranchName))
                {
                    _lastPrCheckedSessionId = ChatState.CurrentSession.Id;
                    _ = CheckAndUpdatePrStatus(ChatState.CurrentSession);
                }
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "HandleStateChanged failed");
            }
        });
    }

    private async Task RestorePlanContentAsync(string worktreePath, string? savedPlanFilePath = null)
    {
        _planFilePath = null;
        _planContent = null;

        // Try saved plan file path first
        if (!string.IsNullOrEmpty(savedPlanFilePath) && File.Exists(savedPlanFilePath))
        {
            _planFilePath = savedPlanFilePath;
            _planContent = await File.ReadAllTextAsync(savedPlanFilePath);
        }
        else
        {
            // Fallback: find most recent plan file (no timestamp filter for restore)
            var plansDir = Path.Combine(worktreePath, ".claude", "plans");
            if (Directory.Exists(plansDir))
            {
                var planFile = Directory.GetFiles(plansDir, "*.md")
                    .OrderByDescending(f => File.GetLastWriteTimeUtc(f))
                    .FirstOrDefault();
                if (planFile != null)
                {
                    _planFilePath = planFile;
                    _planContent = await File.ReadAllTextAsync(planFile);
                }
            }
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadBranchesInBackground()
    {
        try
        {
            var ws = ChatState.CurrentWorkspace;
            if (ws == null || string.IsNullOrEmpty(ws.RepoLocalPath)) return;

            var (groups, defaultBranch) = await SessionInitializer.LoadBranchesAsync(ws.RepoLocalPath);
            _branchGroups = groups;
            _selectedBranch = defaultBranch;
        }
        finally
        {
            _isLoadingBranches = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_shouldAutoScroll)
        {
            _shouldAutoScroll = false;
            await JSRuntime.InvokeVoidAsync("scrollToBottom", "message-list");
        }
    }

    private async Task HandlePermissionModeChanged(string mode)
    {
        if (ChatState.CurrentSession == null) return;
        ChatState.CurrentSession.PermissionMode = mode;
        ChatState.NotifyStateChanged();
        await SessionService.SaveSessionAsync(ChatState.CurrentSession);
    }

    private bool _shouldAutoScroll;

    private Task HandleQuickResponse(string response)
    {
        _quickResponseVisible = false;
        _quickResponseOptions = [];
        return HandleSend(new ChatInputMessage { Text = response });
    }

    private async Task HandlePlanReviewAction(PlanReviewAction action)
    {
        _planReviewVisible = false;

        switch (action)
        {
            case PlanReviewAction.Approve:
                await HandlePermissionModeChanged("bypassAll");
                var planRef = !string.IsNullOrEmpty(_planFilePath)
                    ? ".claude/plans/ 에 저장된 플랜 파일을 참고하여 "
                    : "";
                await HandleSend(new ChatInputMessage
                {
                    Text = $"플랜을 승인합니다. {planRef}구현을 진행해주세요. 플랜의 각 단계를 순서대로 실행하세요."
                });
                if (ChatState.CurrentSession != null)
                {
                    ChatState.CurrentSession.PlanCompleted = false;
                    ChatState.CurrentSession.PlanFilePath = null;
                }
                _planFilePath = null;
                _planContent = null;
                break;

            case PlanReviewAction.Advice:
                // Handled by OnAdvice callback in PlanReviewBar
                break;

            case PlanReviewAction.Reject:
                await HandleSend(new ChatInputMessage
                {
                    Text = "플랜을 거절합니다. 다른 접근 방식을 제안해주세요."
                });
                break;
        }
    }

    private async Task HandlePlanAdvice(string advice)
    {
        _planReviewVisible = false;
        // Stay in plan mode — send feedback and let Claude revise the plan
        await HandleSend(new ChatInputMessage
        {
            Text = $"플랜에 대한 피드백: {advice}\n\n이 피드백을 반영하여 플랜을 수정해주세요."
        });
    }

    private Task HandleSend(ChatInputMessage input)
    {
        if (ChatState.CurrentSession == null || (string.IsNullOrWhiteSpace(input.Text) && input.Attachments.Count == 0))
            return Task.CompletedTask;

        _quickResponseVisible = false;
        _quickResponseOptions = [];
        _planReviewVisible = false;

        _ = Task.Run(() => ProcessMessageAsync(input));
        return Task.CompletedTask;
    }

    private async Task ProcessMessageAsync(ChatInputMessage input)
    {
        var session = ChatState.CurrentSession!;

        if (session.Status == SessionStatus.Pending)
        {
            if (string.IsNullOrEmpty(_selectedBranch))
                return;

            try
            {
                _isInitializingWorktree = true;
                await InvokeAsync(StateHasChanged);

                var updated = await SessionService.InitializeWorktreeAsync(session.Id, _selectedBranch);
                session.WorktreePath = updated.WorktreePath;
                session.BranchName = updated.BranchName;
                session.BaseBranch = updated.BaseBranch;
                session.SetInitialStatus(updated.Status);
                session.ErrorMessage = updated.ErrorMessage;

                if (session.Status == SessionStatus.Error)
                {
                    ChatState.NotifyStateChanged();
                    return;
                }
            }
            catch (Exception ex)
            {
                session.TransitionStatus(SessionStatus.Error);
                session.ErrorMessage = ex.Message;
                ChatState.NotifyStateChanged();
                return;
            }
            finally
            {
                _isInitializingWorktree = false;
                await InvokeAsync(StateHasChanged);
            }
        }

        var isFirstMessage = session.Messages.Count(m => m.Role == MessageRole.User) == 0;

        var fileAttachments = new List<FileAttachment>();
        foreach (var pending in input.Attachments)
        {
            FileAttachment attachment;
            if (pending.FilePath != null && pending.Data.Length == 0)
            {
                attachment = await AttachmentService.CopyFileToWorktreeAsync(pending.FilePath, session.WorktreePath);
            }
            else
            {
                attachment = await AttachmentService.SaveBytesToWorktreeAsync(
                    pending.Data, pending.FileName, pending.ContentType, session.WorktreePath);
            }
            fileAttachments.Add(attachment);
        }

        var messageForClaude = AttachmentService.BuildMessageWithAttachments(input.Text, fileAttachments);

        if (fileAttachments.Count > 0)
            ChatState.AddUserMessage(session, input.Text, fileAttachments);
        else
            ChatState.AddUserMessage(session, input.Text);

        // Save immediately so user message persists even if navigation occurs mid-stream
        await SessionService.SaveSessionAsync(session);

        // Register so switching back to this session uses the live in-memory object
        ChatState.RegisterActiveSession(session);

        ChatState.SetStreaming(true, session.Id);
        ChatState.SetPhase(StreamingPhase.Sending, sessionId: session.Id);
        var assistantMsg = ChatState.StartAssistantMessage(session);

        // Summarize with Haiku before main model processing to set title & branch name
        if (isFirstMessage && session.Status == SessionStatus.Ready && !string.IsNullOrWhiteSpace(input.Text))
        {
            ChatState.SetPhase(StreamingPhase.Preparing, sessionId: session.Id);
            var (title, newBranch) = await SessionInitializer.SummarizeAndRenameBranchAsync(session, input.Text);
            if (!string.IsNullOrEmpty(title))
            {
                session.Title = title;
                if (newBranch != null)
                    session.BranchName = newBranch;

                ChatState.Tabs.UpdateChatTabTitle(title);

                var branchInfo = session.IsLocalDir ? "" : $" · 브랜치: {session.BranchName}";
                ChatState.AddSystemMessage(session, $"제목이 \"{title}\"(으)로 설정됨{branchInfo}");

                await SessionService.SaveSessionAsync(session);
            }
            ChatState.SetPhase(StreamingPhase.Sending, sessionId: session.Id);
        }
        bool firstEvent = true;
        _streamStartTime = DateTime.UtcNow;
        var streamCtx = new StreamProcessingContext
        {
            Session = session,
            AssistantMessage = assistantMsg,
            StreamStartTime = _streamStartTime
        };

        try
        {
            var conversationId = session.ConversationId;
            var systemPrompt = await SystemPromptBuilder.BuildAsync(session, ChatState.CurrentWorkspace);

            await foreach (var evt in ClaudeService.SendMessageAsync(
                messageForClaude,
                session.WorktreePath,
                session.Model,
                session.PermissionMode,
                effortLevel: session.EffortLevel ?? "auto",
                sessionId: session.Id,
                conversationId: conversationId,
                systemPrompt: systemPrompt))
            {
                if (firstEvent)
                {
                    ChatState.SetPhase(StreamingPhase.Thinking, sessionId: session.Id);
                    firstEvent = false;
                }

                await StreamProcessor.ProcessEventAsync(evt, streamCtx);
            }

            await StreamProcessor.FinalizeAsync(streamCtx);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error during message processing for session {SessionId}", session.Id);
            if (string.IsNullOrEmpty(assistantMsg.Text))
                ChatState.AppendText(assistantMsg, $"Error: {ex.Message}");
            await InvokeAsync(() => Snackbar.StreamingError(ex.Message));
        }
        finally
        {
            ChatState.FinishMessage(assistantMsg);
            ChatState.SetStreaming(false, session.Id);
            _shouldAutoScroll = true;

            // Apply finalized stream context results to UI state
            _planFilePath = streamCtx.PlanFilePath;
            _planContent = streamCtx.PlanContent;
            _planReviewVisible = streamCtx.PlanReviewVisible;
            _quickResponseVisible = streamCtx.QuickResponseVisible;
            _quickResponseOptions = streamCtx.QuickResponseOptions;

            if (streamCtx.PlanReviewVisible)
                _ = SendNotificationIfNeeded(session, "Plan ready for review", NotificationType.PlanReview);
            else if (streamCtx.QuickResponseVisible)
                _ = SendNotificationIfNeeded(session, "Response needed", NotificationType.Question);

            await InvokeAsync(StateHasChanged);
            await SessionService.SaveSessionAsync(session);
            ChatState.UnregisterActiveSession(session.Id);

            _ = Task.Run(async () =>
            {
                try
                {
                    await HooksEngine.FireAsync(HookEvent.OnMessageComplete, new Dictionary<string, string>
                    {
                        ["COMINOMI_SESSION_ID"] = session.Id,
                        ["COMINOMI_CITY_NAME"] = session.CityName
                    });
                }
                catch (Exception ex)
                {
                    Logger.LogWarning(ex, "Hook fire failed for OnMessageComplete");
                }
            });

            // Check if AI created a PR during this conversation
            if (session.Status == SessionStatus.Pushed && !string.IsNullOrEmpty(session.BranchName))
            {
                _ = CheckAndUpdatePrStatus(session);
            }

            if (!_quickResponseVisible && !_planReviewVisible)
            {
                _ = SendNotificationIfNeeded(session, "Task completed", NotificationType.Info);
            }
        }
    }

    private async Task CheckAndUpdatePrStatus(Session session)
    {
        var result = await PrWorkflow.CheckPrStatusAsync(session);
        if (result is var (prNumber, prUrl))
        {
            session.TransitionStatus(SessionStatus.PrOpen);
            session.PrUrl = prUrl;
            session.PrNumber = prNumber;
            await SessionService.SaveSessionAsync(session);
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task HandleEffortLevelChanged(string level)
    {
        if (ChatState.CurrentSession == null) return;
        ChatState.CurrentSession.EffortLevel = level;
        ChatState.NotifyStateChanged();
        await SessionService.SaveSessionAsync(ChatState.CurrentSession);
    }

    private async Task HandleModelChanged(string model)
    {
        if (ChatState.CurrentSession != null)
        {
            ChatState.CurrentSession.Model = model;
            await SessionService.SaveSessionAsync(ChatState.CurrentSession);
        }
    }


    private async Task SendNotificationIfNeeded(Session session, string body, NotificationType type)
    {
        try
        {
            // Only send if window is not focused or viewing a different session
            var isFocused = await JSRuntime.InvokeAsync<bool>("isWindowFocused");
            var isCurrentSession = ChatState.CurrentSession?.Id == session.Id;

            if (!isFocused || !isCurrentSession)
            {
                await NotificationService.SendAsync(session.CityName, body, type);
            }
        }
        catch { }
    }

    private void HandleCancel()
    {
        ClaudeService.Cancel(ChatState.CurrentSession?.Id);
    }

    // Workflow: send PR creation request to AI
    private async Task CreatePr(Session session)
    {
        try
        {
            var prompt = await PrWorkflow.BuildCreatePrPromptAsync(session);
            _ = HandleSend(new ChatInputMessage { Text = prompt });
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "CreatePr failed for session {SessionId}", session.Id);
            Snackbar.MergeError(ex.Message);
        }
    }

    // Workflow: merge an existing PR
    private async Task MergePr(Session session)
    {
        _operatingSessionId = session.Id;
        StateHasChanged();
        try
        {
            var (status, error) = await PrWorkflow.MergePrAsync(session);
            session.TransitionStatus(status);
            session.ErrorMessage = error;

            if (status == SessionStatus.Merged)
            {
                Snackbar.MergeSuccess(session.BranchName);
                _ = SendNotificationIfNeeded(session, $"Branch {session.BranchName} merged", NotificationType.Success);
            }
            else if (status == SessionStatus.ConflictDetected)
                Snackbar.ConflictDetected(session.BranchName);
            else if (!string.IsNullOrEmpty(error))
                Snackbar.MergeError(error);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "MergePr failed for session {SessionId}", session.Id);
            session.ErrorMessage = ex.Message;
            Snackbar.MergeError(ex.Message);
        }
        finally { _operatingSessionId = null; StateHasChanged(); }
    }

    private async Task ForcePushAndMerge(Session session)
    {
        _operatingSessionId = session.Id;
        StateHasChanged();
        try
        {
            var (status, error) = await PrWorkflow.ForcePushAsync(session);
            session.TransitionStatus(status);
            session.ErrorMessage = error;

            if (status != SessionStatus.Pushed)
            {
                if (!string.IsNullOrEmpty(error))
                    Snackbar.PushError(error);
                return;
            }

            session.ErrorMessage = null;
            Snackbar.Add("강제 푸시 완료. PR을 생성하세요.", Severity.Success);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "ForcePushAndMerge failed for session {SessionId}", session.Id);
            session.ErrorMessage = ex.Message;
            Snackbar.MergeError(ex.Message);
        }
        finally { _operatingSessionId = null; StateHasChanged(); }
    }

    private async Task ResolveConflicts(Session session)
    {
        session.TransitionStatus(SessionStatus.Ready);
        session.ErrorMessage = null;
        session.ConflictFiles = null;

        var (fullSession, prompt) = await PrWorkflow.ResolveConflictsAsync(session);
        if (fullSession != null)
        {
            ChatState.SetPendingMessage(prompt);
            ChatState.SetSession(fullSession);
        }

        StateHasChanged();
    }

    private async Task HandleIssueLinked(IssueInfo issue)
    {
        if (ChatState.CurrentSession == null) return;
        ChatState.CurrentSession.IssueNumber = issue.Number;
        ChatState.CurrentSession.IssueUrl = issue.Url;
        await SessionService.SaveSessionAsync(ChatState.CurrentSession);
        StateHasChanged();
    }

    // === Landing page helpers ===

    private static string GetStatusDotClass(SessionStatus status) => status switch
    {
        SessionStatus.Ready => "ready",
        SessionStatus.Pushed => "pushed",
        SessionStatus.PrOpen => "pr-open",
        SessionStatus.Merged => "merged",
        SessionStatus.ConflictDetected => "conflict",
        SessionStatus.Error => "error",
        SessionStatus.Pending => "pending",
        _ => "pending"
    };

    private async Task LoadRecentSessions()
    {
        if (ChatState.CurrentWorkspace == null) { _recentSessions = []; return; }
        try
        {
            var sessions = await SessionService.GetSessionsByWorkspaceAsync(ChatState.CurrentWorkspace.Id);
            _recentSessions = sessions
                .Where(s => s.Status != SessionStatus.Archived && !string.IsNullOrEmpty(s.Title))
                .OrderByDescending(s => s.UpdatedAt)
                .Take(3)
                .ToList();
        }
        catch { _recentSessions = []; }
    }

    private void LandingCreateWorkspace()
    {
        ChatState.RequestCreateWorkspace();
    }

    private async Task ResumeRecentSession(Session session)
    {
        var fullSession = await SessionService.LoadSessionAsync(session.Id);
        if (fullSession != null) ChatState.SetSession(fullSession);
    }

    public void Dispose()
    {
        ChatState.OnChange -= HandleStateChanged;
    }
}
