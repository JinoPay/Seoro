@using Cominomi.Shared.Models
@using Microsoft.Extensions.Logging
@using System.Text.Json
@inject IChatState ChatState
@inject IClaudeService ClaudeService
@inject ISessionService SessionService
@inject IChatPrWorkflowService PrWorkflow
@inject IAttachmentService AttachmentService
@inject ISystemPromptBuilder SystemPromptBuilder
@inject ISessionInitializer SessionInitializer
@inject IHooksEngine HooksEngine
@inject IJSRuntime JSRuntime
@inject ILogger<ChatView> Logger
@inject ISnackbar Snackbar
@inject INotificationService NotificationService
@inject IStreamEventProcessor StreamProcessor
@implements IDisposable

<div class="chat-container">
    @* Workflow actions bar *@
    <SessionWorkflowBar Session="ChatState.CurrentSession"
                        OnLinkIssueRequested="@(() => _linkIssueDialogOpen = true)"
                        OnSendMessage="HandleSend" />

    @* Message area *@
    <div class="message-area" id="message-list">
        @if (ChatState.CurrentSession == null)
        {
            <LandingPage @ref="_landingPage" />
        }
        else if (ChatState.CurrentSession.Messages.Count == 0)
        {
            <div class="welcome-container">
                <MudIcon Icon="@Icons.Material.Filled.Terminal" Size="Size.Large" Color="Color.Primary" Style="opacity: 0.4;" />
                <span class="welcome-title">무엇을 도와드릴까요?</span>
                @if (ChatState.CurrentSession.Status == SessionStatus.Pending)
                {
                    <BranchSelector BranchGroups="_branchGroups"
                                    SelectedBranch="@_selectedBranch"
                                    SelectedBranchChanged="@(b => _selectedBranch = b)"
                                    IsLoading="_isLoadingBranches" />
                }
            </div>
        }
        else
        {
            <div class="message-container">
                @foreach (var message in ChatState.CurrentSession.Messages)
                {
                    <MessageBubble Message="message" />
                }
            </div>
        }
    </div>

    @* Quick response bar *@
    <QuickResponseBar IsVisible="@(_quickResponseVisible && !_planReviewVisible)"
                      Options="_quickResponseOptions"
                      OnResponse="HandleQuickResponse" />

    @* Plan review bar *@
    <PlanReviewBar IsVisible="_planReviewVisible"
                   PlanContent="@_planContent"
                   PlanFilePath="@_planFilePath"
                   OnAction="HandlePlanReviewAction"
                   OnAdvice="HandlePlanAdvice" />

    @* Input area *@
    @if (ChatState.CurrentSession != null)
    {
        <InputArea OnSend="HandleSend" OnCancel="HandleCancel" OnContinue="HandleContinue"
                   IsStreaming="ChatState.IsStreaming"
                   CanContinue="@(!string.IsNullOrEmpty(ChatState.CurrentSession.ConversationId))"
                   Disabled="@(ChatState.CurrentSession.Status == SessionStatus.Archived || _isInitializingWorktree)"
                   PermissionMode="@(ChatState.CurrentSession.PermissionMode ?? "bypassAll")"
                   PermissionModeChanged="HandlePermissionModeChanged"
                   EffortLevel="@(ChatState.CurrentSession.EffortLevel ?? "auto")"
                   EffortLevelChanged="HandleEffortLevelChanged"
                   Model="@(ChatState.CurrentSession.Model ?? "")"
                   OnModelChanged="HandleModelChanged"
                   ResolvedModel="@(ChatState.CurrentSession.ResolvedModel)"
                   CurrentSession="@ChatState.CurrentSession" />
    }
</div>

<LinkIssueDialog @bind-IsOpen="_linkIssueDialogOpen" OnIssueLinked="HandleIssueLinked" />

@code {
    private List<BranchGroup> _branchGroups = [];
    private string _selectedBranch = "";
    private bool _isInitializingWorktree;
    private bool _linkIssueDialogOpen;
    private bool _quickResponseVisible;
    private List<string> _quickResponseOptions = [];
    private bool _planReviewVisible;
    private string? _planFilePath;
    private string? _planContent;
    private DateTime _streamStartTime;
    private string? _lastPrCheckedSessionId;
    private bool _shouldAutoScroll;
    private bool _isLoadingBranches;
    private LandingPage? _landingPage;
    private CancellationTokenSource? _messageCts;

    protected override void OnInitialized()
    {
        ChatState.OnChange += HandleStateChanged;
    }

    private void HandleStateChanged()
    {
        _ = InvokeAsync(() =>
        {
            try
            {
                bool needsBranches = ChatState.CurrentSession?.Status == SessionStatus.Pending
                                     && _branchGroups.Count == 0 && !_isLoadingBranches;

                var pendingMsg = ChatState.ConsumePendingMessage();
                if (pendingMsg != null && ChatState.CurrentSession != null && !ChatState.IsStreaming)
                {
                    StateHasChanged();
                    _ = HandleSend(new ChatInputMessage { Text = pendingMsg });
                    return;
                }

                // Restore plan review state when switching to a session with completed plan
                if (ChatState.CurrentSession is { PlanCompleted: true, PermissionMode: "plan" } && !ChatState.IsStreaming)
                {
                    _planReviewVisible = true;
                    if (_planContent == null && !string.IsNullOrEmpty(ChatState.CurrentSession.Git.WorktreePath))
                        _ = RestorePlanContentAsync(ChatState.CurrentSession.Git.WorktreePath, ChatState.CurrentSession.PlanFilePath);
                }
                else if (ChatState.CurrentSession?.PermissionMode != "plan" || ChatState.IsStreaming)
                {
                    if (!ChatState.IsStreaming)
                        _planReviewVisible = false;
                }

                if (ChatState.IsStreaming)
                    _shouldAutoScroll = true;

                if (needsBranches)
                    _isLoadingBranches = true;

                StateHasChanged();

                if (needsBranches)
                    _ = LoadBranchesInBackground();

                if (ChatState.CurrentSession == null)
                    _ = _landingPage?.RefreshAsync();

                // 세션 전환 시 GitHub PR 상태 자동 확인
                if (ChatState.CurrentSession != null
                    && !ChatState.CurrentSession.Git.IsLocalDir
                    && ChatState.CurrentSession.Id != _lastPrCheckedSessionId
                    && ChatState.CurrentSession.Status is SessionStatus.Ready or SessionStatus.Pushed
                    && ChatState.CurrentSession.Pr.PrNumber == null
                    && !string.IsNullOrEmpty(ChatState.CurrentSession.Git.BranchName))
                {
                    _lastPrCheckedSessionId = ChatState.CurrentSession.Id;
                    _ = CheckAndUpdatePrStatus(ChatState.CurrentSession);
                }
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "HandleStateChanged failed");
            }
        });
    }

    private async Task RestorePlanContentAsync(string worktreePath, string? savedPlanFilePath = null)
    {
        _planFilePath = null;
        _planContent = null;

        if (!string.IsNullOrEmpty(savedPlanFilePath) && File.Exists(savedPlanFilePath))
        {
            _planFilePath = savedPlanFilePath;
            _planContent = await File.ReadAllTextAsync(savedPlanFilePath);
        }
        else
        {
            var plansDir = Path.Combine(worktreePath, ".claude", "plans");
            if (Directory.Exists(plansDir))
            {
                var planFile = Directory.GetFiles(plansDir, "*.md")
                    .OrderByDescending(f => File.GetLastWriteTimeUtc(f))
                    .FirstOrDefault();
                if (planFile != null)
                {
                    _planFilePath = planFile;
                    _planContent = await File.ReadAllTextAsync(planFile);
                }
            }
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadBranchesInBackground()
    {
        try
        {
            var ws = ChatState.CurrentWorkspace;
            if (ws == null || string.IsNullOrEmpty(ws.RepoLocalPath)) return;

            var (groups, defaultBranch) = await SessionInitializer.LoadBranchesAsync(ws.RepoLocalPath);
            _branchGroups = groups;
            _selectedBranch = defaultBranch;
        }
        finally
        {
            _isLoadingBranches = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_shouldAutoScroll)
        {
            _shouldAutoScroll = false;
            await JSRuntime.InvokeVoidAsync("scrollToBottom", "message-list");
        }
    }

    private async Task HandlePermissionModeChanged(string mode)
    {
        if (ChatState.CurrentSession == null) return;
        ChatState.CurrentSession.PermissionMode = mode;
        ChatState.NotifyStateChanged();
        await SessionService.SaveSessionAsync(ChatState.CurrentSession);
    }

    private Task HandleQuickResponse(string response)
    {
        _quickResponseVisible = false;
        _quickResponseOptions = [];
        return HandleSend(new ChatInputMessage { Text = response });
    }

    private async Task HandlePlanReviewAction(PlanReviewAction action)
    {
        _planReviewVisible = false;

        switch (action)
        {
            case PlanReviewAction.Approve:
                await HandlePermissionModeChanged("bypassAll");
                var planRef = !string.IsNullOrEmpty(_planFilePath)
                    ? ".claude/plans/ 에 저장된 플랜 파일을 참고하여 "
                    : "";
                await HandleSend(new ChatInputMessage
                {
                    Text = $"플랜을 승인합니다. {planRef}구현을 진행해주세요. 플랜의 각 단계를 순서대로 실행하세요."
                });
                if (ChatState.CurrentSession != null)
                {
                    ChatState.CurrentSession.PlanCompleted = false;
                    ChatState.CurrentSession.PlanFilePath = null;
                }
                _planFilePath = null;
                _planContent = null;
                break;

            case PlanReviewAction.Advice:
                break;

            case PlanReviewAction.Reject:
                await HandleSend(new ChatInputMessage
                {
                    Text = "플랜을 거절합니다. 다른 접근 방식을 제안해주세요."
                });
                break;
        }
    }

    private async Task HandlePlanAdvice(string advice)
    {
        _planReviewVisible = false;
        await HandleSend(new ChatInputMessage
        {
            Text = $"플랜에 대한 피드백: {advice}\n\n이 피드백을 반영하여 플랜을 수정해주세요."
        });
    }

    private Task HandleSend(ChatInputMessage input)
    {
        if (ChatState.CurrentSession == null || (string.IsNullOrWhiteSpace(input.Text) && input.Attachments.Count == 0))
            return Task.CompletedTask;

        _quickResponseVisible = false;
        _quickResponseOptions = [];
        _planReviewVisible = false;

        _messageCts?.Cancel();
        _messageCts?.Dispose();
        _messageCts = new CancellationTokenSource();
        var ct = _messageCts.Token;

        _ = Task.Run(async () =>
        {
            try
            {
                await ProcessMessageAsync(input, ct);
            }
            catch (OperationCanceledException)
            {
                // Cancellation is expected — no action needed
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Unhandled exception in ProcessMessageAsync for session {SessionId}",
                    ChatState.CurrentSession?.Id);
            }
        });
        return Task.CompletedTask;
    }

    private async Task ProcessMessageAsync(ChatInputMessage input, CancellationToken ct = default)
    {
        var session = ChatState.CurrentSession!;

        if (session.Status == SessionStatus.Pending)
        {
            if (string.IsNullOrEmpty(_selectedBranch) || _isInitializingWorktree)
                return;

            try
            {
                _isInitializingWorktree = true;
                await InvokeAsync(StateHasChanged);

                var updated = await SessionService.InitializeWorktreeAsync(session.Id, _selectedBranch);
                session.Git.WorktreePath = updated.Git.WorktreePath;
                session.Git.BranchName = updated.Git.BranchName;
                session.Git.BaseBranch = updated.Git.BaseBranch;
                session.SetInitialStatus(updated.Status);
                session.Error = updated.Error;

                if (session.Status == SessionStatus.Error)
                {
                    ChatState.NotifyStateChanged();
                    return;
                }
            }
            catch (Exception ex)
            {
                session.TransitionStatus(SessionStatus.Error);
                session.Error = AppError.FromException(ErrorCode.WorktreeCreationFailed, ex);
                ChatState.NotifyStateChanged();
                return;
            }
            finally
            {
                _isInitializingWorktree = false;
                await InvokeAsync(StateHasChanged);
            }
        }

        ct.ThrowIfCancellationRequested();

        var isFirstMessage = session.Messages.Count(m => m.Role == MessageRole.User) == 0;

        var fileAttachments = new List<FileAttachment>();
        foreach (var pending in input.Attachments)
        {
            FileAttachment attachment;
            if (pending.FilePath != null && pending.Data.Length == 0)
            {
                attachment = await AttachmentService.CopyFileToWorktreeAsync(pending.FilePath, session.Git.WorktreePath);
            }
            else
            {
                attachment = await AttachmentService.SaveBytesToWorktreeAsync(
                    pending.Data, pending.FileName, pending.ContentType, session.Git.WorktreePath);
            }
            fileAttachments.Add(attachment);
        }

        var messageForClaude = AttachmentService.BuildMessageWithAttachments(input.Text, fileAttachments);

        if (fileAttachments.Count > 0)
            ChatState.AddUserMessage(session, input.Text, fileAttachments);
        else
            ChatState.AddUserMessage(session, input.Text);

        await SessionService.SaveSessionAsync(session);
        ChatState.RegisterActiveSession(session);

        ChatState.SetStreaming(true, session.Id);
        ChatState.SetPhase(StreamingPhase.Sending, sessionId: session.Id);
        var assistantMsg = ChatState.StartAssistantMessage(session);

        if (isFirstMessage && session.Status == SessionStatus.Ready && !string.IsNullOrWhiteSpace(input.Text))
        {
            ChatState.SetPhase(StreamingPhase.Preparing, sessionId: session.Id);
            var (title, newBranch) = await SessionInitializer.SummarizeAndRenameBranchAsync(session, input.Text);
            if (!string.IsNullOrEmpty(title))
            {
                session.Title = title;
                if (newBranch != null)
                    session.Git.BranchName = newBranch;

                ChatState.Tabs.UpdateChatTabTitle(title);

                var branchInfo = session.Git.IsLocalDir ? "" : $" · 브랜치: {session.Git.BranchName}";
                ChatState.AddSystemMessage(session, $"제목이 \"{title}\"(으)로 설정됨{branchInfo}");

                await SessionService.SaveSessionAsync(session);
            }
            ChatState.SetPhase(StreamingPhase.Sending, sessionId: session.Id);
        }
        bool firstEvent = true;
        _streamStartTime = DateTime.UtcNow;
        var streamCtx = new StreamProcessingContext
        {
            Session = session,
            AssistantMessage = assistantMsg,
            StreamStartTime = _streamStartTime
        };

        try
        {
            ct.ThrowIfCancellationRequested();

            var conversationId = session.ConversationId;
            var systemPrompt = await SystemPromptBuilder.BuildAsync(session, ChatState.CurrentWorkspace);

            await foreach (var evt in ClaudeService.SendMessageAsync(
                messageForClaude,
                session.Git.WorktreePath,
                session.Model,
                session.PermissionMode,
                effortLevel: session.EffortLevel ?? "auto",
                sessionId: session.Id,
                conversationId: conversationId,
                systemPrompt: systemPrompt).WithCancellation(ct))
            {
                if (firstEvent)
                {
                    ChatState.SetPhase(StreamingPhase.Thinking, sessionId: session.Id);
                    firstEvent = false;
                }

                await StreamProcessor.ProcessEventAsync(evt, streamCtx);
            }

            await StreamProcessor.FinalizeAsync(streamCtx);
        }
        catch (OperationCanceledException) when (ct.IsCancellationRequested)
        {
            Logger.LogInformation("Message processing cancelled for session {SessionId}", session.Id);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error during message processing for session {SessionId}", session.Id);
            if (string.IsNullOrEmpty(assistantMsg.Text))
                ChatState.AppendText(assistantMsg, $"Error: {ex.Message}");
            await InvokeAsync(() => Snackbar.StreamingError(ex.Message));
        }
        finally
        {
            ChatState.FinishMessage(assistantMsg);
            ChatState.SetStreaming(false, session.Id);
            _shouldAutoScroll = true;

            _planFilePath = streamCtx.PlanFilePath;
            _planContent = streamCtx.PlanContent;
            _planReviewVisible = streamCtx.PlanReviewVisible;
            _quickResponseVisible = streamCtx.QuickResponseVisible;
            _quickResponseOptions = streamCtx.QuickResponseOptions;

            if (streamCtx.PlanReviewVisible)
                _ = SendNotificationIfNeeded(session, "Plan ready for review", NotificationType.PlanReview);
            else if (streamCtx.QuickResponseVisible)
                _ = SendNotificationIfNeeded(session, "Response needed", NotificationType.Question);

            await InvokeAsync(StateHasChanged);
            await SessionService.SaveSessionAsync(session);
            ChatState.UnregisterActiveSession(session.Id);

            _ = Task.Run(async () =>
            {
                try
                {
                    await HooksEngine.FireAsync(HookEvent.OnMessageComplete, new Dictionary<string, string>
                    {
                        ["COMINOMI_SESSION_ID"] = session.Id,
                        ["COMINOMI_CITY_NAME"] = session.CityName
                    });
                }
                catch (Exception ex)
                {
                    Logger.LogWarning(ex, "Hook fire failed for OnMessageComplete");
                }
            });

            if (session.Status == SessionStatus.Pushed && !string.IsNullOrEmpty(session.Git.BranchName))
            {
                _ = CheckAndUpdatePrStatus(session);
            }

            if (!_quickResponseVisible && !_planReviewVisible)
            {
                _ = SendNotificationIfNeeded(session, "Task completed", NotificationType.Info);
            }
        }
    }

    private async Task CheckAndUpdatePrStatus(Session session)
    {
        try
        {
            var result = await PrWorkflow.CheckPrStatusAsync(session);
            if (result is var (prNumber, prUrl))
            {
                session.TransitionStatus(SessionStatus.PrOpen);
                session.Pr.PrUrl = prUrl;
                session.Pr.PrNumber = prNumber;
                await SessionService.SaveSessionAsync(session);
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "PR status check failed for session {SessionId}", session.Id);
        }
    }

    private async Task HandleEffortLevelChanged(string level)
    {
        if (ChatState.CurrentSession == null) return;
        ChatState.CurrentSession.EffortLevel = level;
        ChatState.NotifyStateChanged();
        await SessionService.SaveSessionAsync(ChatState.CurrentSession);
    }

    private async Task HandleModelChanged(string model)
    {
        if (ChatState.CurrentSession != null)
        {
            ChatState.CurrentSession.Model = model;
            await SessionService.SaveSessionAsync(ChatState.CurrentSession);
        }
    }

    private async Task SendNotificationIfNeeded(Session session, string body, NotificationType type)
    {
        try
        {
            var isFocused = await JSRuntime.InvokeAsync<bool>("isWindowFocused");
            var isCurrentSession = ChatState.CurrentSession?.Id == session.Id;

            if (!isFocused || !isCurrentSession)
            {
                await NotificationService.SendAsync(session.CityName, body, type);
            }
        }
        catch (Exception ex)
        {
            Logger.LogDebug(ex, "Failed to send notification for session {SessionId}", session.Id);
        }
    }

    private void HandleCancel()
    {
        ClaudeService.Cancel(ChatState.CurrentSession?.Id);
    }

    private Task HandleContinue()
    {
        if (ChatState.CurrentSession == null || string.IsNullOrEmpty(ChatState.CurrentSession.ConversationId))
            return Task.CompletedTask;

        _quickResponseVisible = false;
        _quickResponseOptions = [];
        _planReviewVisible = false;

        _messageCts?.Cancel();
        _messageCts?.Dispose();
        _messageCts = new CancellationTokenSource();
        var ct = _messageCts.Token;

        _ = Task.Run(async () =>
        {
            try
            {
                await ProcessContinueAsync(ct);
            }
            catch (OperationCanceledException)
            {
                // Cancellation is expected — no action needed
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Unhandled exception in ProcessContinueAsync for session {SessionId}",
                    ChatState.CurrentSession?.Id);
            }
        });
        return Task.CompletedTask;
    }

    private async Task ProcessContinueAsync(CancellationToken ct = default)
    {
        var session = ChatState.CurrentSession!;

        ChatState.AddSystemMessage(session, "계속 진행 중...");
        ChatState.SetStreaming(true, session.Id);
        ChatState.SetPhase(StreamingPhase.Sending, sessionId: session.Id);
        var assistantMsg = ChatState.StartAssistantMessage(session);
        ChatState.RegisterActiveSession(session);

        bool firstEvent = true;
        _streamStartTime = DateTime.UtcNow;
        var streamCtx = new StreamProcessingContext
        {
            Session = session,
            AssistantMessage = assistantMsg,
            StreamStartTime = _streamStartTime
        };

        try
        {
            ct.ThrowIfCancellationRequested();

            var systemPrompt = await SystemPromptBuilder.BuildAsync(session, ChatState.CurrentWorkspace);

            await foreach (var evt in ClaudeService.SendMessageAsync(
                string.Empty,
                session.Git.WorktreePath,
                session.Model,
                session.PermissionMode,
                effortLevel: session.EffortLevel ?? "auto",
                sessionId: session.Id,
                conversationId: session.ConversationId,
                systemPrompt: systemPrompt,
                continueMode: true).WithCancellation(ct))
            {
                if (firstEvent)
                {
                    ChatState.SetPhase(StreamingPhase.Thinking, sessionId: session.Id);
                    firstEvent = false;
                }

                await StreamProcessor.ProcessEventAsync(evt, streamCtx);
            }

            await StreamProcessor.FinalizeAsync(streamCtx);
        }
        catch (OperationCanceledException) when (ct.IsCancellationRequested)
        {
            Logger.LogInformation("Continue cancelled for session {SessionId}", session.Id);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error during continue for session {SessionId}", session.Id);
            if (string.IsNullOrEmpty(assistantMsg.Text))
                ChatState.AppendText(assistantMsg, $"Error: {ex.Message}");
            await InvokeAsync(() => Snackbar.StreamingError(ex.Message));
        }
        finally
        {
            ChatState.FinishMessage(assistantMsg);
            ChatState.SetStreaming(false, session.Id);
            _shouldAutoScroll = true;

            _planFilePath = streamCtx.PlanFilePath;
            _planContent = streamCtx.PlanContent;
            _planReviewVisible = streamCtx.PlanReviewVisible;
            _quickResponseVisible = streamCtx.QuickResponseVisible;
            _quickResponseOptions = streamCtx.QuickResponseOptions;

            await InvokeAsync(StateHasChanged);
            await SessionService.SaveSessionAsync(session);
            ChatState.UnregisterActiveSession(session.Id);
        }
    }

    private async Task HandleIssueLinked(IssueInfo issue)
    {
        if (ChatState.CurrentSession == null) return;
        ChatState.CurrentSession.Pr.IssueNumber = issue.Number;
        ChatState.CurrentSession.Pr.IssueUrl = issue.Url;
        await SessionService.SaveSessionAsync(ChatState.CurrentSession);
        StateHasChanged();
    }

    public void Dispose()
    {
        ChatState.OnChange -= HandleStateChanged;
        _messageCts?.Cancel();
        _messageCts?.Dispose();
    }
}
