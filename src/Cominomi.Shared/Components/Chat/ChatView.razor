@using Cominomi.Shared.Models
@inject ChatState ChatState
@inject IClaudeService ClaudeService
@inject ISessionService SessionService
@inject IGitService GitService
@inject IWorkspaceService WorkspaceService
@inject IAttachmentService AttachmentService
@inject IContextService ContextService
@inject IMemoryService MemoryService
@inject IHooksEngine HooksEngine
@inject IJSRuntime JSRuntime
@implements IDisposable

<MudStack Style="height: 100%; overflow: hidden;" Justify="Justify.SpaceBetween" Spacing="0">
    @if (ChatState.CurrentSession?.PermissionMode == "plan")
    {
        <div class="mode-bar plan">
            <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Small" />
            <span>플랜 모드 — Claude가 읽기와 조사만 하고 수정하지 않습니다</span>
        </div>
    }
    else if (ChatState.CurrentSession?.PermissionMode == "bypassAll")
    {
        <div class="mode-bar full-access">
            <MudIcon Icon="@Icons.Material.Filled.Security" Size="Size.Small" />
            <span>풀 액세스 — Claude가 모든 작업을 묻지 않고 자동 승인합니다</span>
        </div>
    }

    <MudStack Style="flex: 1; overflow-y: auto; padding: 16px; min-height: 0;" id="message-list" @ref="_messageListRef">
        @if (ChatState.CurrentSession == null)
        {
            <div class="welcome-container">
                <MudIcon Icon="@Icons.Material.Filled.Chat" Size="Size.Large" Color="Color.Primary" Style="opacity: 0.6;" />
                <span class="welcome-title" style="color: var(--mud-palette-primary);">Cominomi</span>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Style="opacity: 0.6;">
                    새 대화를 시작하거나 사이드바에서 선택하세요
                </MudText>
            </div>
        }
        else if (ChatState.CurrentSession.Messages.Count == 0)
        {
            <div class="welcome-container">
                <MudIcon Icon="@Icons.Material.Filled.Terminal" Size="Size.Large" Color="Color.Primary" Style="opacity: 0.5;" />
                <span class="welcome-title">무엇을 도와드릴까요?</span>
                @if (ChatState.CurrentSession.Status == SessionStatus.Pending && _branches.Count > 0)
                {
                    <MudSelect T="string" @bind-Value="_selectedBranch" Label="기본 브랜치"
                               Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true"
                               Style="max-width: 280px;">
                        @foreach (var branch in _branches)
                        {
                            <MudSelectItem T="string" Value="@branch">@branch</MudSelectItem>
                        }
                    </MudSelect>
                }
            </div>
        }
        else
        {
            <div class="message-list-inner">
                @foreach (var message in ChatState.CurrentSession.Messages)
                {
                    <MessageBubble Message="message" />
                }
            </div>
        }
    </MudStack>

    @if (ChatState.CurrentSession != null)
    {
        <div class="branch-bar">
            <MudIcon Icon="@Icons.Material.Filled.AccountTree" Size="Size.Small" Style="width: 14px; height: 14px;" />
            <span class="branch-name">
                @if (ChatState.CurrentSession.Status == SessionStatus.Pending)
                {
                    @($"base: {_selectedBranch}")
                }
                else
                {
                    @(ChatState.CurrentSession.BranchName ?? "브랜치 없음")
                }
            </span>
            @if (ChatState.CurrentSession.Status != SessionStatus.Pending)
            {
                <span class="worktree-path">@ShortenPath(ChatState.CurrentSession.WorktreePath)</span>
            }
        </div>
    }

    <InputArea OnSend="HandleSend" OnCancel="HandleCancel" IsStreaming="ChatState.IsStreaming"
               Disabled="@(ChatState.CurrentSession == null || ChatState.CurrentSession.Status == SessionStatus.Archived || _isInitializingWorktree)"
               PermissionMode="@(ChatState.CurrentSession?.PermissionMode ?? "default")"
               PermissionModeChanged="HandlePermissionModeChanged"
               Model="@(ChatState.CurrentSession?.Model ?? "")"
               OnModelChanged="HandleModelChanged"
               ResolvedModel="@(ChatState.CurrentSession?.ResolvedModel)"
               CurrentSession="@ChatState.CurrentSession" />
</MudStack>

@code {
    private MudStack? _messageListRef;
    private List<string> _branches = [];
    private string _selectedBranch = "";
    private bool _isInitializingWorktree;

    protected override void OnInitialized()
    {
        ChatState.OnChange += HandleStateChanged;
    }

    private bool _isLoadingBranches;

    private async void HandleStateChanged()
    {
        await InvokeAsync(() =>
        {
            // Check if we need branches but don't block render on it
            bool needsBranches = ChatState.CurrentSession?.Status == SessionStatus.Pending
                                 && _branches.Count == 0 && !_isLoadingBranches;

            // Auto-send pending message (e.g., conflict resolution prompt)
            var pendingMsg = ChatState.ConsumePendingMessage();
            if (pendingMsg != null && ChatState.CurrentSession != null && !ChatState.IsStreaming)
            {
                StateHasChanged();
                _ = HandleSend(new ChatInputMessage { Text = pendingMsg });
                return;
            }

            // Auto-scroll during streaming (debounced via ChatState timer)
            if (ChatState.IsStreaming)
                _shouldAutoScroll = true;

            StateHasChanged(); // Render immediately without waiting for branches

            if (needsBranches)
            {
                _ = LoadBranchesInBackground(); // Fire-and-forget
            }
        });
    }

    private async Task LoadBranchesInBackground()
    {
        _isLoadingBranches = true;
        try
        {
            var ws = ChatState.CurrentWorkspace;
            if (ws == null || string.IsNullOrEmpty(ws.RepoLocalPath)) return;

            // Run both git commands in parallel instead of sequentially
            var branchesTask = GitService.ListBranchesAsync(ws.RepoLocalPath);
            var defaultBranchTask = GitService.DetectDefaultBranchAsync(ws.RepoLocalPath);
            await Task.WhenAll(branchesTask, defaultBranchTask);

            _branches = branchesTask.Result;
            var defaultBranch = defaultBranchTask.Result;
            _selectedBranch = defaultBranch ?? _branches.FirstOrDefault() ?? "";

            await InvokeAsync(StateHasChanged); // Re-render with branches loaded
        }
        finally
        {
            _isLoadingBranches = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_shouldAutoScroll)
        {
            _shouldAutoScroll = false;
            await JSRuntime.InvokeVoidAsync("scrollToBottom", "message-list");
        }
    }

    private static string ShortenPath(string path)
    {
        if (string.IsNullOrEmpty(path)) return "(디렉토리 미설정)";
        var home = Environment.GetFolderPath(Environment.SpecialFolder.UserProfile);
        if (path.StartsWith(home))
            return "~" + path[home.Length..];
        return path;
    }

    private async Task HandlePermissionModeChanged(string mode)
    {
        if (ChatState.CurrentSession == null) return;
        ChatState.CurrentSession.PermissionMode = mode;
        ChatState.NotifyStateChanged();
        await SessionService.SaveSessionAsync(ChatState.CurrentSession);
    }

    private bool _shouldAutoScroll;

    private Task HandleSend(ChatInputMessage input)
    {
        if (ChatState.CurrentSession == null || (string.IsNullOrWhiteSpace(input.Text) && input.Attachments.Count == 0))
            return Task.CompletedTask;

        _ = ProcessMessageAsync(input);
        return Task.CompletedTask;
    }

    private async Task ProcessMessageAsync(ChatInputMessage input)
    {
        var session = ChatState.CurrentSession!;

        // Initialize worktree on first message if session is Pending
        if (session.Status == SessionStatus.Pending)
        {
            if (string.IsNullOrEmpty(_selectedBranch))
                return;

            _isInitializingWorktree = true;
            StateHasChanged();

            try
            {
                var updated = await SessionService.InitializeWorktreeAsync(session.Id, _selectedBranch);
                session.WorktreePath = updated.WorktreePath;
                session.BranchName = updated.BranchName;
                session.BaseBranch = updated.BaseBranch;
                session.Status = updated.Status;
                session.ErrorMessage = updated.ErrorMessage;

                if (session.Status == SessionStatus.Error)
                {
                    ChatState.NotifyStateChanged();
                    return;
                }
            }
            catch (Exception ex)
            {
                session.Status = SessionStatus.Error;
                session.ErrorMessage = ex.Message;
                ChatState.NotifyStateChanged();
                return;
            }
            finally
            {
                _isInitializingWorktree = false;
                StateHasChanged();
            }
        }

        var isFirstMessage = session.Messages.Count(m => m.Role == MessageRole.User) == 0;

        // Process attachments
        var fileAttachments = new List<FileAttachment>();
        foreach (var pending in input.Attachments)
        {
            FileAttachment attachment;
            if (pending.FilePath != null && pending.Data.Length == 0)
            {
                attachment = await AttachmentService.CopyFileToWorktreeAsync(pending.FilePath, session.WorktreePath);
            }
            else
            {
                attachment = await AttachmentService.SaveBytesToWorktreeAsync(
                    pending.Data, pending.FileName, pending.ContentType, session.WorktreePath);
            }
            fileAttachments.Add(attachment);
        }

        // Build the message to send to Claude (with file references)
        var messageForClaude = AttachmentService.BuildMessageWithAttachments(input.Text, fileAttachments);

        if (fileAttachments.Count > 0)
            ChatState.AddUserMessage(input.Text, fileAttachments);
        else
            ChatState.AddUserMessage(input.Text);

        ChatState.SetStreaming(true, session.Id);
        ChatState.SetPhase(StreamingPhase.Sending, sessionId: session.Id);

        var assistantMsg = ChatState.StartAssistantMessage();
        ToolCall? currentToolCall = null;
        bool firstEvent = true;

        try
        {
            // Build full system prompt: workspace prompt + context + memory
            var conversationId = session.ConversationId;
            var systemPrompt = await BuildSystemPromptAsync(session);

            await foreach (var evt in ClaudeService.SendMessageAsync(
                messageForClaude,
                session.WorktreePath,
                session.Model,
                session.PermissionMode,
                sessionId: session.Id,
                conversationId: conversationId,
                systemPrompt: systemPrompt))
            {
                if (firstEvent)
                {
                    ChatState.SetPhase(StreamingPhase.Thinking, sessionId: session.Id);
                    firstEvent = false;
                }

                switch (evt.Type)
                {
                    case "system" when evt.Subtype == "init":
                        if (evt.Model != null)
                            ChatState.CurrentSession!.ResolvedModel = evt.Model;
                        // Capture conversation ID for resume
                        if (!string.IsNullOrEmpty(evt.SessionId))
                            session.ConversationId = evt.SessionId;
                        break;

                    case "content_block_start" when evt.ContentBlock?.Type == "tool_use":
                        currentToolCall = new ToolCall
                        {
                            Id = evt.ContentBlock.Id ?? "",
                            Name = evt.ContentBlock.Name ?? ""
                        };
                        ChatState.AddToolCall(assistantMsg, currentToolCall);
                        ChatState.SetPhase(StreamingPhase.UsingTool, evt.ContentBlock.Name, session.Id);
                        break;

                    case "content_block_delta":
                        if (evt.Delta?.Type == "text_delta" && evt.Delta.Text != null)
                        {
                            ChatState.AppendText(assistantMsg, evt.Delta.Text);
                            ChatState.SetPhase(StreamingPhase.WritingText, sessionId: session.Id);
                        }
                        else if (evt.Delta?.Type == "input_json_delta" && evt.Delta.PartialJson != null && currentToolCall != null)
                        {
                            currentToolCall.Input += evt.Delta.PartialJson;
                        }
                        break;

                    case "content_block_stop":
                        if (currentToolCall != null)
                        {
                            currentToolCall.IsComplete = true;
                            currentToolCall = null;
                            ChatState.NotifyStateChanged();
                        }
                        ChatState.SetPhase(StreamingPhase.Thinking, sessionId: session.Id);
                        break;

                    case "result":
                        // Capture conversation ID from result if not already set
                        if (string.IsNullOrEmpty(session.ConversationId) && !string.IsNullOrEmpty(evt.SessionId))
                            session.ConversationId = evt.SessionId;
                        if (string.IsNullOrEmpty(assistantMsg.Text) && evt.Message?.Content != null)
                        {
                            foreach (var block in evt.Message.Content)
                            {
                                if (block.Type == "text" && block.Text != null)
                                    ChatState.AppendText(assistantMsg, block.Text);
                            }
                        }
                        if (string.IsNullOrEmpty(assistantMsg.Text) && !string.IsNullOrEmpty(evt.Result))
                            ChatState.AppendText(assistantMsg, evt.Result);
                        break;

                    case "error":
                        if (!string.IsNullOrEmpty(evt.Error))
                        {
                            ChatState.AppendText(assistantMsg, $"\n\n**Error:** {evt.Error}");
                        }
                        break;

                    default:
                        if (evt.Message?.Content != null)
                        {
                            foreach (var block in evt.Message.Content)
                            {
                                if (block.Type == "text" && !string.IsNullOrEmpty(block.Text))
                                    ChatState.AppendText(assistantMsg, block.Text);
                            }
                        }
                        break;
                }

            }
        }
        catch (Exception ex)
        {
            if (string.IsNullOrEmpty(assistantMsg.Text))
                ChatState.AppendText(assistantMsg, $"Error: {ex.Message}");
        }
        finally
        {
            ChatState.FinishMessage(assistantMsg);
            ChatState.SetStreaming(false, session.Id);
            _shouldAutoScroll = true;
            await InvokeAsync(StateHasChanged);
            await SessionService.SaveSessionAsync(session);

            // Fire hooks
            _ = HooksEngine.FireAsync(HookEvent.OnMessageComplete, new Dictionary<string, string>
            {
                ["COMINOMI_SESSION_ID"] = session.Id,
                ["COMINOMI_CITY_NAME"] = session.CityName
            });

            // Auto-rename branch after first message
            if (isFirstMessage && session.Status == SessionStatus.Ready)
            {
                try
                {
                    var newBranchName = Services.SessionService.GenerateBranchName(input.Text);
                    await SessionService.RenameBranchAsync(session.Id, newBranchName);
                    session.BranchName = newBranchName;
                    ChatState.NotifyStateChanged();
                }
                catch { }
            }
        }
    }

    private async Task HandleModelChanged(string model)
    {
        if (ChatState.CurrentSession != null)
        {
            ChatState.CurrentSession.Model = model;
            await SessionService.SaveSessionAsync(ChatState.CurrentSession);
        }
    }

    private async Task<string?> BuildSystemPromptAsync(Session session)
    {
        var parts = new List<string>();

        // Workspace system prompt
        var wsPrompt = ChatState.CurrentWorkspace?.SystemPrompt;
        if (!string.IsNullOrWhiteSpace(wsPrompt))
            parts.Add(wsPrompt);

        // Agent type context
        if (session.AgentType == AgentType.Explore)
            parts.Add("You are in Explore mode. Only read and search — do not modify any files.");
        else if (session.AgentType == AgentType.Plan)
            parts.Add("You are in Plan mode. Create a detailed implementation plan and save it to .context/plans/.");

        // Workspace context (.context/ notes, todos, plans)
        if (!string.IsNullOrEmpty(session.WorktreePath) && Directory.Exists(session.WorktreePath))
        {
            try
            {
                var context = await ContextService.LoadContextAsync(session.WorktreePath);
                var contextPrompt = ContextService.BuildContextPrompt(context);
                if (!string.IsNullOrWhiteSpace(contextPrompt))
                    parts.Add(contextPrompt);
            }
            catch { }
        }

        // Persistent memory
        try
        {
            var memories = await MemoryService.GetAllAsync();
            if (memories.Count > 0)
            {
                var memoryPrompt = MemoryService.BuildMemoryPrompt(memories);
                parts.Add(memoryPrompt);
            }
        }
        catch { }

        return parts.Count > 0 ? string.Join("\n\n", parts) : null;
    }

    private void HandleCancel()
    {
        ClaudeService.Cancel(ChatState.CurrentSession?.Id);
    }

    public void Dispose()
    {
        ChatState.OnChange -= HandleStateChanged;
    }
}
