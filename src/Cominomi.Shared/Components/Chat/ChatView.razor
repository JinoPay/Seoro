    // Workflow: single merge-all action (push + PR + merge)
    private async Task MergeAll(Session session)
    {
        _operatingSessionId = session.Id;
        StateHasChanged();
        try
        {
            var settings = await SettingsService.LoadAsync();
            var mergeMethod = settings.DefaultMergeStrategy ?? "squash";
            var bodyTemplate = settings.DefaultPrBodyTemplate;

            var updated = await GitWorkflow.MergeAllAsync(session.Id, mergeMethod, bodyTemplate);
            session.Status = updated.Status;
            session.ErrorMessage = updated.ErrorMessage;
            session.PrUrl = updated.PrUrl;
            session.PrNumber = updated.PrNumber;

            if (updated.Status == SessionStatus.Merged)
            {
                Snackbar.MergeSuccess(session.BranchName);
                _ = SendNotificationIfNeeded(session, $"Branch {session.BranchName} merged", NotificationType.Success);
            }
            else if (updated.Status == SessionStatus.ConflictDetected)
                Snackbar.ConflictDetected(session.BranchName);
            else if (!string.IsNullOrEmpty(updated.ErrorMessage))
                Snackbar.MergeError(updated.ErrorMessage);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "MergeAll failed for session {SessionId}", session.Id);
            session.ErrorMessage = ex.Message;
            Snackbar.MergeError(ex.Message);
        }
        finally { _operatingSessionId = null; StateHasChanged(); }
    }

    private async Task ForcePushAndMerge(Session session)
    {
        _operatingSessionId = session.Id;
        StateHasChanged();
        try
        {
            // Force push first
            var pushed = await GitWorkflow.PushBranchAsync(session.Id, force: true);
            if (pushed.Status != SessionStatus.Pushed)
            {
                session.Status = pushed.Status;
                session.ErrorMessage = pushed.ErrorMessage;
                if (!string.IsNullOrEmpty(pushed.ErrorMessage))
                    Snackbar.PushError(pushed.ErrorMessage);
                return;
            }

            session.Status = pushed.Status;
            session.ErrorMessage = null;

            // Continue with PR + merge
            var settings = await SettingsService.LoadAsync();
            var mergeMethod = settings.DefaultMergeStrategy ?? "squash";
            var bodyTemplate = settings.DefaultPrBodyTemplate;

            var updated = await GitWorkflow.MergeAllAsync(session.Id, mergeMethod, bodyTemplate);
            session.Status = updated.Status;
            session.ErrorMessage = updated.ErrorMessage;
            session.PrUrl = updated.PrUrl;
            session.PrNumber = updated.PrNumber;

            if (updated.Status == SessionStatus.Merged)
                Snackbar.MergeSuccess(session.BranchName);
            else if (updated.Status == SessionStatus.ConflictDetected)
                Snackbar.ConflictDetected(session.BranchName);
            else if (!string.IsNullOrEmpty(updated.ErrorMessage))
                Snackbar.MergeError(updated.ErrorMessage);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "ForcePushAndMerge failed for session {SessionId}", session.Id);
            session.ErrorMessage = ex.Message;
            Snackbar.MergeError(ex.Message);
        }
        finally { _operatingSessionId = null; StateHasChanged(); }
    }

    private async Task ResolveConflicts(Session session)
    {
        await GitWorkflow.RetryAfterConflictResolveAsync(session.Id);
        session.Status = SessionStatus.Ready;
        session.ErrorMessage = null;
        session.ConflictFiles = null;

        var fullSession = await SessionService.LoadSessionAsync(session.Id);
        if (fullSession != null)
        {
            var baseBranch = !string.IsNullOrEmpty(fullSession.BaseBranch) ? fullSession.BaseBranch : "main";
            ChatState.SetPendingMessage(
                $"{baseBranch} 브랜치와의 충돌로 PR 병합에 실패했습니다. 이 브랜치를 origin/{baseBranch}에 리베이스하고 충돌을 해결한 후 결과를 커밋해 주세요.");
            ChatState.SetSession(fullSession);
        }

        StateHasChanged();
    }

