@inject ChatState ChatState
@inject IClaudeService ClaudeService
@inject ISessionService SessionService
@inject ISettingsService SettingsService
@inject IJSRuntime JSRuntime
@implements IDisposable

<MudStack Style="height: 100%; overflow: hidden;" Justify="Justify.SpaceBetween" Spacing="0">
    @if (ChatState.CurrentSession?.PermissionMode == "plan")
    {
        <MudAlert Severity="Severity.Info" Dense="true" NoIcon="false"
                  Icon="@Icons.Material.Filled.Description"
                  Style="border-radius: 0; flex-shrink: 0;">
            Plan Mode — Claude will only read and research, not make edits
        </MudAlert>
    }

    <MudStack Style="flex: 1; overflow-y: auto; padding: 16px; min-height: 0;" id="message-list" @ref="_messageListRef">
        @if (ChatState.CurrentSession == null)
        {
            <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="height: 100%;">
                <MudIcon Icon="@Icons.Material.Filled.Chat" Size="Size.Large" Color="Color.Primary" />
                <MudText Typo="Typo.h5" Align="Align.Center" Color="Color.Primary">Cominomi</MudText>
                <MudText Typo="Typo.body2" Align="Align.Center" Color="Color.Secondary">
                    Start a new conversation or select one from the sidebar
                </MudText>
            </MudStack>
        }
        else if (ChatState.CurrentSession.Messages.Count == 0)
        {
            <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="height: 100%;">
                <MudIcon Icon="@Icons.Material.Filled.Terminal" Size="Size.Large" Color="Color.Primary" />
                <MudText Typo="Typo.h6" Align="Align.Center">What can I help you with?</MudText>
            </MudStack>
        }
        else
        {
            @foreach (var message in ChatState.CurrentSession.Messages)
            {
                <MessageBubble Message="message" />
            }
        }
    </MudStack>

    @if (ChatState.CurrentSession != null)
    {
        <MudPaper Class="px-3 py-1" Elevation="0"
                  Style="border-top: 1px solid var(--mud-palette-lines-default); background: var(--mud-palette-surface);">
            @if (_editingPath)
            {
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <MudIcon Icon="@Icons.Material.Filled.Folder" Size="Size.Small" Color="Color.Secondary" />
                    <MudTextField @bind-Value="_editPath"
                                  Variant="Variant.Text"
                                  Margin="Margin.Dense"
                                  Placeholder="Enter working directory path..."
                                  Style="font-size: 0.8rem;"
                                  Immediate="true"
                                  OnKeyDown="HandlePathKeyDown"
                                  Class="flex-grow-1" />
                    <MudIconButton Icon="@Icons.Material.Filled.Check" Size="Size.Small"
                                   Color="Color.Success" OnClick="SavePath" />
                    <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                   Color="Color.Error" OnClick="CancelEditPath" />
                </MudStack>
            }
            else
            {
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1"
                           Style="cursor: pointer;" @onclick="StartEditPath">
                    <MudIcon Icon="@Icons.Material.Filled.Folder" Size="Size.Small" Color="Color.Secondary" />
                    <MudText Typo="Typo.caption" Color="Color.Secondary"
                             Style="flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                        @ShortenPath(ChatState.CurrentSession.WorkingDirectory)
                    </MudText>
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                   Color="Color.Secondary" OnClick="StartEditPath"
                                   OnClickStopPropagation="true" />
                </MudStack>
            }
        </MudPaper>
    }

    <InputArea OnSend="HandleSend" OnCancel="HandleCancel" IsStreaming="ChatState.IsStreaming"
               Disabled="ChatState.CurrentSession == null"
               IsPlanMode="@(ChatState.CurrentSession?.PermissionMode == "plan")"
               IsPlanModeChanged="HandlePlanModeChanged"
               Model="@(ChatState.CurrentSession?.Model ?? "")"
               OnModelChanged="HandleModelChanged"
               ResolvedModel="@(ChatState.CurrentSession?.ResolvedModel)" />
</MudStack>

@code {
    private MudStack? _messageListRef;
    private bool _editingPath;
    private string _editPath = "";

    protected override void OnInitialized()
    {
        ChatState.OnChange += StateHasChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_shouldAutoScroll)
        {
            _shouldAutoScroll = false;
            await JSRuntime.InvokeVoidAsync("scrollToBottom", "message-list");
        }
    }

    private void StartEditPath()
    {
        _editPath = ChatState.CurrentSession?.WorkingDirectory ?? "";
        _editingPath = true;
    }

    private void CancelEditPath() => _editingPath = false;

    private async Task HandlePathKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SavePath();
        else if (e.Key == "Escape") CancelEditPath();
    }

    private async Task SavePath()
    {
        if (!string.IsNullOrWhiteSpace(_editPath) && ChatState.CurrentSession != null)
        {
            ChatState.UpdateWorkingDirectory(_editPath.Trim());
            await SessionService.SaveSessionAsync(ChatState.CurrentSession);

            var settings = await SettingsService.LoadAsync();
            var path = _editPath.Trim();
            settings.RecentDirectories.Remove(path);
            settings.RecentDirectories.Insert(0, path);
            if (settings.RecentDirectories.Count > 10)
                settings.RecentDirectories.RemoveRange(10, settings.RecentDirectories.Count - 10);
            await SettingsService.SaveAsync(settings);
        }
        _editingPath = false;
    }

    private static string ShortenPath(string path)
    {
        if (string.IsNullOrEmpty(path)) return "(no directory set)";
        var home = Environment.GetFolderPath(Environment.SpecialFolder.UserProfile);
        if (path.StartsWith(home))
            return "~" + path[home.Length..];
        return path;
    }

    private async Task HandlePlanModeChanged(bool isPlan)
    {
        if (ChatState.CurrentSession == null) return;
        ChatState.CurrentSession.PermissionMode = isPlan ? "plan" : "default";
        ChatState.NotifyStateChanged();
        await SessionService.SaveSessionAsync(ChatState.CurrentSession);
    }

    private bool _shouldAutoScroll;

    private async Task HandleSend(string message)
    {
        if (ChatState.CurrentSession == null || string.IsNullOrWhiteSpace(message))
            return;

        ChatState.AddUserMessage(message);
        ChatState.SetStreaming(true);
        ChatState.SetPhase(StreamingPhase.Sending);

        var assistantMsg = ChatState.StartAssistantMessage();
        ToolCall? currentToolCall = null;
        bool firstEvent = true;

        try
        {
            await foreach (var evt in ClaudeService.SendMessageAsync(
                message,
                ChatState.CurrentSession.WorkingDirectory,
                ChatState.CurrentSession.Model,
                ChatState.CurrentSession.PermissionMode))
            {
                if (firstEvent)
                {
                    ChatState.SetPhase(StreamingPhase.Thinking);
                    firstEvent = false;
                }

                switch (evt.Type)
                {
                    case "system" when evt.Subtype == "init" && evt.Model != null:
                        ChatState.CurrentSession!.ResolvedModel = evt.Model;
                        break;

                    case "content_block_start" when evt.ContentBlock?.Type == "tool_use":
                        currentToolCall = new ToolCall
                        {
                            Id = evt.ContentBlock.Id ?? "",
                            Name = evt.ContentBlock.Name ?? ""
                        };
                        ChatState.AddToolCall(assistantMsg, currentToolCall);
                        ChatState.SetPhase(StreamingPhase.UsingTool, evt.ContentBlock.Name);
                        break;

                    case "content_block_delta":
                        if (evt.Delta?.Type == "text_delta" && evt.Delta.Text != null)
                        {
                            ChatState.AppendText(assistantMsg, evt.Delta.Text);
                            ChatState.SetPhase(StreamingPhase.WritingText);
                        }
                        else if (evt.Delta?.Type == "input_json_delta" && evt.Delta.PartialJson != null && currentToolCall != null)
                        {
                            currentToolCall.Input += evt.Delta.PartialJson;
                        }
                        break;

                    case "content_block_stop":
                        if (currentToolCall != null)
                        {
                            currentToolCall.IsComplete = true;
                            currentToolCall = null;
                            ChatState.NotifyStateChanged();
                        }
                        ChatState.SetPhase(StreamingPhase.Thinking);
                        break;

                    case "result":
                        if (string.IsNullOrEmpty(assistantMsg.Text) && evt.Message?.Content != null)
                        {
                            foreach (var block in evt.Message.Content)
                            {
                                if (block.Type == "text" && block.Text != null)
                                    ChatState.AppendText(assistantMsg, block.Text);
                            }
                        }
                        if (string.IsNullOrEmpty(assistantMsg.Text) && !string.IsNullOrEmpty(evt.Result))
                            ChatState.AppendText(assistantMsg, evt.Result);
                        break;

                    case "error":
                        if (!string.IsNullOrEmpty(evt.Error))
                        {
                            ChatState.AppendText(assistantMsg, $"\n\n**Error:** {evt.Error}");
                        }
                        break;

                    default:
                        if (evt.Message?.Content != null)
                        {
                            foreach (var block in evt.Message.Content)
                            {
                                if (block.Type == "text" && !string.IsNullOrEmpty(block.Text))
                                    ChatState.AppendText(assistantMsg, block.Text);
                            }
                        }
                        break;
                }

                _shouldAutoScroll = true;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            if (string.IsNullOrEmpty(assistantMsg.Text))
                ChatState.AppendText(assistantMsg, $"Error: {ex.Message}");
        }
        finally
        {
            ChatState.FinishMessage(assistantMsg);
            ChatState.SetStreaming(false);
            _shouldAutoScroll = true;
            StateHasChanged();
            await SessionService.SaveSessionAsync(ChatState.CurrentSession);
        }
    }

    private async Task HandleModelChanged(string model)
    {
        if (ChatState.CurrentSession != null)
        {
            ChatState.CurrentSession.Model = model;
            await SessionService.SaveSessionAsync(ChatState.CurrentSession);
        }
    }

    private void HandleCancel()
    {
        ClaudeService.Cancel();
    }

    public void Dispose()
    {
        ChatState.OnChange -= StateHasChanged;
    }
}
