<div class="tool-card @(!Tool.IsComplete ? "running" : "")">
    <div class="tool-card-header" @onclick="@(() => _expanded = !_expanded)">
        @if (ShowStatusIcon)
        {
            @if (!Tool.IsComplete)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true"
                                     Style="width: 14px; height: 14px;" Color="Color.Warning"/>
            }
            else if (Tool.IsError)
            {
                <MudIcon Icon="@Icons.Material.Filled.Error" Size="Size.Small" Color="Color.Error"
                         Style="width: 16px; height: 16px;"/>
            }
            else
            {
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Color="Color.Success"
                         Style="width: 16px; height: 16px;"/>
            }
        }
        <MudIcon Icon="@ToolDisplayHelper.GetToolIcon(Tool.Name)" Size="Size.Small"
                 Style="width: 16px; height: 16px; opacity: 0.6;"/>
        <span class="tool-card-name">@_headerLabel</span>
        @if (Tool.IsComplete && _compactResult is string hint)
        {
            <span class="tool-card-hint">@hint</span>
        }
        <MudIcon Icon="@(_expanded ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                 Size="Size.Small" Style="opacity: 0.4; width: 16px; height: 16px;"/>
    </div>

    @if (_expanded)
    {
        <div class="tool-card-body">
            @switch (GetWidgetType())
            {
                case WidgetType.Read:
                    <ReadToolWidget Tool="Tool"/>
                    break;
                case WidgetType.Edit:
                    <EditToolWidget Tool="Tool"/>
                    break;
                case WidgetType.Bash:
                    <BashToolWidget Tool="Tool"/>
                    break;
                case WidgetType.Grep:
                    <GrepToolWidget Tool="Tool"/>
                    break;
                case WidgetType.Glob:
                    <GlobToolWidget Tool="Tool"/>
                    break;
                case WidgetType.AskUserQuestion:
                    <AskUserQuestionWidget Tool="Tool"/>
                    break;
                case WidgetType.Agent:
                    <AgentToolWidget Tool="Tool"/>
                    break;
                case WidgetType.WebSearch:
                    <WebSearchWidget Tool="Tool"/>
                    break;
                case WidgetType.TodoWrite:
                    <TodoWriteWidget Tool="Tool"/>
                    break;
                default:
                    @* 일반 폴백 *@
                    @if (!string.IsNullOrEmpty(Tool.Input))
                    {
                        var formattedInput = ToolDisplayHelper.FormatJson(Tool.Input);
                        var inputLineCount = formattedInput.Split('\n').Length;
                        <div class="tool-card-section">
                            <div class="tool-card-section-label">
                                입력 @(inputLineCount > 1 ? $"({inputLineCount}줄)" : "")</div>
                            <div class="tool-card-content">
                                <pre>@formattedInput</pre>
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Tool.Output))
                    {
                        var lineCount = Tool.Output.Split('\n').Length;
                        <div class="tool-card-section">
                            <div class="tool-card-section-label">출력 @(lineCount > 1 ? $"({lineCount}줄)" : "")</div>
                            <div
                                class="tool-card-content @(lineCount > 15 && !_outputExpanded ? "tool-output-collapsed" : "")">
                                <pre>@Tool.Output</pre>
                            </div>
                            @if (lineCount > 15)
                            {
                                <div class="tool-output-toggle" @onclick="@(() => _outputExpanded = !_outputExpanded)"
                                     @onclick:stopPropagation="true">
                                    @(_outputExpanded ? "접기" : "전체 보기")
                                </div>
                            }
                        </div>
                    }

                    break;
            }
        </div>
    }
</div>

@code {
    [Parameter][EditorRequired] public ToolCall Tool { get; set; } = default!;

    [Parameter] public bool ShowStatusIcon { get; set; } = true;

    private bool _expanded;
    private bool _outputExpanded;

    // 모든 렌더링에서 JSON 재파싱을 피하기 위한 캐시된 헤더 값
    private string _headerLabel = "";
    private string? _compactResult;
    private string? _lastInput;
    private string? _lastOutput;
    private bool _lastIsComplete;

    protected override void OnParametersSet()
    {
        if (!ReferenceEquals(_lastInput, Tool.Input))
        {
            _lastInput = Tool.Input;
            _headerLabel = ToolDisplayHelper.GetHeaderLabel(Tool);

            // AskUserQuestion은 하단 표시줄에서 처리되므로 기본적으로 축소 상태로 유지합니다
        }

        if (!ReferenceEquals(_lastOutput, Tool.Output) || _lastIsComplete != Tool.IsComplete)
        {
            _lastOutput = Tool.Output;
            _lastIsComplete = Tool.IsComplete;
            _compactResult = ToolDisplayHelper.GetCompactResult(Tool);
        }
    }

    private enum WidgetType
    {
        Generic,
        Read,
        Edit,
        Bash,
        Grep,
        Glob,
        AskUserQuestion,
        Agent,
        WebSearch,
        TodoWrite
    }

    private WidgetType GetWidgetType()
    {
        return Tool.Name.ToLowerInvariant() switch
        {
            "read" or "read_file" => WidgetType.Read,
            "edit" or "edit_file" => WidgetType.Edit,
            "write" or "write_file" => WidgetType.Edit, // Write는 동일한 diff 스타일 위젯 사용
            "bash" or "execute_bash" => WidgetType.Bash,
            "grep" => WidgetType.Grep,
            "glob" => WidgetType.Glob,
            "askuserquestion" or "ask_user_question" => WidgetType.AskUserQuestion,
            "agent" => WidgetType.Agent,
            "websearch" or "web_search" => WidgetType.WebSearch,
            "todowrite" or "todo_write" => WidgetType.TodoWrite,
            _ => WidgetType.Generic
        };
    }

}
