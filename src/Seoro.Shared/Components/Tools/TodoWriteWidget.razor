@* TodoWrite 인라인 위젯: 진행 카운터 + 항목별 상태 아이콘 *@
<div class="tool-widget tool-widget-todo">
    @if (_entries.Count == 0)
    {
        @* 폴백: 파싱 실패 또는 todos 빈 배열 *@
        @if (!string.IsNullOrEmpty(Tool.Input))
        {
            <pre class="todo-fallback">@ToolDisplayHelper.FormatJson(Tool.Input)</pre>
        }
    }
    else
    {
        <div class="todo-widget-header">
            <span class="todo-widget-counter">@_completed / @_total</span>
            <div class="todo-widget-progress">
                <div class="todo-widget-progress-fill" style="width: @(_progressPercent)%;"></div>
            </div>
        </div>
        <div class="todo-widget-list">
            @foreach (var entry in _entries)
            {
                <div class="todo-widget-item todo-status-@entry.Status.ToString().ToLowerInvariant()">
                    @switch (entry.Status)
                    {
                        case TodoStatus.Completed:
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small"
                                     Color="Color.Success"
                                     Style="width: 16px; height: 16px;"/>
                            break;
                        case TodoStatus.InProgress:
                            <MudProgressCircular Size="Size.Small" Indeterminate="true"
                                                 Color="Color.Warning"
                                                 Style="width: 14px; height: 14px;"/>
                            break;
                        default:
                            <MudIcon Icon="@Icons.Material.Filled.RadioButtonUnchecked" Size="Size.Small"
                                     Style="width: 16px; height: 16px; opacity: 0.4;"/>
                            break;
                    }
                    <span class="todo-widget-text">@GetDisplayText(entry)</span>
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter][EditorRequired] public ToolCall Tool { get; set; } = default!;

    private List<TodoEntry> _entries = new();
    private int _completed;
    private int _total;
    private int _progressPercent;
    private string? _lastInput;

    protected override void OnParametersSet()
    {
        if (ReferenceEquals(_lastInput, Tool.Input)) return;
        _lastInput = Tool.Input;

        if (TodoSnapshotParser.TryParse(Tool.Input, out var snap))
        {
            _entries = snap.Entries.ToList();
            _completed = snap.Completed;
            _total = snap.Total;
            _progressPercent = _total == 0 ? 0 : (int)Math.Round(_completed * 100.0 / _total);
        }
        // 파싱 실패 시 직전 상태 유지 (스트리밍 partial JSON 깜빡임 방지)
    }

    private static string GetDisplayText(TodoEntry entry)
    {
        return entry.Status == TodoStatus.InProgress && !string.IsNullOrEmpty(entry.ActiveForm)
            ? entry.ActiveForm
            : entry.Content;
    }
}
