@using System.Text.Json
@using System.Text.RegularExpressions
<div class="tool-widget tool-widget-bash">
    <div class="tool-widget-header">
        <MudIcon Icon="@Icons.Material.Filled.Terminal" Size="Size.Small"
                 Style="width: 14px; height: 14px; opacity: 0.6;"/>
        <span class="tool-widget-command">$ @_command</span>
    </div>
    @if (_isMultilineCommand)
    {
        <div class="tool-widget-fullcmd @(_cmdExpanded ? "" : "collapsed")" style="margin-bottom: 2px;">
            <pre>@_fullCommand</pre>
        </div>
        <div class="tool-widget-toggle" @onclick="@(() => _cmdExpanded = !_cmdExpanded)"
             @onclick:stopPropagation="true">
            @(_cmdExpanded ? "명령 접기" : "전체 명령 보기")
        </div>
    }
    @if (!string.IsNullOrEmpty(Tool.Output))
    {
        <div class="tool-widget-output @(_collapsed ? "collapsed" : "") @(Tool.IsError ? "error-output" : "")">
            <pre>@StripAnsi(Tool.Output)</pre>
        </div>
        @if (_lineCount > 30)
        {
            <div class="tool-widget-toggle" @onclick="@(() => _collapsed = !_collapsed)"
                 @onclick:stopPropagation="true">
                @(_collapsed ? $"전체 보기 ({_lineCount}줄)" : "접기")
            </div>
        }
    }
</div>

@code {
    [Parameter][EditorRequired] public ToolCall Tool { get; set; } = null!;

    private string _command = "";
    private string _fullCommand = "";
    private bool _isMultilineCommand;
    private bool _cmdExpanded;
    private int _lineCount;
    private bool _collapsed = true;
    private string? _lastInput;
    private string? _lastOutput;

    protected override void OnParametersSet()
    {
        if (!ReferenceEquals(_lastInput, Tool.Input))
        {
            _lastInput = Tool.Input;
            (_command, _fullCommand, _isMultilineCommand) = ParseCommand(Tool.Input);
        }

        if (!ReferenceEquals(_lastOutput, Tool.Output))
        {
            _lastOutput = Tool.Output;
            _lineCount = string.IsNullOrEmpty(Tool.Output) ? 0 : Tool.Output.Split('\n').Length;
            _collapsed = _lineCount > 30;
        }
    }

    private static (string header, string full, bool isMultiline) ParseCommand(string? input)
    {
        if (string.IsNullOrEmpty(input)) return ("", "", false);
        try
        {
            using var doc = JsonDocument.Parse(input);
            if (doc.RootElement.TryGetProperty("command", out var cmd))
            {
                var text = cmd.GetString() ?? "";
                var lines = text.Split('\n');
                var firstLine = lines[0];
                var header = firstLine.Length > 80 ? firstLine[..80] + "…" : firstLine;
                var isMultiline = lines.Length > 1 && lines.Any(l => !string.IsNullOrWhiteSpace(l));
                return (header, text.TrimEnd(), isMultiline);
            }
        }
        catch (JsonException)
        {
            /* 잘못된 도구 입력 — 빈 상태로 렌더링 */
        }

        return ("", "", false);
    }

    private static string StripAnsi(string text)
    {
        // ANSI 이스케이프 시퀀스 제거
        return Regex.Replace(text, @"\x1B\[[0-9;]*[a-zA-Z]", "");
    }

}
