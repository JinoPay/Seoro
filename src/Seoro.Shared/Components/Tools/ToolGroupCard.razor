<div class="tool-group @(_expanded ? "expanded" : "") @(IsActive ? "running" : "")">
    <div class="tool-group-header" @onclick="Toggle">
        @if (IsActive)
        {
            <Spinner Size="14" Tone="Tone.Warning"/>
        }
        else if (HasError)
        {
            <Icon Svg="@Lucide.CircleAlert" Size="16" Tone="Tone.Error"/>
        }
        else
        {
            <Icon Svg="@Lucide.CircleCheck" Size="16" Tone="Tone.Success"/>
        }

        <div class="tool-group-icons">
            @foreach (var icon in GetUniqueIcons())
            {
                <Icon Svg="@icon" Size="14" Style="opacity: 0.5;"/>
            }
        </div>

        <span class="tool-group-summary">@Group.Summary</span>

        <Icon Svg="@(_expanded ? Lucide.ChevronUp : Lucide.ChevronDown)"
              Size="16" Style="opacity: 0.4; margin-left: auto;"/>
    </div>

    @if (_expanded)
    {
        <div class="tool-group-body">
            @foreach (var part in Group.Parts)
            {
                @if (part.ToolCall != null)
                {
                    <ToolCallCard Tool="part.ToolCall" ShowStatusIcon="false"/>
                }
            }
        </div>
    }
</div>

@code {
    [Parameter][EditorRequired] public ContentGroup Group { get; set; } = default!;

    [Parameter] public bool IsActive { get; set; }

    private bool _expanded;
    private bool _wasActive;

    private bool HasError => Group.Parts.Any(p => p.ToolCall?.IsError == true);

    protected override void OnParametersSet()
    {
        // 활성 상태일 때 자동 확장 (스트리밍), 완료 시 자동 축소
        if (IsActive && !_wasActive)
            _expanded = true;
        else if (!IsActive && _wasActive)
            _expanded = HasError;

        _wasActive = IsActive;
    }

    private void Toggle()
    {
        _expanded = !_expanded;
    }

    private List<string> GetUniqueIcons()
    {
        return Group.Parts
            .Where(p => p.ToolCall != null)
            .Select(p => ToolDisplayHelper.GetToolLucideIcon(p.ToolCall!.Name))
            .Distinct()
            .ToList();
    }

}
