@using Seoro.Shared.UiKit

<label class="ui-switch @(Disabled ? "ui-switch--disabled" : null) @ToneClass @Class" style="@Style">
    <input type="checkbox"
           checked="@Value"
           disabled="@Disabled"
           @onchange="HandleChange" />
    <span class="ui-switch__track"><span class="ui-switch__thumb"></span></span>
    @if (!string.IsNullOrEmpty(Label) || ChildContent is not null)
    {
        <span class="ui-switch__label">@Label@ChildContent</span>
    }
</label>

@code {
    [Parameter] public bool Value { get; set; }
    [Parameter] public EventCallback<bool> ValueChanged { get; set; }
    [Parameter] public string? Label { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public Tone Tone { get; set; } = Tone.Primary;
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public string? Style { get; set; }

    private string? ToneClass => Tone == Tone.Default ? null : $"ui-switch--{Tone.ToString().ToLowerInvariant()}";

    private Task HandleChange(ChangeEventArgs e)
    {
        Value = e.Value is true;
        return ValueChanged.InvokeAsync(Value);
    }
}
