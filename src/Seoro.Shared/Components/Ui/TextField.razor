@using Seoro.Shared.UiKit

<div class="ui-field @(Disabled ? "ui-field--disabled" : null) @(HasError ? "ui-field--error" : null) @Class" style="@Style">
    @if (!string.IsNullOrEmpty(Label))
    {
        <label class="ui-field__label">@Label</label>
    }
    <div class="ui-field__control">
        @if (!string.IsNullOrEmpty(AdornmentIcon) && !AdornmentEnd)
        {
            <Icon Svg="@AdornmentIcon" Size="14" Class="ui-field__adornment" />
        }
        @if (Lines > 1)
        {
            <textarea @ref="_element"
                      class="ui-field__input"
                      rows="@Lines"
                      placeholder="@Placeholder"
                      disabled="@Disabled"
                      readonly="@ReadOnly"
                      value="@Value"
                      spellcheck="@SpellcheckAttr"
                      @oninput="HandleInput"
                      @onchange="HandleChange"
                      @onkeydown="OnKeyDown"
                      @onblur="OnBlur"></textarea>
        }
        else
        {
            <input @ref="_element"
                   class="ui-field__input"
                   type="@Type"
                   placeholder="@Placeholder"
                   disabled="@Disabled"
                   readonly="@ReadOnly"
                   value="@Value"
                   spellcheck="@SpellcheckAttr"
                   @oninput="HandleInput"
                   @onchange="HandleChange"
                   @onkeydown="OnKeyDown"
                   @onblur="OnBlur" />
        }
        @if (!string.IsNullOrEmpty(AdornmentIcon) && AdornmentEnd)
        {
            <Icon Svg="@AdornmentIcon" Size="14" Class="ui-field__adornment" />
        }
    </div>
    @if (!string.IsNullOrEmpty(ErrorText))
    {
        <div class="ui-field__helper ui-field__helper--error">@ErrorText</div>
    }
    else if (!string.IsNullOrEmpty(HelperText))
    {
        <div class="ui-field__helper">@HelperText</div>
    }
</div>

@code {
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }
    [Parameter] public string? Label { get; set; }
    [Parameter] public string? Placeholder { get; set; }
    [Parameter] public string? HelperText { get; set; }
    [Parameter] public string? ErrorText { get; set; }
    [Parameter] public bool Error { get; set; }
    [Parameter] public bool Immediate { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool ReadOnly { get; set; }
    [Parameter] public bool AutoFocus { get; set; }
    [Parameter] public bool Spellcheck { get; set; }
    [Parameter] public int Lines { get; set; } = 1;
    [Parameter] public string Type { get; set; } = "text";
    [Parameter] public string? AdornmentIcon { get; set; }
    [Parameter] public bool AdornmentEnd { get; set; }
    [Parameter] public EventCallback<KeyboardEventArgs> OnKeyDown { get; set; }
    [Parameter] public EventCallback<FocusEventArgs> OnBlur { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public string? Style { get; set; }

    private ElementReference _element;
    private bool HasError => Error || !string.IsNullOrEmpty(ErrorText);
    private string SpellcheckAttr => Spellcheck ? "true" : "false";

    public ValueTask FocusAsync() => _element.FocusAsync();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && AutoFocus)
            await _element.FocusAsync();
    }

    private Task HandleInput(ChangeEventArgs e)
        => Immediate ? SetValueAsync(e.Value?.ToString()) : Task.CompletedTask;

    private Task HandleChange(ChangeEventArgs e)
        => Immediate ? Task.CompletedTask : SetValueAsync(e.Value?.ToString());

    private Task SetValueAsync(string? value)
    {
        Value = value;
        return ValueChanged.InvokeAsync(value);
    }
}
