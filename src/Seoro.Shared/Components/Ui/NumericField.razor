@using System.Globalization
@using System.Numerics
@using Seoro.Shared.UiKit
@typeparam T where T : struct, INumber<T>

<div class="ui-field @(Disabled ? "ui-field--disabled" : null) @Class" style="@Style">
    @if (!string.IsNullOrEmpty(Label))
    {
        <label class="ui-field__label">@Label</label>
    }
    <div class="ui-field__control">
        <input class="ui-field__input"
               type="number"
               min="@(Min?.ToString(null, CultureInfo.InvariantCulture))"
               max="@(Max?.ToString(null, CultureInfo.InvariantCulture))"
               step="@(Step?.ToString(null, CultureInfo.InvariantCulture))"
               placeholder="@Placeholder"
               disabled="@Disabled"
               value="@Value.ToString(null, CultureInfo.InvariantCulture)"
               @onchange="HandleChange" />
    </div>
    @if (!string.IsNullOrEmpty(HelperText))
    {
        <div class="ui-field__helper">@HelperText</div>
    }
</div>

@code {
    [Parameter] public T Value { get; set; }
    [Parameter] public EventCallback<T> ValueChanged { get; set; }
    [Parameter] public T? Min { get; set; }
    [Parameter] public T? Max { get; set; }
    [Parameter] public T? Step { get; set; }
    [Parameter] public string? Label { get; set; }
    [Parameter] public string? Placeholder { get; set; }
    [Parameter] public string? HelperText { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public string? Style { get; set; }

    private Task HandleChange(ChangeEventArgs e)
    {
        if (!T.TryParse(e.Value?.ToString(), CultureInfo.InvariantCulture, out var parsed))
            return Task.CompletedTask;
        if (Min is { } min && parsed < min) parsed = min;
        if (Max is { } max && parsed > max) parsed = max;
        Value = parsed;
        return ValueChanged.InvokeAsync(parsed);
    }
}
