@using Seoro.Shared.UiKit

<div class="ui-alert ui-alert--@ToneClass @(Dense ? "ui-alert--dense" : null) @Class" style="@Style" role="alert">
    @if (!NoIcon)
    {
        <Icon Svg="@ResolvedIcon" Size="@(Dense ? 14 : 16)" Class="ui-alert__icon" />
    }
    <div class="ui-alert__content">@ChildContent</div>
    @if (OnClose.HasDelegate)
    {
        <button type="button" class="ui-alert__close" aria-label="close" @onclick="OnClose">
            <Icon Svg="@Lucide.X" Size="14" />
        </button>
    }
</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public Tone Tone { get; set; } = Tone.Info;
    [Parameter] public bool Dense { get; set; }
    [Parameter] public bool NoIcon { get; set; }
    [Parameter] public string? Icon { get; set; }
    [Parameter] public EventCallback<MouseEventArgs> OnClose { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public string? Style { get; set; }

    private string ToneClass => (Tone == Tone.Default ? Tone.Info : Tone).ToString().ToLowerInvariant();

    private string ResolvedIcon => Icon ?? Tone switch
    {
        Tone.Success => Lucide.CircleCheck,
        Tone.Warning => Lucide.TriangleAlert,
        Tone.Error => Lucide.CircleX,
        _ => Lucide.Info,
    };
}
