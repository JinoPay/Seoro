@using Seoro.Shared.UiKit

<span class="ui-badge-host @Class" style="@Style">
    @ChildContent
    @if (Visible)
    {
        <span class="ui-badge @ToneClass @(Dot ? "ui-badge--dot" : null)">@(Dot ? null : Content)</span>
    }
</span>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string? Content { get; set; }
    [Parameter] public bool Dot { get; set; }
    [Parameter] public bool Visible { get; set; } = true;
    [Parameter] public Tone Tone { get; set; } = Tone.Primary;
    [Parameter] public string? Class { get; set; }
    [Parameter] public string? Style { get; set; }

    private string ToneClass => $"ui-badge--{(Tone == Tone.Default ? Tone.Primary : Tone).ToString().ToLowerInvariant()}";
}
