@using Seoro.Shared.UiKit

<button type="button"
        class="ui-menu__item @ToneClass @Class"
        role="menuitem"
        disabled="@Disabled"
        @onclick="HandleClickAsync"
        @onclick:stopPropagation="true">
    @if (!string.IsNullOrEmpty(Icon))
    {
        <Icon Svg="@Icon" Size="14" />
    }
    <span class="ui-menu__item-label">@ChildContent</span>
</button>

@code {
    [CascadingParameter] private Menu? Parent { get; set; }

    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public EventCallback<MouseEventArgs> OnClick { get; set; }
    [Parameter] public string? Icon { get; set; }
    [Parameter] public Tone Tone { get; set; } = Tone.Default;
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string? Class { get; set; }

    private string? ToneClass => Tone == Tone.Default ? null : $"ui-menu__item--{Tone.ToString().ToLowerInvariant()}";

    private async Task HandleClickAsync(MouseEventArgs e)
    {
        if (Parent is not null)
            await Parent.CloseAsync();
        await OnClick.InvokeAsync(e);
    }
}
