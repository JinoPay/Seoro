@using Markdig
@using Seoro.Shared.Helpers
@using System.Text.RegularExpressions
@using Timer = System.Timers.Timer
@implements IAsyncDisposable
@inject IJSRuntime JS
@inject IGitService GitService
@inject IChatState ChatState
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<div class="filediff-view">
    <div class="filediff-header">
        <MudIcon Icon="@Icons.Material.Filled.InsertDriveFile" Size="Size.Small"
                 Style="width: 16px; height: 16px; opacity: 0.5;"/>
        <span class="filediff-path">@FilePath</span>
        @if (_readOnlyOversize)
        {
            <span class="filediff-badge" title="파일이 너무 커서 읽기 전용입니다">읽기 전용 (큰 파일)</span>
        }
        @if (_isMarkdown && !_readOnlyOversize)
        {
            <MudIconButton Icon="@(_previewMode ? Icons.Material.Filled.Edit : Icons.Material.Filled.Visibility)"
                           Size="Size.Small"
                           Style="margin-left: auto; width: 24px; height: 24px;"
                           OnClick="TogglePreviewAsync"
                           title="@(_previewMode ? "편집 모드" : "미리보기")"/>
        }
    </div>

    <div id="@_elementId" class="cm-host" style="@(_previewMode ? "display:none;" : "")"></div>
    @if (_isMarkdown)
    {
        <div class="filecontent-markdown" style="@(_previewMode ? "" : "display:none;")">
            <div id="@_previewElementId" class="filecontent-markdown-inner markdown-body">
                @((MarkupString)_previewHtml)
            </div>
        </div>
    }
</div>

@code {
    [Parameter][EditorRequired] public string FilePath { get; set; } = "";

    [Parameter][EditorRequired] public string Content { get; set; } = "";

    [Parameter] public string? WorkingDir { get; set; }

    private string _language = "";
    private string _elementId = "";
    private string _previewElementId = "";
    private bool _needsCreate;
    private bool _readOnlyOversize;
    private bool _isMarkdown;
    private bool _previewMode;
    private string _previewHtml = "";
    private bool _previewNeedsHighlight;
    private string? _lastFilePath;
    private DotNetObjectReference<FileContentView>? _selfRef;
    private FileSystemWatcher? _watcher;
    private Timer? _watchDebounce;
    private readonly Lock _watcherLock = new();
    private bool _saveInProgress;
    private bool _conflictDialogOpen;

    private string EffectiveWorkingDir => WorkingDir ?? ChatState.CurrentSession?.Git?.WorktreePath ?? "";

    protected override void OnParametersSet()
    {
        if (_lastFilePath == FilePath) return;
        _lastFilePath = FilePath;

        _readOnlyOversize = Content.Length > 500_000;
        _language = GetLanguage(FilePath);
        _elementId = $"cm-{FilePath.GetHashCode():x8}";
        _previewElementId = $"mdp-{FilePath.GetHashCode():x8}";
        _isMarkdown = IsMarkdownFile(FilePath);
        _previewMode = false;

        _needsCreate = true;
        StartWatching();
    }

    private async Task TogglePreviewAsync()
    {
        if (!_isMarkdown || _readOnlyOversize) return;
        if (_previewMode)
        {
            _previewMode = false;
            StateHasChanged();
            return;
        }

        try
        {
            var text = await JS.InvokeAsync<string>("getEditorContent", _elementId);
            var html = Markdown.ToHtml(text, MarkdownHelper.TrustedPipeline);
            _previewHtml = ResolveLocalAssets(html, EffectiveWorkingDir, FilePath);
            _previewMode = true;
            _previewNeedsHighlight = true;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"미리보기 생성 실패: {ex.Message}", Severity.Error);
        }
    }

    private static bool IsMarkdownFile(string filePath)
    {
        var ext = Path.GetExtension(filePath).ToLowerInvariant();
        return ext is ".md" or ".mdx";
    }

    private const long MaxInlineAssetBytes = 5 * 1024 * 1024;
    private static readonly Regex ImgSrcRegex = new("""<img\s+[^>]*?src=(?:"([^"]+)"|'([^']+)')""",
        RegexOptions.IgnoreCase | RegexOptions.Compiled);

    private static string ResolveLocalAssets(string html, string workingDir, string mdRelPath)
    {
        if (string.IsNullOrEmpty(html) || string.IsNullOrEmpty(workingDir)) return html;
        string root;
        try { root = Path.GetFullPath(workingDir); }
        catch { return html; }
        var rootSep = root.EndsWith(Path.DirectorySeparatorChar) ? root : root + Path.DirectorySeparatorChar;
        var mdDir = Path.GetDirectoryName(mdRelPath) ?? "";

        return ImgSrcRegex.Replace(html, m =>
        {
            var raw = m.Groups[1].Success ? m.Groups[1].Value : m.Groups[2].Value;
            if (string.IsNullOrEmpty(raw)) return m.Value;
            if (raw.StartsWith("data:", StringComparison.OrdinalIgnoreCase) ||
                raw.StartsWith("http://", StringComparison.OrdinalIgnoreCase) ||
                raw.StartsWith("https://", StringComparison.OrdinalIgnoreCase) ||
                raw.StartsWith("//"))
                return m.Value;

            string src;
            try { src = Uri.UnescapeDataString(raw.Split('?', '#')[0]); }
            catch { src = raw; }

            string fullPath;
            try
            {
                fullPath = src.StartsWith("/")
                    ? Path.GetFullPath(Path.Combine(root, src.TrimStart('/').Replace('/', Path.DirectorySeparatorChar)))
                    : Path.GetFullPath(Path.Combine(root, mdDir, src.Replace('/', Path.DirectorySeparatorChar)));
            }
            catch { return m.Value; }

            if (!fullPath.StartsWith(rootSep, StringComparison.OrdinalIgnoreCase) &&
                !string.Equals(fullPath, root, StringComparison.OrdinalIgnoreCase))
                return m.Value;
            if (!File.Exists(fullPath)) return m.Value;
            var info = new FileInfo(fullPath);
            if (info.Length > MaxInlineAssetBytes) return m.Value;

            try
            {
                var bytes = File.ReadAllBytes(fullPath);
                var mime = GuessImageMime(Path.GetExtension(fullPath).ToLowerInvariant());
                var dataUri = $"data:{mime};base64,{Convert.ToBase64String(bytes)}";
                return m.Value.Replace(raw, dataUri);
            }
            catch { return m.Value; }
        });
    }

    private static string GuessImageMime(string ext) => ext switch
    {
        ".png" => "image/png",
        ".jpg" or ".jpeg" => "image/jpeg",
        ".gif" => "image/gif",
        ".svg" => "image/svg+xml",
        ".webp" => "image/webp",
        ".bmp" => "image/bmp",
        ".ico" => "image/x-icon",
        ".avif" => "image/avif",
        _ => "application/octet-stream"
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_needsCreate)
        {
            _needsCreate = false;
            try
            {
                _selfRef ??= DotNetObjectReference.Create(this);
                await JS.InvokeVoidAsync(
                    "createCodeMirrorView",
                    _elementId,
                    Content,
                    _language,
                    _readOnlyOversize,
                    _readOnlyOversize ? null : _selfRef);
            }
            catch
            {
                // JS interop이 처리 중에 실패할 수 있습니다
            }
        }

        if (_previewNeedsHighlight && _previewMode)
        {
            _previewNeedsHighlight = false;
            try { await JS.InvokeVoidAsync("enhanceMarkdownCodeBlocks", _previewElementId, false); }
            catch { /* 무시 */ }
        }
    }

    [JSInvokable]
    public Task OnFirstDirty()
    {
        ChatState.Tabs.MarkDirty(FilePath);
        return Task.CompletedTask;
    }

    [JSInvokable]
    public async Task OnSaveRequested()
    {
        await SaveAsync();
    }

    private async Task SaveAsync()
    {
        if (_saveInProgress || _readOnlyOversize) return;
        var workingDir = EffectiveWorkingDir;
        if (string.IsNullOrEmpty(workingDir))
        {
            Snackbar.Add("워크스페이스 경로를 확인할 수 없습니다.", Severity.Error);
            return;
        }

        _saveInProgress = true;
        try
        {
            var text = await JS.InvokeAsync<string>("getEditorContent", _elementId);

            // mtime 충돌 검사
            var diskMtime = await GitService.GetFileMtimeUtcAsync(workingDir, FilePath);
            var tab = ChatState.Tabs.OpenTabs
                .FirstOrDefault(t => t.FilePath == FilePath && t.Type == Models.ViewModels.MainTabType.FileContent);
            var loadedMtime = tab?.LastLoadedMtimeUtc;
            if (diskMtime.HasValue && loadedMtime.HasValue &&
                Math.Abs((diskMtime.Value - loadedMtime.Value).TotalMilliseconds) > 1)
            {
                var overwrite = await DialogService.ShowMessageBoxAsync(
                    "외부 변경 감지",
                    "이 파일이 외부에서 변경되었습니다. 그래도 덮어쓸까요?",
                    yesText: "덮어쓰기", cancelText: "취소");
                if (overwrite != true)
                {
                    Snackbar.Add("저장이 취소되었습니다.", Severity.Normal);
                    return;
                }
            }

            await GitService.WriteFileAsync(workingDir, FilePath, text);
            var newMtime = (await GitService.GetFileMtimeUtcAsync(workingDir, FilePath)) ?? DateTime.UtcNow;
            ChatState.Tabs.MarkSaved(FilePath, text, newMtime);
            await JS.InvokeVoidAsync("clearDirty", _elementId);
            Snackbar.Add("저장됨", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"저장 실패: {ex.Message}", Severity.Error);
        }
        finally
        {
            _saveInProgress = false;
        }
    }

    public Task SaveExternallyAsync() => SaveAsync();

    private void StartWatching()
    {
        StopWatching();
        var workingDir = EffectiveWorkingDir;
        if (string.IsNullOrEmpty(workingDir) || string.IsNullOrEmpty(FilePath)) return;

        try
        {
            var fullPath = Path.Combine(workingDir, FilePath.Replace('/', Path.DirectorySeparatorChar));
            var dir = Path.GetDirectoryName(fullPath);
            var fileName = Path.GetFileName(fullPath);
            if (string.IsNullOrEmpty(dir) || string.IsNullOrEmpty(fileName) || !Directory.Exists(dir))
                return;

            _watcher = new FileSystemWatcher(dir, fileName)
            {
                NotifyFilter = NotifyFilters.LastWrite | NotifyFilters.FileName | NotifyFilters.Size,
                EnableRaisingEvents = true
            };

            _watchDebounce = new Timer(1000) { AutoReset = false };
            _watchDebounce.Elapsed += async (_, _) =>
            {
                try { await InvokeAsync(HandleExternalChangeAsync); } catch { /* disposed */ }
            };

            void OnChange(object _, FileSystemEventArgs __)
            {
                lock (_watcherLock)
                {
                    _watchDebounce?.Stop();
                    _watchDebounce?.Start();
                }
            }

            _watcher.Changed += OnChange;
            _watcher.Created += OnChange;
            _watcher.Renamed += (_, e) => OnChange(_, e);
        }
        catch
        {
            // 워처 시작 실패는 치명적이지 않음
        }
    }

    private void StopWatching()
    {
        if (_watcher != null)
        {
            try
            {
                _watcher.EnableRaisingEvents = false;
                _watcher.Dispose();
            }
            catch { /* ignore */ }
            _watcher = null;
        }
        lock (_watcherLock)
        {
            _watchDebounce?.Dispose();
            _watchDebounce = null;
        }
    }

    private async Task HandleExternalChangeAsync()
    {
        if (_saveInProgress || _conflictDialogOpen) return;

        var workingDir = EffectiveWorkingDir;
        if (string.IsNullOrEmpty(workingDir) || string.IsNullOrEmpty(FilePath)) return;

        var tab = ChatState.Tabs.OpenTabs
            .FirstOrDefault(t => t.FilePath == FilePath && t.Type == Models.ViewModels.MainTabType.FileContent);
        if (tab == null) return;

        DateTime? diskMtime;
        try { diskMtime = await GitService.GetFileMtimeUtcAsync(workingDir, FilePath); }
        catch { return; }

        if (!diskMtime.HasValue) return;
        if (tab.LastLoadedMtimeUtc.HasValue &&
            Math.Abs((diskMtime.Value - tab.LastLoadedMtimeUtc.Value).TotalMilliseconds) <= 1)
            return; // 동일 mtime

        if (!tab.IsDirty)
        {
            try
            {
                var fresh = await GitService.ReadFileAsync(workingDir, FilePath);
                await JS.InvokeVoidAsync("setEditorContent", _elementId, fresh);
                ChatState.Tabs.UpdateLoadedMtime(FilePath, diskMtime.Value);
                tab.FileContent = fresh;
                tab.OriginalContent = fresh;
                tab.ContentSizeBytes = (long)fresh.Length * 2;
                Snackbar.Add("디스크에서 변경되어 다시 불러왔습니다.", Severity.Info);
            }
            catch (Exception ex)
            {
                Snackbar.Add($"외부 변경 적용 실패: {ex.Message}", Severity.Error);
            }
            return;
        }

        // 더티 상태 + 외부 변경 → 충돌 다이얼로그
        _conflictDialogOpen = true;
        try
        {
            var keepDisk = await DialogService.ShowMessageBoxAsync(
                "충돌: 외부 변경 감지",
                "에디터에 저장되지 않은 변경이 있는데 디스크가 외부에서 변경되었습니다. 디스크 내용으로 다시 불러올까요? (현재 변경 사항은 사라집니다)",
                yesText: "디스크로 덮어쓰기", cancelText: "내 변경 유지");
            if (keepDisk == true)
            {
                var fresh = await GitService.ReadFileAsync(workingDir, FilePath);
                await JS.InvokeVoidAsync("setEditorContent", _elementId, fresh);
                ChatState.Tabs.MarkSaved(FilePath, fresh, diskMtime.Value);
            }
            else
            {
                ChatState.Tabs.UpdateLoadedMtime(FilePath, diskMtime.Value);
            }
        }
        finally
        {
            _conflictDialogOpen = false;
        }
    }

    public async ValueTask DisposeAsync()
    {
        StopWatching();
        if (!string.IsNullOrEmpty(_elementId))
        {
            try { await JS.InvokeVoidAsync("destroyCodeMirrorView", _elementId); }
            catch { /* 폐기 중 JS interop 실패 가능 */ }
        }
        _selfRef?.Dispose();
        _selfRef = null;
    }

    private static string GetLanguage(string filePath)
    {
        var ext = Path.GetExtension(filePath).ToLowerInvariant();
        return ext switch
        {
            ".md" or ".mdx" => "markdown",
            ".cs" => "csharp",
            ".js" or ".jsx" => "javascript",
            ".ts" or ".tsx" => "typescript",
            ".py" => "python",
            ".rs" => "rust",
            ".go" => "go",
            ".java" => "java",
            ".html" or ".razor" => "xml",
            ".css" or ".scss" => "css",
            ".json" => "json",
            ".yaml" or ".yml" => "yaml",
            ".xml" or ".csproj" or ".sln" or ".xaml" => "xml",
            ".sh" or ".bash" or ".zsh" => "bash",
            ".sql" => "sql",
            ".rb" => "ruby",
            ".swift" => "swift",
            ".kt" => "kotlin",
            ".dart" => "dart",
            ".php" => "php",
            ".dockerfile" => "dockerfile",
            ".toml" or ".ini" or ".cfg" => "ini",
            ".c" or ".cpp" or ".h" or ".hpp" => "cpp",
            ".m" or ".mm" => "objectivec",
            ".r" => "r",
            ".lua" => "lua",
            ".pl" => "perl",
            ".makefile" => "makefile",
            ".graphql" => "graphql",
            ".proto" => "protobuf",
            _ => ""
        };
    }

}
