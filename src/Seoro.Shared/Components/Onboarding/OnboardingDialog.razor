@using Seoro.Shared.Resources

<Modal IsOpen="IsOpen" IsOpenChanged="OnVisibleChanged" MaxWidth="560px"
       ShowCloseButton="false" CloseOnEscape="false">
    <HeaderContent>
        <div class="stack-row items-center gap-2">
            <img src="logo.png" width="22" height="22" alt="Seoro"/>
            <span class="typo-h6">@Strings.Onboarding_Title</span>
        </div>
    </HeaderContent>
    <ChildContent>
        <div class="onboarding-dialog">
            @* Step indicator *@
            <div class="onboarding-steps">
                @for (var i = 0; i < TotalSteps; i++)
                {
                    var step = i;
                    @if (i > 0)
                    {
                        <div class="onboarding-step-line @(step <= _currentStep ? "completed" : "")"></div>
                    }

                    <button
                        class="onboarding-step @(step == _currentStep ? "active" : "") @(step < _currentStep ? "completed" : "")"
                        @onclick="@(() => _currentStep = step)">
                        @if (step < _currentStep)
                        {
                            <Icon Svg="@Lucide.Check" Size="14"/>
                        }
                        else
                        {
                            @(step + 1)
                        }
                    </button>
                }
            </div>

            @* Step content *@
            <div class="onboarding-content">
                @switch (_currentStep)
                {
                    case 0:
                        <div class="onboarding-icon-wrap">
                            <Icon Svg="@Lucide.Sparkles" Size="32"
                                  Style="color: var(--accent);"/>
                        </div>
                        <div class="typo-h6" style="margin-top: 16px;">@Strings.Onboarding_Welcome_Title</div>
                        <p class="typo-body2 text-secondary" style="margin-top: 8px; line-height: 1.6;">
                            @Strings.Onboarding_Welcome_Desc
                        </p>
                        <div class="onboarding-highlights">
                            <div class="onboarding-highlight">
                                <Icon Svg="@Lucide.Code" Size="14" Tone="Tone.Primary"/>
                                <span class="typo-body2">@Strings.Onboarding_Feature1</span>
                            </div>
                            <div class="onboarding-highlight">
                                <Icon Svg="@Lucide.GitFork" Size="14" Tone="Tone.Primary"/>
                                <span class="typo-body2">@Strings.Onboarding_Feature2</span>
                            </div>
                            <div class="onboarding-highlight">
                                <Icon Svg="@Lucide.Terminal" Size="14" Tone="Tone.Primary"/>
                                <span class="typo-body2">@Strings.Onboarding_Feature3</span>
                            </div>
                        </div>
                        break;

                    case 1:
                        <div class="onboarding-icon-wrap">
                            <Icon Svg="@Lucide.FolderPlus" Size="32"
                                  Style="color: var(--accent);"/>
                        </div>
                        <div class="typo-h6" style="margin-top: 16px;">@Strings.Onboarding_Workspace_Title</div>
                        <p class="typo-body2 text-secondary" style="margin-top: 8px; line-height: 1.6;">
                            @Strings.Onboarding_Workspace_Desc
                        </p>
                        <div class="onboarding-highlights">
                            <div class="onboarding-highlight">
                                <Icon Svg="@Lucide.Plus" Size="14" Tone="Tone.Primary"/>
                                <span class="typo-body2">@Strings.Onboarding_Workspace_Step1</span>
                            </div>
                            <div class="onboarding-highlight">
                                <Icon Svg="@Lucide.CloudDownload" Size="14" Tone="Tone.Primary"/>
                                <span class="typo-body2">@Strings.Onboarding_Workspace_Step2</span>
                            </div>
                            <div class="onboarding-highlight">
                                <Icon Svg="@Lucide.Folder" Size="14" Tone="Tone.Primary"/>
                                <span class="typo-body2">@Strings.Onboarding_Workspace_Step3</span>
                            </div>
                        </div>
                        break;

                    case 2:
                        <div class="onboarding-icon-wrap">
                            <Icon Svg="@Lucide.MessageCircle" Size="32"
                                  Style="color: var(--accent);"/>
                        </div>
                        <div class="typo-h6" style="margin-top: 16px;">@Strings.Onboarding_Session_Title</div>
                        <p class="typo-body2 text-secondary" style="margin-top: 8px; line-height: 1.6;">
                            @Strings.Onboarding_Session_Desc
                        </p>
                        <div class="onboarding-highlights">
                            <div class="onboarding-highlight">
                                <Icon Svg="@Lucide.GitBranch" Size="14" Tone="Tone.Primary"/>
                                <span class="typo-body2">@Strings.Onboarding_Session_Step1</span>
                            </div>
                            <div class="onboarding-highlight">
                                <Icon Svg="@Lucide.ListPlus" Size="14" Tone="Tone.Primary"/>
                                <span class="typo-body2">@Strings.Onboarding_Session_Step2</span>
                            </div>
                            <div class="onboarding-highlight">
                                <Icon Svg="@Lucide.Diff" Size="14" Tone="Tone.Primary"/>
                                <span class="typo-body2">@Strings.Onboarding_Session_Step3</span>
                            </div>
                        </div>
                        break;

                    case 3:
                        <div class="onboarding-icon-wrap">
                            <Icon Svg="@Lucide.LayoutDashboard" Size="32"
                                  Style="color: var(--accent);"/>
                        </div>
                        <div class="typo-h6" style="margin-top: 16px;">@Strings.Onboarding_Layout_Title</div>
                        <p class="typo-body2 text-secondary" style="margin-top: 8px; line-height: 1.6;">
                            @Strings.Onboarding_Layout_Desc
                        </p>
                        <div class="onboarding-highlights">
                            <div class="onboarding-highlight">
                                <Icon Svg="@Lucide.PanelLeft" Size="14" Tone="Tone.Primary"/>
                                <span class="typo-body2">@Strings.Onboarding_Layout_Sidebar</span>
                            </div>
                            <div class="onboarding-highlight">
                                <Icon Svg="@Lucide.MessageSquare" Size="14" Tone="Tone.Primary"/>
                                <span class="typo-body2">@Strings.Onboarding_Layout_Chat</span>
                            </div>
                            <div class="onboarding-highlight">
                                <Icon Svg="@Lucide.Diff" Size="14" Tone="Tone.Primary"/>
                                <span class="typo-body2">@Strings.Onboarding_Layout_Panel</span>
                            </div>
                            <div class="onboarding-highlight">
                                <Icon Svg="@Lucide.Settings" Size="14" Tone="Tone.Primary"/>
                                <span class="typo-body2">@Strings.Onboarding_Layout_Settings</span>
                            </div>
                        </div>
                        break;
                }
            </div>
        </div>
    </ChildContent>
    <Footer>
        <div style="display: flex; justify-content: space-between; width: 100%;">
            <Button ButtonStyle="ButtonStyle.Text" OnClick="Skip">
                @Strings.Onboarding_Skip
            </Button>
            <div class="stack-row gap-2">
                @if (_currentStep > 0)
                {
                    <Button ButtonStyle="ButtonStyle.Outlined" OnClick="PreviousStep">
                        @Strings.Onboarding_Prev
                    </Button>
                }
                @if (_currentStep < TotalSteps - 1)
                {
                    <Button Tone="Tone.Primary" ButtonStyle="ButtonStyle.Filled" OnClick="NextStep">
                        @Strings.Onboarding_Next
                    </Button>
                }
                else
                {
                    <Button Tone="Tone.Primary" ButtonStyle="ButtonStyle.Filled" OnClick="Complete">
                        @Strings.Onboarding_Start
                    </Button>
                }
            </div>
        </div>
    </Footer>
</Modal>

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback<bool> IsOpenChanged { get; set; }
    [Parameter] public EventCallback OnCompleted { get; set; }

    private int _currentStep;
    private const int TotalSteps = 4;

    private async Task OnVisibleChanged(bool visible)
    {
        if (IsOpen != visible)
        {
            IsOpen = visible;
            await IsOpenChanged.InvokeAsync(visible);
        }
    }

    private void NextStep()
    {
        if (_currentStep < TotalSteps - 1)
            _currentStep++;
    }

    private void PreviousStep()
    {
        if (_currentStep > 0)
            _currentStep--;
    }

    private async Task Complete()
    {
        _currentStep = 0;
        IsOpen = false;
        await IsOpenChanged.InvokeAsync(false);
        await OnCompleted.InvokeAsync();
    }

    private async Task Skip()
    {
        _currentStep = 0;
        IsOpen = false;
        await IsOpenChanged.InvokeAsync(false);
        await OnCompleted.InvokeAsync();
    }

}
