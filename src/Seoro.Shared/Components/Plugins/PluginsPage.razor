@using System.Diagnostics
@inject IPluginService PluginService
@inject ISnackbar Snackbar

<div class="settings-content-area wide">
    <div class="settings-content-header">
        <div>
            <span class="typo-h6">@Strings.Plugins_Title</span>
            <div class="typo-caption text-secondary">@Strings.Plugins_Desc</div>
        </div>
    </div>

    <div class="settings-content-body">
        @if (_loading)
        {
            <div class="plugins-loading">
                <MudProgressCircular Indeterminate="true" Size="Size.Small"/>
            </div>
        }
        else
        {
            @* ── 탭 + 검색 헤더 ── *@
            <div class="plugins-toolbar">
                <div class="plugins-tab-switcher">
                    <button class="plugins-tab-btn @(_activeTab == "installed" ? "active" : "")"
                            @onclick="@(() => SetTab("installed"))">
                        @Strings.Plugins_TabInstalled
                        @if (InstalledCount > 0)
                        {
                            <span class="plugins-tab-badge">@InstalledCount</span>
                        }
                    </button>
                    <button class="plugins-tab-btn @(_activeTab == "marketplace" ? "active" : "")"
                            @onclick="@(() => SetTab("marketplace"))">
                        @Strings.Plugins_TabMarketplace
                        @if (_installCounts.Count > 0)
                        {
                            <span class="plugins-tab-badge plugins-tab-badge--muted">@_installCounts.Count</span>
                        }
                    </button>
                </div>
                <div style="flex:1;"></div>
                <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                               Size="Size.Small" title="@Strings.Common_Refresh"
                               OnClick="RefreshAll"/>
            </div>

            <div class="plugins-search-bar">
                <MudIcon Icon="@Icons.Material.Filled.Search"
                         Size="Size.Small" Class="plugins-search-icon"/>
                <input class="plugins-search-input"
                       type="text"
                       placeholder="@(_activeTab == "installed" ? Strings.Plugins_SearchInstalled : Strings.Plugins_SearchMarketplace)"
                       @bind="_search" @bind:event="oninput"/>
            </div>

            @* ── 설치됨 탭 ── *@
            @if (_activeTab == "installed")
            {
                var filteredMp = FilteredMarketplaceInstalled;
                var filteredLocal = FilteredLocalOnly;
                var hasAny = filteredMp.Count > 0 || filteredLocal.Count > 0;

                @if (!hasAny)
                {
                    <div class="plugins-empty-state">
                        <MudIcon Icon="@Icons.Material.Filled.Extension"
                                 Style="font-size:36px; opacity:0.18;"/>
                        <p class="typo-body2 text-secondary mt-2">
                            @(_search.Length > 0 ? Strings.Plugins_NoResults : Strings.Plugins_NoneInstalled)
                        </p>
                        @if (_search.Length == 0)
                        {
                            <p class="typo-caption text-secondary" style="text-align:center;">
                                @Strings.Plugins_NoneInstalledHint<br/>
                                <code>@PluginService.PluginsDirectory</code>
                            </p>
                        }
                    </div>
                }
                else
                {
                    <div class="plugins-grid">
                        @foreach (var p in filteredMp)
                        {
                            var blocked = IsBlocked(p.Name);
                            var updating = _updatingPlugin == p.Name;
                            <div @key="p.Name" class="plugin-card @(!p.Enabled ? "plugin-card--disabled" : "") @(blocked ? "plugin-card--blocked" : "")">
                                <div class="plugin-card-top">
                                    <div class="plugin-card-avatar @(!p.Enabled ? "plugin-card-avatar--off" : "")">
                                        <MudIcon Icon="@Icons.Material.Filled.Extension" Size="Size.Small"/>
                                    </div>
                                    <div class="plugin-card-info">
                                        <span class="plugin-card-name">@p.Name</span>
                                        <span class="plugin-card-sub">@(p.Marketplace.Length > 0 ? p.Marketplace : "unknown")</span>
                                    </div>
                                    <div class="plugin-card-actions">
                                        @if (updating)
                                        {
                                            <MudProgressCircular Size="Size.Small" Indeterminate="true"
                                                                 Style="width:16px;height:16px;"/>
                                        }
                                        else if (p.HasUpdate)
                                        {
                                            <MudTooltip Text="@Strings.Plugins_Update">
                                                <MudIconButton Icon="@Icons.Material.Filled.SystemUpdateAlt"
                                                               Size="Size.Small"
                                                               Class="plugin-card-action-btn"
                                                               OnClick="@(() => UpdatePlugin(p))"/>
                                            </MudTooltip>
                                        }
                                        <MudTooltip Text="@Strings.Plugins_Uninstall">
                                            <MudIconButton Icon="@Icons.Material.Filled.DeleteOutline"
                                                           Size="Size.Small" Color="Color.Error"
                                                           Class="plugin-card-action-btn"
                                                           OnClick="@(() => ConfirmUninstall(p))"/>
                                        </MudTooltip>
                                        <MudSwitch T="bool" Value="@p.Enabled"
                                                   ValueChanged="@(v => ToggleMarketplacePlugin(p, v))"
                                                   Color="Color.Primary" Size="Size.Small"/>
                                    </div>
                                </div>
                                <div class="plugin-card-tags">
                                    @if (p.HasUpdate && !string.IsNullOrEmpty(p.LatestVersion))
                                    {
                                        <span class="plugin-tag plugin-tag--update">v@(p.Version) → v@(p.LatestVersion)</span>
                                    }
                                    else
                                    {
                                        <span class="plugin-tag">v@(p.Version)</span>
                                    }
                                    <span class="plugin-tag">@p.Scope</span>
                                    @if (!string.IsNullOrEmpty(p.InstalledAt))
                                    {
                                        <span class="plugin-tag">@FormatDate(p.InstalledAt)</span>
                                    }
                                    @if (!p.Enabled)
                                    {
                                        <span class="plugin-tag plugin-tag--muted">@Strings.Plugins_Inactive</span>
                                    }
                                    @if (blocked)
                                    {
                                        <span class="plugin-tag plugin-tag--danger">@Strings.Plugins_Blocked</span>
                                    }
                                </div>
                            </div>
                        }
                        @foreach (var p in filteredLocal)
                        {
                            <div @key="p.Name" class="plugin-card">
                                <div class="plugin-card-top">
                                    <div class="plugin-card-avatar plugin-card-avatar--local">
                                        <MudIcon Icon="@Icons.Material.Filled.FolderSpecial" Size="Size.Small"/>
                                    </div>
                                    <div class="plugin-card-info">
                                        <span class="plugin-card-name">@p.Name</span>
                                        <span class="plugin-card-sub">@(p.Description ?? Strings.Plugins_LocalSource)</span>
                                    </div>
                                    <MudSwitch T="bool" Value="@p.IsEnabled"
                                               ValueChanged="@(v => ToggleLocalPlugin(p, v))"
                                               Color="Color.Primary" Size="Size.Small"
                                               Disabled="@(p.Status is PluginStatus.Invalid or PluginStatus.Error)"/>
                                </div>
                                <div class="plugin-card-tags">
                                    @if (!string.IsNullOrEmpty(p.Version))
                                    {
                                        <span class="plugin-tag">v@(p.Version)</span>
                                    }
                                    @{
                                        var (_, statusColor, statusLabel) = GetStatusDisplay(p);
                                    }
                                    <MudChip T="string" Size="Size.Small"
                                             Variant="Variant.Outlined" Color="@statusColor"
                                             Style="height:20px; font-size:11px;">
                                        @statusLabel
                                    </MudChip>
                                    @if (!string.IsNullOrEmpty(p.Error))
                                    {
                                        <MudTooltip Text="@p.Error">
                                            <MudIcon Icon="@Icons.Material.Filled.Info"
                                                     Size="Size.Small" Color="Color.Warning"
                                                     Style="width:14px;height:14px;cursor:help;"/>
                                        </MudTooltip>
                                    }
                                </div>
                            </div>
                        }
                    </div>

                    @if (_blockedPlugins.Count > 0)
                    {
                        <div class="plugins-section-title mt-4">
                            <MudIcon Icon="@Icons.Material.Filled.Block" Size="Size.Small"/>
                            @Strings.Plugins_Blocked
                        </div>
                        <div class="stack gap-1 mt-1">
                            @foreach (var b in _blockedPlugins)
                            {
                                <div class="plugin-blocked-row">
                                    <span class="typo-body2">@b.Plugin</span>
                                    @if (!string.IsNullOrEmpty(b.Reason))
                                    {
                                        <span class="typo-caption text-secondary">@b.Reason</span>
                                    }
                                </div>
                            }
                        </div>
                    }
                }

                <div class="mt-3">
                    <MudButton StartIcon="@Icons.Material.Filled.FolderOpen"
                               Size="Size.Small" Variant="Variant.Text"
                               Style="text-transform:none;"
                               OnClick="OpenPluginsDirectory">
                        @Strings.Plugins_OpenDirectory
                    </MudButton>
                </div>
            }

            @* ── 마켓플레이스 탭 ── *@
            @if (_activeTab == "marketplace")
            {
                var filtered = FilteredMarketplace;

                @if (filtered.Count == 0)
                {
                    <div class="plugins-empty-state">
                        <MudIcon Icon="@Icons.Material.Filled.Store"
                                 Style="font-size:36px; opacity:0.18;"/>
                        <p class="typo-body2 text-secondary mt-2">
                            @(_search.Length > 0 ? Strings.Plugins_NoResults : Strings.Plugins_NoMarketplace)
                        </p>
                        @if (_search.Length == 0)
                        {
                            <p class="typo-caption text-secondary">
                                @Strings.Plugins_MarketplaceHint
                            </p>
                        }
                    </div>
                }
                else
                {
                    <div class="plugins-grid plugins-grid--3col">
                        @foreach (var item in filtered)
                        {
                            var name = item.Plugin.Contains('@') ? item.Plugin.Split('@')[0] : item.Plugin;
                            var already = IsMarketplaceInstalled(item.Plugin);
                            var installing = _installingPlugin == item.Plugin;
                            <div class="plugin-card">
                                <div class="plugin-card-top">
                                    <div class="plugin-card-avatar">
                                        <MudIcon Icon="@Icons.Material.Filled.Extension" Size="Size.Small"/>
                                    </div>
                                    <div class="plugin-card-info">
                                        <span class="plugin-card-name">@name</span>
                                        <span class="plugin-card-sub">
                                            <MudIcon Icon="@Icons.Material.Filled.Download"
                                                     Style="width:11px;height:11px;vertical-align:middle;"/>
                                            @FormatInstalls(item.UniqueInstalls) installs
                                        </span>
                                    </div>
                                </div>
                                <div class="mt-2">
                                    @if (already)
                                    {
                                        var installed = FindInstalledPlugin(item.Plugin);
                                        <div class="plugin-installed-label">
                                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle"
                                                     Size="Size.Small"/>
                                            @Strings.Plugins_TabInstalled
                                            @if (installed != null)
                                            {
                                                <span class="plugin-installed-version">v@(installed.Version)</span>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <button class="plugin-install-btn @(installing ? "plugin-install-btn--loading" : "")"
                                                disabled="@installing"
                                                @onclick="@(() => InstallPlugin(item.Plugin))">
                                            @if (installing)
                                            {
                                                <MudProgressCircular Size="Size.Small"
                                                                     Indeterminate="true"
                                                                     Style="width:14px;height:14px;"/>
                                                <span>@Strings.Plugins_Installing</span>
                                            }
                                            else
                                            {
                                                <span>@Strings.Plugins_Install</span>
                                            }
                                        </button>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
            }
        }
    </div>
</div>

@* 언인스톨 확인 *@
@if (_uninstallingPlugin != null)
{
    <MudDialog Visible="true" Options="@(new DialogOptions { MaxWidth = MaxWidth.ExtraSmall, FullWidth = true })">
        <TitleContent>@Strings.Plugins_UninstallTitle</TitleContent>
        <DialogContent>
            <p>@((MarkupString)Strings.Plugins_UninstallConfirm($"<strong>{_uninstallingPlugin.Split('@')[0]}</strong>"))</p>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@(() => _uninstallingPlugin = null)">@Strings.Common_Cancel</MudButton>
            <MudButton Color="Color.Error" Variant="Variant.Filled"
                       OnClick="DoUninstall">@Strings.Plugins_Uninstall</MudButton>
        </DialogActions>
    </MudDialog>
}

@code {
    private string _activeTab = "installed";
    private string _search = "";
    private bool _loading = true;

    private List<MarketplaceInstalledPlugin> _marketplaceInstalled = [];
    private List<PluginInfo> _localPlugins = [];
    private List<PluginInstallCount> _installCounts = [];
    private List<BlockedPlugin> _blockedPlugins = [];

    private string? _installingPlugin;
    private string? _uninstallingPlugin;
    private string? _updatingPlugin;

    // ── Computed ─────────────────────────────────────────────────────────

    private int InstalledCount => _marketplaceInstalled.Count + _localPlugins.Count;

    private List<MarketplaceInstalledPlugin> FilteredMarketplaceInstalled =>
        _marketplaceInstalled
            .Where(p => _search.Length == 0 ||
                        p.Name.Contains(_search, StringComparison.OrdinalIgnoreCase))
            .ToList();

    private List<PluginInfo> FilteredLocalOnly =>
        _localPlugins
            .Where(p => _search.Length == 0 ||
                        p.Name.Contains(_search, StringComparison.OrdinalIgnoreCase))
            .ToList();

    private List<PluginInstallCount> FilteredMarketplace =>
        _installCounts
            .Where(p => _search.Length == 0 ||
                        p.Plugin.Contains(_search, StringComparison.OrdinalIgnoreCase))
            .OrderByDescending(p => p.UniqueInstalls)
            .ToList();

    // ── Lifecycle ────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync() => await LoadAllAsync();

    private async Task LoadAllAsync()
    {
        _loading = true;
        StateHasChanged();

        await PluginService.EnsurePluginsDirectoryAsync();

        var t1 = PluginService.GetInstalledPluginsFileAsync();
        var t2 = PluginService.GetBlockedPluginsAsync();
        var t3 = PluginService.GetInstallCountsCacheAsync();
        var t4 = PluginService.GetInstalledPluginsAsync();
        var t5 = PluginService.ListMarketplacePluginsAsync();
        await Task.WhenAll(t1, t2, t3, t4, t5);

        var mpFile = t1.Result;
        var blocked = t2.Result;
        var counts = t3.Result;
        var local = t4.Result;
        var cliList = t5.Result.ToDictionary(e => e.Id, StringComparer.OrdinalIgnoreCase);

        _marketplaceInstalled = mpFile.Plugins
            .Select(kv =>
            {
                var parts = kv.Key.Split('@', 2);
                var latest = kv.Value.LastOrDefault() ?? new InstallEntry();
                // CLI list로 enabled 상태 보강
                cliList.TryGetValue(kv.Key, out var cliEntry);
                return new MarketplaceInstalledPlugin
                {
                    Name = parts[0],
                    Marketplace = parts.Length > 1 ? parts[1] : "",
                    Scope = latest.Scope,
                    Version = latest.Version,
                    InstalledAt = latest.InstalledAt,
                    Enabled = cliEntry?.Enabled ?? true,
                    HasUpdate = cliEntry?.HasUpdate ?? false,
                    LatestVersion = cliEntry?.LatestVersion ?? ""
                };
            })
            .ToList();

        _blockedPlugins = blocked;
        _installCounts = counts.Counts;

        var mpNames = _marketplaceInstalled
            .Select(p => p.Name)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);
        _localPlugins = local.Where(p => !mpNames.Contains(p.Name)).ToList();

        _loading = false;
        StateHasChanged();
    }

    private async Task RefreshAll() => await LoadAllAsync();

    private void SetTab(string tab) { _activeTab = tab; _search = ""; }

    // ── Helpers ──────────────────────────────────────────────────────────

    private bool IsBlocked(string name) =>
        _blockedPlugins.Any(b =>
            b.Plugin.Equals(name, StringComparison.OrdinalIgnoreCase) ||
            b.Plugin.StartsWith(name + "@", StringComparison.OrdinalIgnoreCase));

    private bool IsMarketplaceInstalled(string fullName)
    {
        var name = fullName.Contains('@') ? fullName.Split('@')[0] : fullName;
        return _marketplaceInstalled.Any(p =>
            p.Name.Equals(name, StringComparison.OrdinalIgnoreCase));
    }

    private MarketplaceInstalledPlugin? FindInstalledPlugin(string fullName)
    {
        var name = fullName.Contains('@') ? fullName.Split('@')[0] : fullName;
        return _marketplaceInstalled.FirstOrDefault(p =>
            p.Name.Equals(name, StringComparison.OrdinalIgnoreCase));
    }

    private static string FormatInstalls(int n) => n switch
    {
        >= 1_000_000 => $"{n / 1_000_000.0:F1}M",
        >= 1_000 => $"{n / 1_000.0:F1}K",
        _ => n.ToString()
    };

    private static string FormatDate(string s) =>
        DateTime.TryParse(s, out var d) ? d.ToString("yyyy-MM-dd") : s;

    private static (string icon, Color color, string label) GetStatusDisplay(PluginInfo p) =>
        !p.IsEnabled
            ? (Icons.Material.Filled.PauseCircle, Color.Default, Strings.Plugins_Inactive)
            : p.Status switch
            {
                PluginStatus.Valid => (Icons.Material.Filled.CheckCircle, Color.Success, Strings.Plugins_StatusNormal),
                PluginStatus.Loaded => (Icons.Material.Filled.CheckCircle, Color.Success, Strings.Plugins_StatusLoaded),
                PluginStatus.Invalid => (Icons.Material.Filled.Error, Color.Error, Strings.Plugins_StatusError),
                PluginStatus.Error => (Icons.Material.Filled.Error, Color.Error, Strings.Plugins_StatusError),
                _ => (Icons.Material.Filled.RadioButtonUnchecked, Color.Default, Strings.Plugins_StatusChecking)
            };

    // ── Actions ──────────────────────────────────────────────────────────

    private async Task InstallPlugin(string pluginName)
    {
        _installingPlugin = pluginName;
        StateHasChanged();
        var (success, output) = await PluginService.InstallMarketplacePluginAsync(pluginName);
        _installingPlugin = null;
        if (success)
        {
            Snackbar.Add(Strings.Plugins_InstallSuccess(pluginName.Split('@')[0]), Severity.Success);
            await LoadAllAsync();
        }
        else
        {
            Snackbar.Add(Strings.Plugins_InstallFailed(output), Severity.Error);
            StateHasChanged();
        }
    }

    private async Task ToggleMarketplacePlugin(MarketplaceInstalledPlugin p, bool enabled)
    {
        var fullName = p.Marketplace.Length > 0 ? $"{p.Name}@{p.Marketplace}" : p.Name;
        var (success, output) = enabled
            ? await PluginService.EnableMarketplacePluginAsync(fullName)
            : await PluginService.DisableMarketplacePluginAsync(fullName);

        if (success)
        {
            p.Enabled = enabled;
            Snackbar.Add(Strings.Plugins_ToggleSuccess(p.Name, enabled ? Strings.Plugins_VerbEnable : Strings.Plugins_VerbDisable), Severity.Info);
            StateHasChanged();
        }
        else
        {
            Snackbar.Add(Strings.Plugins_ToggleFailed(output), Severity.Error);
        }
    }

    private async Task UpdatePlugin(MarketplaceInstalledPlugin p)
    {
        _updatingPlugin = p.Name;
        StateHasChanged();
        var fullName = p.Marketplace.Length > 0 ? $"{p.Name}@{p.Marketplace}" : p.Name;
        var (success, output) = await PluginService.UpdateMarketplacePluginAsync(fullName);
        _updatingPlugin = null;
        if (success)
        {
            Snackbar.Add(Strings.Plugins_UpdateSuccess(p.Name), Severity.Success);
            await LoadAllAsync();
        }
        else
        {
            Snackbar.Add(Strings.Plugins_UpdateFailed(output), Severity.Error);
            StateHasChanged();
        }
    }

    private void ConfirmUninstall(MarketplaceInstalledPlugin p) =>
        _uninstallingPlugin = p.Marketplace.Length > 0 ? $"{p.Name}@{p.Marketplace}" : p.Name;

    private async Task DoUninstall()
    {
        if (_uninstallingPlugin == null) return;
        var name = _uninstallingPlugin;
        _uninstallingPlugin = null;
        var (success, output) = await PluginService.UninstallMarketplacePluginAsync(name);
        if (success)
        {
            Snackbar.Add(Strings.Plugins_RemoveSuccess(name.Split('@')[0]), Severity.Success);
            await LoadAllAsync();
        }
        else
        {
            Snackbar.Add(Strings.Plugins_RemoveFailed(output), Severity.Error);
        }
    }

    private async Task ToggleLocalPlugin(PluginInfo p, bool enabled)
    {
        await PluginService.SetPluginEnabledAsync(p.Id, enabled);
        p.IsEnabled = enabled;
        Snackbar.Add(Strings.Plugins_ToggleSuccess(p.Name, enabled ? Strings.Plugins_VerbEnable : Strings.Plugins_VerbDisable), Severity.Info);
        StateHasChanged();
    }

    private async Task OpenPluginsDirectory()
    {
        await PluginService.EnsurePluginsDirectoryAsync();
        try { Process.Start(new ProcessStartInfo { FileName = PluginService.PluginsDirectory, UseShellExecute = true }); }
        catch (Exception ex) { Snackbar.Add(Strings.Plugins_OpenDirFailed(ex.Message), Severity.Warning); }
    }
}
