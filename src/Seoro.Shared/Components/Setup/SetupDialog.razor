@using System.Runtime.InteropServices
@using Seoro.Shared.Resources
@inject IDependencyCheckService DependencyCheckService

<Modal IsOpen="IsOpen" IsOpenChanged="OnVisibleChanged" MaxWidth="560px"
       ShowCloseButton="false" CloseOnEscape="false">
    <HeaderContent>
        <div class="typo-h6" style="display:flex;align-items:center;gap:8px;">
            <img src="logo.png" width="22" height="22" alt="Seoro"/>
            @Strings.Setup_Title
        </div>
    </HeaderContent>
    <ChildContent>
        <div class="stack gap-3 pa-2" style="min-width: 440px;">
            <p class="typo-body2 text-secondary">
                @Strings.Setup_Desc
            </p>

            @if (_loading)
            {
                <ProgressBar Indeterminate="true"/>
            }
            else if (_results != null)
            {
                @foreach (var dep in _results)
                {
                    <div class="ui-card pa-3">
                        <div class="stack-row items-center gap-2">
                            @if (dep.IsInstalled)
                            {
                                <Icon Svg="@Lucide.CircleCheck" Tone="Tone.Success" Size="18"/>
                            }
                            else
                            {
                                <Icon Svg="@Lucide.TriangleAlert" Tone="Tone.Warning" Size="18"/>
                            }
                            <div class="stack flex-1">
                                <div class="typo-subtitle2">@dep.Name</div>
                                <small class="typo-caption text-secondary">@dep.Description</small>
                            </div>
                            @if (dep.IsInstalled)
                            {
                                <Chip Tone="Tone.Success">
                                    @(dep.Version ?? Strings.Setup_Installed)
                                </Chip>
                            }
                        </div>

                        @if (!dep.IsInstalled)
                        {
                            <Divider Class="my-2"/>
                            <div class="stack gap-1">
                                <small class="typo-caption text-secondary">@Strings.Setup_HowToInstall</small>
                                @{
                                    var methods = _isMac ? dep.MacMethods : dep.WindowsMethods;
                                }
                                @if (methods.Count > 0)
                                {
                                    @foreach (var method in methods)
                                    {
                                        <div class="stack-row items-center gap-2">
                                            <Chip ButtonStyle="ButtonStyle.Outlined"
                                                  Style="min-width: 80px; justify-content: center;">
                                                @method.Label
                                            </Chip>
                                            <code style="flex: 1;">@method.InstallCommand</code>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <p class="typo-body2">
                                        <code>@(_isMac ? dep.MacInstallHint : dep.WindowsInstallHint)</code>
                                    </p>
                                }
                                <TextLink Href="@dep.InstallUrl" Target="_blank" Class="typo-caption">
                                    @dep.InstallUrl
                                </TextLink>
                            </div>
                        }
                    </div>
                }
            }
        </div>
    </ChildContent>
    <Footer>
        @if (_allInstalled)
        {
            <Button Tone="Tone.Primary" ButtonStyle="ButtonStyle.Filled" OnClick="Close">
                @Strings.Setup_Start
            </Button>
        }
        else
        {
            <Button OnClick="Close">@Strings.Setup_Skip</Button>
            <Button Tone="Tone.Primary" ButtonStyle="ButtonStyle.Filled" OnClick="Recheck"
                    Disabled="_loading">
                @Strings.Setup_Recheck
            </Button>
        }
    </Footer>
</Modal>

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback<bool> IsOpenChanged { get; set; }

    private List<DependencyResult>? _results;
    private bool _loading;
    private bool _allInstalled;
    private readonly bool _isMac = !RuntimeInformation.IsOSPlatform(OSPlatform.Windows);

    protected override async Task OnParametersSetAsync()
    {
        if (IsOpen && _results == null)
        {
            await RunCheck();
        }
    }

    private async Task RunCheck()
    {
        _loading = true;
        StateHasChanged();

        _results = await DependencyCheckService.CheckAllAsync();
        _allInstalled = _results.All(r => r.IsInstalled);
        _loading = false;

        if (_allInstalled)
        {
            await Close();
        }
    }

    private async Task Recheck()
    {
        _results = null;
        await RunCheck();
    }

    private async Task OnVisibleChanged(bool visible)
    {
        if (IsOpen != visible)
        {
            IsOpen = visible;
            await IsOpenChanged.InvokeAsync(visible);
        }
    }

    private async Task Close()
    {
        IsOpen = false;
        await IsOpenChanged.InvokeAsync(false);
    }

}
