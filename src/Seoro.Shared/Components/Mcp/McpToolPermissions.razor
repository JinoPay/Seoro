@implements IDisposable
@inject IClaudeSettingsService ClaudeSettingsService
@inject IMcpService McpService
@inject IToastService Snackbar

<div class="mcp-permissions">
    <div class="mcp-permissions-header">
        <Icon Svg="@Lucide.Shield" Size="14"/>
        <span class="typo-subtitle2">도구 권한</span>
        <Tooltip Text="Claude가 이 서버의 도구를 사용할 시기를 제어합니다">
            <Icon Svg="@Lucide.CircleHelp" Size="14" Style="opacity:0.5;"/>
        </Tooltip>
        @if (Server != null)
        {
            <Tooltip Text="서버에 연결하여 도구 목록을 가져오고 전부 허용으로 설정합니다" Class="ml-auto">
                <Button StartIcon="@(_discovering ? null : Lucide.RefreshCw)"
                        ButtonStyle="ButtonStyle.Text"
                        OnClick="DiscoverAndAllowTools"
                        Disabled="@_discovering">
                    @if (_discovering)
                    {
                        <Spinner Size="14" Style="margin-right:4px;"/>
                    }
                    도구 조회
                </Button>
            </Tooltip>
        }
    </div>

    @if (_discoverError != null)
    {
        <Alert Tone="Tone.Error" Dense="true" Class="mt-1"
               OnClose="@(() => _discoverError = null)">@_discoverError</Alert>
    }

    @if (_loading)
    {
        <ProgressBar Indeterminate="true" Class="my-2"/>
    }
    else
    {
        @if (_permissions.Count > 0)
        {
            <div class="stack gap-1 mt-2">
                @foreach (var perm in _permissions)
                {
                    <div class="mcp-tool-row">
                        <span class="typo-caption mcp-tool-name">@perm.ToolName</span>
                        <div class="mcp-tool-actions">
                            <Tooltip Text="허용">
                                <IconButton Icon="@Lucide.CircleCheck"
                                            Tone="@(perm.Level == McpPermissionLevel.Allow ? Tone.Success : Tone.Default)"
                                            OnClick="@(() => SetPermission(perm, McpPermissionLevel.Allow))"/>
                            </Tooltip>
                            <Tooltip Text="확인 후 허용">
                                <IconButton Icon="@Lucide.CircleHelp"
                                            Tone="@(perm.Level == McpPermissionLevel.Ask ? Tone.Warning : Tone.Default)"
                                            OnClick="@(() => SetPermission(perm, McpPermissionLevel.Ask))"/>
                            </Tooltip>
                            <Tooltip Text="금지">
                                <IconButton Icon="@Lucide.Ban"
                                            Tone="@(perm.Level == McpPermissionLevel.Deny ? Tone.Error : Tone.Default)"
                                            OnClick="@(() => SetPermission(perm, McpPermissionLevel.Deny))"/>
                            </Tooltip>
                            <Tooltip Text="제거">
                                <IconButton Icon="@Lucide.Trash2"
                                            OnClick="@(() => RemovePermission(perm))"/>
                            </Tooltip>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="typo-caption text-secondary mt-2">설정된 도구 권한이 없습니다.</div>
        }

        @* Add new tool permission *@
        <div class="mcp-add-permission mt-2">
            @if (_addingNew)
            {
                <div class="d-flex gap-1 align-center">
                    <TextField @bind-Value="_newToolName" Placeholder="도구 이름 (예: get_screenshot)"
                               Style="flex: 1;" Immediate="true"/>
                    <Select T="McpPermissionLevel" @bind-Value="_newLevel" Fixed="true" Style="width: 100px;">
                        <SelectItem T="McpPermissionLevel" Value="McpPermissionLevel.Allow" Text="허용">허용</SelectItem>
                        <SelectItem T="McpPermissionLevel" Value="McpPermissionLevel.Ask" Text="확인">확인</SelectItem>
                        <SelectItem T="McpPermissionLevel" Value="McpPermissionLevel.Deny" Text="금지">금지</SelectItem>
                    </Select>
                    <IconButton Icon="@Lucide.Check" Tone="Tone.Primary"
                                OnClick="AddPermission" Disabled="@string.IsNullOrWhiteSpace(_newToolName)"/>
                    <IconButton Icon="@Lucide.X"
                                OnClick="@(() => { _addingNew = false; _newToolName = ""; })"/>
                </div>
            }
            else
            {
                <Button StartIcon="@Lucide.Plus" ButtonStyle="ButtonStyle.Text"
                        OnClick="@(() => _addingNew = true)">
                    도구 권한 추가
                </Button>
            }
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public string ServerName { get; set; } = "";
    [Parameter] public McpServer? Server { get; set; }
    [Parameter] public McpScope Scope { get; set; }
    [Parameter] public string? ProjectPath { get; set; }

    private List<McpToolPermission> _permissions = [];
    private bool _loading;
    private bool _addingNew;
    private string _newToolName = "";
    private McpPermissionLevel _newLevel = McpPermissionLevel.Allow;
    private bool _discovering;
    private string? _discoverError;
    private CancellationTokenSource? _discoverCts;

    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrEmpty(ServerName))
            await LoadPermissionsAsync();
    }

    private ClaudeSettingsScope GetSettingsScope() => Scope switch
    {
        McpScope.Project => ClaudeSettingsScope.Project,
        McpScope.Local => ClaudeSettingsScope.Local,
        _ => ClaudeSettingsScope.Global
    };

    private async Task LoadPermissionsAsync()
    {
        _loading = true;
        StateHasChanged();
        try
        {
            var settingsScope = GetSettingsScope();
            var settings = await ClaudeSettingsService.ReadAsync(settingsScope, ProjectPath);
            _permissions = McpService.ExtractToolPermissions(ServerName, settings.Permissions);
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task SetPermission(McpToolPermission perm, McpPermissionLevel newLevel)
    {
        var settingsScope = GetSettingsScope();
        var settings = await ClaudeSettingsService.ReadAsync(settingsScope, ProjectPath);
        settings.Permissions = McpService.ApplyToolPermission(settings.Permissions, ServerName, perm.ToolName, newLevel);
        await ClaudeSettingsService.WriteAsync(settingsScope, settings, ProjectPath);
        await LoadPermissionsAsync();
    }

    private async Task RemovePermission(McpToolPermission perm)
    {
        var settingsScope = GetSettingsScope();
        var settings = await ClaudeSettingsService.ReadAsync(settingsScope, ProjectPath);
        settings.Permissions = McpService.RemoveToolPermission(settings.Permissions, perm.RawPattern);
        await ClaudeSettingsService.WriteAsync(settingsScope, settings, ProjectPath);
        await LoadPermissionsAsync();
    }

    private async Task AddPermission()
    {
        if (string.IsNullOrWhiteSpace(_newToolName)) return;
        var settingsScope = GetSettingsScope();
        var settings = await ClaudeSettingsService.ReadAsync(settingsScope, ProjectPath);
        settings.Permissions = McpService.ApplyToolPermission(settings.Permissions, ServerName, _newToolName.Trim(), _newLevel);
        await ClaudeSettingsService.WriteAsync(settingsScope, settings, ProjectPath);
        _newToolName = "";
        _addingNew = false;
        Snackbar.Add("도구 권한이 추가되었습니다.", ToastSeverity.Success);
        await LoadPermissionsAsync();
    }

    private async Task DiscoverAndAllowTools()
    {
        if (Server == null) return;

        _discovering = true;
        _discoverError = null;
        StateHasChanged();

        if (_discoverCts != null)
        {
            await _discoverCts.CancelAsync();
            _discoverCts.Dispose();
        }
        _discoverCts = new CancellationTokenSource();

        try
        {
            var result = await McpService.ListToolsAsync(Server, _discoverCts.Token);
            if (!result.Success)
            {
                _discoverError = result.Error;
                return;
            }

            // 현재 권한이 없는 도구만 Allow로 추가
            var settingsScope = GetSettingsScope();
            var settings = await ClaudeSettingsService.ReadAsync(settingsScope, ProjectPath);
            var existing = McpService.ExtractToolPermissions(ServerName, settings.Permissions)
                .Select(p => p.ToolName)
                .ToHashSet(StringComparer.OrdinalIgnoreCase);

            var newCount = 0;
            foreach (var tool in result.Tools)
            {
                if (existing.Contains(tool.Name)) continue;
                settings.Permissions = McpService.ApplyToolPermission(
                    settings.Permissions, ServerName, tool.Name, McpPermissionLevel.Allow);
                newCount++;
            }

            if (newCount > 0)
            {
                await ClaudeSettingsService.WriteAsync(settingsScope, settings, ProjectPath);
                Snackbar.Add($"도구 {newCount}개를 허용으로 설정했습니다.", ToastSeverity.Success);
            }
            else
            {
                Snackbar.Add($"도구 {result.Tools.Count}개 조회 완료 (이미 모두 권한 설정됨)", ToastSeverity.Info);
            }

            await LoadPermissionsAsync();
        }
        finally
        {
            _discovering = false;
            StateHasChanged();
        }
    }

    public void Dispose()
    {
        _discoverCts?.Cancel();
        _discoverCts?.Dispose();
    }
}

<style>
    .mcp-permissions {
        padding-top: 12px;
        border-top: 1px solid var(--border-default);
        margin-top: 12px;
    }

    .mcp-permissions-header {
        display: flex;
        align-items: center;
        gap: 6px;
        margin-bottom: 4px;
    }

    .mcp-tool-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 2px 4px;
        border-radius: 4px;
    }

    .mcp-tool-row:hover {
        background: var(--bg-hover);
    }

    .mcp-tool-name {
        font-family: var(--font-mono);
        flex: 1;
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .mcp-tool-actions {
        display: flex;
        gap: 0;
        flex-shrink: 0;
    }

    .mcp-add-permission {
        margin-top: 4px;
    }
</style>
