@inject IClaudeAccountService AccountService
@inject IClaudeCredentialService CredentialService
@inject IToastService Snackbar
@inject IJSRuntime JS
@implements IDisposable

<div class="stack gap-3" style="min-width: 380px;">
    @switch (_step)
    {
        case WizardStep.Confirm:
            <div class="typo-caption text-secondary">
                현재 계정의 인증 정보를 백업한 후 로그아웃 상태로 만듭니다.
                새 계정으로 로그인하면 자동으로 감지됩니다.
            </div>

            @if (_activeEmail != null)
            {
                <div class="d-flex align-center gap-2 pa-2"
                     style="background: var(--bg-sidebar); border-radius: 8px;">
                    <Icon Svg="@Lucide.CircleUser" Size="14" Tone="Tone.Info"/>
                    <div>
                        <div class="typo-caption text-secondary">현재 활성 계정</div>
                        <div class="typo-body2">@_activeEmail</div>
                    </div>
                </div>
            }

            @if (_activeEmail == null && !_loading)
            {
                <Alert Tone="Tone.Info" Dense="true">
                    활성 계정이 없습니다. 바로 로그인 단계로 진행합니다.
                </Alert>
            }
            break;

        case WizardStep.WaitingLogin:
            @if (_preparing)
            {
                <div class="d-flex flex-column align-center gap-2 pa-4">
                    <Spinner Size="16"/>
                    <div class="typo-caption text-secondary">백업 및 로그아웃 처리 중...</div>
                </div>
            }
            else if (_prepareError != null)
            {
                <Alert Tone="Tone.Error" Dense="true">@_prepareError</Alert>
            }
            else
            {
                <Alert Tone="Tone.Success" Dense="true" Class="mb-2">
                    이전 계정이 안전하게 백업되었습니다.
                </Alert>

                <div class="typo-caption text-secondary">
                    터미널에서 아래 명령어를 실행하여 새 계정으로 로그인하세요.
                </div>

                <div class="d-flex align-center gap-2 pa-2"
                     style="background: var(--bg-sidebar); border-radius: 8px; font-family: var(--font-mono);">
                    <code style="flex: 1;">claude login</code>
                    <IconButton Icon="@Lucide.Copy"
                                OnClick="CopyLoginCommand"/>
                </div>

                <div class="d-flex align-center gap-2 pa-2">
                    <Spinner Size="16"/>
                    <span class="typo-caption text-secondary">로그인 대기 중...</span>
                </div>
            }
            break;

        case WizardStep.Register:
            @if (!string.IsNullOrEmpty(_detectedEmail))
            {
                <div class="d-flex align-center gap-2 pa-2"
                     style="background: var(--bg-sidebar); border-radius: 8px;">
                    <Icon Svg="@Lucide.CircleUser" Size="14" Tone="Tone.Success"/>
                    <div>
                        <div class="typo-caption text-secondary">감지된 새 계정</div>
                        <div class="typo-body2">@_detectedEmail</div>
                    </div>
                    <Chip Tone="Tone.Success" ButtonStyle="ButtonStyle.Outlined"
                          Style="margin-left: auto;">로그인됨</Chip>
                </div>
            }

            <TextField @bind-Value="_profileName" Label="프로필 이름"
                       Placeholder="예: 개인, 회사, 프리랜서..."
                       HelperText="여러 계정을 구분하는 이름"
                       Immediate="true" AutoFocus="true"
                       OnKeyDown="OnKeyDown"/>
            break;
    }
</div>
<div class="ui-modal__footer">
    @switch (_step)
    {
        case WizardStep.Confirm:
            <Button OnClick="Cancel" ButtonStyle="ButtonStyle.Text">취소</Button>
            <Button OnClick="GoToWaitingLogin" ButtonStyle="ButtonStyle.Filled" Tone="Tone.Primary"
                    Disabled="@_loading">
                계속
            </Button>
            break;

        case WizardStep.WaitingLogin:
            <Button OnClick="CancelWithRestore" ButtonStyle="ButtonStyle.Text"
                    Disabled="@_preparing">취소</Button>
            break;

        case WizardStep.Register:
            <Button OnClick="CancelWithRestore" ButtonStyle="ButtonStyle.Text">취소</Button>
            <Button OnClick="ConfirmRegister" ButtonStyle="ButtonStyle.Filled" Tone="Tone.Primary"
                    Disabled="@(!CanRegister)" StartIcon="@Lucide.Save">
                등록
            </Button>
            break;
    }
</div>

@code {
    [CascadingParameter] private IModalInstance Modal { get; set; } = null!;

    private enum WizardStep { Confirm, WaitingLogin, Register }

    private WizardStep _step = WizardStep.Confirm;
    private bool _loading = true;
    private string? _activeEmail;
    private string? _backedUpAccountId;
    private bool _preparing;
    private string? _prepareError;
    private string? _detectedEmail;
    private string _profileName = "";
    private CancellationTokenSource? _pollCts;
    private bool _disposed;

    private bool CanRegister => !string.IsNullOrWhiteSpace(_profileName);

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var configJson = await CredentialService.ReadCurrentConfigAsync();
            var credJson = await CredentialService.ReadCurrentCredentialsAsync();
            _activeEmail = CredentialService.ExtractEmail(configJson, credJson);
        }
        catch { /* ignore */ }
        finally
        {
            _loading = false;
        }
    }

    private async Task GoToWaitingLogin()
    {
        _step = WizardStep.WaitingLogin;
        _preparing = true;
        _prepareError = null;
        StateHasChanged();

        try
        {
            _backedUpAccountId = await AccountService.PrepareForNewLoginAsync();
            _preparing = false;
            StateHasChanged();

            StartPolling();
        }
        catch (Exception ex)
        {
            _preparing = false;
            _prepareError = $"백업 실패: {ex.Message}";
            StateHasChanged();
        }
    }

    private void StartPolling()
    {
        _pollCts = new CancellationTokenSource();
        var token = _pollCts.Token;

        _ = Task.Run(async () =>
        {
            try
            {
                using var timer = new PeriodicTimer(TimeSpan.FromSeconds(2));
                while (await timer.WaitForNextTickAsync(token))
                {
                    var config = await CredentialService.ReadCurrentConfigAsync();
                    if (config != null && ContainsOAuthAccount(config))
                    {
                        var creds = await CredentialService.ReadCurrentCredentialsAsync();
                        var email = CredentialService.ExtractEmail(config, creds);

                        await InvokeAsync(() =>
                        {
                            _detectedEmail = email;
                            _step = WizardStep.Register;
                            StateHasChanged();
                        });
                        break;
                    }
                }
            }
            catch (OperationCanceledException) { /* expected on cancel */ }
        }, token);
    }

    private static bool ContainsOAuthAccount(string configJson)
    {
        try
        {
            var doc = System.Text.Json.JsonDocument.Parse(configJson);
            return doc.RootElement.TryGetProperty("oauthAccount", out _);
        }
        catch { return false; }
    }

    private async Task ConfirmRegister()
    {
        if (!CanRegister) return;

        try
        {
            var account = await AccountService.RegisterCurrentAsync(_profileName.Trim());
            Snackbar.Add($"'{account.ProfileName}' 계정이 등록되었습니다.", ToastSeverity.Success);
            Modal.Close(ModalResult.Ok(account));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"등록 실패: {ex.Message}", ToastSeverity.Error);
        }
    }

    private void Cancel() => Modal.Cancel();

    private async Task CancelWithRestore()
    {
        StopPolling();

        var idToRestore = _backedUpAccountId;
        _backedUpAccountId = null; // Dispose에서 이중 복원 방지

        if (idToRestore != null)
        {
            try
            {
                await AccountService.RestoreAfterCancelAsync(idToRestore);
                Snackbar.Add("이전 계정이 복원되었습니다.", ToastSeverity.Info);
            }
            catch (Exception ex)
            {
                Snackbar.Add($"계정 복원 실패: {ex.Message}", ToastSeverity.Error);
            }
        }

        Modal.Cancel();
    }

    private async Task CopyLoginCommand()
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", "claude login");
        Snackbar.Add("클립보드에 복사되었습니다.", ToastSeverity.Info);
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await ConfirmRegister();
    }

    private void StopPolling()
    {
        _pollCts?.Cancel();
        _pollCts?.Dispose();
        _pollCts = null;
    }

    public void Dispose()
    {
        if (_disposed) return;
        _disposed = true;
        StopPolling();

        // 완료하지 않고 WaitingLogin/Register 중에 폐기된 경우 복원
        if (_backedUpAccountId != null && _step != WizardStep.Confirm)
        {
            _ = Task.Run(async () =>
            {
                try { await AccountService.RestoreAfterCancelAsync(_backedUpAccountId); }
                catch { /* best effort */ }
            });
        }
    }
}
