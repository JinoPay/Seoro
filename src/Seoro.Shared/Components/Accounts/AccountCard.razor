@inject IClaudeAccountService AccountService
@inject IToastService Snackbar

<div class="@($"acct-card{(Account.IsActive ? " acct-card--active" : "")}")">

    @* ── Identity ── *@
    <div class="acct-card-top">
        <Avatar Size="38" Style="@($"background:{AvatarColor()};color:#fff;font-weight:700;flex-shrink:0;")">
            @if (!string.IsNullOrEmpty(Account.EmailAddress))
            {
                @Account.EmailAddress[0].ToString().ToUpper()
            }
            else
            {
                <Icon Svg="@Lucide.User" Size="14"/>
            }
        </Avatar>

        <div class="acct-card-identity">
            @if (_editingName)
            {
                <TextField @bind-Value="_editName"
                           Style="font-size:13px;margin:0;" AutoFocus="true"
                           OnKeyDown="OnEditKeyDown" OnBlur="SaveName"/>
            }
            else
            {
                <span class="acct-name" @ondblclick="StartEdit">@Account.ProfileName</span>
            }
            <span class="acct-email">@Account.EmailAddress</span>
        </div>

        <div style="display:flex;align-items:center;gap:4px;flex-shrink:0;margin-left:auto;">
            @if (Account.IsActive)
            {
                <Chip Tone="Tone.Success" ButtonStyle="ButtonStyle.Filled"
                      Icon="@Lucide.CircleCheck">활성</Chip>
            }
            @if (_backupMissing)
            {
                <Tooltip Text="백업 파일이 없습니다. 계정을 다시 등록하세요.">
                    <Icon Svg="@Lucide.TriangleAlert" Size="14" Tone="Tone.Error"/>
                </Tooltip>
            }
        </div>
    </div>

    @* ── Usage ── *@
    @if (_fetchingUsage)
    {
        <ProgressBar Indeterminate="true" Style="margin:8px 0 4px;"/>
    }
    else if (HasAnyUsage())
    {
        <div class="acct-usage-grid">
            @if (_usage!.FiveHour is { } fh)
            {
                <div class="acct-usage-col">
                    <span class="acct-usage-label">현재 세션</span>
                    <div class="acct-usage-bar-row">
                        <ProgressBar Value="@fh.Utilization"
                                     Tone="@UsageTone(fh.Utilization)"/>
                        <span class="acct-usage-pct" style="color:@UsageColorCss(fh.Utilization);">@($"{fh.Utilization:F0}%")</span>
                    </div>
                    <span class="acct-usage-reset">@FormatResetTime(fh.ResetsAt)</span>
                </div>
            }
            @if (_usage!.SevenDayAll is { } all)
            {
                <div class="acct-usage-col">
                    <span class="acct-usage-label">모든 모델</span>
                    <div class="acct-usage-bar-row">
                        <ProgressBar Value="@all.Utilization"
                                     Tone="@UsageTone(all.Utilization)"/>
                        <span class="acct-usage-pct" style="color:@UsageColorCss(all.Utilization);">@($"{all.Utilization:F0}%")</span>
                    </div>
                    <span class="acct-usage-reset">@FormatResetTime(all.ResetsAt)</span>
                </div>
            }
            @if (_usage!.SevenDaySonnet is { } sonnet)
            {
                <div class="acct-usage-col">
                    <span class="acct-usage-label">Sonnet만</span>
                    <div class="acct-usage-bar-row">
                        <ProgressBar Value="@sonnet.Utilization"
                                     Tone="@UsageTone(sonnet.Utilization)"/>
                        <span class="acct-usage-pct" style="color:@UsageColorCss(sonnet.Utilization);">@($"{sonnet.Utilization:F0}%")</span>
                    </div>
                    <span class="acct-usage-reset">@FormatResetTime(sonnet.ResetsAt)</span>
                </div>
            }
        </div>
    }

    @* ── Stats + Actions ── *@
    <div class="acct-card-footer">
        <div class="acct-stats">
            <span>전환 <strong>@Account.SwitchCount</strong></span>
            <span class="acct-stats-dot">·</span>
            <span><strong>@FormatDuration(Account.TotalActiveSeconds)</strong></span>
            <span class="acct-stats-dot">·</span>
            <span>@FormatLastUsed(Account.LastSwitchedAt)</span>
        </div>

        <div class="acct-actions">
            <Tooltip Text="@(CanSwitch ? "" : "진행 중인 세션이 있어 전환할 수 없습니다.")">
                <Button ButtonStyle="@(Account.IsActive ? ButtonStyle.Outlined : ButtonStyle.Filled)"
                        Tone="Tone.Primary"
                        StartIcon="@(Account.IsActive ? Lucide.Check : Lucide.UsersRound)"
                        OnClick="Switch"
                        Disabled="@(Account.IsActive || !CanSwitch || _switching)"
                        Style="min-width:76px;">
                    @if (_switching)
                    {
                        <Spinner Size="14" Style="margin-right:4px;"/>
                    }
                    @(Account.IsActive ? "현재 계정" : "전환")
                </Button>
            </Tooltip>

            <Tooltip Text="사용량 새로고침">
                <IconButton Icon="@Lucide.RefreshCw"
                            OnClick="FetchUsage" Disabled="_fetchingUsage"/>
            </Tooltip>
            <Tooltip Text="토큰 갱신">
                <IconButton Icon="@Lucide.Key"
                            OnClick="RefreshToken" Disabled="_refreshingToken"/>
            </Tooltip>
            <Tooltip Text="이름 편집">
                <IconButton Icon="@Lucide.Pencil"
                            OnClick="StartEdit"/>
            </Tooltip>
            <Tooltip Text="계정 삭제">
                <IconButton Icon="@Lucide.Trash2"
                            Tone="Tone.Error" OnClick="Delete"/>
            </Tooltip>
        </div>
    </div>

</div>

@code {
    [Parameter, EditorRequired] public ClaudeAccount Account { get; set; } = null!;
    [Parameter] public bool CanSwitch { get; set; }
    [Parameter] public EventCallback OnChanged { get; set; }
    [Parameter] public bool AutoFetch { get; set; }

    private bool _switching;
    private bool _fetchingUsage;
    private bool _refreshingToken;
    private bool _editingName;
    private bool _backupMissing;
    private string _editName = "";
    private AccountUsageInfo? _usage;

    protected override async Task OnInitializedAsync()
    {
        if (AutoFetch) await FetchUsage();
    }

    private async Task Switch()
    {
        _switching = true;
        StateHasChanged();
        try
        {
            var success = await AccountService.SwitchToAsync(Account.Id);
            if (success)
                Snackbar.Add($"'{Account.ProfileName}' 계정으로 전환했습니다.", ToastSeverity.Success);
            else
                Snackbar.Add("계정 전환에 실패했습니다.", ToastSeverity.Error);
            await OnChanged.InvokeAsync();
        }
        finally { _switching = false; }
    }

    private async Task FetchUsage()
    {
        _fetchingUsage = true;
        StateHasChanged();
        try
        {
            _usage = await AccountService.FetchUsageAsync(Account.Id);
            if (_usage == null)
            {
                if (!AutoFetch)
                    Snackbar.Add("사용량 정보를 불러올 수 없습니다.", ToastSeverity.Warning);
            }
        }
        catch (Exception ex)
        {
            if (!AutoFetch)
                Snackbar.Add($"사용량 조회 오류: {ex.Message}", ToastSeverity.Error);
        }
        finally { _fetchingUsage = false; }
    }

    private async Task RefreshToken()
    {
        _refreshingToken = true;
        StateHasChanged();
        try
        {
            var ok = await AccountService.RefreshTokenAsync(Account.Id);
            if (ok)
            {
                Snackbar.Add("토큰이 갱신되었습니다.", ToastSeverity.Success);
                await FetchUsage();
            }
            else
            {
                Snackbar.Add("토큰 갱신 실패. refresh_token이 없거나 만료되었습니다.", ToastSeverity.Warning);
            }
        }
        finally { _refreshingToken = false; }
    }

    private void StartEdit() { _editName = Account.ProfileName; _editingName = true; }

    private async Task SaveName()
    {
        _editingName = false;
        if (_editName.Trim() == Account.ProfileName || string.IsNullOrWhiteSpace(_editName)) return;
        await AccountService.UpdateProfileNameAsync(Account.Id, _editName.Trim());
        await OnChanged.InvokeAsync();
    }

    private async Task OnEditKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SaveName();
        else if (e.Key == "Escape") _editingName = false;
    }

    private async Task Delete()
    {
        await AccountService.RemoveAccountAsync(Account.Id);
        Snackbar.Add($"'{Account.ProfileName}' 계정이 삭제되었습니다.", ToastSeverity.Info);
        await OnChanged.InvokeAsync();
    }

    private string AvatarColor()
    {
        var colors = new[] { "#7c6cf6", "#22c55e", "#3b82f6", "#f97316", "#ec4899", "#06b6d4", "#a855f7" };
        return colors[Math.Abs(Account.Id.GetHashCode()) % colors.Length];
    }

    private static string FormatDuration(long s)
    {
        if (s < 60) return $"{s}초";
        if (s < 3600) return $"{s / 60}분";
        return $"{s / 3600}h {s % 3600 / 60}m";
    }

    private static string FormatLastUsed(DateTime? dt)
    {
        if (dt == null) return "사용 없음";
        var d = DateTime.UtcNow - dt.Value;
        if (d.TotalMinutes < 1) return "방금 전";
        if (d.TotalHours < 1)   return $"{(int)d.TotalMinutes}분 전";
        if (d.TotalDays < 1)    return $"{(int)d.TotalHours}시간 전";
        return $"{(int)d.TotalDays}일 전";
    }

    private bool HasAnyUsage() =>
        _usage?.FiveHour != null || _usage?.SevenDayAll != null || _usage?.SevenDaySonnet != null;

    private static string FormatResetTime(DateTimeOffset? resetsAt)
    {
        if (resetsAt == null) return "";

        var diff = resetsAt.Value - DateTimeOffset.UtcNow;

        if (diff is { TotalSeconds: > 0, TotalHours: < 24 })
        {
            if (diff.TotalMinutes < 1) return "곧 재설정";
            if (diff.TotalHours < 1) return $"{(int)diff.TotalMinutes}분 후 재설정";
            var hours = (int)diff.TotalHours;
            var mins  = (int)(diff.TotalMinutes % 60);
            return mins > 0 ? $"{hours}시간 {mins}분 후 재설정" : $"{hours}시간 후 재설정";
        }

        var local = resetsAt.Value.ToLocalTime();
        var day = local.DayOfWeek switch
        {
            DayOfWeek.Monday    => "월",
            DayOfWeek.Tuesday   => "화",
            DayOfWeek.Wednesday => "수",
            DayOfWeek.Thursday  => "목",
            DayOfWeek.Friday    => "금",
            DayOfWeek.Saturday  => "토",
            _                   => "일",
        };
        var amPm  = local.Hour < 12 ? "오전" : "오후";
        var hour12 = local.Hour % 12 is 0 ? 12 : local.Hour % 12;
        return $"({day}) {amPm} {hour12}:{local.Minute:D2}에 재설정";
    }

    private static Tone UsageTone(double p) => p >= 90 ? Tone.Error : p >= 70 ? Tone.Warning : Tone.Success;
    private static string UsageColorCss(double p) => p >= 90 ? "var(--color-error)" : p >= 70 ? "var(--color-warning)" : "var(--color-success)";
}
