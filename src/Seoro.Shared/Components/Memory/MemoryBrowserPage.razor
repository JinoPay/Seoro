@inject IMemoryService MemoryService
@inject IWorkspaceService WorkspaceService
@inject IToastService Snackbar

<div class="settings-content-area wide">
    <div class="settings-content-header">
        <span class="typo-h6">메모리 브라우저</span>
        <Chip>@_entries.Count 항목</Chip>
    </div>
    <div class="settings-content-body">
        <div class="memory-layout">
            @* Left: Filters + List *@
            <div class="memory-sidebar">
                <TextField @bind-Value="_search" Placeholder="검색..."
                           AdornmentIcon="@Lucide.Search" Immediate="true"
                           Class="mb-2"/>

                <Select T="string" @bind-Value="_selectedWorkspace" Label="워크스페이스"
                        Fixed="true" Class="mb-2">
                    <SelectItem T="string" Value="@("")" Text="전체">전체</SelectItem>
                    @foreach (var ws in _workspaces)
                    {
                        <SelectItem T="string" Value="@ws.Id" Text="@ws.Name">@ws.Name</SelectItem>
                    }
                </Select>

                <div class="d-flex flex-wrap gap-1 mb-2">
                    <Chip ButtonStyle="ButtonStyle.Outlined"
                          Selected="@(_selectedType == null)"
                          OnClick="@(() => OnTypeChanged(null))">전체</Chip>
                    <Chip ButtonStyle="ButtonStyle.Outlined" Tone="Tone.Primary"
                          Selected="@(_selectedType == MemoryType.User)"
                          OnClick="@(() => OnTypeChanged(MemoryType.User))">사용자</Chip>
                    <Chip ButtonStyle="ButtonStyle.Outlined" Tone="Tone.Warning"
                          Selected="@(_selectedType == MemoryType.Feedback)"
                          OnClick="@(() => OnTypeChanged(MemoryType.Feedback))">피드백</Chip>
                    <Chip ButtonStyle="ButtonStyle.Outlined" Tone="Tone.Info"
                          Selected="@(_selectedType == MemoryType.Project)"
                          OnClick="@(() => OnTypeChanged(MemoryType.Project))">프로젝트</Chip>
                    <Chip ButtonStyle="ButtonStyle.Outlined" Tone="Tone.Secondary"
                          Selected="@(_selectedType == MemoryType.Reference)"
                          OnClick="@(() => OnTypeChanged(MemoryType.Reference))">참조</Chip>
                </div>

                @if (_loading)
                {
                    <div style="display: flex; justify-content: center; padding: 20px;">
                        <Spinner Size="16"/>
                    </div>
                }
                else
                {
                    @foreach (var entry in FilteredEntries)
                    {
                        <div class="@MemoryItemClass(entry)" @onclick="@(() => SelectEntry(entry))">
                            <div class="d-flex align-center gap-2">
                                <Chip ButtonStyle="ButtonStyle.Filled"
                                      Tone="@GetTypeTone(entry.Type)"
                                      Style="min-width: 50px; text-align: center;">
                                    @GetTypeLabel(entry.Type)
                                </Chip>
                                <span class="typo-subtitle2"
                                      style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                    @entry.Name
                                </span>
                            </div>
                            <div class="typo-caption text-secondary"
                                 style="margin-top: 2px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                @entry.Description
                            </div>
                            <div class="typo-caption text-secondary" style="margin-top: 2px; opacity: 0.5;">
                                @entry.UpdatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                            </div>
                        </div>
                    }

                    @if (!FilteredEntries.Any())
                    {
                        <div class="typo-caption text-secondary text-center pa-4">
                            메모리 항목이 없습니다
                        </div>
                    }
                }
            </div>

            @* Right: Detail/Editor *@
            <div class="memory-detail">
                @if (_selected != null)
                {
                    <div class="memory-detail-header">
                        <span class="typo-h6">@_selected.Name</span>
                        <div style="margin-left: auto; display: flex; gap: 4px;">
                            <IconButton Icon="@(_editing ? Lucide.X : Lucide.Pencil)"
                                        OnClick="ToggleEdit"/>
                            <IconButton Icon="@Lucide.Trash2"
                                        Tone="Tone.Error" OnClick="DeleteSelected"/>
                        </div>
                    </div>

                    @if (_editing)
                    {
                        <div class="stack gap-3 pa-3">
                            <TextField @bind-Value="_editName" Label="이름"/>
                            <TextField @bind-Value="_editDescription" Label="설명"/>
                            <Select T="MemoryType" @bind-Value="_editType" Label="타입" Fixed="true">
                                <SelectItem T="MemoryType" Value="MemoryType.User" Text="사용자">사용자</SelectItem>
                                <SelectItem T="MemoryType" Value="MemoryType.Feedback" Text="피드백">피드백</SelectItem>
                                <SelectItem T="MemoryType" Value="MemoryType.Project" Text="프로젝트">프로젝트</SelectItem>
                                <SelectItem T="MemoryType" Value="MemoryType.Reference" Text="참조">참조</SelectItem>
                            </Select>
                            <TextField @bind-Value="_editContent" Label="내용" Lines="12"/>
                            <div class="stack-row gap-2">
                                <Button ButtonStyle="ButtonStyle.Filled" Tone="Tone.Primary" OnClick="SaveEdit">저장
                                </Button>
                                <Button ButtonStyle="ButtonStyle.Text" OnClick="CancelEdit">취소</Button>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="pa-3">
                            <div class="d-flex gap-2 mb-3">
                                <Chip ButtonStyle="ButtonStyle.Filled"
                                      Tone="@GetTypeTone(_selected.Type)">
                                    @GetTypeLabel(_selected.Type)
                                </Chip>
                                @if (!string.IsNullOrEmpty(_selected.WorkspaceId))
                                {
                                    <Chip ButtonStyle="ButtonStyle.Outlined"
                                          Tone="Tone.Info">@GetWorkspaceName(_selected.WorkspaceId)</Chip>
                                }
                            </div>
                            @if (!string.IsNullOrEmpty(_selected.Description))
                            {
                                <div class="typo-body2 text-secondary mb-3">@_selected.Description</div>
                            }
                            <div class="memory-content-view">@_selected.Content</div>
                            <div class="typo-caption text-secondary mt-3" style="opacity: 0.5;">
                                생성: @_selected.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm") &middot;
                                수정: @_selected.UpdatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="d-flex flex-column align-center justify-center" style="height: 300px; opacity: 0.5;">
                        <Icon Svg="@Lucide.Cpu" Size="24"/>
                        <div class="typo-body2 mt-2">왼쪽에서 메모리를 선택하세요</div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private List<MemoryEntry> _entries = [];
    private List<Workspace> _workspaces = [];
    private MemoryEntry? _selected;
    private string _search = "";
    private string _selectedWorkspace = "";
    private MemoryType? _selectedType;
    private bool _loading = true;
    private bool _editing;

    // 편집 필드
    private string _editName = "";
    private string _editDescription = "";
    private MemoryType _editType;
    private string _editContent = "";

    private IEnumerable<MemoryEntry> FilteredEntries
    {
        get
        {
            IEnumerable<MemoryEntry> result = _entries;

            if (!string.IsNullOrEmpty(_selectedWorkspace))
                result = result.Where(e => e.WorkspaceId == _selectedWorkspace);

            if (_selectedType.HasValue)
                result = result.Where(e => e.Type == _selectedType.Value);

            if (!string.IsNullOrWhiteSpace(_search))
                result = result.Where(e =>
                    (e.Name?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (e.Description?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (e.Content?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false));

            return result.OrderByDescending(e => e.UpdatedAt);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var entriesTask = MemoryService.GetAllAsync();
        var workspacesTask = WorkspaceService.GetWorkspacesAsync();
        _entries = await entriesTask;
        _workspaces = await workspacesTask;
        _loading = false;
    }

    private void OnTypeChanged(MemoryType? type)
    {
        _selectedType = type;
    }

    private void SelectEntry(MemoryEntry entry)
    {
        _selected = entry;
        _editing = false;
    }

    private void ToggleEdit()
    {
        if (_editing)
        {
            _editing = false;
            return;
        }

        if (_selected == null) return;
        _editName = _selected.Name;
        _editDescription = _selected.Description;
        _editType = _selected.Type;
        _editContent = _selected.Content;
        _editing = true;
    }

    private void CancelEdit()
    {
        _editing = false;
    }

    private async Task SaveEdit()
    {
        if (_selected == null) return;
        _selected.Name = _editName;
        _selected.Description = _editDescription;
        _selected.Type = _editType;
        _selected.Content = _editContent;
        _selected.UpdatedAt = DateTime.UtcNow;
        await MemoryService.SaveAsync(_selected);
        _editing = false;
        Snackbar.Add("메모리가 저장되었습니다.", ToastSeverity.Success);
        StateHasChanged();
    }

    private async Task DeleteSelected()
    {
        if (_selected == null) return;
        await MemoryService.DeleteAsync(_selected.Id);
        _entries.Remove(_selected);
        _selected = null;
        _editing = false;
        Snackbar.Add("메모리가 삭제되었습니다.", ToastSeverity.Success);
        StateHasChanged();
    }

    private string GetWorkspaceName(string workspaceId)
    {
        return _workspaces.FirstOrDefault(w => w.Id == workspaceId)?.Name ?? workspaceId;
    }

    private string MemoryItemClass(MemoryEntry entry)
    {
        var active = _selected?.Id == entry.Id ? " active" : "";
        return $"memory-item{active}";
    }

    private static Tone GetTypeTone(MemoryType type)
    {
        return type switch
        {
            MemoryType.User => Tone.Primary,
            MemoryType.Feedback => Tone.Warning,
            MemoryType.Project => Tone.Info,
            MemoryType.Reference => Tone.Secondary,
            _ => Tone.Default
        };
    }

    private static string GetTypeLabel(MemoryType type)
    {
        return type switch
        {
            MemoryType.User => "사용자",
            MemoryType.Feedback => "피드백",
            MemoryType.Project => "프로젝트",
            MemoryType.Reference => "참조",
            _ => "기타"
        };
    }

}

<style>
    .memory-layout {
        display: flex;
        gap: 0;
        min-height: 500px;
    }

    .memory-sidebar {
        width: 340px;
        min-width: 340px;
        border-right: 1px solid var(--border-default);
        padding: 12px;
        overflow-y: auto;
        max-height: 70vh;
    }

    .memory-item {
        padding: 10px 12px;
        border-radius: 6px;
        cursor: pointer;
        margin-bottom: 4px;
    }

    .memory-item:hover {
        background: var(--bg-hover);
    }

    .memory-item.active {
        background: var(--accent-subtle);
        border-left: 2px solid var(--accent);
    }

    .memory-detail {
        flex: 1;
        overflow-y: auto;
        max-height: 70vh;
    }

    .memory-detail-header {
        display: flex;
        align-items: center;
        padding: 12px 16px;
        border-bottom: 1px solid var(--border-default);
    }

    .memory-content-view {
        white-space: pre-wrap;
        word-break: break-word;
        font-family: var(--font-mono);
        font-size: 0.85rem;
        background: var(--bg-hover);
        border-radius: 8px;
        padding: 12px;
        line-height: 1.5;
    }
</style>
