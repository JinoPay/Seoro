<div class="achievement-card">
    <div class="achievement-header">
        <span class="achievement-title">
            @Strings.Dashboard_Achievement_Title <span class="achievement-count">(@UnlockedCount/@Achievements.Count)</span>
        </span>
        <div class="achievement-filter-row">
            <div class="d-flex flex-wrap gap-1">
                <Chip Selected="@(_selectedCategory == "all")" Style="font-size:0.7rem;"
                      OnClick="@(() => _selectedCategory = "all")">@Strings.Dashboard_Achievement_All</Chip>
                @foreach (var cat in _categories)
                {
                    var key = cat.Key;
                    <Chip Selected="@(_selectedCategory == key)" Style="font-size:0.7rem;"
                          OnClick="@(() => _selectedCategory = key)">@cat.Value</Chip>
                }
            </div>
        </div>
    </div>

    @* Rarity legend *@
    <div class="rarity-legend">
        <span class="rarity-badge rarity-common">@Strings.Dashboard_Achievement_Rarity_Common</span>
        <span class="rarity-badge rarity-rare">@Strings.Dashboard_Achievement_Rarity_Rare</span>
        <span class="rarity-badge rarity-epic">@Strings.Dashboard_Achievement_Rarity_Epic</span>
        <span class="rarity-badge rarity-legendary">@Strings.Dashboard_Achievement_Rarity_Legendary</span>
    </div>

    <div class="achievement-grid">
        @foreach (var a in FilteredAchievements)
        {
            <div
                class="achievement-item @(a.Unlocked ? "unlocked" : "locked") rarity-border-@a.Rarity.ToString().ToLower()"
                title="@a.Description">
                <div
                    class="achievement-icon-box @(a.Unlocked ? $"unlocked rarity-bg-{a.Rarity.ToString().ToLower()}" : "")">
                    <Icon Svg="@GetIcon(a.Icon)" Size="14"/>
                </div>
                <div class="achievement-text">
                    <div class="achievement-name-row">
                        <span class="achievement-name">@a.Name</span>
                        @if (a.Rarity != AchievementRarity.Common)
                        {
                            <span class="rarity-dot rarity-@a.Rarity.ToString().ToLower()"></span>
                        }
                    </div>
                    <div class="achievement-desc">@a.Description</div>
                </div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public List<Achievement> Achievements { get; set; } = [];

    private string _selectedCategory = "all";

    private int UnlockedCount => Achievements.Count(a => a.Unlocked);

    private Dictionary<string, string> _categories => new()
    {
        ["Config"] = Strings.Dashboard_Achievement_Category_Config,
        ["Usage"] = Strings.Dashboard_Achievement_Category_Usage,
        ["Streak"] = Strings.Dashboard_Achievement_Category_Streak,
        ["Mastery"] = Strings.Dashboard_Achievement_Category_Mastery,
        ["Explorer"] = Strings.Dashboard_Achievement_Category_Explorer,
        ["Efficiency"] = Strings.Dashboard_Achievement_Category_Efficiency,
        ["Time"] = Strings.Dashboard_Achievement_Category_Time,
        ["Economy"] = Strings.Dashboard_Achievement_Category_Economy,
        ["Pattern"] = Strings.Dashboard_Achievement_Category_Pattern
    };

    private List<Achievement> FilteredAchievements => _selectedCategory == "all"
        ? Achievements
        : Achievements.Where(a => a.Category.ToString() == _selectedCategory).ToList();

    private static string GetIcon(string icon)
    {
        return icon switch
        {
            // 설정
            "tune" => Lucide.SlidersHorizontal,
            "bolt" => Lucide.Zap,
            "hub" => Lucide.Network,
            "device_hub" => Lucide.Network,
            "cloud" => Lucide.Cloud,
            "security" => Lucide.Shield,
            "terminal" => Lucide.Terminal,
            "verified" => Lucide.BadgeCheck,
            "psychology" => Lucide.Brain,
            "memory" => Lucide.Cpu,
            "rule" => Lucide.ListTodo,
            "precision_manufacturing" => Lucide.Cog,
            "webhook" => Lucide.Webhook,
            "dns" => Lucide.Server,
            // 사용
            "waving_hand" => Lucide.Hand,
            "chat" => Lucide.MessageCircle,
            "mark_chat_read" => Lucide.CheckCheck,
            "forum" => Lucide.MessagesSquare,
            "question_answer" => Lucide.MessagesSquare,
            "whatshot" => Lucide.Flame,
            "sms" => Lucide.MessageSquareText,
            "rocket_launch" => Lucide.Rocket,
            "play_circle" => Lucide.CirclePlay,
            "collections" => Lucide.Images,
            "layers" => Lucide.Layers,
            "video_library" => Lucide.Film,
            "workspace_premium" => Lucide.Award,
            "all_inclusive" => Lucide.Infinity,
            "construction" => Lucide.Construction,
            "handyman" => Lucide.Hammer,
            "hardware" => Lucide.Hammer,
            "build" => Lucide.Wrench,
            "engineering" => Lucide.HardHat,
            "factory" => Lucide.Factory,
            // 연쇄
            "local_fire_department" => Lucide.Flame,
            "military_tech" => Lucide.Medal,
            "shield" => Lucide.Shield,
            "emoji_events" => Lucide.Trophy,
            "diamond" => Lucide.Gem,
            "crown" => Lucide.Award,
            "auto_awesome" => Lucide.Sparkles,
            "fitness_center" => Lucide.Dumbbell,
            // 숙달도
            "thumb_up" => Lucide.ThumbsUp,
            "favorite" => Lucide.Heart,
            "star" => Lucide.Star,
            "cake" => Lucide.Cake,
            "settings" => Lucide.Settings,
            "smart_toy" => Lucide.Bot,
            // 탐험가
            "folder_open" => Lucide.FolderOpen,
            "explore" => Lucide.Compass,
            "account_tree" => Lucide.GitFork,
            "source" => Lucide.FolderCode,
            "public" => Lucide.Globe,
            "inventory" => Lucide.Package,
            "travel_explore" => Lucide.Telescope,
            "language" => Lucide.Globe,
            // 효율성
            "trending_up" => Lucide.TrendingUp,
            "speed" => Lucide.Gauge,
            "flash_on" => Lucide.Zap,
            "electric_bolt" => Lucide.Zap,
            "savings" => Lucide.PiggyBank,
            "account_balance_wallet" => Lucide.Wallet,
            "paid" => Lucide.CircleDollarSign,
            "monetization_on" => Lucide.CircleDollarSign,
            // 시간
            "directions_run" => Lucide.Footprints,
            "sprint" => Lucide.Footprints,
            "dark_mode" => Lucide.Moon,
            "wb_sunny" => Lucide.Sun,
            "timer" => Lucide.Timer,
            "hourglass_top" => Lucide.Hourglass,
            "nightlight" => Lucide.Moon,
            "bedtime" => Lucide.Moon,
            "wb_twilight" => Lucide.Sunset,
            "mode_night" => Lucide.Moon,
            "light_mode" => Lucide.Sun,
            // 경제
            "token" => Lucide.Coins,
            "generating_tokens" => Lucide.Coins,
            "data_usage" => Lucide.ChartPie,
            "attach_money" => Lucide.DollarSign,
            "payments" => Lucide.CreditCard,
            "account_balance" => Lucide.Landmark,
            "currency_exchange" => Lucide.CircleDollarSign,
            "diversity_3" => Lucide.Users,
            // 패턴
            "weekend" => Lucide.Sofa,
            "event_available" => Lucide.CalendarCheck,
            "schedule" => Lucide.Clock,
            "lunch_dining" => Lucide.Sandwich,
            "access_time" => Lucide.Clock,
            "contrast" => Lucide.Contrast,
            _ => Lucide.Trophy
        };
    }

}

<style>
    .achievement-card {
        border: 1px solid var(--border-default);
        border-radius: 12px;
        padding: 16px;
    }

    .achievement-header {
        margin-bottom: 8px;
    }

    .achievement-title {
        font-size: 0.85rem;
        font-weight: 500;
        color: var(--text-secondary);
    }

    .achievement-count {
        color: var(--text-secondary);
    }

    .achievement-filter-row {
        margin-top: 4px;
    }

    .rarity-legend {
        display: flex;
        gap: 8px;
        margin-bottom: 10px;
        padding: 0 2px;
    }

    .rarity-badge {
        font-size: 0.6rem;
        padding: 1px 6px;
        border-radius: 4px;
        font-weight: 500;
    }

    .rarity-badge.rarity-common {
        background: var(--bg-hover);
        color: var(--text-secondary);
    }

    .rarity-badge.rarity-rare {
        background: rgba(59, 130, 246, 0.15);
        color: #3b82f6;
    }

    .rarity-badge.rarity-epic {
        background: rgba(168, 85, 247, 0.15);
        color: #a855f7;
    }

    .rarity-badge.rarity-legendary {
        background: rgba(245, 158, 11, 0.15);
        color: #f59e0b;
    }

    .achievement-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 8px;
        max-height: 500px;
        overflow-y: auto;
    }

    .achievement-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px;
        border-radius: 10px;
        border: 1px solid var(--border-default);
        transition: transform 0.1s, box-shadow 0.15s;
    }

    .achievement-item.unlocked:hover {
        transform: translateY(-1px);
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    }

    .achievement-item.unlocked {
        background: var(--accent-subtle);
    }

    .achievement-item.unlocked.rarity-border-rare {
        border-color: rgba(59, 130, 246, 0.4);
        background: rgba(59, 130, 246, 0.06);
    }

    .achievement-item.unlocked.rarity-border-epic {
        border-color: rgba(168, 85, 247, 0.4);
        background: rgba(168, 85, 247, 0.06);
    }

    .achievement-item.unlocked.rarity-border-legendary {
        border-color: rgba(245, 158, 11, 0.5);
        background: rgba(245, 158, 11, 0.06);
    }

    .achievement-item.locked {
        background: var(--bg-hover);
        opacity: 0.4;
    }

    .achievement-icon-box {
        width: 34px;
        height: 34px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        background: var(--bg-hover);
        color: var(--text-secondary);
    }

    .achievement-icon-box.unlocked {
        background: var(--accent-dim);
        color: var(--accent);
    }

    .achievement-icon-box.rarity-bg-rare {
        background: rgba(59, 130, 246, 0.15);
        color: #3b82f6;
    }

    .achievement-icon-box.rarity-bg-epic {
        background: rgba(168, 85, 247, 0.15);
        color: #a855f7;
    }

    .achievement-icon-box.rarity-bg-legendary {
        background: rgba(245, 158, 11, 0.15);
        color: #f59e0b;
    }

    .achievement-text {
        min-width: 0;
    }

    .achievement-name-row {
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .achievement-name {
        font-size: 0.7rem;
        font-weight: 600;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .rarity-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .rarity-dot.rarity-rare {
        background: #3b82f6;
    }

    .rarity-dot.rarity-epic {
        background: #a855f7;
    }

    .rarity-dot.rarity-legendary {
        background: #f59e0b;
    }

    .achievement-desc {
        font-size: 0.6rem;
        color: var(--text-secondary);
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }
</style>
