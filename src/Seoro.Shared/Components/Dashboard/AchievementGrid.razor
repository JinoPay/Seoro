<style>
    .achievement-card {
        border: 1px solid var(--mud-palette-lines-default);
        border-radius: 12px;
        padding: 16px;
    }

    .achievement-header {
        margin-bottom: 8px;
    }

    .achievement-title {
        font-size: 0.85rem;
        font-weight: 500;
        color: var(--mud-palette-text-secondary);
    }

    .achievement-count {
        color: var(--mud-palette-text-secondary);
    }

    .achievement-filter-row {
        margin-top: 4px;
    }

    .rarity-legend {
        display: flex;
        gap: 8px;
        margin-bottom: 10px;
        padding: 0 2px;
    }

    .rarity-badge {
        font-size: 0.6rem;
        padding: 1px 6px;
        border-radius: 4px;
        font-weight: 500;
    }

    .rarity-badge.rarity-common {
        background: var(--mud-palette-action-default-hover);
        color: var(--mud-palette-text-secondary);
    }

    .rarity-badge.rarity-rare {
        background: rgba(59, 130, 246, 0.15);
        color: #3b82f6;
    }

    .rarity-badge.rarity-epic {
        background: rgba(168, 85, 247, 0.15);
        color: #a855f7;
    }

    .rarity-badge.rarity-legendary {
        background: rgba(245, 158, 11, 0.15);
        color: #f59e0b;
    }

    .achievement-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 8px;
        max-height: 500px;
        overflow-y: auto;
    }

    .achievement-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px;
        border-radius: 10px;
        border: 1px solid var(--mud-palette-lines-default);
        transition: transform 0.1s, box-shadow 0.15s;
    }

    .achievement-item.unlocked:hover {
        transform: translateY(-1px);
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    }

    .achievement-item.unlocked {
        background: rgba(var(--mud-palette-primary-rgb, 98, 0, 234), 0.06);
    }

    .achievement-item.unlocked.rarity-border-rare {
        border-color: rgba(59, 130, 246, 0.4);
        background: rgba(59, 130, 246, 0.06);
    }

    .achievement-item.unlocked.rarity-border-epic {
        border-color: rgba(168, 85, 247, 0.4);
        background: rgba(168, 85, 247, 0.06);
    }

    .achievement-item.unlocked.rarity-border-legendary {
        border-color: rgba(245, 158, 11, 0.5);
        background: rgba(245, 158, 11, 0.06);
    }

    .achievement-item.locked {
        background: var(--mud-palette-action-default-hover);
        opacity: 0.4;
    }

    .achievement-icon-box {
        width: 34px;
        height: 34px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        background: var(--mud-palette-action-default-hover);
        color: var(--mud-palette-text-secondary);
    }

    .achievement-icon-box.unlocked {
        background: rgba(var(--mud-palette-primary-rgb, 98, 0, 234), 0.15);
        color: var(--mud-palette-primary);
    }

    .achievement-icon-box.rarity-bg-rare {
        background: rgba(59, 130, 246, 0.15);
        color: #3b82f6;
    }

    .achievement-icon-box.rarity-bg-epic {
        background: rgba(168, 85, 247, 0.15);
        color: #a855f7;
    }

    .achievement-icon-box.rarity-bg-legendary {
        background: rgba(245, 158, 11, 0.15);
        color: #f59e0b;
    }

    .achievement-text {
        min-width: 0;
    }

    .achievement-name-row {
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .achievement-name {
        font-size: 0.7rem;
        font-weight: 600;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .rarity-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .rarity-dot.rarity-rare {
        background: #3b82f6;
    }

    .rarity-dot.rarity-epic {
        background: #a855f7;
    }

    .rarity-dot.rarity-legendary {
        background: #f59e0b;
    }

    .achievement-desc {
        font-size: 0.6rem;
        color: var(--mud-palette-text-secondary);
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }
</style>
