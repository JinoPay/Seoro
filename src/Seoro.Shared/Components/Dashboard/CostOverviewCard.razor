<div class="cost-card">
    <div class="cost-card-title">
        <Icon Svg="@Lucide.DollarSign" Size="14"/>
        @Strings.Dashboard_Cost_Title
    </div>
    @if (Cost is not null)
    {
        <div class="cost-card-rows">
            <div class="cost-card-row">
                <div class="cost-card-row-header">
                    <span class="cost-card-label">@Strings.Dashboard_Cost_Today</span>
                    <span
                        class="cost-card-amount @(Cost.DailyExceeded ? "exceeded" : "")">$@Cost.Today.ToString("F2")</span>
                </div>
                @if (Cost.DailyLimit.HasValue)
                {
                    <div class="cost-card-bar">
                        <div class="cost-card-bar-fill @(Cost.DailyExceeded ? "exceeded" : "")"
                             style="width: @(Math.Min((double)(Cost.Today / Cost.DailyLimit.Value) * 100, 100))%"></div>
                    </div>
                }
            </div>
            <div class="cost-card-row">
                <div class="cost-card-row-header">
                    <span class="cost-card-label">@Strings.Dashboard_Cost_ThisMonth</span>
                    <span class="cost-card-amount">$@Cost.ThisMonth.ToString("F2")</span>
                </div>
                @if (Cost.MonthlyLimit.HasValue)
                {
                    <div class="cost-card-bar">
                        <div class="cost-card-bar-fill @(Cost.MonthlyExceeded ? "exceeded" : "")"
                             style="width: @(Math.Min((double)(Cost.ThisMonth / Cost.MonthlyLimit.Value) * 100, 100))%"></div>
                    </div>
                }
            </div>
            <div class="cost-card-row-header">
                <span class="cost-card-label">
                    <Icon Svg="@Lucide.TrendingUp" Size="11"/>
                    @Strings.Dashboard_Cost_Projection
                </span>
                <span class="cost-card-projection">$@Cost.MonthlyProjection.ToString("F2")@Strings.Dashboard_Cost_PerMonth</span>
            </div>
            <button class="cost-card-link" @onclick="GoToAnalytics">@Strings.Dashboard_Cost_ViewAnalytics</button>
        </div>
    }
    else
    {
        <span class="cost-card-label">@Strings.Common_Loading</span>
    }
</div>

@code {
    [Parameter] public CostSummary? Cost { get; set; }
    [Parameter] public EventCallback OnNavigateToUsage { get; set; }

    private async Task GoToAnalytics()
    {
        await OnNavigateToUsage.InvokeAsync();
    }

}

<style>
    .cost-card {
        border: 1px solid var(--border-default);
        border-radius: 12px;
        padding: 16px;
    }

    .cost-card-title {
        font-size: 0.85rem;
        font-weight: 500;
        color: var(--text-secondary);
        margin-bottom: 12px;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .cost-card-rows {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .cost-card-row-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-size: 0.7rem;
        margin-bottom: 2px;
    }

    .cost-card-label {
        color: var(--text-secondary);
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .cost-card-amount {
        font-weight: 500;
    }

    .cost-card-amount.exceeded {
        color: var(--color-error);
    }

    .cost-card-projection {
        color: var(--text-secondary);
        font-size: 0.7rem;
    }

    .cost-card-bar {
        height: 6px;
        background: var(--bg-hover);
        border-radius: 99px;
        overflow: hidden;
    }

    .cost-card-bar-fill {
        height: 100%;
        background: var(--accent);
        border-radius: 99px;
    }

    .cost-card-bar-fill.exceeded {
        background: var(--color-error);
    }

    .cost-card-link {
        width: 100%;
        font-size: 0.7rem;
        color: var(--accent);
        background: none;
        border: none;
        cursor: pointer;
        padding: 4px 0;
        transition: color 0.15s;
    }

    .cost-card-link:hover {
        color: var(--accent-hover);
    }
</style>
