@inject IChatState ChatState
@inject IModalService ModalService
@implements IDisposable

<div class="main-tab-bar">
    @foreach (var tab in ChatState.Tabs.OpenTabs)
    {
        <div class="main-tab @(ChatState.Tabs.ActiveTab?.Id == tab.Id ? "active" : "")"
             @onclick="@(() => ChatState.Tabs.SetActiveTab(tab.Id))"
             @oncontextmenu="@(() => OpenContextMenu(tab))"
             @oncontextmenu:preventDefault="true">
            <Icon Svg="@GetTabIcon(tab)" Size="14"/>
            <span class="main-tab-title">@(tab.DisambiguatedTitle ?? tab.Title)</span>
            @if (tab.IsDirty)
            {
                <span class="main-tab-dirty" title="저장되지 않은 변경 사항">•</span>
            }
            @if (tab.Type != MainTabType.Chat)
            {
                <button class="main-tab-close" @onclick="@(() => HandleCloseAsync(tab))"
                        @onclick:stopPropagation="true">
                    <Icon Svg="@Lucide.X" Size="12"/>
                </button>
            }
            <span @onclick:stopPropagation="true" @oncontextmenu:stopPropagation="true">
                <Popover Open="@(_contextTab == tab)"
                         OpenChanged="@(v => { if (!v) _contextTab = null; })"
                         Placement="PopoverPlacement.BottomStart" Fixed="true"
                         PopoverClass="ui-menu ui-menu--dense">
                    <ChildContent>
                        <MenuItem OnClick="@HandleCloseTab"
                                  Icon="@Lucide.X"
                                  Disabled="@(_contextTab?.Type == MainTabType.Chat)">
                            @Strings.Layout_MainTabBar_CloseTab
                        </MenuItem>
                        <MenuItem OnClick="@HandleCloseOtherTabs"
                                  Icon="@Lucide.Layers2"
                                  Disabled="@(ChatState.Tabs.OpenTabs.Count(t => t.Type != MainTabType.Chat) <= 1)">
                            @Strings.Layout_MainTabBar_CloseOtherTabs
                        </MenuItem>
                        <MenuItem OnClick="@HandleCloseTabsToRight"
                                  Icon="@Lucide.ArrowRightToLine"
                                  Disabled="@IsNoTabsToRight()">
                            @Strings.Layout_MainTabBar_CloseTabsToRight
                        </MenuItem>
                        <Divider/>
                        <MenuItem OnClick="@HandleCloseAllTabs"
                                  Icon="@Lucide.ListX"
                                  Disabled="@(ChatState.Tabs.OpenTabs.All(t => t.Type == MainTabType.Chat))">
                            @Strings.Layout_MainTabBar_CloseAllTabs
                        </MenuItem>
                    </ChildContent>
                </Popover>
            </span>
        </div>
    }
</div>

@code {

    private MainTab? _contextTab;

    protected override void OnInitialized()
    {
        ChatState.Tabs.OnTabChanged += HandleTabChanged;
    }

    private void HandleTabChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private void OpenContextMenu(MainTab tab)
    {
        _contextTab = tab;
    }

    private async Task HandleCloseAsync(MainTab tab)
    {
        if (tab.IsDirty && !await ConfirmCloseDirtyAsync(1)) return;
        ChatState.Tabs.CloseTab(tab.Id);
    }

    private async Task HandleCloseTab()
    {
        var tab = _contextTab;
        _contextTab = null;
        if (tab == null) return;
        if (tab.IsDirty && !await ConfirmCloseDirtyAsync(1)) return;
        ChatState.Tabs.CloseTab(tab.Id);
    }

    private async Task HandleCloseOtherTabs()
    {
        var tab = _contextTab;
        _contextTab = null;
        if (tab == null) return;
        var dirtyCount = ChatState.Tabs.OpenTabs.Count(t =>
            t.Type != MainTabType.Chat && t.Id != tab.Id && t.IsDirty);
        if (dirtyCount > 0 && !await ConfirmCloseDirtyAsync(dirtyCount)) return;
        ChatState.Tabs.CloseOtherTabs(tab.Id);
    }

    private async Task HandleCloseTabsToRight()
    {
        var tab = _contextTab;
        _contextTab = null;
        if (tab == null) return;
        var idx = ChatState.Tabs.OpenTabs.IndexOf(tab);
        if (idx < 0) return;
        var dirtyCount = ChatState.Tabs.OpenTabs.Skip(idx + 1).Count(t => t.IsDirty);
        if (dirtyCount > 0 && !await ConfirmCloseDirtyAsync(dirtyCount)) return;
        ChatState.Tabs.CloseTabsToTheRight(tab.Id);
    }

    private async Task HandleCloseAllTabs()
    {
        _contextTab = null;
        var dirtyCount = ChatState.Tabs.OpenTabs.Count(t => t.Type != MainTabType.Chat && t.IsDirty);
        if (dirtyCount > 0 && !await ConfirmCloseDirtyAsync(dirtyCount)) return;
        ChatState.Tabs.CloseAllFileTabs();
    }

    private async Task<bool> ConfirmCloseDirtyAsync(int dirtyCount)
    {
        var msg = dirtyCount == 1
            ? "저장되지 않은 변경 사항이 있습니다. 그래도 닫을까요?"
            : $"저장되지 않은 변경이 {dirtyCount}개 있습니다. 그래도 닫을까요?";
        var result = await ModalService.ShowMessageBoxAsync(
            "변경 사항 버리기",
            msg,
            yesText: "그대로 닫기", cancelText: "취소");
        return result == true;
    }

    private bool IsNoTabsToRight()
    {
        if (_contextTab == null) return true;
        var idx = ChatState.Tabs.OpenTabs.IndexOf(_contextTab);
        return idx < 0 || idx == ChatState.Tabs.OpenTabs.Count - 1;
    }

    private static string GetTabIcon(MainTab tab)
    {
        return tab.Type switch
        {
            MainTabType.Chat => Lucide.MessageCircle,
            MainTabType.FileContent => Lucide.File,
            MainTabType.FileDiff => Lucide.FileText,
            _ => Lucide.AppWindow
        };
    }

    public void Dispose()
    {
        ChatState.Tabs.OnTabChanged -= HandleTabChanged;
    }

}
