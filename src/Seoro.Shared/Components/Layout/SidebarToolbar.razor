@using Seoro.Shared.Resources
@inject INotificationHistoryService NotificationHistory
@implements IDisposable

<div class="sidebar-toolbar">
    <span class="sidebar-brand">
        <img src="logo.png" width="20" height="20" alt="Seoro" style="display:block;"/>
        <span class="sidebar-brand-text">Seoro</span>
    </span>
    @if (SidebarOpen)
    {
        <div style="display: flex; align-items: center; gap: 6px;">
            <MudBadge Content="@_unreadCount" Visible="@(_unreadCount > 0)" Color="Color.Error"
                      Overlap="true" Dot="@(_unreadCount <= 0)" Class="notification-badge">
                <MudIconButton Icon="@Icons.Material.Filled.Notifications" Color="Color.Inherit"
                               Size="Size.Small" OnClick="@OnOpenNotifications"
                               Style="width: 28px; height: 28px; opacity: 0.5;"
                               title="@Strings.Layout_SidebarToolbar_NotificationHistory"/>
            </MudBadge>
            <button class="sidebar-collapse-btn" @onclick="@OnToggleSidebar" title="@Strings.Layout_SidebarToolbar_CollapseSidebar">
                <MudIcon Icon="@Icons.Material.Filled.ChevronLeft" Size="Size.Small"
                         Style="width: 18px; height: 18px;"/>
            </button>
        </div>
    }
    else
    {
        <button class="sidebar-collapse-btn" @onclick="@OnToggleSidebar" title="@Strings.Layout_SidebarToolbar_ExpandSidebar">
            <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small"
                     Style="width: 18px; height: 18px;"/>
        </button>
    }
</div>

@code {
    [Parameter] public bool SidebarOpen { get; set; }
    [Parameter] public EventCallback OnToggleSidebar { get; set; }
    [Parameter] public EventCallback OnOpenNotifications { get; set; }

    private int _unreadCount;

    protected override void OnInitialized()
    {
        NotificationHistory.OnChange += HandleNotificationChange;
        Strings.CultureChanged += HandleCultureChanged;
        _unreadCount = NotificationHistory.UnreadCount;
    }

    private void HandleNotificationChange()
    {
        _ = InvokeAsync(() =>
        {
            _unreadCount = NotificationHistory.UnreadCount;
            StateHasChanged();
        });
    }

    private void HandleCultureChanged()
    {
        _ = InvokeAsync(() =>
        {
            var uiCulture = CultureInfo.DefaultThreadCurrentUICulture;
            if (uiCulture != null)
            {
                CultureInfo.CurrentUICulture = uiCulture;
                CultureInfo.CurrentCulture = CultureInfo.DefaultThreadCurrentCulture ?? uiCulture;
            }
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        NotificationHistory.OnChange -= HandleNotificationChange;
        Strings.CultureChanged -= HandleCultureChanged;
    }

}
