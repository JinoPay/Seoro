@using Seoro.Shared.Resources
@implements IDisposable

<div class="sidebar-footer">
    <button class="sidebar-footer-btn" @onclick="@OnOpenSettings" title="@Strings.Common_Settings">
        <Icon Svg="@Lucide.Settings" Size="18"/>
        <span>@Strings.Common_Settings</span>
    </button>
</div>

@code {
    [Parameter] public EventCallback OnOpenSettings { get; set; }

    protected override void OnInitialized()
    {
        Strings.CultureChanged += HandleCultureChanged;
    }

    private void HandleCultureChanged()
    {
        _ = InvokeAsync(() =>
        {
            var uiCulture = CultureInfo.DefaultThreadCurrentUICulture;
            if (uiCulture != null)
            {
                CultureInfo.CurrentUICulture = uiCulture;
                CultureInfo.CurrentCulture = CultureInfo.DefaultThreadCurrentCulture ?? uiCulture;
            }
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        Strings.CultureChanged -= HandleCultureChanged;
    }
}
