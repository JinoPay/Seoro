@inject IChatState ChatState
@inject ILauncherService Launcher
@inject IWorktreeSyncService SyncService
@inject IWorkspaceService WorkspaceService
@inject IChatEventBus EventBus
@inject ISnackbar Snackbar
@using System.Runtime.InteropServices
@implements IDisposable

<div class="main-toolbar">
    @if (ChatState.CurrentSession != null)
    {
        <span class="toolbar-title @(_titleChanged ? "title-changed" : "")"
              @onanimationend="@(() => _titleChanged = false)">@(ChatState.CurrentSession.Title ?? Strings.Layout_MainToolbar_NewConversation)</span>

        @if (!string.IsNullOrEmpty(ChatState.CurrentSession.Git.BranchName))
        {
            <MudTooltip Text="@Strings.Layout_MainToolbar_Branch(ChatState.CurrentSession.Git.BranchName)" Placement="Placement.Bottom">
                <span class="toolbar-branch-badge">
                    <MudIcon Icon="@Icons.Material.Filled.AccountTree" Size="Size.Small"
                             Style="width: 12px; height: 12px; opacity: 0.6;"/>
                    @ChatState.CurrentSession.Git.BranchName
                </span>
            </MudTooltip>
        }

        @if (ChatState.CurrentSession.PermissionMode == "plan")
        {
            <MudTooltip Text="@Strings.Layout_MainToolbar_PlanModeTooltip" Placement="Placement.Bottom">
                <span class="toolbar-indicator plan">
                    <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Small"
                             Style="width: 14px; height: 14px;"/>
                </span>
            </MudTooltip>
        }

        @if (ChatState.CurrentSession.EffortLevel is not (null or "" or "auto"))
        {
            <MudTooltip Text="@Strings.Layout_MainToolbar_EffortLevelTooltip(FormatEffortLevel(ChatState.CurrentSession.EffortLevel))"
                        Placement="Placement.Bottom">
                <span class="toolbar-indicator effort">
                    <MudIcon Icon="@Icons.Material.Filled.Psychology" Size="Size.Small"
                             Style="width: 14px; height: 14px;"/>
                </span>
            </MudTooltip>
        }
    }
    else
    {
        <span class="toolbar-title" style="opacity: 0.4;">@Strings.Layout_MainToolbar_SelectConversation</span>
    }

    <div style="flex: 1;"></div>

    @if (ChatState.CurrentSession != null && !string.IsNullOrEmpty(GetEffectivePath()))
    {
        <div class="toolbar-actions">
            @if (ShowSyncButton)
            {
                <MudTooltip Text="@SyncTooltip" Placement="Placement.Bottom">
                    <MudIconButton Icon="@(IsSynced ? Icons.Material.Filled.SyncDisabled : Icons.Material.Filled.Sync)"
                                   Color="@(IsSynced ? Color.Success : Color.Default)"
                                   Size="Size.Small"
                                   OnClick="ToggleSync"
                                   Disabled="_syncBusy || IsSyncBlockedByOther"
                                   Class="@(IsSynced ? "sync-active" : "")"
                                   Style="width: 28px; height: 28px;"/>
                </MudTooltip>
            }

            <MudTooltip Text="@Strings.Layout_MainToolbar_OpenFolder" Placement="Placement.Bottom">
                <MudIconButton Icon="@Icons.Material.Outlined.FolderOpen" Size="Size.Small"
                               OnClick="OpenFolder"
                               Style="width: 28px; height: 28px; opacity: 0.5;"/>
            </MudTooltip>

            @if (_availableIdes.Count == 1)
            {
                <MudTooltip Text="@Strings.Layout_MainToolbar_OpenInIde(_availableIdes[0].Name)" Placement="Placement.Bottom">
                    <MudIconButton Icon="@Icons.Material.Outlined.Code" Size="Size.Small"
                                   OnClick="@(() => OpenInIde(_availableIdes[0].Command))"
                                   Style="width: 28px; height: 28px; opacity: 0.5;"/>
                </MudTooltip>
            }
            else if (_availableIdes.Count > 1)
            {
                <MudMenu Icon="@Icons.Material.Outlined.Code" Size="Size.Small"
                         Dense="true"
                         AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight"
                         Style="width: 28px; height: 28px; opacity: 0.5;"
                         ActivationEvent="@MouseEvent.LeftClick">
                    @foreach (var ide in _availableIdes)
                    {
                        <MudMenuItem OnClick="@(() => OpenInIde(ide.Command))"
                                     Icon="@Icons.Material.Outlined.Code">
                            @ide.Name
                        </MudMenuItem>
                    }
                </MudMenu>
            }
        </div>
    }

</div>

@code {
    private List<IdeInfo> _availableIdes = [];
    private bool _syncBusy;
    private IDisposable? _syncStartSub;
    private IDisposable? _syncStopSub;
    private IDisposable? _syncToggleSub;
    private IDisposable? _branchChangedSub;
    private IDisposable? _titleChangedSub;
    private string? _prevTitle;
    private bool _titleChanged;

    private bool IsSynced => SyncService.IsSessionSynced(ChatState.CurrentSession?.Id ?? "");
    private bool IsSyncBlockedByOther => SyncService.IsSyncActive && !IsSynced;

    private readonly string _mod = RuntimeInformation.IsOSPlatform(OSPlatform.OSX) ? "\u2318" : "Ctrl";

    private string SyncTooltip => IsSynced
        ? Strings.Layout_MainToolbar_SyncDisable(_mod)
        : IsSyncBlockedByOther
            ? Strings.Layout_MainToolbar_SyncBlockedByOther
            : Strings.Layout_MainToolbar_SyncEnable(_mod);

    private bool ShowSyncButton
    {
        get
        {
            var session = ChatState.CurrentSession;
            return session is { Git.IsLocalDir: false } &&
                   !string.IsNullOrEmpty(session.Git.WorktreePath);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        ChatState.OnChange += HandleStateChanged;
        _syncStartSub = EventBus.Subscribe<WorktreeSyncStartedEvent>(_ => InvokeAsync(StateHasChanged));
        _syncStopSub = EventBus.Subscribe<WorktreeSyncStoppedEvent>(_ => InvokeAsync(StateHasChanged));
        _syncToggleSub = EventBus.Subscribe<ToggleSyncEvent>(_ => InvokeAsync(async () =>
        {
            if (ShowSyncButton && !_syncBusy && !IsSyncBlockedByOther)
                await ToggleSync();
        }));
        _branchChangedSub = EventBus.Subscribe<BranchChangedEvent>(evt =>
        {
            System.Diagnostics.Debug.WriteLine($"[TRACE] MainToolbar received BranchChangedEvent: {evt.BranchName}");
            InvokeAsync(() =>
            {
                var newTitle = ChatState.CurrentSession?.Title;
                System.Diagnostics.Debug.WriteLine($"[TRACE] MainToolbar render: prevTitle={_prevTitle}, newTitle={newTitle}, branch={ChatState.CurrentSession?.Git.BranchName}");
                if (_prevTitle != null && _prevTitle != newTitle)
                    _titleChanged = true;
                _prevTitle = newTitle;
                StateHasChanged();
            });
        });
        _titleChangedSub = EventBus.Subscribe<SessionTitleChangedEvent>(_ => InvokeAsync(() =>
        {
            var newTitle = ChatState.CurrentSession?.Title;
            if (_prevTitle != null && _prevTitle != newTitle)
                _titleChanged = true;
            _prevTitle = newTitle;
            StateHasChanged();
        }));
        _availableIdes = await Launcher.GetAvailableIdesAsync();
    }

    private string? GetEffectivePath()
    {
        var session = ChatState.CurrentSession;
        if (session == null) return null;

        if (!string.IsNullOrEmpty(session.Git.WorktreePath))
            return session.Git.WorktreePath;

        return ChatState.CurrentWorkspace?.RepoLocalPath;
    }

    private async Task ToggleSync()
    {
        var session = ChatState.CurrentSession;
        if (session == null) return;

        _syncBusy = true;
        StateHasChanged();

        try
        {
            if (IsSynced)
            {
                await SyncService.StopSyncAsync();
                Snackbar.Add(Strings.Layout_MainToolbar_SyncDisabled_Snackbar, Severity.Info);
            }
            else
            {
                var workspace = ChatState.CurrentWorkspace;
                if (workspace == null) return;
                var success = await SyncService.StartSyncAsync(session, workspace);
                Snackbar.Add(success ? Strings.Layout_MainToolbar_SyncSuccess : Strings.Layout_MainToolbar_SyncFailed, success ? Severity.Success : Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add(Strings.Layout_MainToolbar_SyncError(ex.Message), Severity.Error);
        }
        finally
        {
            _syncBusy = false;
            StateHasChanged();
        }
    }

    private async Task OpenFolder()
    {
        var path = GetEffectivePath();
        if (path != null)
            await Launcher.OpenFolderAsync(path);
    }

    private async Task OpenInIde(string ideCommand)
    {
        var path = GetEffectivePath();
        if (path != null)
            await Launcher.OpenInIdeAsync(path, ideCommand);
    }

    private void HandleStateChanged()
    {
        var newTitle = ChatState.CurrentSession?.Title;
        if (_prevTitle != null && _prevTitle != newTitle)
            _titleChanged = true;
        _prevTitle = newTitle;
        InvokeAsync(StateHasChanged);
    }

    private static string FormatEffortLevel(string? level)
    {
        return level switch
        {
            "low" => Strings.Layout_MainToolbar_EffortLow,
            "high" => Strings.Layout_MainToolbar_EffortHigh,
            _ => level ?? "auto"
        };
    }

    public void Dispose()
    {
        ChatState.OnChange -= HandleStateChanged;
        _syncStartSub?.Dispose();
        _syncStopSub?.Dispose();
        _syncToggleSub?.Dispose();
        _branchChangedSub?.Dispose();
        _titleChangedSub?.Dispose();
    }

}

