<Modal IsOpen="IsOpen" IsOpenChanged="OnModalOpenChanged" Class="template-gallery-dialog"
       MaxWidth="800px" CloseOnEscape="true" CloseOnBackdropClick="true">
    <HeaderContent>
        <div class="d-flex align-center gap-2">
            <Icon Svg="@Lucide.Sparkles" Size="18"/>
            <span class="typo-h6">템플릿 갤러리</span>
            <Chip>@_filtered.Count</Chip>
        </div>
    </HeaderContent>
    <ChildContent>
        @* Category chips + search *@
        <div class="d-flex flex-column gap-2 mb-3">
            <div class="d-flex flex-wrap gap-1">
                <Chip ButtonStyle="ButtonStyle.Outlined" Tone="Tone.Primary" Icon="@Lucide.LayoutGrid"
                      Selected="@(_activeCategory == "all")" OnClick="@(() => OnCategoryChanged("all"))">
                    전체 (@BuiltInTemplates.All.Count)
                </Chip>
                <Chip ButtonStyle="ButtonStyle.Outlined" Tone="Tone.Warning" Icon="@Lucide.WandSparkles"
                      Selected="@(_activeCategory == "Skill")" OnClick="@(() => OnCategoryChanged("Skill"))">
                    스킬 (@CountByCategory(TemplateCategory.Skill))
                </Chip>
                <Chip ButtonStyle="ButtonStyle.Outlined" Tone="Tone.Secondary" Icon="@Lucide.Bot"
                      Selected="@(_activeCategory == "Agent")" OnClick="@(() => OnCategoryChanged("Agent"))">
                    에이전트 (@CountByCategory(TemplateCategory.Agent))
                </Chip>
                <Chip ButtonStyle="ButtonStyle.Outlined" Tone="Tone.Info" Icon="@Lucide.Shield"
                      Selected="@(_activeCategory == "Rule")" OnClick="@(() => OnCategoryChanged("Rule"))">
                    룰 (@CountByCategory(TemplateCategory.Rule))
                </Chip>
                <Chip ButtonStyle="ButtonStyle.Outlined" Tone="Tone.Success" Icon="@Lucide.Zap"
                      Selected="@(_activeCategory == "Hook")" OnClick="@(() => OnCategoryChanged("Hook"))">
                    훅 (@CountByCategory(TemplateCategory.Hook))
                </Chip>
                <Chip ButtonStyle="ButtonStyle.Outlined" Tone="Tone.Error" Icon="@Lucide.Network"
                      Selected="@(_activeCategory == "Mcp")" OnClick="@(() => OnCategoryChanged("Mcp"))">
                    MCP (@CountByCategory(TemplateCategory.Mcp))
                </Chip>
            </div>

            <TextField Value="@_search" Placeholder="템플릿 검색..."
                       AdornmentIcon="@Lucide.Search"
                       Immediate="true"
                       ValueChanged="@(v => OnSearchChanged(v ?? ""))"/>
        </div>

        @* Template grid *@
        <div class="template-grid">
            @foreach (var template in _filtered)
            {
                <div class="ui-card template-card" @onclick="@(() => SelectTemplate(template))">
                    <div class="d-flex justify-space-between align-start mb-2">
                        <Chip ButtonStyle="ButtonStyle.Filled"
                              Tone="@GetCategoryTone(template.Category)">
                            @GetCategoryLabel(template.Category)
                        </Chip>
                        <Icon Svg="@Lucide.Plus" Size="14"
                              Class="template-add-icon" Tone="Tone.Primary"/>
                    </div>
                    <div class="typo-subtitle2">@template.Name</div>
                    <div class="typo-caption text-secondary mt-1"
                         style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                        @template.Description
                    </div>
                </div>
            }
        </div>

        @if (_filtered.Count == 0)
        {
            <div class="d-flex justify-center pa-8">
                <span class="typo-body2 text-secondary">
                    검색 결과가 없습니다
                </span>
            </div>
        }
    </ChildContent>
    <Footer>
        <Button OnClick="Close">닫기</Button>
    </Footer>
</Modal>

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback<bool> IsOpenChanged { get; set; }

    /// <summary>Filter to a specific category on open. Null = show all.</summary>
    [Parameter]
    public TemplateCategory? DefaultCategory { get; set; }

    /// <summary>Raised when a template is selected.</summary>
    [Parameter]
    public EventCallback<TemplateDefinition> OnTemplateSelected { get; set; }

    private string _activeCategory = "all";
    private string _search = "";
    private List<TemplateDefinition> _filtered = [];

    protected override void OnParametersSet()
    {
        if (IsOpen)
        {
            _activeCategory = DefaultCategory?.ToString() ?? "all";
            _search = "";
            ApplyFilter();
        }
    }

    private void OnCategoryChanged(string value)
    {
        _activeCategory = value;
        ApplyFilter();
    }

    private void OnSearchChanged(string value)
    {
        _search = value;
        ApplyFilter();
    }

    private void ApplyFilter()
    {
        _filtered = BuiltInTemplates.All.Where(t =>
        {
            if (_activeCategory != "all" &&
                !string.Equals(t.Category.ToString(), _activeCategory, StringComparison.OrdinalIgnoreCase))
                return false;

            if (!string.IsNullOrWhiteSpace(_search))
            {
                var q = _search.Trim();
                return t.Name.Contains(q, StringComparison.OrdinalIgnoreCase)
                       || t.Description.Contains(q, StringComparison.OrdinalIgnoreCase);
            }

            return true;
        }).ToList();
    }

    private async Task SelectTemplate(TemplateDefinition template)
    {
        await OnTemplateSelected.InvokeAsync(template);
        await Close();
    }

    private async Task Close()
    {
        IsOpen = false;
        await IsOpenChanged.InvokeAsync(false);
    }

    private async Task OnModalOpenChanged(bool open)
    {
        IsOpen = open;
        await IsOpenChanged.InvokeAsync(open);
    }

    private static int CountByCategory(TemplateCategory category)
    {
        return BuiltInTemplates.All.Count(t => t.Category == category);
    }

    private static Tone GetCategoryTone(TemplateCategory category)
    {
        return category switch
        {
            TemplateCategory.Skill => Tone.Warning,
            TemplateCategory.Agent => Tone.Secondary,
            TemplateCategory.Rule => Tone.Info,
            TemplateCategory.Hook => Tone.Success,
            TemplateCategory.Mcp => Tone.Error,
            _ => Tone.Default
        };
    }

    private static string GetCategoryLabel(TemplateCategory category)
    {
        return category switch
        {
            TemplateCategory.Skill => "스킬",
            TemplateCategory.Agent => "에이전트",
            TemplateCategory.Rule => "룰",
            TemplateCategory.Hook => "훅",
            TemplateCategory.Mcp => "MCP",
            _ => category.ToString()
        };
    }

}

<style>
    .template-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: 12px;
        max-height: 50vh;
        overflow-y: auto;
        padding: 4px;
    }

    .template-card {
        padding: 14px;
        cursor: pointer;
        transition: border-color 0.15s;
    }

    .template-card:hover {
        border-color: var(--accent) !important;
    }

    .template-add-icon {
        opacity: 0;
        transition: opacity 0.15s;
    }

    .template-card:hover .template-add-icon {
        opacity: 1;
    }
</style>
