@inject IWorkspaceService WorkspaceService

<Select T="string" Value="SelectedPath" ValueChanged="OnValueChanged" Label="@Label"
        Fixed="true" Placeholder="프로젝트 선택...">
    @foreach (var ws in _workspaces)
    {
        <SelectItem T="string" Value="@GetProjectPath(ws)" Text="@GetProjectName(ws)">
            <div class="d-flex align-center gap-2">
                <Icon Svg="@Lucide.Folder" Size="14"/>
                <span>@GetProjectName(ws)</span>
            </div>
        </SelectItem>
    }
</Select>

@code {
    [Parameter] public string? SelectedPath { get; set; }
    [Parameter] public EventCallback<string?> SelectedPathChanged { get; set; }
    [Parameter] public string Label { get; set; } = "프로젝트";

    private List<Workspace> _workspaces = [];

    protected override async Task OnInitializedAsync()
    {
        _workspaces = await WorkspaceService.GetWorkspacesAsync();
    }

    private async Task OnValueChanged(string? value)
    {
        SelectedPath = value;
        await SelectedPathChanged.InvokeAsync(value);
    }

    private static string? GetProjectPath(Workspace ws)
    {
        return ws.RepoLocalPath;
    }

    private static string GetProjectName(Workspace ws)
    {
        if (!string.IsNullOrEmpty(ws.RepoUrl))
        {
            var url = ws.RepoUrl.TrimEnd('/');
            if (url.EndsWith(".git")) url = url[..^4];
            var idx = url.LastIndexOf('/');
            if (idx >= 0) return url[(idx + 1)..];
        }

        if (!string.IsNullOrEmpty(ws.RepoLocalPath))
            return Path.GetFileName(ws.RepoLocalPath.TrimEnd(Path.DirectorySeparatorChar, '/'));
        return ws.Name;
    }

}
