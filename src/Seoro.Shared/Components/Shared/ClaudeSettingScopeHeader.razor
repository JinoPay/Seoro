<div class="settings-content-header">
    <div class="d-flex align-center gap-3">
        <div class="settings-segmented">
            <button class="settings-seg-item @(Scope == ClaudeSettingsScope.Global ? "active" : "")"
                    @onclick="@(() => OnScopeChanged(ClaudeSettingsScope.Global))">
                <MudIcon Icon="@Icons.Material.Filled.Public" Size="Size.Small" Style="margin-right: 4px;"/>
                글로벌
            </button>
            <button class="settings-seg-item @(Scope == ClaudeSettingsScope.Project ? "active" : "")"
                    disabled="@(string.IsNullOrEmpty(ProjectPath))"
                    @onclick="@(() => OnScopeChanged(ClaudeSettingsScope.Project))">
                <MudIcon Icon="@Icons.Material.Filled.Folder" Size="Size.Small" Style="margin-right: 4px;"/>
                프로젝트
            </button>
            @if (ShowLocalScope)
            {
                <button class="settings-seg-item @(Scope == ClaudeSettingsScope.Local ? "active" : "")"
                        disabled="@(string.IsNullOrEmpty(ProjectPath))"
                        @onclick="@(() => OnScopeChanged(ClaudeSettingsScope.Local))">
                    <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Small" Style="margin-right: 4px;"/>
                    @(LocalScopeLabel ?? "로컬")
                </button>
            }
        </div>

        @if (Scope != ClaudeSettingsScope.Global)
        {
            <div style="width: 200px;">
                <ProjectScopePicker SelectedPath="@ProjectPath"
                                    SelectedPathChanged="OnProjectChanged" Label=""/>
            </div>
            <span class="typo-caption" style="color: @(Scope == ClaudeSettingsScope.Project ? "var(--color-info)" : "var(--color-warning)");">
                @(Scope == ClaudeSettingsScope.Project ? "git tracked" : "gitignored")
            </span>
        }
    </div>

    <div style="flex: 1;"></div>

    <div class="d-flex align-center gap-2">
        @if (ExtraActions != null)
        {
            @ExtraActions
        }
        @if (ShowSaveButton)
        {
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="OnSave"
                       Size="Size.Small" Style="text-transform: none;" Disabled="Saving">
                @(Saving ? "저장 중..." : "저장")
            </MudButton>
        }
    </div>
</div>

@code {
    [Parameter] public ClaudeSettingsScope Scope { get; set; }
    [Parameter] public EventCallback<ClaudeSettingsScope> ScopeChanged { get; set; }
    [Parameter] public string? ProjectPath { get; set; }
    [Parameter] public EventCallback<string?> ProjectPathChanged { get; set; }
    [Parameter] public bool ShowLocalScope { get; set; } = true;
    [Parameter] public bool ShowSaveButton { get; set; } = true;
    [Parameter] public string? LocalScopeLabel { get; set; }
    [Parameter] public bool Saving { get; set; }
    [Parameter] public EventCallback OnSave { get; set; }
    [Parameter] public RenderFragment? ExtraActions { get; set; }

    private async Task OnScopeChanged(ClaudeSettingsScope scope)
    {
        await ScopeChanged.InvokeAsync(scope);
    }

    private async Task OnProjectChanged(string? path)
    {
        await ProjectPathChanged.InvokeAsync(path);
    }

}
