@inject LightboxService Lightbox
@inject IJSRuntime JS
@implements IDisposable

@if (Lightbox.IsOpen)
{
    <div class="image-lightbox-overlay" @onclick="Close" @onkeydown="HandleKeyDown" tabindex="0">
        <button class="image-lightbox-close" @onclick="Close" @onclick:stopPropagation="true">
            <MudIcon Icon="@Icons.Material.Filled.Close" Style="color: inherit; width: 20px; height: 20px;"/>
        </button>

        <img src="@Lightbox.ImageSrc" alt="@Lightbox.AltText"
             class="image-lightbox-img"
             @onclick:stopPropagation="true"
             @oncontextmenu="OpenContextMenu"
             @oncontextmenu:preventDefault="true"
             @oncontextmenu:stopPropagation="true"/>

        @if (!string.IsNullOrEmpty(Lightbox.AltText))
        {
            <div class="image-lightbox-caption">@Lightbox.AltText</div>
        }
    </div>
}

<MudMenu @ref="_contextMenu"
         ActivationEvent="@MouseEvent.RightClick"
         PositionAtCursor="true"
         Dense="true"
         Style="position: absolute; visibility: hidden; width: 0; height: 0;">
    <MudMenuItem OnClick="SaveImage" Icon="@Icons.Material.Filled.Download">
        @Strings.Common_Save
    </MudMenuItem>
    <MudMenuItem OnClick="CopyImage" Icon="@Icons.Material.Filled.ContentCopy">
        @Strings.Common_Copy
    </MudMenuItem>
</MudMenu>

@code {

    private MudMenu? _contextMenu;

    protected override void OnInitialized()
    {
        Lightbox.OnChange += OnLightboxChanged;
    }

    private void OnLightboxChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private void Close()
    {
        Lightbox.Close();
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape")
            Lightbox.Close();
    }

    private async Task OpenContextMenu()
    {
        if (_contextMenu != null)
            await _contextMenu.OpenMenuAsync(EventArgs.Empty);
    }

    private async Task SaveImage()
    {
        var filename = string.IsNullOrEmpty(Lightbox.AltText) ? "image" : Lightbox.AltText;
        await JS.InvokeVoidAsync("saveImage", Lightbox.ImageSrc, filename);
    }

    private async Task CopyImage()
    {
        await JS.InvokeAsync<bool>("copyImageToClipboard", Lightbox.ImageSrc);
    }

    public void Dispose()
    {
        Lightbox.OnChange -= OnLightboxChanged;
    }

}
