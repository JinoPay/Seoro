@inject LightboxService Lightbox
@inject IJSRuntime JS
@implements IDisposable

@if (Lightbox.IsOpen)
{
    <div class="image-lightbox-overlay" @onclick="Close" @onkeydown="HandleKeyDown" tabindex="0">
        <button class="image-lightbox-close" @onclick="Close" @onclick:stopPropagation="true">
            <Icon Svg="@Lucide.X" Size="20" Style="color: inherit;"/>
        </button>

        <img src="@Lightbox.ImageSrc" alt="@Lightbox.AltText"
             class="image-lightbox-img"
             @onclick:stopPropagation="true"
             @oncontextmenu="OpenContextMenu"
             @oncontextmenu:preventDefault="true"
             @oncontextmenu:stopPropagation="true"/>

        @if (!string.IsNullOrEmpty(Lightbox.AltText))
        {
            <div class="image-lightbox-caption">@Lightbox.AltText</div>
        }

        @if (_contextMenuOpen)
        {
            <div class="ui-popover-backdrop" style="z-index: 10000;"
                 @onclick="CloseContextMenu" @onclick:stopPropagation="true"
                 @oncontextmenu="CloseContextMenu" @oncontextmenu:preventDefault="true"></div>
            <div class="ui-popover ui-popover--fixed ui-menu ui-menu--dense"
                 style="left: @(_menuX)px; top: @(_menuY)px; z-index: 10001;"
                 @onclick:stopPropagation="true">
                <button type="button" class="ui-menu__item" @onclick="SaveImage">
                    <Icon Svg="@Lucide.Download" Size="14"/>
                    <span class="ui-menu__item-label">@Strings.Common_Save</span>
                </button>
                <button type="button" class="ui-menu__item" @onclick="CopyImage">
                    <Icon Svg="@Lucide.Copy" Size="14"/>
                    <span class="ui-menu__item-label">@Strings.Common_Copy</span>
                </button>
            </div>
        }
    </div>
}

@code {

    private bool _contextMenuOpen;
    private double _menuX;
    private double _menuY;

    protected override void OnInitialized()
    {
        Lightbox.OnChange += OnLightboxChanged;
    }

    private void OnLightboxChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private void Close()
    {
        _contextMenuOpen = false;
        Lightbox.Close();
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape")
        {
            if (_contextMenuOpen)
            {
                _contextMenuOpen = false;
                return;
            }
            Lightbox.Close();
        }
    }

    private void OpenContextMenu(MouseEventArgs e)
    {
        _menuX = e.ClientX;
        _menuY = e.ClientY;
        _contextMenuOpen = true;
    }

    private void CloseContextMenu()
    {
        _contextMenuOpen = false;
    }

    private async Task SaveImage()
    {
        _contextMenuOpen = false;
        var filename = string.IsNullOrEmpty(Lightbox.AltText) ? "image" : Lightbox.AltText;
        await JS.InvokeVoidAsync("saveImage", Lightbox.ImageSrc, filename);
    }

    private async Task CopyImage()
    {
        _contextMenuOpen = false;
        await JS.InvokeAsync<bool>("copyImageToClipboard", Lightbox.ImageSrc);
    }

    public void Dispose()
    {
        Lightbox.OnChange -= OnLightboxChanged;
    }

}
