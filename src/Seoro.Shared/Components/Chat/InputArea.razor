@inject IFilePickerService FilePickerService
@inject ISkillRegistry SkillRegistry
@inject IJSRuntime JSRuntime
@inject IChatState ChatState
@inject ISessionService SessionService
@inject ISnackbar Snackbar
@implements IAsyncDisposable

<div class="input-area-container" id="input-area">
    <div class="input-area-float" style="position: relative;">
        <span class="input-focus-hint">@_shortcutHint</span>

        <SlashCommandPopup IsOpen="_slashPopupOpen"
                           FilteredCommands="_filteredCommands"
                           SelectedIndex="_slashSelectedIndex"
                           OnCommandSelected="SelectSlashCommand"
                           OnDismiss="DismissSlashPopup"
                           OnHover="@(i =>
                                    {
                                        _slashSelectedIndex = i;
                                        StateHasChanged();
                                    })"/>

        <AttachmentChips Attachments="_pendingAttachments" OnRemove="RemoveAttachment"/>

        <MudTextField T="string" Value="@_inputText" ValueChanged="@HandleInputValueChanged"
                      Placeholder="@GetPlaceholder()"
                      Variant="Variant.Text"
                      Lines="2"
                      Sizing="InputSizing.Auto"
                      MaxLines="8"
                      Immediate="true"
                      Disabled="Disabled"
                      ReadOnly="IsStreaming"
                      Class="input-textarea-full"
                      Style="font-size: var(--text-base);"/>

        <InputToolbar PermissionMode="@_currentPermissionMode"
                      OnPermissionModeChanged="HandlePermissionModeChangedLocal"
                      EffortLevel="@_currentEffortLevel"
                      OnEffortLevelChanged="HandleEffortLevelChangedLocal"
                      Model="@_currentModel"
                      OnModelChanged="HandleModelChangedLocal"
                      CurrentSession="CurrentSession"
                      IsStreaming="IsStreaming"
                      Disabled="Disabled"
                      HasInput="@(!string.IsNullOrWhiteSpace(_inputText))"
                      HasAttachments="@(_pendingAttachments.Count > 0)"
                      OnSend="Send"
                      OnCancel="@(() => OnCancel.InvokeAsync())"
                      OnPickFiles="PickFiles"
                      OnModelMenuClosed="RefocusTextarea"
                      PlanFilePath="@PlanFilePath"
                      PlanContent="@PlanContent"
                      OnViewPlan="OpenPlanTab"
                      WebSearchEnabled="_currentWebSearch"
                      OnWebSearchChanged="HandleWebSearchChangedLocal"/>
    </div>
</div>

@code {
    [Parameter] public EventCallback<ChatInputMessage> OnSend { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public bool IsStreaming { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string PermissionMode { get; set; } = "bypassAll";
    [Parameter] public EventCallback<string> PermissionModeChanged { get; set; }
    [Parameter] public string Model { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> OnModelChanged { get; set; }
    [Parameter] public string EffortLevel { get; set; } = "auto";
    [Parameter] public EventCallback<string> EffortLevelChanged { get; set; }
    [Parameter] public Session? CurrentSession { get; set; }
    [Parameter] public string? PlanFilePath { get; set; }
    [Parameter] public string? PlanContent { get; set; }
    [Parameter] public bool IsPlanReviewVisible { get; set; }
    [Parameter] public bool WebSearchEnabled { get; set; }
    [Parameter] public EventCallback<bool> WebSearchEnabledChanged { get; set; }

    private string _inputText = string.Empty;
    private readonly List<PendingAttachment> _pendingAttachments = [];
    private const int DraftSaveDebounceMs = 400;
    private DotNetObjectReference<InputArea>? _dotNetRef;
    private bool _handlersRegistered;
    private bool _suppressInputUpdates;
    private string? _trackedSessionId;
    private Session? _trackedSession;
    private CancellationTokenSource? _draftSaveCts;
    private Task? _draftSaveTask;

    // 로컬 도구 모음 상태 복사본 — 부모 파라미터와 사용자 클릭 모두에서 업데이트됨 (낙관적 업데이트)
    // 도구 모음 렌더링을 부모 리렌더 사이클과 분리하여 ShouldRender가 업데이트를 무시하지 않도록 함
    private string _currentPermissionMode = "bypassAll";
    private string _currentEffortLevel = "auto";
    private string _currentModel = string.Empty;
    private bool _currentWebSearch;

    // 불필요한 리렌더를 방지하기 위한 파라미터 추적 (커서 이동 수정)
    private bool _prevIsStreaming;
    private bool _lastDropDisabled;
    private bool _prevDisabled;
    private string _prevPermissionMode = "bypassAll";
    private string _prevModel = string.Empty;
    private string _prevEffortLevel = "auto";
    private string? _prevPlanFilePath;
    private string? _prevPlanContent;
    private bool _prevIsPlanReviewVisible;
    private bool _prevWebSearch;
    private bool _forceRender;
    private bool _isComposing;
    private readonly string _shortcutHint = OperatingSystem.IsMacOS() ? "⌘⇧L" : "Ctrl+Shift+L";

    // 슬래시 명령 자동 완성 상태
    private bool _slashPopupOpen;
    private IReadOnlyList<SkillDefinition> _filteredCommands = Array.Empty<SkillDefinition>();
    private int _slashSelectedIndex;

    protected override void OnParametersSet()
    {
        // 세션 변경 시 입력 초안 저장/복원
        var newSessionId = CurrentSession?.Id;
        if (_trackedSessionId != newSessionId)
        {
            PersistDraftState(_trackedSession, _inputText, _pendingAttachments, immediate: true);

            _inputText = string.Empty;
            _pendingAttachments.Clear();
            if (CurrentSession != null)
            {
                _inputText = GetRestoredInputDraft(CurrentSession);
                _pendingAttachments.AddRange(GetRestoredAttachmentDraft(CurrentSession));
                SyncDraftState(CurrentSession, _inputText, _pendingAttachments);
            }

            _trackedSession = CurrentSession;
            _trackedSessionId = newSessionId;

            // 세션 변경 시 로컬 복사본을 부모 파라미터에서 무조건 동기화 (stale optimistic state 방지)
            _currentPermissionMode = PermissionMode;
            _currentModel = Model;
            _currentEffortLevel = EffortLevel;
            _currentWebSearch = WebSearchEnabled;

            _forceRender = true;
        }

        // 부모 파라미터에서 로컬 복사본 동기화
        if (_prevPermissionMode != PermissionMode)
            _currentPermissionMode = PermissionMode;
        if (_prevModel != Model)
            _currentModel = Model;
        if (_prevEffortLevel != EffortLevel)
            _currentEffortLevel = EffortLevel;
        if (_prevWebSearch != WebSearchEnabled)
            _currentWebSearch = WebSearchEnabled;

        if (_prevIsStreaming != IsStreaming ||
            _prevDisabled != Disabled ||
            _prevPermissionMode != PermissionMode ||
            _prevModel != Model ||
            _prevEffortLevel != EffortLevel ||
            _prevPlanFilePath != PlanFilePath ||
            _prevPlanContent != PlanContent ||
            _prevIsPlanReviewVisible != IsPlanReviewVisible ||
            _prevWebSearch != WebSearchEnabled)
        {
            _prevIsStreaming = IsStreaming;
            _prevDisabled = Disabled;
            _prevPermissionMode = PermissionMode;
            _prevModel = Model;
            _prevEffortLevel = EffortLevel;
            _prevPlanFilePath = PlanFilePath;
            _prevPlanContent = PlanContent;
            _prevIsPlanReviewVisible = IsPlanReviewVisible;
            _prevWebSearch = WebSearchEnabled;
            _forceRender = true;
        }
    }

    private async Task RefocusTextarea()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("focusInputArea", "input-area");
        }
        catch (JSDisconnectedException)
        {
        }
    }

    private async Task HandlePermissionModeChangedLocal(string mode)
    {
        _currentPermissionMode = mode;
        _forceRender = true;
        StateHasChanged();
        await PermissionModeChanged.InvokeAsync(mode);
        await RefocusTextarea();
    }

    private async Task HandleEffortLevelChangedLocal(string level)
    {
        _currentEffortLevel = level;
        _forceRender = true;
        StateHasChanged();
        await EffortLevelChanged.InvokeAsync(level);
        await RefocusTextarea();
    }

    private async Task HandleWebSearchChangedLocal(bool enabled)
    {
        _currentWebSearch = enabled;
        _forceRender = true;
        StateHasChanged();
        await WebSearchEnabledChanged.InvokeAsync(enabled);
        await RefocusTextarea();
    }

    private async Task HandleModelChangedLocal(string model)
    {
        _currentModel = model;

        // 자동 조정: 노력도를 새 모델의 최대값으로 제한
        var maxLevel = ModelDefinitions.GetMaxEffortLevel(model);
        if (_currentEffortLevel != "auto" && _currentEffortLevel != maxLevel)
        {
            _currentEffortLevel = maxLevel;
            await EffortLevelChanged.InvokeAsync(maxLevel);
        }

        _forceRender = true;
        StateHasChanged();
        await OnModelChanged.InvokeAsync(model);
        await RefocusTextarea();
    }

    protected override bool ShouldRender()
    {
        if (_forceRender)
        {
            _forceRender = false;
            return true;
        }

        return false;
    }

    private void HandleInputValueChanged(string value)
    {
        if (_suppressInputUpdates) return;
        var wasEmpty = string.IsNullOrWhiteSpace(_inputText);
        _inputText = value;
        var isEmpty = string.IsNullOrWhiteSpace(_inputText);

        if (_trackedSessionId != null)
            PersistDraftState(_trackedSession, _inputText, _pendingAttachments);

        UpdateSlashPopupState();

        if (wasEmpty != isEmpty && !_isComposing)
        {
            _forceRender = true;
            StateHasChanged();
        }
    }

    [JSInvokable]
    public void OnCompositionStart()
    {
        _isComposing = true;
    }

    [JSInvokable]
    public void OnCompositionEnd()
    {
        _isComposing = false;
        _forceRender = true;
        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JSRuntime.InvokeVoidAsync("registerInputHandlers", "input-area", _dotNetRef);
            _handlersRegistered = true;
            _lastDropDisabled = IsStreaming;
            if (IsStreaming)
                await JSRuntime.InvokeVoidAsync("setDropDisabled", "input-area", true);
        }
        else if (_handlersRegistered && _lastDropDisabled != IsStreaming)
        {
            _lastDropDisabled = IsStreaming;
            await JSRuntime.InvokeVoidAsync("setDropDisabled", "input-area", IsStreaming);
        }
    }

    [JSInvokable]
    public void OnFilePasted(string fileName, string contentType, string base64Data)
    {
        AddPendingAttachmentFromBase64(fileName, contentType, base64Data);
    }

    [JSInvokable]
    public void OnLargeTextPasted(string fileName, string contentType, string base64Data)
    {
        AddPendingAttachmentFromBase64(fileName, contentType, base64Data);
        Snackbar.Add("긴 텍스트가 파일로 첨부되었습니다.", Severity.Info);
    }

    [JSInvokable]
    public void OnFileDropped(string fileName, string contentType, string base64Data)
    {
        if (IsStreaming) return;
        AddPendingAttachmentFromBase64(fileName, contentType, base64Data);
    }

    private void AddPendingAttachmentFromBase64(string fileName, string contentType, string base64Data)
    {
        var data = Convert.FromBase64String(base64Data);
        var attachment = new PendingAttachment
        {
            FileName = GetUniqueFileName(fileName),
            ContentType = contentType,
            Data = data
        };

        if (attachment.IsImage)
        {
            attachment.PreviewDataUrl = $"data:{contentType};base64,{base64Data}";
        }

        _pendingAttachments.Add(attachment);
        PersistDraftState(_trackedSession, _inputText, _pendingAttachments);
        _forceRender = true;
        StateHasChanged();
    }

    private async Task PickFiles()
    {
        var files = await FilePickerService.PickFilesAsync();
        if (files == null || files.Count == 0)
        {
            await RefocusTextarea();
            return;
        }

        foreach (var file in files)
            file.FileName = GetUniqueFileName(file.FileName);

        _pendingAttachments.AddRange(files);
        PersistDraftState(_trackedSession, _inputText, _pendingAttachments);
        _forceRender = true;
        StateHasChanged();
        await RefocusTextarea();
    }

    private async Task RemoveAttachment(PendingAttachment attachment)
    {
        _pendingAttachments.Remove(attachment);
        PersistDraftState(_trackedSession, _inputText, _pendingAttachments);
        _forceRender = true;
        await RefocusTextarea();
    }

    private string GetUniqueFileName(string fileName)
    {
        if (!_pendingAttachments.Any(a => a.FileName.Equals(fileName, StringComparison.OrdinalIgnoreCase)))
            return fileName;

        var ext = Path.GetExtension(fileName);
        var baseName = Path.GetFileNameWithoutExtension(fileName);

        for (var i = 2; ; i++)
        {
            var candidate = $"{baseName}{i}{ext}";
            if (!_pendingAttachments.Any(a => a.FileName.Equals(candidate, StringComparison.OrdinalIgnoreCase)))
                return candidate;
        }
    }

    private string GetPlaceholder()
    {
        if (Disabled) return "먼저 세션을 선택하거나 만드세요...";
        if (IsStreaming) return "Claude가 응답 중...";
        if (IsPlanReviewVisible) return "플랜에 대한 피드백을 입력하세요...";
        return _currentPermissionMode switch
        {
            "plan" => "플랜 모드: Claude가 읽기와 조사만 합니다...",
            "acceptEdits" => "편집 허용 모드: 파일 편집은 허용, 명령 실행은 확인...",
            _ => "메시지를 입력하세요..."
        };
    }

    [JSInvokable]
    public void OnNewlineInserted(string value)
    {
        _inputText = value;
        _forceRender = true;
        StateHasChanged();
    }

    // --- Slash command autocomplete ---

    private void UpdateSlashPopupState()
    {
        if (_isComposing) return;

        var wasOpen = _slashPopupOpen;

        if (_inputText.StartsWith('/') && !_inputText.Contains(' '))
        {
            var filter = _inputText[1..];
            var all = SkillRegistry.GetAll();
            _filteredCommands = string.IsNullOrEmpty(filter)
                ? all
                : all.Where(s => s.Name.Contains(filter, StringComparison.OrdinalIgnoreCase)).ToList();

            _slashPopupOpen = _filteredCommands.Count > 0;
            _slashSelectedIndex = Math.Clamp(_slashSelectedIndex, 0, Math.Max(0, _filteredCommands.Count - 1));
        }
        else
        {
            _slashPopupOpen = false;
            _filteredCommands = Array.Empty<SkillDefinition>();
            _slashSelectedIndex = 0;
        }

        if (wasOpen != _slashPopupOpen)
        {
            _ = JSRuntime.InvokeVoidAsync("setSlashPopupState", "input-area", _slashPopupOpen);
            _forceRender = true;
            StateHasChanged();
        }
        else if (_slashPopupOpen)
        {
            _forceRender = true;
            StateHasChanged();
        }
    }

    [JSInvokable]
    public async Task OnSlashArrowDown()
    {
        if (_filteredCommands.Count == 0) return;
        _slashSelectedIndex = (_slashSelectedIndex + 1) % _filteredCommands.Count;
        _forceRender = true;
        StateHasChanged();
        await JSRuntime.InvokeVoidAsync("scrollSlashPopupActiveIntoView");
    }

    [JSInvokable]
    public async Task OnSlashArrowUp()
    {
        if (_filteredCommands.Count == 0) return;
        _slashSelectedIndex = (_slashSelectedIndex - 1 + _filteredCommands.Count) % _filteredCommands.Count;
        _forceRender = true;
        StateHasChanged();
        await JSRuntime.InvokeVoidAsync("scrollSlashPopupActiveIntoView");
    }

    [JSInvokable]
    public async Task OnSlashEnterSelect()
    {
        if (_slashSelectedIndex >= 0 && _slashSelectedIndex < _filteredCommands.Count)
            await SelectSlashCommand(_filteredCommands[_slashSelectedIndex]);
    }

    [JSInvokable]
    public void OnSlashDismiss()
    {
        DismissSlashPopup();
    }

    private void DismissSlashPopup()
    {
        _slashPopupOpen = false;
        _forceRender = true;
        StateHasChanged();
        _ = JSRuntime.InvokeVoidAsync("setSlashPopupState", "input-area", false);
    }

    private async Task SelectSlashCommand(SkillDefinition command)
    {
        _slashPopupOpen = false;
        _slashSelectedIndex = 0;

        var newText = $"/{command.Name} ";
        _inputText = newText;

        _forceRender = true;
        StateHasChanged();

        await JSRuntime.InvokeVoidAsync("setSlashPopupState", "input-area", false);
        await JSRuntime.InvokeVoidAsync("replaceSlashCommand", "input-area", newText);
    }

    private void OpenPlanTab()
    {
        if (!string.IsNullOrEmpty(PlanFilePath) && !string.IsNullOrEmpty(PlanContent))
            ChatState.Tabs.OpenFileContentTab(PlanFilePath, PlanContent);
    }

    [JSInvokable]
    public async Task SendFromJs()
    {
        await Send();
    }

    private async Task Send()
    {
        _forceRender = true;
        if (Disabled || (string.IsNullOrWhiteSpace(_inputText) && _pendingAttachments.Count == 0))
            return;

        var text = _inputText.Trim();
        List<SkillChainStep>? pendingChain = null;

        // 스킬 체이닝 먼저 시도 (파이프 문법 또는 정의 체인)
        if (CurrentSession != null && SkillRegistry.TryParseSkillChain(text, CurrentSession, out var chainSteps))
        {
            text = chainSteps[0].ExpandedText;
            pendingChain = chainSteps.Count > 1 ? chainSteps.GetRange(1, chainSteps.Count - 1) : null;
        }
        else
        {
            // 단일 슬래시 명령어 (체인 없음)
            var skillName = SkillRegistry.TryParseSkillCommand(text, out var skillArgs);
            if (skillName != null)
            {
                var skill = SkillRegistry.Find(skillName);
                if (skill != null && CurrentSession != null)
                {
                    text = SkillRegistry.ExpandSkill(skill, skillArgs, CurrentSession);
                }
            }
        }

        var input = new ChatInputMessage
        {
            Text = text,
            Attachments = [.._pendingAttachments],
            PendingChain = pendingChain
        };

        _suppressInputUpdates = true; // oninput가 개행을 다시 삽입하는 것 차단
        _inputText = string.Empty;
        if (_trackedSessionId != null)
        {
            ChatState.SetInputDraft(_trackedSessionId, string.Empty);
            ChatState.SetAttachmentDraft(_trackedSessionId, []);
        }
        PersistDraftState(_trackedSession, string.Empty, [], immediate: true);
        _pendingAttachments.Clear();
        StateHasChanged();
        await OnSend.InvokeAsync(input);

        // JS 안전장치: textarea DOM을 직접 지우기
        try
        {
            await JSRuntime.InvokeVoidAsync("clearInputArea", "input-area");
        }
        catch (JSDisconnectedException)
        {
            /* expected during circuit disposal */
        }

        _suppressInputUpdates = false; // 차단 해제
    }

    public async ValueTask DisposeAsync()
    {
        PersistDraftState(_trackedSession, _inputText, _pendingAttachments, immediate: true);
        if (_draftSaveTask != null)
            await _draftSaveTask;

        if (_handlersRegistered)
        {
            try
            {
                await JSRuntime.InvokeVoidAsync("unregisterInputHandlers", "input-area");
            }
            catch (JSDisconnectedException)
            {
                /* expected during circuit disposal */
            }
        }

        _dotNetRef?.Dispose();
        _draftSaveCts?.Dispose();
    }

    private string GetRestoredInputDraft(Session session)
    {
        var draft = ChatState.GetInputDraft(session.Id);
        return string.IsNullOrEmpty(draft) ? session.DraftInputText : draft;
    }

    private List<PendingAttachment> GetRestoredAttachmentDraft(Session session)
    {
        var draft = ChatState.GetAttachmentDraft(session.Id);
        if (draft.Count > 0)
            return CloneAttachments(draft);

        return CloneAttachments(session.DraftAttachments);
    }

    private void PersistDraftState(Session? session, string text, List<PendingAttachment> attachments, bool immediate = false)
    {
        if (session == null) return;

        SyncDraftState(session, text, attachments);

        if (immediate)
        {
            CancelDraftSave();
            _draftSaveTask = PersistDraftAsync(session);
            return;
        }

        QueueDraftSave(session);
    }

    private void SyncDraftState(Session session, string text, List<PendingAttachment> attachments)
    {
        ChatState.SetInputDraft(session.Id, text);
        ChatState.SetAttachmentDraft(session.Id, attachments);
        session.DraftInputText = text;
        session.DraftAttachments = CloneAttachments(attachments);
    }

    private void QueueDraftSave(Session session)
    {
        CancelDraftSave();
        var cts = new CancellationTokenSource();
        _draftSaveCts = cts;
        _draftSaveTask = PersistDraftLaterAsync(session, cts.Token);
    }

    private async Task PersistDraftLaterAsync(Session session, CancellationToken cancellationToken)
    {
        try
        {
            await Task.Delay(DraftSaveDebounceMs, cancellationToken);
            await PersistDraftAsync(session);
        }
        catch (OperationCanceledException)
        {
        }
    }

    private Task PersistDraftAsync(Session session)
    {
        return SessionService.SaveSessionAsync(session);
    }

    private void CancelDraftSave()
    {
        if (_draftSaveCts == null) return;
        _draftSaveCts.Cancel();
        _draftSaveCts.Dispose();
        _draftSaveCts = null;
    }

    private static List<PendingAttachment> CloneAttachments(IEnumerable<PendingAttachment> attachments)
    {
        return attachments.Select(CloneAttachment).ToList();
    }

    private static PendingAttachment CloneAttachment(PendingAttachment attachment)
    {
        var clone = new PendingAttachment
        {
            FileName = attachment.FileName,
            ContentType = attachment.ContentType,
            FilePath = attachment.FilePath,
            Data = [..attachment.Data],
            PreviewDataUrl = attachment.PreviewDataUrl
        };

        if (clone.IsImage && clone.PreviewDataUrl == null && clone.Data.Length > 0)
            clone.PreviewDataUrl = $"data:{clone.ContentType};base64,{Convert.ToBase64String(clone.Data)}";

        return clone;
    }

}
