    private static string StatusIcon(MergeStatusKind kind) => kind switch
    {
        MergeStatusKind.Clean => Icons.Material.Filled.CheckCircle,
        MergeStatusKind.BehindTarget => Icons.Material.Filled.Warning,
        MergeStatusKind.ConflictExpected => Icons.Material.Filled.Error,
        MergeStatusKind.UncommittedDirty => Icons.Material.Outlined.EditNote,
        MergeStatusKind.InConflict => Icons.Material.Filled.Warning,
        MergeStatusKind.NetworkError => Icons.Material.Filled.WifiOff,
        _ => Icons.Material.Outlined.HourglassEmpty
    };

    private static string StatusCssClass(MergeStatusKind kind) => kind switch
    {
        MergeStatusKind.Clean => "status-clean",
        MergeStatusKind.BehindTarget => "status-behind",
        MergeStatusKind.ConflictExpected => "status-conflict",
        MergeStatusKind.UncommittedDirty => "status-uncommitted",
        MergeStatusKind.InConflict => "status-in-conflict",
        MergeStatusKind.NetworkError => "status-offline",
        _ => "status-unknown"
    };

    private static string BuildStatusTooltip(MergeStatus status) => status.Kind switch
    {
        MergeStatusKind.Unknown => "머지 상태 계산 대기 중",
        MergeStatusKind.Clean =>
            $"머지 가능 (ahead {status.AheadCount ?? 0}, behind {status.BehindCount ?? 0})",
        MergeStatusKind.BehindTarget =>
            $"타겟이 {status.BehindCount ?? 0}커밋 앞섰습니다 — stale 경고",
        MergeStatusKind.ConflictExpected =>
            $"머지 시 {status.ConflictingFiles?.Count ?? 0}개 파일 충돌이 예상됩니다",
        MergeStatusKind.UncommittedDirty =>
            $"미커밋 변경 {status.UncommittedChangeCount}개 — 먼저 커밋하세요",
        MergeStatusKind.InConflict =>
            "현재 머지 진행 중 — 충돌 해결 버튼을 사용하세요",
        MergeStatusKind.NetworkError =>
            $"오프라인 또는 fetch 실패 — 마지막 확인 {status.LastCheckedAt:HH:mm:ss}",
        _ => ""
    };

    private static string BuildPushTooltip(Session session, RemoteInfo remote)
    {
        if (remote.Mode != RemoteMode.GitHub)
            return "GitHub 원격만 지원됩니다";
        return $"origin/{session.Git.BranchName} 으로 푸시";
    }

    private static string BuildMergeTooltip(bool noTarget, string? target)
    {
        if (noTarget) return "먼저 타겟 브랜치를 선택하세요";
        return $"{target} 에 스쿼시 머지 (임시 클론 방식)";
    }

