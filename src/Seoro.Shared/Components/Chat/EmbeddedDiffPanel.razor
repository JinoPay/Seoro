@inject IChatState ChatState
@inject IChatEventBus EventBus
@implements IAsyncDisposable

@*
    EmbeddedDiffPanel — 오른쪽 패널의 호스트.
    상단 콘텐츠 영역 + 하단 RightPanelBottomBar.
    ChatState.RightPanel 모드에 따라 한 번에 하나의 패널만 표시(display:none으로 마운트 유지).
*@

<div class="right-panel-host">
    <div class="right-panel-content">
        <div style="@(ChatState.RightPanel == RightPanelMode.Explorer
                        ? "flex:1;min-height:0;display:flex;flex-direction:column"
                        : "display:none;height:0;overflow:hidden")">
            <SidebarExplorer/>
        </div>

        <div style="@(ChatState.RightPanel == RightPanelMode.Git
                        ? "flex:1;min-height:0;display:flex;flex-direction:column"
                        : "display:none;height:0;overflow:hidden")">
            <GitPanel/>
        </div>

        <div style="@(ChatState.RightPanel == RightPanelMode.Terminal
                        ? "flex:1;min-height:0;display:flex;flex-direction:column"
                        : "display:none;height:0;overflow:hidden")">
            <TerminalPanel @ref="_terminalPanel"/>
        </div>

        @if (ChatState.RightPanel == RightPanelMode.None)
        {
            <div class="right-panel-empty"></div>
        }
    </div>

    <RightPanelBottomBar/>
</div>

@code {
    private TerminalPanel? _terminalPanel;
    private IDisposable? _conflictSub;

    protected override void OnInitialized()
    {
        ChatState.OnChange += HandleStateChanged;

        // 충돌 진입 시 자동으로 Git 모드로 전환 (GitPanel 내부에서 Merge sub-tab으로 추가 전환).
        _conflictSub = EventBus.Subscribe<ConflictDetectedEvent>(e =>
            InvokeAsync(() =>
            {
                if (e.Entered && ChatState.RightPanel != RightPanelMode.Git)
                    ChatState.SetRightPanel(RightPanelMode.Git);
            }));
    }

    private void HandleStateChanged() => InvokeAsync(StateHasChanged);

    public async ValueTask DisposeAsync()
    {
        ChatState.OnChange -= HandleStateChanged;
        _conflictSub?.Dispose();
        if (_terminalPanel != null)
            await _terminalPanel.DisposeAsync();
    }
}
