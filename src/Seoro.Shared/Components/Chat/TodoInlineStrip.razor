@* 채팅 인풋 위에 인라인으로 표시되는 TodoWrite 진행 스트립 (Chip ↔ Expanded) *@
@if (State == TodoFloaterVisibility.Chip && Snapshot is { Total: > 0 })
{
    <div class="todo-inline-strip todo-inline-chip @(Snapshot.HasInProgress ? "has-progress" : "") @(Snapshot.AllDone ? "all-done" : "")">
        <button class="todo-inline-chip-main"
                @onclick="HandleExpand"
                type="button"
                title="@Strings.Todo_FloaterTitle">
            @if (Snapshot.AllDone)
            {
                <Icon Svg="@Lucide.CircleCheck" Size="14" Tone="Tone.Success"/>
            }
            else if (Snapshot.HasInProgress)
            {
                <Spinner Size="12" Tone="Tone.Warning"/>
            }
            else
            {
                <Icon Svg="@Lucide.ListChecks" Size="14"/>
            }
            <span class="todo-inline-current">@GetCurrentTaskText()</span>
            <span class="todo-inline-counter">@Snapshot.Completed/@Snapshot.Total</span>
        </button>
        <button class="todo-inline-close"
                @onclick="HandleDismiss"
                type="button"
                title="@Strings.Common_Close">
            <Icon Svg="@Lucide.X" Size="12"/>
        </button>
    </div>
}
else if (State == TodoFloaterVisibility.Expanded && Snapshot is { Total: > 0 })
{
    <div class="todo-inline-strip todo-inline-card">
        <div class="todo-inline-header" @onclick="HandleCollapse">
            <Icon Svg="@Lucide.ChevronDown" Size="14" Style="opacity: 0.7;"/>
            <span class="todo-inline-title">@Strings.Todo_FloaterTitle</span>
            <span class="todo-inline-counter">@Snapshot.Completed/@Snapshot.Total</span>
            <button class="todo-inline-close"
                    @onclick="HandleDismiss"
                    @onclick:stopPropagation="true"
                    type="button"
                    title="@Strings.Common_Close">
                <Icon Svg="@Lucide.X" Size="12"/>
            </button>
        </div>
        <div class="todo-inline-progress">
            <div class="todo-inline-progress-fill" style="width: @ProgressPercent%;"></div>
        </div>
        <div class="todo-inline-list">
            @foreach (var entry in Snapshot.Entries)
            {
                <div class="todo-inline-row todo-status-@entry.Status.ToString().ToLowerInvariant()">
                    @switch (entry.Status)
                    {
                        case TodoStatus.Completed:
                            <Icon Svg="@Lucide.CircleCheck" Size="14" Tone="Tone.Success"/>
                            break;
                        case TodoStatus.InProgress:
                            <Spinner Size="12" Tone="Tone.Warning"/>
                            break;
                        default:
                            <Icon Svg="@Lucide.Circle" Size="14" Style="opacity: 0.4;"/>
                            break;
                    }
                    <span class="todo-inline-text">@GetDisplayText(entry)</span>
                </div>
            }
        </div>
    </div>
}

@code {
    [Parameter] public TodoSnapshot? Snapshot { get; set; }
    [Parameter] public TodoFloaterVisibility State { get; set; }
    [Parameter] public EventCallback OnRequestExpand { get; set; }
    [Parameter] public EventCallback OnRequestCollapse { get; set; }
    [Parameter] public EventCallback OnDismiss { get; set; }

    private int ProgressPercent =>
        Snapshot is { Total: > 0 } s ? (int)Math.Round(s.Completed * 100.0 / s.Total) : 0;

    private Task HandleExpand() => OnRequestExpand.InvokeAsync();
    private Task HandleCollapse() => OnRequestCollapse.InvokeAsync();
    private Task HandleDismiss() => OnDismiss.InvokeAsync();

    private string GetCurrentTaskText()
    {
        if (Snapshot is null || Snapshot.Entries.Count == 0) return string.Empty;

        var inProgress = Snapshot.Entries.FirstOrDefault(e => e.Status == TodoStatus.InProgress);
        if (inProgress is not null)
            return !string.IsNullOrEmpty(inProgress.ActiveForm) ? inProgress.ActiveForm : inProgress.Content;

        var pending = Snapshot.Entries.FirstOrDefault(e => e.Status == TodoStatus.Pending);
        if (pending is not null) return pending.Content;

        return Snapshot.Entries[^1].Content;
    }

    private static string GetDisplayText(TodoEntry entry)
    {
        return entry.Status == TodoStatus.InProgress && !string.IsNullOrEmpty(entry.ActiveForm)
            ? entry.ActiveForm
            : entry.Content;
    }
}
