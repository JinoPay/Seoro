@if (IsVisible && Options.Count > 0)
{
    <div class="quick-response-bar">
        @foreach (var option in Options)
        {
            <Button ButtonStyle="ButtonStyle.Outlined" Tone="Tone.Primary"
                    OnClick="@(() => OnResponse.InvokeAsync(option))"
                    Style="border-radius: 16px; padding: 2px 14px;">
                @option
            </Button>
        }
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public List<string> Options { get; set; } = [];
    [Parameter] public EventCallback<string> OnResponse { get; set; }
}
