@inject IChatState ChatState
@inject IChatEventBus EventBus
@inject ISessionInitializer SessionInitializer
@inject IGitService GitService
@inject IWorkspaceService WorkspaceService
@inject IMergeStatusService MergeStatusService
@inject IConflictWatcherService ConflictWatcher
@inject ISessionService SessionService
@inject ISessionListFacade SessionListFacade
@inject ISettingsService SettingsService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IPullRequestService PullRequestService
@inject IHooksEngine HooksEngine
@inject ILogger<MergePanel> Logger
@using Microsoft.Extensions.Logging
@using System.Diagnostics
@using System.Runtime.InteropServices
@implements IDisposable

@*
    MergePanel — EmbeddedDiffPanel 의 "Merge" 탭 콘텐츠.
    MergeToolbar 에서 이동된 전체 머지 로직을 세로 레이아웃으로 표시.
    슬림 MergeToolbar 는 36px 상태 요약줄만 남기고, 상세 컨트롤은 이 패널에서 처리.
*@

<div class="merge-panel">
    @{
        var session = ChatState.CurrentSession;
        var workspace = ChatState.CurrentWorkspace;
    }

    @if (session == null || session.Status == SessionStatus.Pending)
    {
        <div class="merge-panel-empty">
            <MudIcon Icon="@Icons.Material.Outlined.CallMerge" Style="width: 24px; height: 24px;"/>
            <span>세션을 선택하세요</span>
        </div>
    }
    else
    {
        var isStreaming = ChatState.IsSessionStreaming(session.Id);
        var remoteInfo = workspace != null ? WorkspaceService.GetRemoteInfo(workspace.Id) : RemoteInfo.None;
        var status = MergeStatusService.GetCurrent(session.Id);
        var blocked = isStreaming || _busy;

        @* ─── 로컬 디렉토리 세션 ─── *@
        @if (session.Git.IsLocalDir)
        {
            var localHasChanges = (status.AheadCount ?? 0) > 0 || status.UncommittedChangeCount > 0;

            @* 상태 행 *@
            <MudTooltip Text="@BuildStatusTooltip(status)" Placement="Placement.Bottom">
                <div class="mp-status-row @StatusCssClass(status.Kind)">
                    <span class="merge-status-icon @StatusCssClass(status.Kind)">
                        <MudIcon Icon="@StatusIcon(status.Kind, status.AheadCount ?? 0)" Style="width: 13px; height: 13px;"/>
                    </span>
                    <span class="mp-status-label">@BuildStatusLabel(status)</span>
                    @if (_diffStats is { Additions: > 0 } or { Deletions: > 0 })
                    {
                        <button class="mp-diff-link" @onclick="HandleNavigateToChanges" title="Changes 탭에서 보기">
                            <span class="diff-add">+@(_diffStats!.Value.Additions)</span>
                            <span class="mp-diff-sep">/</span>
                            <span class="diff-del">-@(_diffStats!.Value.Deletions)</span>
                            <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Style="width: 11px; height: 11px; opacity: 0.5;"/>
                        </button>
                    }
                    else if ((status.AheadCount ?? 0) > 0)
                    {
                        <span class="mp-status-sub">↑@status.AheadCount</span>
                    }
                    else if (status.UncommittedChangeCount > 0)
                    {
                        <button class="mp-diff-link" @onclick="HandleNavigateToChanges" title="Changes 탭에서 보기">
                            <span>@status.UncommittedChangeCount 변경</span>
                            <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Style="width: 11px; height: 11px; opacity: 0.5;"/>
                        </button>
                    }
                </div>
            </MudTooltip>

            @if (localHasChanges && remoteInfo.Mode == RemoteMode.GitHub)
            {
                <MudTooltip Text="@BuildLocalDirPushTooltip(status, _diffStats)" Placement="Placement.Bottom">
                    <button class="mp-main-btn @(blocked ? "disabled" : "")"
                            @onclick="HandlePush"
                            disabled="@blocked">
                        <MudIcon Icon="@Icons.Material.Outlined.CloudUpload" Style="width: 13px; height: 13px;"/>
                        <span>AI에게 커밋 · 푸시 요청</span>
                    </button>
                </MudTooltip>
            }
        }
        else
        {
            @* ─── 워크트리 세션 ─── *@

            var noTarget = string.IsNullOrEmpty(_targetBranch);
            var isEmpty = status.Kind != MergeStatusKind.InConflict
                          && (status.AheadCount ?? 0) == 0
                          && status.UncommittedChangeCount == 0;

            @* 브랜치 행 — 현재 브랜치 → 타겟 *@
            <div class="mp-branch-row">
                <div class="merge-branch-selector-wrap" style="flex: 1; min-width: 0;">
                    <button class="mp-branch-btn @(blocked ? "disabled" : "")"
                            @onclick="ToggleBranchMenu" disabled="@blocked">
                        <MudIcon Icon="@Icons.Material.Filled.CallMerge"
                                 Style="width: 12px; height: 12px; flex-shrink: 0; opacity: 0.6;"/>
                        <span class="mp-branch-current">@(session.Git.BranchName ?? "—")</span>
                        <span class="mp-branch-arrow">→</span>
                        <span class="mp-branch-target @(noTarget ? "mp-branch-placeholder" : "")">
                            @(_targetBranch ?? "브랜치 선택")
                        </span>
                        <MudIcon Icon="@Icons.Material.Filled.UnfoldMore"
                                 Style="width: 12px; height: 12px; opacity: 0.4; flex-shrink: 0;"/>
                    </button>

                    <MudPopover Open="@_branchMenuOpen" AnchorOrigin="Origin.BottomLeft"
                                TransformOrigin="Origin.TopLeft" Class="branch-popover">
                        <div class="branch-search-container">
                            <MudTextField T="string" @bind-Value="_branchSearchText"
                                          Placeholder="브랜치 검색..."
                                          Variant="Variant.Text"
                                          Immediate="true"
                                          Adornment="Adornment.Start"
                                          AdornmentIcon="@Icons.Material.Filled.Search"
                                          Style="font-size: var(--text-sm);"/>
                        </div>
                        <MudList T="string" Dense="true" Class="branch-list">
                            @foreach (var group in FilteredBranchGroups)
                            {
                                <div class="branch-group-header">@group.Name</div>
                                @foreach (var branch in group.Branches)
                                {
                                    <MudListItem T="string" OnClick="@(() => SelectTargetBranch(branch))"
                                                 Class="@(branch == _targetBranch ? "branch-item-active" : "")">
                                        <div class="branch-item-content">
                                            <MudIcon Icon="@Icons.Material.Filled.AccountTree"
                                                     Style="font-size: 14px; opacity: 0.5;"/>
                                            <span class="branch-item-name">@branch</span>
                                            @if (branch == _targetBranch)
                                            {
                                                <MudIcon Icon="@Icons.Material.Filled.Check"
                                                         Style="font-size: 14px; color: var(--accent);"/>
                                            }
                                        </div>
                                    </MudListItem>
                                }
                            }
                            @if (!FilteredBranchGroups.Any())
                            {
                                <div class="branch-no-results">일치하는 브랜치 없음</div>
                            }
                        </MudList>
                    </MudPopover>

                    @if (_branchMenuOpen)
                    {
                        <MudOverlay Visible="true" OnClick="CloseBranchMenu" DarkBackground="false" ZIndex="1"/>
                    }
                </div>

                <MudTooltip Text="브랜치 · 머지 상태 새로고침" Placement="Placement.Left">
                    <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                                   Size="Size.Small" Disabled="@blocked"
                                   OnClick="HandleManualRefresh"
                                   Style="width: 26px; height: 26px; flex-shrink: 0; opacity: 0.5;"/>
                </MudTooltip>
            </div>

            @* 상태 행 *@
            <MudTooltip Text="@BuildStatusTooltip(status)" Placement="Placement.Bottom">
                <div class="mp-status-row @StatusCssClass(status.Kind)">
                    <span class="merge-status-icon @StatusCssClass(status.Kind)">
                        <MudIcon Icon="@StatusIcon(status.Kind, status.AheadCount ?? 0)" Style="width: 13px; height: 13px;"/>
                    </span>
                    <span class="mp-status-label">@BuildStatusLabel(status)</span>

                    @if (status.Kind == MergeStatusKind.BehindTarget && status.BehindCount is > 0)
                    {
                        <span class="mp-status-sub">↓@status.BehindCount</span>
                    }
                    else if (status.Kind == MergeStatusKind.ConflictExpected && status.ConflictingFiles is { Count: > 0 })
                    {
                        <span class="mp-status-sub">@status.ConflictingFiles.Count 파일</span>
                    }
                    else if (_diffStats is { Additions: > 0 } or { Deletions: > 0 })
                    {
                        <button class="mp-diff-link" @onclick="HandleNavigateToChanges" title="Changes 탭에서 보기">
                            <span class="diff-add">+@(_diffStats!.Value.Additions)</span>
                            <span class="mp-diff-sep">/</span>
                            <span class="diff-del">-@(_diffStats!.Value.Deletions)</span>
                            <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Style="width: 11px; height: 11px; opacity: 0.5;"/>
                        </button>
                    }
                    else if (status.UncommittedChangeCount > 0)
                    {
                        <button class="mp-diff-link" @onclick="HandleNavigateToChanges" title="Changes 탭에서 보기">
                            <span>@status.UncommittedChangeCount 변경</span>
                            <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Style="width: 11px; height: 11px; opacity: 0.5;"/>
                        </button>
                    }
                </div>
            </MudTooltip>

            <div class="mp-action-area">
            @* PR 카드 *@
            @if (session.Git.TrackedPr != null)
            {
                var pr = session.Git.TrackedPr;
                <div class="mp-pr-card">
                    <div class="mp-pr-top">
                        <span class="pr-badge @PrBadgeCssClass(pr)">
                            <MudIcon Icon="@PrStatusIcon(pr)" Style="width: 11px; height: 11px;"/>
                            <span>#@pr.Number</span>
                        </span>
                        <span class="mp-pr-title" title="@pr.Title">@pr.Title</span>
                        <MudTooltip Text="PR 상태 새로고침" Placement="Placement.Top">
                            <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                                           Size="Size.Small" Disabled="@(blocked || _prLoading)"
                                           OnClick="HandleRefreshPr"
                                           Style="width: 22px; height: 22px; flex-shrink: 0; opacity: 0.5;"/>
                        </MudTooltip>
                        <MudTooltip Text="PR 링크 해제" Placement="Placement.Top">
                            <MudIconButton Icon="@Icons.Material.Outlined.Close"
                                           Size="Size.Small" Disabled="@blocked"
                                           OnClick="ClearSavedPr"
                                           Style="width: 22px; height: 22px; flex-shrink: 0; opacity: 0.4;"/>
                        </MudTooltip>
                    </div>

                    @{
                        var metaParts = new List<string>();
                        if (!string.IsNullOrEmpty(pr.MergeStateStatus)) metaParts.Add(pr.MergeStateStatus);
                        if (!string.IsNullOrEmpty(pr.ReviewDecision)) metaParts.Add(pr.ReviewDecision);
                        if (!string.IsNullOrEmpty(pr.ChecksSummary)) metaParts.Add(pr.ChecksSummary);
                    }
                    @if (metaParts.Count > 0)
                    {
                        <div class="mp-pr-meta">@string.Join(" · ", metaParts)</div>
                    }

                    <button class="mp-pr-open-btn @(blocked ? "disabled" : "")"
                            @onclick="OpenSavedPr" disabled="@blocked">
                        <MudIcon Icon="@Icons.Material.Outlined.OpenInNew" Style="width: 11px; height: 11px;"/>
                        <span>PR 열기</span>
                    </button>
                </div>
            }

            @* 액션 영역 *@
            @if (status.Kind == MergeStatusKind.InConflict)
            {
                <MudTooltip Text="워크트리 충돌을 AI에게 위임해 해결" Placement="Placement.Bottom">
                    <button class="mp-main-btn mp-main-btn-conflict @(blocked ? "disabled" : "")"
                            @onclick="HandleResolveConflict"
                            disabled="@blocked">
                        <MudIcon Icon="@Icons.Material.Filled.Warning" Style="width: 13px; height: 13px;"/>
                        <span>충돌 해결 요청</span>
                    </button>
                </MudTooltip>
            }
            else if (session.Git.TrackedPr is { IsMerged: true })
            {
                <button class="mp-main-btn @(blocked ? "disabled" : "")"
                        @onclick="HandleArchiveAfterMerge"
                        disabled="@blocked">
                    <MudIcon Icon="@Icons.Material.Outlined.Archive" Style="width: 13px; height: 13px;"/>
                    <span>세션 아카이브</span>
                </button>
            }
            else if (session.Git.TrackedPr is { State: PullRequestLifecycleState.Open })
            {
                @* 미푸시 경고 *@
                if (_upstreamAhead > 0 || status.UncommittedChangeCount > 0)
                {
                    <div class="mp-unpushed-warning">
                        <MudIcon Icon="@Icons.Material.Filled.Warning" Style="width: 13px; height: 13px;"/>
                        @if (status.UncommittedChangeCount > 0 && _upstreamAhead > 0)
                        {
                            <span>미커밋 @(status.UncommittedChangeCount)개 + 미푸시 커밋 @(_upstreamAhead)개</span>
                        }
                        else if (status.UncommittedChangeCount > 0)
                        {
                            <span>미커밋 변경 @(status.UncommittedChangeCount)개</span>
                        }
                        else
                        {
                            <span>미푸시 커밋 @(_upstreamAhead)개</span>
                        }
                    </div>
                    <MudTooltip Text="미커밋 변경을 커밋하고 origin에 푸시합니다" Placement="Placement.Bottom">
                        <button class="mp-main-btn mp-main-btn-push @(blocked ? "disabled" : "")"
                                @onclick="HandlePush"
                                disabled="@blocked">
                            <MudIcon Icon="@Icons.Material.Outlined.CloudUpload" Style="width: 13px; height: 13px;"/>
                            <span>AI에게 커밋 · 푸시 요청</span>
                        </button>
                    </MudTooltip>
                }

                @* 전략 pills + 머지 버튼 *@
                <div class="mp-strategy-pills">
                    <button class="mp-pill @(_selectedMergeStrategy == PullRequestMergeStrategy.Merge ? "active" : "")"
                            @onclick="() => _selectedMergeStrategy = PullRequestMergeStrategy.Merge"
                            disabled="@blocked">
                        Merge
                    </button>
                    <button class="mp-pill @(_selectedMergeStrategy == PullRequestMergeStrategy.Squash ? "active" : "")"
                            @onclick="() => _selectedMergeStrategy = PullRequestMergeStrategy.Squash"
                            disabled="@blocked">
                        Squash
                    </button>
                    <button class="mp-pill @(_selectedMergeStrategy == PullRequestMergeStrategy.Rebase ? "active" : "")"
                            @onclick="() => _selectedMergeStrategy = PullRequestMergeStrategy.Rebase"
                            disabled="@blocked">
                        Rebase
                    </button>
                </div>
                <MudTooltip Text="@PrMergeButtonTooltip(session.Git.TrackedPr)" Placement="Placement.Bottom">
                    <button class="mp-main-btn @(!session.Git.TrackedPr.CanMerge || blocked || _prMerging ? "disabled" : "")"
                            @onclick="HandleMergePr"
                            disabled="@(!session.Git.TrackedPr.CanMerge || blocked || _prMerging)">
                        @if (_prMerging)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true"
                                                 Style="width: 13px; height: 13px;"/>
                        }
                        else
                        {
                            <MudIcon Icon="@Icons.Material.Outlined.CallMerge" Style="width: 13px; height: 13px;"/>
                        }
                        <span>@MergeMethodLabel(_selectedMergeStrategy) 머지</span>
                    </button>
                </MudTooltip>
            }
            else if (!isEmpty)
            {
                @* PR 없음 또는 닫힌 상태 *@
                <MudTooltip Text="@BuildPrTooltip(noTarget, _targetBranch)" Placement="Placement.Bottom">
                    <button class="mp-main-btn @(blocked || noTarget ? "disabled" : "")"
                            @onclick="HandleCreatePrViaAi"
                            disabled="@(blocked || noTarget)">
                        <MudIcon Icon="@Icons.Material.Outlined.CallMerge" Style="width: 13px; height: 13px;"/>
                        <span>PR 생성 요청</span>
                    </button>
                </MudTooltip>
                @if (remoteInfo.Mode == RemoteMode.GitHub)
                {
                    <MudTooltip Text="이 브랜치에 연결된 PR을 GitHub에서 조회" Placement="Placement.Bottom">
                        <button class="mp-secondary-btn @(blocked || _prLoading ? "disabled" : "")"
                                @onclick="HandleCheckPr"
                                disabled="@(blocked || _prLoading)">
                            @if (_prLoading)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true"
                                                     Style="width: 11px; height: 11px;"/>
                            }
                            else
                            {
                                <MudIcon Icon="@Icons.Material.Outlined.Search" Style="width: 11px; height: 11px;"/>
                            }
                            <span>PR 확인</span>
                        </button>
                    </MudTooltip>
                }
            }
            </div>@* mp-action-area *@
        }
    }
</div>

@code {
    private List<BranchGroup> _branchGroups = [];
    private string? _targetBranch;
    private bool _branchMenuOpen;
    private string _branchSearchText = "";
    private bool _busy;
    private bool _prLoading;
    private bool _prMerging;
    private PullRequestMergeStrategy _selectedMergeStrategy = PullRequestMergeStrategy.Squash;
    private (int Additions, int Deletions)? _diffStats;
    private AppSettings? _appSettings;
    private int _upstreamAhead; // origin 대비 미푸시 커밋 수

    private IDisposable? _sessionChangedSub;
    private IDisposable? _streamingStoppedSub;
    private IDisposable? _branchChangedSub;
    private IDisposable? _conflictSub;

    // PR 대상은 리모트 브랜치만 의미가 있으므로 "로컬" 그룹 제외
    private IEnumerable<BranchGroup> FilteredBranchGroups =>
        _branchGroups
            .Where(g => !g.Name.Equals("로컬", StringComparison.OrdinalIgnoreCase))
            .Select(g => string.IsNullOrWhiteSpace(_branchSearchText)
                ? g
                : new BranchGroup(g.Name,
                    g.Branches.Where(b => b.Contains(_branchSearchText, StringComparison.OrdinalIgnoreCase)).ToList()))
            .Where(g => g.Branches.Count > 0)
            .ToList();

    protected override async Task OnInitializedAsync()
    {
        ChatState.OnChange += HandleStateChanged;

        _sessionChangedSub = EventBus.Subscribe<SessionChangedEvent>(_ =>
            InvokeAsync(async () => await OnSessionChangedAsync()));

        _streamingStoppedSub = EventBus.Subscribe<StreamingStoppedEvent>(_ =>
            InvokeAsync(async () =>
            {
                await ReloadBranchesAsync(forceCacheInvalidate: false);
                var sess = ChatState.CurrentSession;
                if (sess != null)
                {
                    if (!string.IsNullOrEmpty(_targetBranch))
                        await MergeStatusService.RefreshAsync(
                            sess.Id,
                            BranchRefNormalizer.Normalize(_targetBranch));
                    await RefreshUpstreamAheadAsync(sess);
                }
            }));

        _branchChangedSub = EventBus.Subscribe<BranchChangedEvent>(_ =>
            InvokeAsync(StateHasChanged));

        MergeStatusService.StatusChanged += HandleMergeStatusChanged;

        _conflictSub = EventBus.Subscribe<ConflictDetectedEvent>(_ =>
            InvokeAsync(StateHasChanged));

        _appSettings = await SettingsService.LoadAsync();
        _selectedMergeStrategy = Enum.TryParse<PullRequestMergeStrategy>(_appSettings.DefaultMergeStrategy, out var parsed)
            ? parsed
            : PullRequestMergeStrategy.Squash;

        await OnSessionChangedAsync();
    }

    private async Task OnSessionChangedAsync()
    {
        _targetBranch = null;
        _branchGroups = [];
        _branchMenuOpen = false;
        _branchSearchText = "";
        await ReloadBranchesAsync(forceCacheInvalidate: false);
        StateHasChanged();
    }

    private async Task ReloadBranchesAsync(bool forceCacheInvalidate)
    {
        var session = ChatState.CurrentSession;
        var workspace = ChatState.CurrentWorkspace;
        if (session == null || workspace == null || string.IsNullOrEmpty(workspace.RepoLocalPath))
            return;

        if (session.Git.IsLocalDir)
        {
            await MergeStatusService.RefreshAsync(session.Id);
            await LoadLocalDiffStatsAsync(session);
            await RefreshUpstreamAheadAsync(session);
            return;
        }

        if (forceCacheInvalidate)
            await GitService.InvalidateBranchCacheAsync(workspace.RepoLocalPath);

        try
        {
            var (groups, defaultBranch) = await SessionInitializer.LoadBranchesAsync(workspace.RepoLocalPath);
            _branchGroups = groups;

            var remoteGroups = groups
                .Where(g => !g.Name.Equals("로컬", StringComparison.OrdinalIgnoreCase))
                .ToList();
            var storedBase = session.Git.BaseBranch;
            var matched = BranchRefNormalizer.MatchInGroups(storedBase, remoteGroups)
                          ?? BranchRefNormalizer.MatchInGroups(defaultBranch, remoteGroups);
            _targetBranch = matched;

            if (!string.IsNullOrEmpty(_targetBranch))
            {
                var normalized = BranchRefNormalizer.Normalize(_targetBranch);
                MergeStatusService.SetTargetBranch(session.Id, normalized);
                await MergeStatusService.RefreshAsync(session.Id, normalized);
            }
            else
            {
                await MergeStatusService.RefreshAsync(session.Id);
            }

            await LoadLocalDiffStatsAsync(session);
            await RefreshUpstreamAheadAsync(session);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "브랜치 목록 로드 실패: workspace={Ws}", workspace.Id);
        }
    }

    private void HandleMergeStatusChanged(string sessionId)
    {
        var current = ChatState.CurrentSession;
        if (current == null || current.Id != sessionId)
            return;
        InvokeAsync(async () =>
        {
            await LoadLocalDiffStatsAsync(current);
            await RefreshUpstreamAheadAsync(current);
            StateHasChanged();
        });
    }

    private void HandleStateChanged() => InvokeAsync(StateHasChanged);

    private async Task HandleManualRefresh()
    {
        _busy = true;
        try
        {
            await ReloadBranchesAsync(forceCacheInvalidate: true);
            var session = ChatState.CurrentSession;
            if (session != null)
            {
                if (!string.IsNullOrEmpty(_targetBranch))
                    await MergeStatusService.RefreshAsync(
                        session.Id,
                        BranchRefNormalizer.Normalize(_targetBranch));
                await RefreshUpstreamAheadAsync(session);
            }
        }
        finally
        {
            _busy = false;
            StateHasChanged();
        }
    }

    private void ToggleBranchMenu()
    {
        _branchMenuOpen = !_branchMenuOpen;
        if (!_branchMenuOpen) _branchSearchText = "";
    }

    private void CloseBranchMenu()
    {
        _branchMenuOpen = false;
        _branchSearchText = "";
    }

    private async Task SelectTargetBranch(string branch)
    {
        _targetBranch = branch;
        _branchMenuOpen = false;
        _branchSearchText = "";

        var session = ChatState.CurrentSession;
        if (session != null)
        {
            MergeStatusService.SetTargetBranch(session.Id, BranchRefNormalizer.Normalize(branch));
            await MergeStatusService.RefreshAsync(session.Id, BranchRefNormalizer.Normalize(branch));
        }
    }

    // ─────────────────────────────────────────────
    //  탭 네비게이션
    // ─────────────────────────────────────────────

    private void HandleNavigateToChanges()
    {
        EventBus.Publish(new ChangesTabRequestedEvent());
    }

    // ─────────────────────────────────────────────
    //  액션 핸들러
    // ─────────────────────────────────────────────

    private async Task HandleSquashMerge()
    {
        var session = ChatState.CurrentSession;
        var workspace = ChatState.CurrentWorkspace;
        if (session == null || workspace == null || string.IsNullOrEmpty(_targetBranch))
            return;

        var normalizedTarget = BranchRefNormalizer.Normalize(_targetBranch);
        _busy = true;
        StateHasChanged();
        try
        {
            await MergeStatusService.RefreshAsync(session.Id, normalizedTarget);
            var status = MergeStatusService.GetCurrent(session.Id);

            if (status.Kind == MergeStatusKind.NetworkError)
            {
                Snackbar.Add("오프라인 상태입니다. 네트워크 확인 후 다시 시도하세요.", Severity.Warning);
                return;
            }

            if (status.UncommittedChangeCount > 0)
            {
                var ok = await ConfirmAsync(
                    "미커밋 변경 있음",
                    $"워크트리에 미커밋 변경이 {status.UncommittedChangeCount}개 있습니다. 먼저 커밋 또는 stash 를 권장합니다. 그래도 머지할까요?");
                if (!ok) return;
            }

            if (status.Kind == MergeStatusKind.ConflictExpected)
            {
                var files = status.ConflictingFiles?.Count ?? 0;
                var ok = await ConfirmAsync(
                    "충돌 예상",
                    $"{files}개 파일에서 타겟 브랜치와 충돌이 예상됩니다. 충돌이 발생하면 머지가 중단되고 세션 내 해결이 필요합니다. 계속할까요?");
                if (!ok) return;
            }

            if (status.Kind == MergeStatusKind.BehindTarget && (status.BehindCount ?? 0) > 0)
            {
                var ok = await ConfirmAsync(
                    "타겟이 앞섰습니다",
                    $"타겟 브랜치가 {status.BehindCount}커밋 앞서 있습니다. 구버전 기반으로 머지하면 일부 변경이 묻힐 수 있습니다. 계속할까요?");
                if (!ok) return;
            }

            var defaultMessage = $"Squash merge '{session.Git.BranchName}' into '{normalizedTarget}'";
            var commitMessage = await PromptTextAsync(
                "커밋 메시지",
                "스쿼시 머지 커밋 메시지를 입력하세요.",
                defaultMessage);
            if (string.IsNullOrWhiteSpace(commitMessage))
                return;

            Snackbar.Add("스쿼시 머지 진행 중...", Severity.Info);
            Logger.LogInformation("MergePanel 스쿼시 머지 시작: session={Id} source={Src} target={Tgt}",
                session.Id, session.Git.BranchName, normalizedTarget);

            var result = await GitService.SquashMergeViaTempCloneAsync(
                workspace.RepoLocalPath,
                session.Git.WorktreePath,
                session.Git.BranchName,
                normalizedTarget,
                commitMessage);

            if (result.Success)
            {
                Snackbar.Add(
                    $"스쿼시 머지 완료: 메인 레포의 {normalizedTarget} 브랜치에 반영되었습니다.",
                    Severity.Success);

                var settings = await SettingsService.LoadAsync();
                if (settings.AutoArchiveOnMergeSuccess)
                {
                    try
                    {
                        await SessionListFacade.RemoveSessionAsync(session);
                    }
                    catch (Exception ex)
                    {
                        Logger.LogWarning(ex, "자동 아카이브 실패: session={Id}", session.Id);
                    }
                }

                await MergeStatusService.RefreshAsync(session.Id, normalizedTarget);
            }
            else if (result.Conflict)
            {
                Snackbar.Add(
                    $"충돌 발생: {result.ConflictingFiles.Count}개 파일. 세션 채팅에 '머지 충돌을 해결해줘'라고 입력해 AI에게 도움을 요청하세요.",
                    Severity.Warning);
                Logger.LogWarning("스쿼시 머지 충돌: session={Id} files={Files}", session.Id,
                    string.Join(", ", result.ConflictingFiles));
            }
            else
            {
                Snackbar.Add($"머지 실패: {result.Error}", Severity.Error);
                Logger.LogError("스쿼시 머지 실패: session={Id} err={Err}", session.Id, result.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"머지 처리 중 예외: {ex.Message}", Severity.Error);
            Logger.LogError(ex, "HandleSquashMerge 예외");
        }
        finally
        {
            _busy = false;
            StateHasChanged();
        }
    }

    private Task HandlePush()
    {
        var session = ChatState.CurrentSession;
        if (session == null) return Task.CompletedTask;
        HandlePushViaAi(session);
        return Task.CompletedTask;
    }

    private Task OpenSavedPr()
    {
        var session = ChatState.CurrentSession;
        var url = session?.Git.TrackedPr?.Url ?? session?.Git.LastPrUrl;
        if (!string.IsNullOrEmpty(url))
            OpenUrlInBrowser(url);
        return Task.CompletedTask;
    }

    private void OpenUrlInBrowser(string url)
    {
        if (string.IsNullOrWhiteSpace(url)) return;
        if (!url.StartsWith("http://", StringComparison.OrdinalIgnoreCase) &&
            !url.StartsWith("https://", StringComparison.OrdinalIgnoreCase))
        {
            Logger.LogWarning("브라우저 오픈 거부 — http/https 가 아님: {Url}", url);
            return;
        }

        try
        {
            Process.Start(new ProcessStartInfo(url) { UseShellExecute = true });
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "브라우저 오픈 실패: {Url}", url);
            Snackbar.Add("브라우저를 열 수 없습니다. URL을 직접 복사해 사용하세요.", Severity.Warning);
        }
    }

    private async Task ClearSavedPr()
    {
        var session = ChatState.CurrentSession;
        if (session?.Git.TrackedPr == null) return;

        var ok = await ConfirmAsync("PR 링크 삭제", "추적 중인 PR 연결을 이 세션에서 해제하시겠어요?");
        if (!ok) return;
        session.Git.TrackedPr = null;
        await SessionService.SaveSessionAsync(session);
        StateHasChanged();
    }

    private async Task HandleCheckPr()
    {
        var session = ChatState.CurrentSession;
        if (session == null) return;

        _prLoading = true;
        StateHasChanged();
        try
        {
            var pr = await PullRequestService.GetPrForBranchAsync(session);
            if (pr != null)
            {
                await SessionService.SaveSessionAsync(session);
                Snackbar.Add($"PR #{pr.Number} 발견: {pr.Title}", Severity.Success);
            }
            else
            {
                Snackbar.Add("이 브랜치에 연결된 PR이 없습니다.", Severity.Info);
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "PR 확인 실패");
            if (ex.Message.Contains("gh CLI", StringComparison.OrdinalIgnoreCase))
                Snackbar.Add("gh CLI를 찾을 수 없습니다. GitHub CLI를 설치하세요.", Severity.Error);
            else
                Snackbar.Add($"PR 확인 실패: {ex.Message}", Severity.Error);
        }
        finally
        {
            _prLoading = false;
            StateHasChanged();
        }
    }

    private async Task HandleRefreshPr()
    {
        var session = ChatState.CurrentSession;
        if (session?.Git.TrackedPr == null) return;

        _prLoading = true;
        StateHasChanged();
        try
        {
            var pr = await PullRequestService.RefreshAsync(session);
            if (pr != null)
            {
                await SessionService.SaveSessionAsync(session);
                Snackbar.Add($"PR #{pr.Number}: {pr.MergeStateStatus}", Severity.Info);
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "PR 새로고침 실패");
            Snackbar.Add($"PR 새로고침 실패: {ex.Message}", Severity.Warning);
        }
        finally
        {
            _prLoading = false;
            StateHasChanged();
        }
    }

    private async Task HandleMergePr()
    {
        var session = ChatState.CurrentSession;
        if (session?.Git.TrackedPr is not { CanMerge: true }) return;

        var methodLabel = MergeMethodLabel(_selectedMergeStrategy);
        var ok = await ConfirmAsync(
            "PR 머지",
            $"PR #{session.Git.TrackedPr.Number}을 '{methodLabel}' 방식으로 머지합니다. 계속할까요?");
        if (!ok) return;

        _prMerging = true;
        StateHasChanged();
        try
        {
            var result = await PullRequestService.MergeAsync(session, _selectedMergeStrategy);
            if (result.Success)
            {
                await SessionService.SaveSessionAsync(session);
                Snackbar.Add($"PR #{session.Git.TrackedPr.Number} 머지 완료!", Severity.Success);

                var archive = await ConfirmAsync(
                    "PR 머지 완료",
                    "세션을 아카이브할까요?",
                    yesText: "아카이브",
                    noText: "나중에");
                if (archive)
                    await HandleArchiveAfterMerge();
            }
            else
            {
                Snackbar.Add($"PR 머지 실패: {result.ErrorMessage}", Severity.Error);
                await HandleRefreshPr();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"PR 머지 중 오류: {ex.Message}", Severity.Error);
            Logger.LogError(ex, "HandleMergePr 예외");
        }
        finally
        {
            _prMerging = false;
            StateHasChanged();
        }
    }

    private async Task HandleArchiveAfterMerge()
    {
        var session = ChatState.CurrentSession;
        if (session == null) return;

        try
        {
            await SessionListFacade.RemoveSessionAsync(session);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "세션 아카이브 실패: session={Id}", session.Id);
            Snackbar.Add($"아카이브 실패: {ex.Message}", Severity.Warning);
        }
    }

    private void HandleResolveConflict()
    {
        var session = ChatState.CurrentSession;
        if (session == null) return;
        var status = MergeStatusService.GetCurrent(session.Id);
        var conflictFiles = status.ConflictingFiles is { Count: > 0 }
            ? string.Join("\n- ", status.ConflictingFiles)
            : "(상태 재확인 필요)";

        var template = _appSettings?.MergePromptResolveConflict ?? SeoroConstants.DefaultMergePromptResolveConflict;
        var prompt = template.Replace("{conflictFiles}", conflictFiles);

        // 충돌 해결은 세션 현재 모델 사용 (ModelOverride 없음)
        var msg = BuildPromptMessage("첨부된 프롬프트를 읽고 머지 충돌을 해결해주세요.", prompt, "merge-resolve-conflict.txt");
        EventBus.Publish(new MergeRequestedEvent(msg));
        Snackbar.Add("AI에게 충돌 해결을 요청했습니다.", Severity.Info);
    }

    private void HandleCreatePrViaAi()
    {
        var session = ChatState.CurrentSession;
        if (session == null || string.IsNullOrEmpty(_targetBranch)) return;

        var branch = session.Git.BranchName ?? "";
        var target = BranchRefNormalizer.Normalize(_targetBranch);
        var status = MergeStatusService.GetCurrent(session.Id);

        var uncommittedNote = status.UncommittedChangeCount > 0
            ? $"\n- 미커밋 변경이 {status.UncommittedChangeCount}개 있습니다. 먼저 변경 내용을 요약한 메시지로 커밋하세요."
            : "";

        var template = _appSettings?.MergePromptCreatePr ?? SeoroConstants.DefaultMergePromptCreatePr;
        var prompt = template
            .Replace("{branch}", branch)
            .Replace("{target}", target)
            .Replace("{uncommittedNote}", uncommittedNote);

        var msg = BuildPromptMessage("첨부된 프롬프트를 읽고 PR을 생성해주세요.", prompt, "merge-create-pr.txt");
        msg.ModelOverride = "haiku";
        EventBus.Publish(new MergeRequestedEvent(msg));
        Snackbar.Add("AI에게 PR 생성을 요청했습니다.", Severity.Info);
    }

    private async Task LoadLocalDiffStatsAsync(Session session)
    {
        if (string.IsNullOrEmpty(session.Git.WorktreePath))
            return;
        try
        {
            var diff = await GitService.GetDiffSummaryAsync(session.Git.WorktreePath, session.Git.GetDiffBase());
            _diffStats = diff != null
                ? (diff.TotalAdditions, diff.TotalDeletions)
                : null;
        }
        catch
        {
            _diffStats = null;
        }
    }

    private async Task RefreshUpstreamAheadAsync(Session session)
    {
        if (string.IsNullOrEmpty(session.Git.WorktreePath)) return;
        try
        {
            var (ahead, _) = await GitService.GetAheadBehindAsync(session.Git.WorktreePath);
            _upstreamAhead = ahead;
        }
        catch { _upstreamAhead = 0; }
    }

    private void HandlePushViaAi(Session session)
    {
        var branch = session.Git.BranchName ?? "";

        var template = _appSettings?.MergePromptPush ?? SeoroConstants.DefaultMergePromptPush;
        var prompt = template.Replace("{branch}", branch);

        var msg = BuildPromptMessage("첨부된 프롬프트를 읽고 커밋 후 푸시해주세요.", prompt, "merge-push.txt");
        msg.ModelOverride = "haiku";
        EventBus.Publish(new MergeRequestedEvent(msg));
        Snackbar.Add("AI에게 커밋 및 푸시를 요청했습니다.", Severity.Info);
    }

    private static ChatInputMessage BuildPromptMessage(string chatText, string promptContent, string fileName)
    {
        var data = System.Text.Encoding.UTF8.GetBytes(promptContent);
        return new ChatInputMessage
        {
            Text = chatText,
            Attachments =
            [
                new PendingAttachment
                {
                    FileName = fileName,
                    ContentType = "text/plain",
                    Data = data
                }
            ]
        };
    }

