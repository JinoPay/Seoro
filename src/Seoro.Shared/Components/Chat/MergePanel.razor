    private static string BuildStatusLabel(MergeStatus status) => status.Kind switch
    {
        MergeStatusKind.Unknown => "상태 확인 중...",
        MergeStatusKind.Clean when (status.AheadCount ?? 0) == 0 => "변경사항 없음",
        MergeStatusKind.Clean => "머지 가능",
        MergeStatusKind.BehindTarget => "타겟 브랜치가 앞서 있음",
        MergeStatusKind.ConflictExpected => "충돌 예상",
        MergeStatusKind.UncommittedDirty => "미커밋 변경 있음",
        MergeStatusKind.InConflict => "머지 충돌 진행 중",
        MergeStatusKind.NetworkError => "네트워크 오류",
        _ => ""
    };

    private static string BuildStatusTooltip(MergeStatus status) => status.Kind switch
    {
        MergeStatusKind.Unknown => "머지 상태 계산 대기 중",
        MergeStatusKind.Clean when (status.AheadCount ?? 0) == 0 =>
            "타겟 브랜치와 동일 — 머지할 변경사항이 없습니다",
        MergeStatusKind.Clean =>
            $"머지 가능 (ahead {status.AheadCount ?? 0}, behind {status.BehindCount ?? 0})",
        MergeStatusKind.BehindTarget =>
            $"타겟이 {status.BehindCount ?? 0}커밋 앞섰습니다 — stale 경고",
        MergeStatusKind.ConflictExpected =>
            $"머지 시 {status.ConflictingFiles?.Count ?? 0}개 파일 충돌이 예상됩니다",
        MergeStatusKind.UncommittedDirty =>
            $"미커밋 변경 {status.UncommittedChangeCount}개 — PR 생성 요청 시 AI가 자동 커밋",
        MergeStatusKind.InConflict =>
            "현재 머지 진행 중 — 충돌 해결 버튼을 사용하세요",
        MergeStatusKind.NetworkError =>
            $"오프라인 또는 fetch 실패 — 마지막 확인 {status.LastCheckedAt:HH:mm:ss}",
        _ => ""
    };

    private static string BuildLocalDirPushTooltip(MergeStatus status, (int Additions, int Deletions)? diffStats)
    {
        var parts = new List<string>();
        if (diffStats is { } s && (s.Additions > 0 || s.Deletions > 0))
            parts.Add($"+{s.Additions} -{s.Deletions}");
        else if (status.UncommittedChangeCount > 0)
            parts.Add($"변경 {status.UncommittedChangeCount}개");
        if ((status.AheadCount ?? 0) > 0)
            parts.Add($"커밋 {status.AheadCount}개 미푸시");
        var info = parts.Count > 0 ? string.Join(" · ", parts) + " — " : "";
        return $"{info}AI가 커밋하고 origin에 푸시합니다";
    }

    private static string BuildPrTooltip(bool noTarget, string? target)
    {
        if (noTarget) return "먼저 타겟 브랜치를 선택하세요";
        return $"AI에게 위임 — {target}를 base로 PR 생성";
    }

