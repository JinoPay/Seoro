    private async Task<bool> ConfirmAsync(string title, string message,
        string yesText = "계속", string noText = "취소")
    {
        var result = await DialogService.ShowMessageBoxAsync(title, message, yesText: yesText, cancelText: noText);
        return result == true;
    }

    private async Task<string?> PromptTextAsync(string title, string message, string defaultValue)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            title,
            $"{message}\n\n기본값: {defaultValue}",
            yesText: "기본값 사용",
            cancelText: "취소");
        return confirmed == true ? defaultValue : null;
    }

    public void Dispose()
    {
        ChatState.OnChange -= HandleStateChanged;
        MergeStatusService.StatusChanged -= HandleMergeStatusChanged;
        _sessionChangedSub?.Dispose();
        _streamingStoppedSub?.Dispose();
        _branchChangedSub?.Dispose();
        _conflictSub?.Dispose();
    }
