@using System.Text
@inject LightboxService Lightbox
@inject IChatState ChatState

@if (Attachments.Count > 0)
{
    <div class="attachment-chips">
        @foreach (var attachment in Attachments)
        {
            <Chip ButtonStyle="ButtonStyle.Outlined"
                  Icon="@GetIcon(attachment)"
                  OnClose="@(() => OnRemove.InvokeAsync(attachment))"
                  OnClick="@(() => PreviewAttachment(attachment))"
                  Style="font-size: 0.75rem; cursor: pointer;">
                @if (attachment is { IsImage: true, PreviewDataUrl: not null })
                {
                    <img src="@attachment.PreviewDataUrl" alt="@attachment.FileName"
                         @onclick="@(() => Lightbox.Open(attachment.PreviewDataUrl!, attachment.FileName))"
                         @onclick:stopPropagation="true"
                         style="max-height: 48px; max-width: 80px; border-radius: 4px; margin-right: 4px; vertical-align: middle; cursor: pointer;"/>
                }
                @TruncateFileName(attachment.FileName)
            </Chip>
        }
    </div>
}

@code {
    [Parameter] public IReadOnlyList<PendingAttachment> Attachments { get; set; } = [];
    [Parameter] public EventCallback<PendingAttachment> OnRemove { get; set; }

    private static string GetIcon(PendingAttachment attachment)
    {
        if (attachment.IsImage) return Lucide.Image;
        var ext = Path.GetExtension(attachment.FileName).ToLowerInvariant();
        return ext switch
        {
            ".md" or ".mdx" => Lucide.FileText,
            ".json" or ".yaml" or ".yml" or ".xml" or ".toml" or ".ini" or ".cfg"
                => Lucide.Braces,
            ".cs" or ".js" or ".ts" or ".py" or ".rs" or ".go" or ".java" or ".html"
                or ".css" or ".sql" or ".sh" or ".bash" or ".ps1"
                => Lucide.Code,
            _ => Lucide.File
        };
    }

    private void PreviewAttachment(PendingAttachment attachment)
    {
        if (attachment.IsImage)
        {
            if (attachment.PreviewDataUrl != null)
                Lightbox.Open(attachment.PreviewDataUrl, attachment.FileName);
            return;
        }

        if (attachment.Data.Length == 0) return;

        try
        {
            var content = Encoding.UTF8.GetString(attachment.Data);
            ChatState.Tabs.OpenFileContentTab(attachment.FileName, content);
        }
        catch
        {
            // 바이너리 파일 — 텍스트로 미리보기할 수 없음
        }
    }

    private static string TruncateFileName(string name)
    {
        return name.Length > 20 ? string.Concat(name.AsSpan(0, 17), "...") : name;
    }

}
