<div class="input-toolbar">
    <div class="input-toolbar-left">
        <Tooltip Text="@GetPermissionModeTooltip()" Placement="UiPlacement.Top">
            <IconButton Icon="@GetPermissionModeIcon()"
                        Tone="@GetPermissionModeTone()"
                        OnClick="CyclePermissionMode"
                        Disabled="@(Disabled || IsStreaming)"/>
        </Tooltip>

        @if (_capabilities?.SupportsEffortLevel != false)
        {
            <Tooltip Text="@GetEffortLevelTooltip()" Placement="UiPlacement.Top">
                <IconButton Icon="@Lucide.Brain"
                            Active="@(EffortLevel is "max" or "xhigh" or "high")"
                            OnClick="CycleEffortLevel"
                            Disabled="@(Disabled || IsStreaming)"/>
            </Tooltip>
        }

        <Tooltip Text="@Strings.Chat_Toolbar_AttachFile" Placement="UiPlacement.Top">
            <IconButton Icon="@Lucide.Paperclip"
                        OnClick="@(() => OnPickFiles.InvokeAsync())"
                        Disabled="@(Disabled || IsStreaming)"/>
        </Tooltip>

        <ToolPicker DisabledMcpServers="DisabledMcpServers"
                    DisabledMcpServersChanged="OnDisabledMcpServersChanged"
                    Disabled="Disabled"
                    IsStreaming="IsStreaming"
                    ProjectPath="@CurrentSession?.Git?.WorktreePath"/>

        <div class="tool-picker-wrapper">
            <Popover @bind-Open="_addDirPopoverOpen" Placement="PopoverPlacement.BottomStart" Fixed="true"
                     PopoverClass="add-dir-popover">
                <AnchorContent>
                    <Tooltip Text="추가 디렉터리" Placement="UiPlacement.Top">
                        <div class="tool-picker-btn-wrapper">
                            <IconButton Icon="@Lucide.FolderPlus"
                                        Tone="@(AdditionalDirs is { Count: > 0 } ? Tone.Primary : Tone.Default)"
                                        OnClick="ToggleAddDirPopover"
                                        Disabled="@Disabled"/>
                            @if (AdditionalDirs is { Count: > 0 })
                            {
                                <div class="tool-picker-badge">@AdditionalDirs.Count</div>
                            }
                        </div>
                    </Tooltip>
                </AnchorContent>
                <ChildContent>
                    <div class="add-dir-popover-content">
                        <div class="typo-subtitle2 mb-2">추가 작업 디렉터리</div>
                        <AdditionalDirectoriesEditor Directories="AdditionalDirs"
                                                     DirectoriesChanged="OnAdditionalDirsChangedInternal"
                                                     Disabled="@(!IsAddDirEditable)"/>
                    </div>
                </ChildContent>
            </Popover>
        </div>

        @foreach (var dir in AdditionalDirs)
        {
            <Tooltip Text="@dir" Placement="UiPlacement.Top">
                <Chip ButtonStyle="ButtonStyle.Outlined" Tone="Tone.Primary"
                      OnClose="@(IsAddDirEditable ? EventCallback.Factory.Create<MouseEventArgs>(this, () => RemoveDirChip(dir)) : default)"
                      Style="font-size: 0.7rem; font-family: monospace; height: 22px; margin: 0;">
                    @GetDirDisplayName(dir)
                </Chip>
            </Tooltip>
        }

        @if (CurrentSession?.IsCodex == true)
        {
            <Tooltip Text="@(WebSearchEnabled ? Strings.Chat_Toolbar_WebSearchOn : Strings.Chat_Toolbar_WebSearchOff)" Placement="UiPlacement.Top">
                <IconButton Icon="@Lucide.Telescope"
                            Tone="@(WebSearchEnabled ? Tone.Info : Tone.Default)"
                            OnClick="ToggleWebSearch"
                            Disabled="@(Disabled || IsStreaming)"/>
            </Tooltip>
        }
    </div>

    <div class="input-toolbar-right">
        @if (!string.IsNullOrEmpty(PlanFilePath))
        {
            <Tooltip Text="@Strings.Chat_Toolbar_ViewPlan" Placement="UiPlacement.Top">
                <IconButton Icon="@Lucide.Map"
                            Tone="Tone.Warning"
                            OnClick="@(() => OnViewPlan.InvokeAsync())"/>
            </Tooltip>
        }

        <TokenUsageRing CurrentSession="CurrentSession" Model="Model"/>

        <ModelSelector Model="Model"
                       OnModelChanged="OnModelChanged"
                       OnMenuClosed="@(() => OnModelMenuClosed.InvokeAsync())"
                       Disabled="Disabled" IsStreaming="IsStreaming"/>

        @if (IsStreaming)
        {
            <Button ButtonStyle="ButtonStyle.Filled"
                    Tone="Tone.Error"
                    StartIcon="@Lucide.Square"
                    OnClick="@(() => OnCancel.InvokeAsync())"
                    Class="stop-button-glow"
                    Style="border-radius: 20px; min-width: 72px;">
                @Strings.Chat_Toolbar_Stop
            </Button>

            @if (HasInput || HasAttachments || QueueCount > 0)
            {
                <Tooltip Text="@Strings.Chat_Toolbar_QueueMessage" Placement="UiPlacement.Top">
                    <IconButton Icon="@Lucide.Clock"
                                OnClick="@(() => OnSend.InvokeAsync())"
                                Disabled="@(Disabled || (!HasInput && !HasAttachments))"
                                Class="chat-send-btn"/>
                </Tooltip>
                <Menu Icon="@Lucide.ChevronDown" Placement="PopoverPlacement.TopEnd" Fixed="true">
                    @if (HasInput || HasAttachments)
                    {
                        <MenuItem Icon="@Lucide.Zap"
                                  Tone="Tone.Warning"
                                  OnClick="@(() => OnSendNow.InvokeAsync())">
                            <div>
                                <div style="font-size: 0.85rem; font-weight: 500;">@Strings.Chat_Toolbar_SendNow</div>
                                <div style="font-size: 0.7rem; opacity: 0.7;">@Strings.Chat_Toolbar_SendNow_Hint</div>
                            </div>
                        </MenuItem>
                    }
                    @if (QueueCount > 0)
                    {
                        @if (HasInput || HasAttachments)
                        {
                            <Divider/>
                        }
                        <MenuItem Icon="@Lucide.Trash2"
                                  Tone="Tone.Error"
                                  OnClick="@(() => OnClearQueue.InvokeAsync())">
                            @($"{Strings.Chat_Queue_ClearAll} ({QueueCount})")
                        </MenuItem>
                    }
                </Menu>
            }
        }
        else
        {
            <IconButton Icon="@Lucide.ArrowUp"
                        OnClick="@(() => OnSend.InvokeAsync())"
                        Disabled="@(Disabled || (!HasInput && !HasAttachments))"
                        Class="chat-send-btn"/>
        }
    </div>
</div>

@inject ICliProviderFactory CliProviderFactory

@code {
    [Parameter] public string PermissionMode { get; set; } = "bypassAll";
    [Parameter] public EventCallback<string> OnPermissionModeChanged { get; set; }
    [Parameter] public string EffortLevel { get; set; } = "auto";
    [Parameter] public EventCallback<string> OnEffortLevelChanged { get; set; }
    [Parameter] public string Model { get; set; } = string.Empty;
    [Parameter] public Session? CurrentSession { get; set; }
    [Parameter] public EventCallback<string> OnModelChanged { get; set; }
    [Parameter] public bool IsStreaming { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool HasInput { get; set; }
    [Parameter] public bool HasAttachments { get; set; }
    [Parameter] public EventCallback OnSend { get; set; }
    [Parameter] public EventCallback OnSendNow { get; set; }
    [Parameter] public EventCallback OnClearQueue { get; set; }
    [Parameter] public int QueueCount { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public EventCallback OnPickFiles { get; set; }
    [Parameter] public EventCallback OnModelMenuClosed { get; set; }
    [Parameter] public string? PlanFilePath { get; set; }
    [Parameter] public string? PlanContent { get; set; }
    [Parameter] public EventCallback OnViewPlan { get; set; }
    [Parameter] public bool WebSearchEnabled { get; set; }
    [Parameter] public EventCallback<bool> OnWebSearchChanged { get; set; }
    [Parameter] public HashSet<string> DisabledMcpServers { get; set; } = [];
    [Parameter] public EventCallback<HashSet<string>> OnDisabledMcpServersChanged { get; set; }
    [Parameter] public List<string> AdditionalDirs { get; set; } = [];
    [Parameter] public EventCallback<List<string>> OnAdditionalDirsChanged { get; set; }
    [Parameter] public bool IsAddDirEditable { get; set; } = true;

    private bool _addDirPopoverOpen;

    private void ToggleAddDirPopover() => _addDirPopoverOpen = !_addDirPopoverOpen;

    private async Task OnAdditionalDirsChangedInternal(List<string> dirs)
    {
        await OnAdditionalDirsChanged.InvokeAsync(dirs);
    }

    private async Task RemoveDirChip(string dir)
    {
        var updated = AdditionalDirs.Where(d => d != dir).ToList();
        await OnAdditionalDirsChanged.InvokeAsync(updated);
    }

    private static string GetDirDisplayName(string path)
    {
        var name = Path.GetFileName(path.TrimEnd(Path.DirectorySeparatorChar, Path.AltDirectorySeparatorChar));
        return string.IsNullOrEmpty(name) ? path : name;
    }

    private static readonly string[] PermissionModes = ["bypassAll", "plan"];

    private ProviderCapabilities? _capabilities =>
        CurrentSession != null
            ? CliProviderFactory.GetProviderForSession(CurrentSession).Capabilities
            : null;

    private string GetPermissionModeTooltip()
    {
        return PermissionMode switch
        {
            "plan" => Strings.Chat_PermissionMode_PlanTooltip,
            _ => Strings.Chat_PermissionMode_NormalTooltip
        };
    }

    private string GetPermissionModeIcon()
    {
        return PermissionMode switch
        {
            "plan" => Lucide.FileText,
            _ => Lucide.SquarePen
        };
    }

    private Tone GetPermissionModeTone()
    {
        return PermissionMode switch
        {
            "plan" => Tone.Warning,
            _ => Tone.Default
        };
    }

    private async Task CyclePermissionMode()
    {
        var idx = Array.IndexOf(PermissionModes, PermissionMode);
        var next = PermissionModes[(idx + 1) % PermissionModes.Length];
        await OnPermissionModeChanged.InvokeAsync(next);
    }

    private string GetEffortLevelTooltip()
    {
        var maxLevel = ModelDefinitions.GetMaxEffortLevel(Model);
        return EffortLevel switch
        {
            "max" => "Effort: Max (Thinking)",
            "xhigh" => "Effort: X-High",
            "high" => "Effort: High",
            _ => Strings.Chat_EffortLevel_AutoTooltip(maxLevel)
        };
    }

    private async Task CycleEffortLevel()
    {
        var maxLevel = ModelDefinitions.GetMaxEffortLevel(Model);
        var next = EffortLevel == "auto" ? maxLevel : "auto";
        await OnEffortLevelChanged.InvokeAsync(next);
    }

    private async Task ToggleWebSearch()
    {
        await OnWebSearchChanged.InvokeAsync(!WebSearchEnabled);
    }

}
