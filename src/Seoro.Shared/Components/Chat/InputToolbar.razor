<div class="input-toolbar">
    <div class="input-toolbar-left">
        <MudTooltip Text="@GetPermissionModeTooltip()" Placement="Placement.Top">
            <MudIconButton Icon="@GetPermissionModeIcon()"
                           Color="@GetPermissionModeColor()"
                           Size="Size.Small"
                           OnClick="CyclePermissionMode"
                           Disabled="Disabled || IsStreaming"/>
        </MudTooltip>

        @if (_capabilities?.SupportsEffortLevel != false)
        {
            <MudTooltip Text="@GetEffortLevelTooltip()" Placement="Placement.Top">
                <MudIconButton Icon="@Icons.Material.Filled.Psychology"
                               Color="@GetEffortLevelColor()"
                               Size="Size.Small"
                               OnClick="CycleEffortLevel"
                               Disabled="@(Disabled || IsStreaming)"/>
            </MudTooltip>
        }

        <MudTooltip Text="@Strings.Chat_Toolbar_AttachFile" Placement="Placement.Top">
            <MudIconButton Icon="@Icons.Material.Filled.AttachFile"
                           Color="Color.Default"
                           Size="Size.Small"
                           OnClick="@(() => OnPickFiles.InvokeAsync())"
                           Disabled="Disabled || IsStreaming"/>
        </MudTooltip>

        @if (CurrentSession?.IsCodex == true)
        {
            <MudTooltip Text="@(WebSearchEnabled ? Strings.Chat_Toolbar_WebSearchOn : Strings.Chat_Toolbar_WebSearchOff)" Placement="Placement.Top">
                <MudIconButton Icon="@Icons.Material.Filled.TravelExplore"
                               Color="@(WebSearchEnabled ? Color.Info : Color.Default)"
                               Size="Size.Small"
                               OnClick="ToggleWebSearch"
                               Disabled="Disabled || IsStreaming"/>
            </MudTooltip>
        }
    </div>

    <div class="input-toolbar-right">
        @if (!string.IsNullOrEmpty(PlanFilePath))
        {
            <MudTooltip Text="@Strings.Chat_Toolbar_ViewPlan" Placement="Placement.Top">
                <MudIconButton Icon="@Icons.Material.Filled.Map"
                               Color="Color.Warning"
                               Size="Size.Small"
                               OnClick="@(() => OnViewPlan.InvokeAsync())"/>
            </MudTooltip>
        }

        <TokenUsageRing CurrentSession="CurrentSession" Model="Model"/>

        <ModelSelector Model="Model"
                       OnModelChanged="OnModelChanged"
                       OnMenuClosed="@(() => OnModelMenuClosed.InvokeAsync())"
                       Disabled="Disabled" IsStreaming="IsStreaming"/>

        @if (IsStreaming)
        {
            <MudButton Variant="Variant.Filled"
                       Color="Color.Error"
                       Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Stop"
                       OnClick="@(() => OnCancel.InvokeAsync())"
                       Class="stop-button-glow"
                       Style="border-radius: 20px; text-transform: none; min-width: 72px;">
                @Strings.Chat_Toolbar_Stop
            </MudButton>
        }
        else
        {
            <MudIconButton Icon="@Icons.Material.Filled.ArrowUpward"
                           Color="Color.Primary"
                           Variant="Variant.Filled"
                           OnClick="@(() => OnSend.InvokeAsync())"
                           Disabled="@(Disabled || (!HasInput && !HasAttachments))"
                           Size="Size.Small"
                           Style="border-radius: 50%;"/>
        }
    </div>
</div>

@inject ICliProviderFactory CliProviderFactory

@code {
    [Parameter] public string PermissionMode { get; set; } = "bypassAll";
    [Parameter] public EventCallback<string> OnPermissionModeChanged { get; set; }
    [Parameter] public string EffortLevel { get; set; } = "auto";
    [Parameter] public EventCallback<string> OnEffortLevelChanged { get; set; }
    [Parameter] public string Model { get; set; } = string.Empty;
    [Parameter] public Session? CurrentSession { get; set; }
    [Parameter] public EventCallback<string> OnModelChanged { get; set; }
    [Parameter] public bool IsStreaming { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool HasInput { get; set; }
    [Parameter] public bool HasAttachments { get; set; }
    [Parameter] public EventCallback OnSend { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public EventCallback OnPickFiles { get; set; }
    [Parameter] public EventCallback OnModelMenuClosed { get; set; }
    [Parameter] public string? PlanFilePath { get; set; }
    [Parameter] public string? PlanContent { get; set; }
    [Parameter] public EventCallback OnViewPlan { get; set; }
    [Parameter] public bool WebSearchEnabled { get; set; }
    [Parameter] public EventCallback<bool> OnWebSearchChanged { get; set; }

    private static readonly string[] PermissionModes = ["bypassAll", "plan"];

    private ProviderCapabilities? _capabilities =>
        CurrentSession != null
            ? CliProviderFactory.GetProviderForSession(CurrentSession).Capabilities
            : null;

    private string GetPermissionModeTooltip()
    {
        return PermissionMode switch
        {
            "plan" => Strings.Chat_PermissionMode_PlanTooltip,
            _ => Strings.Chat_PermissionMode_NormalTooltip
        };
    }

    private string GetPermissionModeIcon()
    {
        return PermissionMode switch
        {
            "plan" => Icons.Material.Filled.Description,
            _ => Icons.Material.Filled.EditNote
        };
    }

    private Color GetPermissionModeColor()
    {
        return PermissionMode switch
        {
            "plan" => Color.Warning,
            _ => Color.Default
        };
    }

    private async Task CyclePermissionMode()
    {
        var idx = Array.IndexOf(PermissionModes, PermissionMode);
        var next = PermissionModes[(idx + 1) % PermissionModes.Length];
        await OnPermissionModeChanged.InvokeAsync(next);
    }

    private string GetEffortLevelTooltip()
    {
        var maxLevel = ModelDefinitions.GetMaxEffortLevel(Model);
        return EffortLevel switch
        {
            "max" => "Effort: Max (Thinking)",
            "high" => "Effort: High",
            _ => Strings.Chat_EffortLevel_AutoTooltip(maxLevel)
        };
    }

    private Color GetEffortLevelColor()
    {
        return EffortLevel switch
        {
            "max" or "high" => Color.Secondary,
            _ => Color.Default
        };
    }

    private async Task CycleEffortLevel()
    {
        var maxLevel = ModelDefinitions.GetMaxEffortLevel(Model);
        var next = EffortLevel == "auto" ? maxLevel : "auto";
        await OnEffortLevelChanged.InvokeAsync(next);
    }

    private async Task ToggleWebSearch()
    {
        await OnWebSearchChanged.InvokeAsync(!WebSearchEnabled);
    }

}
