@implements IDisposable

<div class="streaming-indicator @PhaseClass">
    @if (Phase == StreamingPhase.WritingText)
    {
        <span class="typing-wave">
            <span></span><span></span><span></span>
        </span>
    }
    else
    {
        <span class="indicator-dot"></span>
    }

    @if (Phase == StreamingPhase.UsingTool && !string.IsNullOrEmpty(ActiveToolName))
    {
        <MudIcon Icon="@ToolDisplayHelper.GetToolIcon(ActiveToolName)" Size="Size.Small"
                 Style="width: 15px; height: 15px; opacity: 0.8;"/>
        <span class="indicator-label">@ToolDisplayHelper.GetStreamingLabel(ActiveToolName)</span>
    }
    else if (Phase != StreamingPhase.WritingText)
    {
        <span class="indicator-label">@PhaseLabel</span>
    }

    @if (!string.IsNullOrEmpty(_elapsed))
    {
        <span class="indicator-time">@_elapsed</span>
    }
</div>

@code {
    [Parameter] public StreamingPhase Phase { get; set; }
    [Parameter] public string? ActiveToolName { get; set; }
    [Parameter] public DateTime? StartedAt { get; set; }

    private Timer? _timer;
    private string _elapsed = "";

    private string PhaseClass => Phase switch
    {
        StreamingPhase.Preparing => "preparing",
        StreamingPhase.Sending => "sending",
        StreamingPhase.Thinking => "thinking",
        StreamingPhase.UsingTool => "using-tool",
        StreamingPhase.WritingText => "writing",
        _ => ""
    };

    private string PhaseLabel => Phase switch
    {
        StreamingPhase.Preparing => Strings.Chat_Streaming_Preparing,
        StreamingPhase.Sending => Strings.Chat_Streaming_Sending,
        StreamingPhase.Thinking => Strings.Chat_Thinking,
        _ => ""
    };

    protected override void OnInitialized()
    {
        _timer = new Timer(_ =>
        {
            if (StartedAt.HasValue)
            {
                var elapsed = DateTime.UtcNow - StartedAt.Value;
                var newElapsed = Strings.FormatElapsedTime(elapsed);
                if (newElapsed != _elapsed)
                {
                    _elapsed = newElapsed;
                    InvokeAsync(StateHasChanged);
                }
            }
        }, null, 1000, 1000);
    }

    public void Dispose()
    {
        _timer?.Dispose();
        _timer = null;
    }

}
