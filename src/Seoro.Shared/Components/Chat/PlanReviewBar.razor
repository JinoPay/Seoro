@using Markdig
@using Seoro.Shared.Helpers
@using System.Runtime.InteropServices
@inject IJSRuntime JS
@if (IsVisible)
{
    <div class="plan-review-panel">
        @* 헤더 *@
        <div class="plan-review-header" @onclick="TogglePreview">
            <div class="plan-review-header-left">
                <div class="plan-review-icon-badge">
                    <MudIcon Icon="@Icons.Material.Filled.Map" Size="Size.Small" Style="width: 18px; height: 18px;"/>
                </div>
                <div class="plan-review-title-area">
                    <span class="plan-review-title">@Strings.Chat_Plan_ReviewTitle</span>
                    @if (!string.IsNullOrEmpty(PlanFilePath))
                    {
                        <span class="plan-review-filename">@Path.GetFileName(PlanFilePath)</span>
                    }
                </div>
            </div>
            <MudIcon Icon="@(_showPreview ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                     Size="Size.Small" Style="width: 18px; height: 18px; opacity: 0.5;"/>
        </div>

        @* 플랜 콘텐츠 마크다운 *@
        @if (_showPreview)
        {
            <div class="plan-review-content" id="plan-review-@_planId">
                @if (!string.IsNullOrEmpty(PlanContent))
                {
                    <div class="markdown-body">
                        @((MarkupString)Markdown.ToHtml(PlanContent, MarkdownHelper.TrustedPipeline))
                    </div>
                }
                else
                {
                    <div style="opacity: 0.5; font-size: var(--text-sm); padding: 8px 0;">
                        @Strings.Chat_Plan_LoadingContent
                    </div>
                }
            </div>
        }

        @* 작업 버튼 *@
        <div class="plan-review-actions">
            <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Success"
                       StartIcon="@Icons.Material.Filled.PlayArrow"
                       OnClick="@(() => OnAction.InvokeAsync(PlanReviewAction.Approve))"
                       Class="plan-review-btn plan-review-btn-approve">
                @Strings.Chat_Plan_Approve
                <kbd class="plan-review-kbd">@_approveShortcut</kbd>
            </MudButton>
            <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Error"
                       StartIcon="@Icons.Material.Filled.Close"
                       OnClick="@(() => OnAction.InvokeAsync(PlanReviewAction.Reject))"
                       Class="plan-review-btn plan-review-btn-reject">
                @Strings.Chat_Plan_Reject
            </MudButton>
        </div>

    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public string? PlanContent { get; set; }
    [Parameter] public string? PlanFilePath { get; set; }
    [Parameter] public EventCallback<PlanReviewAction> OnAction { get; set; }

    private bool _showPreview = true;
    private readonly string _planId = Guid.NewGuid().ToString("N")[..8];
    private static readonly string _approveShortcut = RuntimeInformation.IsOSPlatform(OSPlatform.OSX)
        ? "⌘+Enter" : "Ctrl+Enter";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_showPreview || string.IsNullOrEmpty(PlanContent)) return;
        try
        {
            await JS.InvokeVoidAsync("enhanceMarkdownCodeBlocks", $"plan-review-{_planId}", false);
        }
        catch { }
    }

    private void TogglePreview()
    {
        _showPreview = !_showPreview;
    }

}
