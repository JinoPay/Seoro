@inject IMessageQueueService MessageQueue

@if (Queue.Count > 0)
{
    <div class="attachment-chips queued-message-chips">
        @{
            var visible = Queue.Take(MaxVisible).ToList();
            var hidden = Queue.Skip(MaxVisible).ToList();
        }
        @foreach (var (msg, index) in visible.Select((m, i) => (m, i)))
        {
            <Tooltip Text="@msg.Input.Text" Placement="UiPlacement.Top">
                <Chip ButtonStyle="ButtonStyle.Outlined"
                      Tone="@(index == 0 ? Tone.Primary : Tone.Default)"
                      Icon="@Lucide.Clock"
                      OnClose="@(() => HandleRemove(msg))"
                      OnClick="@(() => HandleEdit(msg))"
                      Class="@(index == 0 ? "queued-chip-next" : null)"
                      Style="font-size: 0.75rem; cursor: pointer;">
                    @($"{index + 1}. {msg.PreviewText}")
                </Chip>
            </Tooltip>
        }
        @if (hidden.Count > 0)
        {
            <Popover @bind-Open="_popoverOpen" Placement="PopoverPlacement.TopStart" Fixed="true"
                     PopoverClass="queued-overflow-popover">
                <AnchorContent>
                    <Chip ButtonStyle="ButtonStyle.Outlined"
                          Icon="@Lucide.Ellipsis"
                          OnClick="@TogglePopover"
                          Style="font-size: 0.75rem; cursor: pointer;">
                        @Strings.Chat_Queue_OverflowMore(hidden.Count)
                    </Chip>
                </AnchorContent>
                <ChildContent>
                    <div class="queued-overflow-content">
                        @foreach (var (msg, idx) in Queue.Select((m, i) => (m, i)).Skip(MaxVisible))
                        {
                            <div class="queued-overflow-row">
                                <span class="queued-overflow-index">@($"{idx + 1}.")</span>
                                <span class="queued-overflow-text" @onclick="@(() => HandleEditFromPopover(msg))">
                                    @msg.PreviewText
                                </span>
                                <IconButton Icon="@Lucide.X"
                                            OnClick="@(() => HandleRemove(msg))"/>
                            </div>
                        }
                    </div>
                </ChildContent>
            </Popover>
        }
    </div>
}

@code {
    [Parameter] public IReadOnlyList<QueuedMessage> Queue { get; set; } = [];
    [Parameter] public EventCallback<QueuedMessage> OnRemove { get; set; }
    [Parameter] public EventCallback<QueuedMessage> OnEditInPlace { get; set; }

    private const int MaxVisible = 3;
    private bool _popoverOpen;

    private void TogglePopover() => _popoverOpen = !_popoverOpen;
    private void ClosePopover() => _popoverOpen = false;

    private Task HandleRemove(QueuedMessage msg) => OnRemove.InvokeAsync(msg);

    private Task HandleEdit(QueuedMessage msg) => OnEditInPlace.InvokeAsync(msg);

    private async Task HandleEditFromPopover(QueuedMessage msg)
    {
        _popoverOpen = false;
        await OnEditInPlace.InvokeAsync(msg);
    }
}
