@inject IClaudeSettingsService ClaudeSettingsService
@inject IChatState ChatState
@implements IDisposable

<Popover @bind-Open="_open" Placement="PopoverPlacement.TopStart" Fixed="true"
         PopoverClass="tool-picker-popover">
    <AnchorContent>
        <Tooltip Text="@GetTooltipText()" Placement="UiPlacement.Top">
            <div class="tool-picker-btn-wrapper">
                <IconButton Icon="@Lucide.Puzzle"
                            Tone="@(DisabledMcpServers.Count > 0 ? Tone.Warning : Tone.Default)"
                            OnClick="TogglePopover"
                            Disabled="@(Disabled || IsStreaming)"/>
                @if (DisabledMcpServers.Count > 0)
                {
                    <span class="tool-picker-badge">@DisabledMcpServers.Count</span>
                }
            </div>
        </Tooltip>
    </AnchorContent>
    <ChildContent>
        <div class="tool-picker-header">@Strings.Chat_ToolPicker_McpServers</div>

        @if (_loading)
        {
            <div class="tool-picker-loading">
                <Spinner Size="16"/>
            </div>
        }
        else if (_servers.Count == 0)
        {
            <div class="tool-picker-empty">MCP 서버가 없습니다</div>
        }
        else
        {
            @foreach (var server in _servers)
            {
                var isEnabled = !DisabledMcpServers.Contains(server.Name);
                <div class="tool-picker-row">
                    <Switch Value="isEnabled"
                            ValueChanged="@(v => ToggleServer(server.Name, v))"/>
                    <span class="tool-picker-server-name @(isEnabled ? "" : "tool-picker-disabled-text")">
                        @server.Name
                    </span>
                    <span class="tool-picker-scope-badge tool-picker-scope-@server.Scope">
                        @server.Scope
                    </span>
                </div>
            }
        }

        <Divider Class="my-1"/>
        <div class="tool-picker-manage" @onclick="NavigateToMcp">
            <Icon Svg="@Lucide.Settings" Size="14"/>
            <span>@Strings.Chat_ToolPicker_ManageMcp</span>
        </div>
    </ChildContent>
</Popover>

@code {
    [Parameter] public HashSet<string> DisabledMcpServers { get; set; } = [];
    [Parameter] public EventCallback<HashSet<string>> DisabledMcpServersChanged { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool IsStreaming { get; set; }
    [Parameter] public string? ProjectPath { get; set; }

    private bool _open;
    private bool _loading;
    private string? _loadedForProject;

    private record ServerEntry(string Name, string Scope);
    private List<ServerEntry> _servers = [];

    private string GetTooltipText()
    {
        if (DisabledMcpServers.Count == 0)
            return Strings.Chat_ToolPicker_AllEnabled;
        return Strings.Chat_ToolPicker_DisabledCount(DisabledMcpServers.Count);
    }

    private async Task TogglePopover()
    {
        _open = !_open;
        if (_open && (_servers.Count == 0 || _loadedForProject != ProjectPath))
            await LoadServersAsync();
    }

    private async Task LoadServersAsync()
    {
        _loading = true;
        StateHasChanged();

        _servers = [];
        _loadedForProject = ProjectPath;

        try
        {
            var global = await ClaudeSettingsService.ReadAsync(ClaudeSettingsScope.Global);
            if (global.McpServers != null)
                foreach (var key in global.McpServers.Keys)
                    _servers.Add(new ServerEntry(key, "global"));

            if (!string.IsNullOrEmpty(ProjectPath))
            {
                try
                {
                    var project = await ClaudeSettingsService.ReadAsync(ClaudeSettingsScope.Project, ProjectPath);
                    if (project.McpServers != null)
                        foreach (var key in project.McpServers.Keys)
                            _servers.Add(new ServerEntry(key, "project"));
                }
                catch { /* 파일 없으면 무시 */ }

                try
                {
                    var local = await ClaudeSettingsService.ReadAsync(ClaudeSettingsScope.Local, ProjectPath);
                    if (local.McpServers != null)
                        foreach (var key in local.McpServers.Keys)
                            _servers.Add(new ServerEntry(key, "local"));
                }
                catch { /* 파일 없으면 무시 */ }
            }
        }
        catch { /* 글로벌 설정 읽기 실패 무시 */ }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task ToggleServer(string serverName, bool enabled)
    {
        var updated = new HashSet<string>(DisabledMcpServers, StringComparer.OrdinalIgnoreCase);
        if (enabled)
            updated.Remove(serverName);
        else
            updated.Add(serverName);
        await DisabledMcpServersChanged.InvokeAsync(updated);
    }

    private void NavigateToMcp()
    {
        _open = false;
        ChatState.OpenSettings("mcp");
    }

    public void Dispose() { }
}
