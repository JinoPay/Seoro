@inject IChatState ChatState
@implements IDisposable

<Popover Open="_modelMenuOpen" OpenChanged="HandleMenuOpenChanged"
         Placement="PopoverPlacement.TopEnd" Fixed="true" PopoverClass="model-popover">
    <AnchorContent>
        <Tooltip Placement="UiPlacement.Top">
            <ChildContent>
                <button class="model-selector-pill @(_modelMenuOpen ? "is-open" : "")" type="button"
                        @onclick="ToggleModelMenu"
                        disabled="@(Disabled || IsStreaming)">
                    <span class="model-selector-dot"></span>
                    <span class="model-selector-label">@GetModelDisplayName()</span>
                    <Icon Svg="@Lucide.ChevronDown" Size="14" Class="model-selector-chevron"/>
                </button>
            </ChildContent>
            <TooltipContent>
                @{
                    var normalized = ModelDefinitions.NormalizeModelId(EffectiveModel);
                    var tooltipModel = ModelDefinitions.All.FirstOrDefault(m => m.Id == normalized);
                }
                <div>@GetModelDisplayName()</div>
                @if (!string.IsNullOrEmpty(tooltipModel?.Description))
                {
                    <div style="opacity: 0.7; font-size: 0.75rem;">@tooltipModel.Description</div>
                }
            </TooltipContent>
        </Tooltip>
    </AnchorContent>
    <ChildContent>
        <div class="model-list">
            @foreach (var group in ModelDefinitions.GetGroupedModels(CurrentProvider))
            {
                <div class="model-group-header">@GetCategoryLabel(group.Key)</div>
                @foreach (var model in group)
                {
                    <button type="button"
                            class="model-item @(IsModelActive(model.Id) ? "model-item-active" : "")"
                            @onclick="@(() => SelectModel(model.Id))">
                        <div class="model-item-content">
                            <div class="model-item-row">
                                <span class="model-item-name">
                                    @model.DisplayName
                                    @if (model.IsAlias)
                                    {
                                        <span class="model-item-alias-badge">alias</span>
                                    }
                                </span>
                                @if (model.Pricing != null)
                                {
                                    <span class="model-item-price">$@model.Pricing.Input/$@model.Pricing.Output</span>
                                }
                            </div>
                            @if (!string.IsNullOrEmpty(model.Description))
                            {
                                <div class="model-item-row">
                                    <span class="model-item-desc">@model.Description</span>
                                    <span class="speed-dots">
                                        @for (var i = 0; i < 3; i++)
                                        {
                                            <span class="speed-dot @(i < model.SpeedTier ? "speed-dot-filled" : "")"></span>
                                        }
                                    </span>
                                </div>
                            }
                        </div>
                    </button>
                }
            }
            <Divider/>
            <div class="model-item @(_isCustomModel ? "model-item-active" : "")"
                 @onclick="@(() => _customModelInput = true)">
                @if (_customModelInput)
                {
                    <TextField @bind-Value="_customModelId"
                               Placeholder="@(CurrentProvider == "codex" ? "o4-mini..." : "claude-sonnet-4-6...")"
                               Immediate="true" AutoFocus="true"
                               OnKeyDown="HandleCustomModelKeyDown"
                               Style="font-size: 0.8rem;"/>
                }
                else
                {
                    <span style="opacity: 0.7;">커스텀 모델...</span>
                }
            </div>
        </div>
    </ChildContent>
</Popover>

@code {
    [Parameter] public string Model { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> OnModelChanged { get; set; }
    [Parameter] public EventCallback OnMenuClosed { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool IsStreaming { get; set; }

    private bool _modelMenuOpen;
    private bool _customModelInput;

    private string _customModelId = "";

    // 낙관적 모델 — 부모가 확인하기 전에 사용자 선택 중에만 설정됩니다.
    // 부모가 일치하는 Model 파라미터를 전달하면 즉시 지워집니다.
    private string? _pendingModel;

    private string EffectiveModel => _pendingModel ?? ChatState.CurrentSession?.Model ?? Model;

    private string CurrentProvider => ChatState.CurrentSession?.Provider ?? "claude";

    private bool _isCustomModel => !string.IsNullOrEmpty(EffectiveModel)
                                   && ModelDefinitions.All.All(m => m.Id != EffectiveModel) && ModelDefinitions.NormalizeModelId(EffectiveModel) == EffectiveModel;

    protected override void OnInitialized()
    {
        ChatState.OnChange += SyncFromState;
    }

    protected override void OnParametersSet()
    {
        // 부모가 대기 중인 선택을 확인했거나 세션 전환을 통해 새 모델을 보냈습니다.
        _pendingModel = null;
    }

    private void SyncFromState()
    {
        InvokeAsync(() =>
        {
            var sessionModel = ChatState.CurrentSession?.Model ?? string.Empty;
            if (EffectiveModel != sessionModel)
            {
                // 파라미터 체인이 아직 새 모델을 전달하지 않았습니다. — 강제 리렌더합니다.
                // EffectiveModel은 Model 파라미터 또는 다음 OnParametersSet을 통해 해결됩니다.
                _pendingModel = null;
                StateHasChanged();
            }
        });
    }

    public void Dispose()
    {
        ChatState.OnChange -= SyncFromState;
    }

    private string GetModelDisplayName()
    {
        if (string.IsNullOrEmpty(EffectiveModel))
            return ModelDefinitions.Default.DisplayName;

        var model = ModelDefinitions.All.FirstOrDefault(m => m.Id == EffectiveModel);
        if (model != null) return model.DisplayName;

        // 비표준 ID에 대해 키워드 정규화 시도 (예: "claude-opus-4-6-...")
        var normalized = ModelDefinitions.NormalizeModelId(EffectiveModel);
        var normalizedModel = ModelDefinitions.All.FirstOrDefault(m => m.Id == normalized);
        if (normalizedModel != null) return normalizedModel.DisplayName;

        // API 모델 ID처럼 보이는 커스텀 모델 ID (예: "claude-...") — 그대로 표시
        if (EffectiveModel.StartsWith("claude-", StringComparison.OrdinalIgnoreCase))
            return EffectiveModel;

        // 알 수 없는 짧은 문자열 (예: "Model") — 기본 표시 이름으로 폴백
        return ModelDefinitions.Default.DisplayName;
    }

    private bool IsModelActive(string modelId)
    {
        if (EffectiveModel == modelId) return true;
        // 비표준 ID 처리 — 정규화 및 비교
        if (!string.IsNullOrEmpty(EffectiveModel) && ModelDefinitions.NormalizeModelId(EffectiveModel) == modelId)
            return true;
        return false;
    }

    private void ToggleModelMenu()
    {
        _modelMenuOpen = !_modelMenuOpen;
    }

    private async Task HandleMenuOpenChanged(bool open)
    {
        _modelMenuOpen = open;
        if (!open)
            await CloseModelMenu();
    }

    private async Task CloseModelMenu()
    {
        _modelMenuOpen = false;
        _customModelInput = false;
        await OnMenuClosed.InvokeAsync();
    }

    private async Task HandleCustomModelKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_customModelId))
        {
            await SelectModel(_customModelId.Trim());
            _customModelInput = false;
            _customModelId = "";
        }
        else if (e.Key == "Escape")
        {
            _customModelInput = false;
        }
    }

    private async Task SelectModel(string modelId)
    {
        _modelMenuOpen = false;
        _pendingModel = modelId;
        await OnModelChanged.InvokeAsync(modelId);
        await OnMenuClosed.InvokeAsync();
    }

    private static string GetCategoryLabel(string? category)
    {
        return category switch
        {
            "standard" => "Standard",
            "extended" => "Extended Context",
            "hybrid" => "Hybrid",
            "alias" => "Alias",
            _ => "Other"
        };
    }

}
