@if (IsLoading)
{
    <div class="branch-selector-loading">
        <Spinner Size="14"/>
        <span>브랜치 불러오는 중...</span>
    </div>
}
else if (BranchGroups.Count > 0)
{
    <div class="branch-selector-wrapper">
        <Popover Open="_branchMenuOpen" OpenChanged="HandleMenuOpenChanged"
                 Placement="PopoverPlacement.BottomStart" Fixed="true" PopoverClass="branch-popover">
            <AnchorContent>
                <button class="branch-selector-pill" type="button" @onclick="ToggleBranchMenu">
                    <Icon Svg="@Lucide.GitFork" Size="16" Style="opacity: 0.7;"/>
                    <span class="branch-selector-name">@SelectedBranch</span>
                    <Icon Svg="@Lucide.ChevronsUpDown" Size="16" Style="opacity: 0.4;"/>
                </button>
            </AnchorContent>
            <ChildContent>
                <div class="branch-search-container">
                    <TextField @bind-Value="_branchSearchText"
                               Placeholder="브랜치 검색..."
                               Immediate="true"
                               AdornmentIcon="@Lucide.Search"
                               Style="font-size: var(--text-sm);"/>
                </div>
                <div class="branch-list">
                    @foreach (var group in FilteredBranchGroups)
                    {
                        <div class="branch-group-header">@group.Name</div>
                        @foreach (var branch in group.Branches)
                        {
                            <button type="button"
                                    class="branch-item @(branch == SelectedBranch ? "branch-item-active" : "")"
                                    @onclick="@(() => SelectBranch(branch))">
                                <div class="branch-item-content">
                                    <Icon Svg="@Lucide.GitFork" Size="14" Style="opacity: 0.5;"/>
                                    <span class="branch-item-name">@branch</span>
                                    @if (branch == SelectedBranch)
                                    {
                                        <Icon Svg="@Lucide.Check" Size="14" Style="color: var(--accent);"/>
                                    }
                                </div>
                            </button>
                        }
                    }
                    @if (!FilteredBranchGroups.Any())
                    {
                        <div class="branch-no-results">일치하는 브랜치 없음</div>
                    }
                </div>
            </ChildContent>
        </Popover>
    </div>
}

@code {
    [Parameter][EditorRequired] public List<BranchGroup> BranchGroups { get; set; } = [];
    [Parameter][EditorRequired] public string SelectedBranch { get; set; } = "";
    [Parameter] public EventCallback<string> SelectedBranchChanged { get; set; }
    [Parameter] public bool IsLoading { get; set; }

    private bool _branchMenuOpen;
    private string _branchSearchText = "";

    private IEnumerable<BranchGroup> FilteredBranchGroups =>
        string.IsNullOrWhiteSpace(_branchSearchText)
            ? BranchGroups
            : BranchGroups
                .Select(g => new BranchGroup(g.Name,
                    g.Branches.Where(b => b.Contains(_branchSearchText, StringComparison.OrdinalIgnoreCase)).ToList()))
                .Where(g => g.Branches.Count > 0)
                .ToList();

    private void ToggleBranchMenu()
    {
        _branchMenuOpen = !_branchMenuOpen;
        if (!_branchMenuOpen) _branchSearchText = "";
    }

    private void HandleMenuOpenChanged(bool open)
    {
        _branchMenuOpen = open;
        if (!open) _branchSearchText = "";
    }

    private async Task SelectBranch(string branch)
    {
        _branchMenuOpen = false;
        _branchSearchText = "";
        await SelectedBranchChanged.InvokeAsync(branch);
    }

}
