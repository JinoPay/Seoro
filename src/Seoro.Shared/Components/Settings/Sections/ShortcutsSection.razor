@using System.Runtime.InteropServices

<div class="settings-shortcuts-table">
    @foreach (var (action, keys) in _shortcuts)
    {
        <div class="shortcut-row">
            <span class="shortcut-label">@action</span>
            <span class="shortcut-keys">@((MarkupString)keys)</span>
        </div>
    }
</div>

@code {
    private readonly string _mod = RuntimeInformation.IsOSPlatform(OSPlatform.OSX) ? "\u2318" : "Ctrl";
    private readonly string _planKey = RuntimeInformation.IsOSPlatform(OSPlatform.OSX) ? "P" : "O";

    private List<(string Action, string Keys)> _shortcuts => [
        (Strings.Settings_Shortcuts_Switch, $"<kbd>{_mod}+1</kbd> ~ <kbd>{_mod}+5</kbd>"),
        (Strings.Settings_Shortcuts_DeleteSession, $"<kbd>{_mod}+D</kbd>"),
        (Strings.Settings_Shortcuts_ExpandAll, $"<kbd>{_mod}+Shift+E</kbd>"),
        (Strings.Settings_Shortcuts_CollapseAll, $"<kbd>{_mod}+Shift+W</kbd>"),
        (Strings.Settings_Shortcuts_ToggleSidebar, $"<kbd>{_mod}+B</kbd>"),
        (Strings.Settings_Shortcuts_FocusInput, $"<kbd>{_mod}+Shift+L</kbd>"),
        (Strings.Settings_Shortcuts_ToggleTheme, $"<kbd>{_mod}+Shift+T</kbd>"),
        (Strings.Settings_Shortcuts_TogglePlanMode, $"<kbd>{_mod}+Shift+{_planKey}</kbd>"),
        (Strings.Settings_Shortcuts_ApprovePlan, $"<kbd>{_mod}+Enter</kbd>"),
        (Strings.Settings_Shortcuts_ToggleEffort, $"<kbd>{_mod}+Shift+M</kbd>"),
        (Strings.Settings_Shortcuts_ToggleSync, $"<kbd>{_mod}+Shift+S</kbd>"),
        (Strings.Settings_Shortcuts_SendMessage, "<kbd>Enter</kbd>"),
        (Strings.Settings_Shortcuts_Newline, "<kbd>Shift+Enter</kbd>"),
        (Strings.Settings_Shortcuts_CloseOverlay, "<kbd>Esc</kbd>"),
        (Strings.Settings_Shortcuts_TerminalCopy, $"<kbd>{_mod}+C</kbd>"),
        (Strings.Settings_Shortcuts_TerminalPaste, $"<kbd>{_mod}+V</kbd>"),
    ];
}
