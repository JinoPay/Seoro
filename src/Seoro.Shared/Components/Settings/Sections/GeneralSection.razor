@using System.Diagnostics
@inject IFolderPickerService FolderPickerService
@inject IJSRuntime JS
@inject IChatState ChatState
@inject CominomiMigrationService MigrationService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<div class="settings-section-title">@Strings.Settings_General_Title</div>
<div class="settings-section-desc">@Strings.Settings_General_Desc</div>

<div class="stack gap-3">
    <div>
        <div class="settings-field-label">@Strings.Settings_General_ThemeLabel</div>
        <div class="settings-segmented">
            <button class="settings-seg-item @(Settings.Theme == "dark" ? "active" : "")"
                    @onclick="@(() => Settings.Theme = "dark")">@Strings.Settings_General_ThemeDark</button>
            <button class="settings-seg-item @(Settings.Theme == "light" ? "active" : "")"
                    @onclick="@(() => Settings.Theme = "light")">@Strings.Settings_General_ThemeLight</button>
            <button class="settings-seg-item @(Settings.Theme == "system" ? "active" : "")"
                    @onclick="@(() => Settings.Theme = "system")">@Strings.Settings_General_ThemeSystem</button>
        </div>
    </div>

    <div class="settings-group-title mt">@Strings.Settings_General_UiScaleTitle</div>

    <div class="stack gap-1">
        <div class="stack-row items-center gap-2">
            <MudSlider T="double"
                       Value="@(Settings.UiScale == 0 ? _autoDefault : Settings.UiScale)"
                       ValueChanged="@(v =>
                                     {
                                         Settings.UiScale = v;
                                         _ = ApplyUiScalePreview(v);
                                     })"
                       Min="0.8" Max="1.5" Step="0.05"
                       Color="Color.Primary"
                       Style="flex: 1;"/>
            <span class="typo-body2" style="min-width: 48px; text-align: right;">
                @((Settings.UiScale == 0 ? _autoDefault : Settings.UiScale).ToString("P0"))
            </span>
        </div>

        <div class="stack-row gap-1 items-center">
            <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Default"
                       OnClick="@(() =>
                                {
                                    Settings.UiScale = 0;
                                    _ = ApplyUiScalePreview(_autoDefault);
                                })"
                       Style="text-transform: none;">
                @Strings.Settings_General_UiScaleAuto
            </MudButton>
            <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Default"
                       OnClick="@(() =>
                                {
                                    Settings.UiScale = 1.0;
                                    _ = ApplyUiScalePreview(1.0);
                                })"
                       Style="text-transform: none;">
                100%
            </MudButton>
        </div>

        <small class="typo-caption text-secondary">
            @Strings.Settings_General_UiScaleHint
        </small>
    </div>

    <div class="settings-group-title mt">@Strings.Settings_General_GitWorkflowTitle</div>

    <div class="stack-row items-center gap-1">
        <MudTextField @bind-Value="Settings.DefaultCloneDirectory"
                      Label="@Strings.Settings_General_CloneDirLabel"
                      Variant="Variant.Outlined" Margin="Margin.Dense"
                      Placeholder="@Strings.Settings_General_CloneDirPlaceholder"
                      HelperText="@Strings.Settings_General_CloneDirHint"
                      Style="flex: 1;"/>
        <MudIconButton Icon="@Icons.Material.Filled.FolderOpen" Color="Color.Primary"
                       OnClick="BrowseCloneDirectory" title="@Strings.Settings_General_BrowseDir"/>
    </div>

    <div>
        <div class="settings-field-label">@Strings.Settings_General_SessionLangLabel</div>
        <div class="settings-segmented">
            <button class="settings-seg-item @(Settings.SessionLanguage == "en" ? "active" : "")"
                    @onclick="@(() => Settings.SessionLanguage = "en")">English</button>
            <button class="settings-seg-item @(Settings.SessionLanguage == "ko" ? "active" : "")"
                    @onclick="@(() => Settings.SessionLanguage = "ko")">한국어</button>
        </div>
        <small class="typo-caption text-secondary">
            @Strings.Settings_General_SessionLangHint
        </small>
    </div>

    <div class="settings-group-title mt">@Strings.Settings_General_HelpTitle</div>

    <div class="stack-row gap-2" style="flex-wrap: wrap;">
        <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small"
                   OnClick="@(() => ChatState.RequestShowOnboarding())"
                   StartIcon="@Icons.Material.Filled.School"
                   Style="text-transform: none;">
            @Strings.Settings_General_ShowTutorial
        </MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small"
                   OnClick="@(() => ChatState.RequestShowWhatsNew())"
                   StartIcon="@Icons.Material.Filled.NewReleases"
                   Style="text-transform: none;">
            @Strings.Settings_General_ShowWhatsNew
        </MudButton>
    </div>

    @if (_cominomiSummary is { Exists: true, TotalFiles: > 0 })
    {
        <div class="settings-group-title mt">@Strings.Settings_General_MigrationTitle</div>
        <div class="typo-caption text-secondary" style="margin-bottom: 8px;">
            @Strings.Settings_General_MigrationDesc
        </div>

        <div class="stack gap-1">
            <div class="typo-body2">
                @Strings.Settings_General_MigrationFoundData(
                    _cominomiSummary.SessionCount,
                    _cominomiSummary.WorkspaceCount,
                    _cominomiSummary.MemoryCount,
                    _cominomiSummary.TaskCount,
                    _cominomiSummary.SettingsFileCount)
            </div>

            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                       OnClick="ImportCominomiData"
                       StartIcon="@Icons.Material.Filled.FileDownload"
                       Disabled="_importing"
                       Style="text-transform: none; align-self: flex-start;">
                @if (_importing)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" Style="width:16px;height:16px;"/>
                    <span>@Strings.Settings_General_MigrationImporting</span>
                }
                else
                {
                    <span>@Strings.Settings_General_MigrationImport</span>
                }
            </MudButton>
        </div>
    }
</div>

@code {
    [Parameter][EditorRequired] public AppSettings Settings { get; set; } = null!;

    private double _autoDefault = 1.0;
    private CominomiDataSummary? _cominomiSummary;
    private bool _importing;

    protected override async Task OnInitializedAsync()
    {
        _cominomiSummary = MigrationService.GetDataSummary();

        try
        {
            _autoDefault = await JS.InvokeAsync<double>("getDefaultUiScale");
        }
        catch
        {
        }
    }

    private async Task ApplyUiScalePreview(double scale)
    {
        try
        {
            await JS.InvokeVoidAsync("setUiScale", scale);
        }
        catch
        {
        }
    }

    private async Task BrowseCloneDirectory()
    {
        var path = await FolderPickerService.PickFolderAsync();
        if (!string.IsNullOrEmpty(path))
        {
            Settings.DefaultCloneDirectory = path;
        }
    }

    private async Task ImportCominomiData()
    {
        var result = await DialogService.ShowMessageBoxAsync(
            Strings.Settings_General_ImportDialogTitle,
            Strings.Settings_General_ImportDialogMsg(_cominomiSummary!.TotalFiles),
            Strings.Settings_General_ImportOverwrite,
            cancelText: Strings.Common_Cancel,
            noText: Strings.Settings_General_ImportKeep);

        if (result is null) return; // cancelled

        var overwrite = result == true;

        _importing = true;
        StateHasChanged();

        try
        {
            var migrationResult = await MigrationService.ImportAsync(overwrite);
            var deleted = MigrationService.DeleteCominomiFolder();

            if (migrationResult.Copied > 0)
            {
                await DialogService.ShowMessageBoxAsync(
                    Strings.Settings_General_ImportDoneTitle,
                    Strings.Settings_General_ImportDoneMsg(migrationResult.Copied),
                    Strings.Common_Confirm);

                var exePath = Environment.ProcessPath;
                if (!string.IsNullOrEmpty(exePath))
                    Process.Start(new ProcessStartInfo(exePath) { UseShellExecute = true });
                Environment.Exit(0);
                return;
            }

            var msg = Strings.Settings_General_ImportResult(migrationResult.Skipped);
            if (migrationResult.Failed > 0)
                msg += Strings.Settings_General_ImportFailedCount(migrationResult.Failed);
            if (!deleted)
                msg += Strings.Settings_General_ImportFolderDeleteFailed;

            Snackbar.Add(msg, migrationResult.Failed > 0 || !deleted ? Severity.Warning : Severity.Info);
            _cominomiSummary = MigrationService.GetDataSummary();
        }
        catch (Exception ex)
        {
            Snackbar.Add(Strings.Settings_General_ImportFailed(ex.Message), Severity.Error);
        }
        finally
        {
            _importing = false;
        }
    }

}
