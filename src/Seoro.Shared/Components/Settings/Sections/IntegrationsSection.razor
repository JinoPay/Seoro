@using System.Runtime.InteropServices
@inject IClaudeService ClaudeService
@inject IDependencyCheckService DependencyCheckService

<div class="settings-section-title">@Strings.Settings_Integrations_Title</div>
<div class="settings-section-desc">@Strings.Settings_Integrations_Desc</div>

<div class="settings-group">
    <div class="settings-group-title">Claude CLI</div>
    <div class="integration-status">
        @if (_claudeCliChecking)
        {
            <Spinner Size="16"/>
            <span class="status-text">@Strings.Settings_Integrations_Checking</span>
        }
        else if (_claudeCliFound)
        {
            <Icon Svg="@Lucide.CircleCheck" Size="14" Class="status-ok"/>
            <span class="status-text">@Strings.Settings_Integrations_Detected</span>
            @if (!string.IsNullOrEmpty(_claudeCliResolvedPath))
            {
                <span class="status-path">@_claudeCliResolvedPath</span>
            }
        }
        else
        {
            <Icon Svg="@Lucide.TriangleAlert" Size="14" Class="status-warn"/>
            <span class="status-text">@Strings.Settings_Integrations_NotDetected</span>
        }
        <IconButton Icon="@Lucide.RefreshCw" OnClick="CheckClaudeCli" Title="@Strings.Settings_Integrations_Recheck"/>
    </div>

    @if (_claudeCliFound && !string.IsNullOrEmpty(_claudeCliVersion))
    {
        <div class="stack gap-1 mt-2">
            <div class="stack-row items-center gap-2">
                <span class="typo-body2">@Strings.Settings_Integrations_Version</span>
                <Chip Tone="@(_claudeVersionOutdated ? Tone.Warning : Tone.Success)">
                    @_claudeCliVersion
                </Chip>
                @if (_claudeVersionOutdated)
                {
                    <Chip Tone="Tone.Warning" ButtonStyle="ButtonStyle.Outlined">
                        @Strings.Settings_Integrations_UpdateNeeded(SeoroConstants.RequiredClaudeVersion)
                    </Chip>
                }
            </div>

            @if (_claudeVersionOutdated)
            {
                <Alert Tone="Tone.Warning" Class="mt-2" Dense="true">
                    <div class="stack gap-1">
                        <span class="typo-body2">@Strings.Settings_Integrations_UpdateMethod</span>
                        @foreach (var method in _isMac ? ClaudeInstallMethods.Mac : ClaudeInstallMethods.Windows)
                        {
                            <div class="stack-row items-center gap-2">
                                <Chip ButtonStyle="ButtonStyle.Outlined"
                                      Style="min-width: 80px; justify-content: center;">
                                    @method.Label
                                </Chip>
                                <code style="flex: 1;">@method.UpdateCommand</code>
                            </div>
                        }
                    </div>
                </Alert>
            }
        </div>
    }

    <TextField @bind-Value="Settings.ClaudePath" Label="@Strings.Settings_Integrations_ClaudePathLabel"
               Placeholder="@Strings.Settings_Integrations_AutoDetect" Class="mt-3"
               HelperText="@Strings.Settings_Integrations_AutoDetectHint"/>
</div>

<div class="settings-group">
    <div class="settings-group-title">Git</div>
    <div class="integration-status">
        @if (_gitChecking)
        {
            <Spinner Size="16"/>
            <span class="status-text">@Strings.Settings_Integrations_Checking</span>
        }
        else if (_gitFound)
        {
            <Icon Svg="@Lucide.CircleCheck" Size="14" Class="status-ok"/>
            <span class="status-text">@Strings.Settings_Integrations_Detected</span>
            @if (!string.IsNullOrEmpty(_gitResolvedPath))
            {
                <span class="status-path">@_gitResolvedPath</span>
            }
        }
        else
        {
            <Icon Svg="@Lucide.TriangleAlert" Size="14" Class="status-warn"/>
            <span class="status-text">@Strings.Settings_Integrations_NotDetected</span>
        }
        <IconButton Icon="@Lucide.RefreshCw" OnClick="CheckGit" Title="@Strings.Settings_Integrations_Recheck"/>
    </div>

    @if (_gitFound && !string.IsNullOrEmpty(_gitVersion))
    {
        <div class="stack gap-1 mt-2">
            <div class="stack-row items-center gap-2">
                <span class="typo-body2">@Strings.Settings_Integrations_Version</span>
                <Chip Tone="Tone.Success">
                    @_gitVersion
                </Chip>
            </div>
        </div>
    }

    @if (!_gitChecking && !_gitFound)
    {
        <Alert Tone="Tone.Warning" Class="mt-2" Dense="true">
            <div class="stack gap-1">
                <span class="typo-body2">@Strings.Settings_Integrations_InstallMethod</span>
                @if (_isMac)
                {
                    <code>brew install git</code>
                }
                else
                {
                    <code>winget install Git.Git</code>
                }
            </div>
        </Alert>
    }

    <TextField @bind-Value="Settings.GitPath" Label="@Strings.Settings_Integrations_GitPathLabel"
               Placeholder="@Strings.Settings_Integrations_AutoDetect" Class="mt-3"
               HelperText="@Strings.Settings_Integrations_AutoDetectHint"/>
</div>

