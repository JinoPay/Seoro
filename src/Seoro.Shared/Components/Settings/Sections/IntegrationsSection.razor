            <span class="status-text">@Strings.Settings_Integrations_NotDetected</span>
        }
        <IconButton Icon="@Lucide.RefreshCw" OnClick="CheckGh" Title="@Strings.Settings_Integrations_Recheck"/>
    </div>

    @if (_ghFound && !string.IsNullOrEmpty(_ghVersion))
    {
        <div class="stack gap-1 mt-2">
            <div class="stack-row items-center gap-2">
