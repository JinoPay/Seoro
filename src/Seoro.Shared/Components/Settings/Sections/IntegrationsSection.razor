<div class="settings-group">
    <div class="settings-group-title">Codex CLI <span style="opacity: 0.5; font-size: 0.75rem;">@Strings.Settings_Integrations_CodexOptional</span></div>
    <div class="integration-status">
        @if (_codexChecking)
        {
            <Spinner Size="16"/>
            <span class="status-text">@Strings.Settings_Integrations_Checking</span>
        }
        else if (_codexFound)
        {
            <Icon Svg="@Lucide.CircleCheck" Size="14" Class="status-ok"/>
            <span class="status-text">@Strings.Settings_Integrations_Detected</span>
            @if (!string.IsNullOrEmpty(_codexResolvedPath))
            {
                <span class="status-path">@_codexResolvedPath</span>
            }
        }
        else
        {
            <Icon Svg="@Lucide.Info" Size="14" Style="color: var(--text-secondary);"/>
            <span class="status-text">@Strings.Settings_Integrations_NotInstalled</span>
        }
        <IconButton Icon="@Lucide.RefreshCw" OnClick="CheckCodex" Title="@Strings.Settings_Integrations_Recheck"/>
    </div>

    @if (_codexFound && !string.IsNullOrEmpty(_codexVersion))
    {
        <div class="stack gap-1 mt-2">
            <div class="stack-row items-center gap-2">
                <span class="typo-body2">@Strings.Settings_Integrations_Version</span>
                <Chip Tone="Tone.Success">
                    @_codexVersion
                </Chip>
            </div>
        </div>
    }

    @if (!_codexChecking && !_codexFound)
    {
        <Alert Tone="Tone.Info" Class="mt-2" Dense="true">
            <div class="stack gap-1">
                <span class="typo-body2">@Strings.Settings_Integrations_InstallMethod</span>
                <code>npm install -g @("@openai/codex")</code>
            </div>
        </Alert>
    }

    <TextField @bind-Value="Settings.CodexPath" Label="@Strings.Settings_Integrations_CodexPathLabel"
               Placeholder="@Strings.Settings_Integrations_AutoDetect" Class="mt-3"
               HelperText="@Strings.Settings_Integrations_AutoDetectHint"/>
</div>

@code {
    [Parameter][EditorRequired] public AppSettings Settings { get; set; } = null!;

    private bool _claudeCliChecking;
    private bool _claudeCliFound;
    private string? _claudeCliResolvedPath;
    private string? _claudeCliVersion;
    private bool _claudeVersionOutdated;
    private bool _gitChecking;
    private bool _gitFound;
    private string? _gitResolvedPath;
    private string? _gitVersion;
    private bool _ghChecking;
    private bool _ghFound;
    private string? _ghResolvedPath;
    private string? _ghVersion;
    private bool _codexChecking;
    private bool _codexFound;
    private string? _codexResolvedPath;
    private string? _codexVersion;
    private readonly bool _isMac = !RuntimeInformation.IsOSPlatform(OSPlatform.Windows);

    protected override async Task OnInitializedAsync()
    {
        await CheckIntegrations();
    }

    private async Task CheckIntegrations()
    {
        _gitChecking = true;
        _ghChecking = true;
        _codexChecking = true;
        StateHasChanged();

        var depsTask = DependencyCheckService.CheckAllAsync();
        var cliTask = CheckClaudeCli();

        var deps = await depsTask;
        ApplyDepResult(deps, "git", ref _gitFound, ref _gitResolvedPath, ref _gitVersion);
        _gitChecking = false;
        ApplyDepResult(deps, "gh", ref _ghFound, ref _ghResolvedPath, ref _ghVersion);
        _ghChecking = false;
        ApplyDepResult(deps, "codex", ref _codexFound, ref _codexResolvedPath, ref _codexVersion);
        _codexChecking = false;

        await cliTask;
        StateHasChanged();
    }

    private static void ApplyDepResult(List<DependencyResult> deps, string name,
        ref bool found, ref string? resolvedPath, ref string? version)
    {
        var dep = deps.FirstOrDefault(d => d.Name == name);
        if (dep != null)
        {
            found = dep.IsInstalled;
            resolvedPath = dep.ResolvedPath;
            version = dep.Version;
        }
    }

    private async Task CheckGit()
    {
        _gitChecking = true;
        StateHasChanged();

        var deps = await DependencyCheckService.CheckAllAsync();
        ApplyDepResult(deps, "git", ref _gitFound, ref _gitResolvedPath, ref _gitVersion);

        _gitChecking = false;
        StateHasChanged();
    }

    private async Task CheckGh()
    {
        _ghChecking = true;
        StateHasChanged();

        var deps = await DependencyCheckService.CheckAllAsync();
        ApplyDepResult(deps, "gh", ref _ghFound, ref _ghResolvedPath, ref _ghVersion);

        _ghChecking = false;
        StateHasChanged();
    }

    private async Task CheckCodex()
    {
        _codexChecking = true;
        StateHasChanged();

        var deps = await DependencyCheckService.CheckAllAsync();
        ApplyDepResult(deps, "codex", ref _codexFound, ref _codexResolvedPath, ref _codexVersion);

        _codexChecking = false;
        StateHasChanged();
    }

    private async Task CheckClaudeCli()
    {
        _claudeCliChecking = true;
        StateHasChanged();
        var (found, path) = await ClaudeService.DetectCliAsync();
        _claudeCliFound = found;
        _claudeCliResolvedPath = path;

        if (found)
        {
            _claudeCliVersion = await ClaudeService.GetDetectedVersionAsync();
            _claudeVersionOutdated = VersionComparer.IsOutdated(
                _claudeCliVersion, SeoroConstants.RequiredClaudeVersion);
        }
        else
        {
            _claudeCliVersion = null;
            _claudeVersionOutdated = false;
        }

        _claudeCliChecking = false;
        StateHasChanged();
    }

}
