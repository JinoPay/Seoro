@using System.Reflection
@inject IUpdateService UpdateService

<div class="settings-section-title">@Strings.Settings_Updates_Title</div>
<div class="settings-section-desc">@Strings.Settings_Updates_Desc</div>

<div class="stack gap-3">
    <div class="stack-row items-center gap-2">
        <span class="typo-body2">@Strings.Settings_Updates_CurrentVersion</span>
        <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Text">
            @(Assembly.GetEntryAssembly()?.GetName().Version?.ToString(3) ?? "개발 모드")
        </MudChip>
        @if (!UpdateService.IsInstalled)
        {
            <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">
                @Strings.Settings_Updates_DevBuild
            </MudChip>
        }
    </div>

    <div class="settings-toggle-row">
        <div>
            <span class="typo-body2">@Strings.Settings_Updates_AutoCheckLabel</span>
            <div class="typo-caption text-secondary">@Strings.Settings_Updates_AutoCheckHint</div>
        </div>
        <MudSwitch T="bool" @bind-Value="Settings.AutoUpdateEnabled"
                   Color="Color.Primary" UncheckedColor="Color.Default"/>
    </div>

    @if (Settings.AutoUpdateEnabled)
    {
        <div>
            <div class="settings-field-label">@Strings.Settings_Updates_IntervalLabel</div>
            <div class="settings-pill-group">
                @foreach (var interval in _intervalValues)
                {
                    <button class="settings-pill @(Settings.UpdateCheckIntervalMinutes == interval ? "active" : "")"
                            @onclick="@(() => Settings.UpdateCheckIntervalMinutes = interval)">
                        @GetIntervalLabel(interval)
                    </button>
                }
            </div>
        </div>
    }

    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
               OnClick="CheckForUpdates"
               StartIcon="@Icons.Material.Filled.Refresh"
               Disabled="@(_updateChecking || _updateDownloading)"
               Style="text-transform: none; align-self: flex-start;">
        @if (_updateChecking)
        {
            <MudProgressCircular Size="Size.Small" Indeterminate="true"
                                 Style="width: 16px; height: 16px; margin-right: 8px;"/>
            @Strings.Settings_Updates_Checking
        }
        else
        {
            @Strings.Settings_Updates_CheckButton
        }
    </MudButton>

    @if (_updateError != null)
    {
        <MudAlert Severity="Severity.Error" Dense="true">@_updateError</MudAlert>
    }
    else if (_updateReady)
    {
        <MudAlert Severity="Severity.Success" Dense="true">
            @Strings.Settings_Updates_Ready
        </MudAlert>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                   OnClick="@(() => UpdateService.ApplyUpdateAndRestart())"
                   StartIcon="@Icons.Material.Filled.RestartAlt"
                   Style="text-transform: none; align-self: flex-start;">
            @Strings.Settings_Updates_RestartButton
        </MudButton>
    }
    else if (_updateDownloading)
    {
        <MudAlert Severity="Severity.Info" Dense="true">
            <MudProgressCircular Size="Size.Small" Indeterminate="true"
                                 Style="width: 16px; height: 16px; margin-right: 8px;"/>
            @Strings.Settings_Updates_Downloading
        </MudAlert>
    }
    else if (_updateInfo != null)
    {
        <MudAlert Severity="Severity.Info" Dense="true">
            @Strings.Settings_Updates_Available(_updateInfo.TargetVersion.ToString())
            @if (_updateInfo.DownloadSize.HasValue)
            {
                @:(@FormatSize(_updateInfo.DownloadSize.Value))
            }
        </MudAlert>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                   OnClick="DownloadUpdate"
                   StartIcon="@Icons.Material.Filled.Download"
                   Style="text-transform: none; align-self: flex-start;">
            @Strings.Settings_Updates_DownloadButton
        </MudButton>
    }
    else if (!_updateChecking)
    {
        <small class="typo-caption text-secondary">
            @Strings.Settings_Updates_UpToDate
        </small>
    }

    @if (!UpdateService.IsInstalled)
    {
        <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-2">
            @Strings.Settings_Updates_DevBuildWarning
        </MudAlert>
    }
</div>

<div class="settings-group-title mt-lg">@Strings.Settings_Updates_ReleaseNotesTitle</div>
<ReleaseNotesPanel/>

@code {
    [Parameter][EditorRequired] public AppSettings Settings { get; set; } = null!;

    private static readonly int[] _intervalValues = [30, 60, 180, 360, 720, 1440];

    private static string GetIntervalLabel(int minutes) => minutes switch
    {
        30 => Strings.Settings_Updates_Interval_30,
        60 => Strings.Settings_Updates_Interval_60,
        180 => Strings.Settings_Updates_Interval_180,
        360 => Strings.Settings_Updates_Interval_360,
        720 => Strings.Settings_Updates_Interval_720,
        1440 => Strings.Settings_Updates_Interval_1440,
        _ => $"{minutes}m"
    };

    private bool _updateChecking;
    private UpdateInfo? _updateInfo;
    private bool _updateDownloading;
    private bool _updateReady;
    private string? _updateError;

    protected override async Task OnInitializedAsync()
    {
        await CheckForUpdates();
    }

    private async Task CheckForUpdates()
    {
        _updateChecking = true;
        _updateError = null;
        _updateInfo = null;
        _updateReady = false;
        StateHasChanged();

        try
        {
            _updateInfo = await UpdateService.CheckForUpdateAsync();
        }
        catch (Exception ex)
        {
            _updateError = Strings.Settings_Updates_CheckFailed(ex.Message);
        }
        finally
        {
            _updateChecking = false;
            StateHasChanged();
        }
    }

    private async Task DownloadUpdate()
    {
        _updateDownloading = true;
        _updateError = null;
        StateHasChanged();

        try
        {
            await UpdateService.DownloadUpdateAsync();
            _updateReady = true;
            _updateDownloading = false;
        }
        catch (Exception ex)
        {
            _updateError = Strings.Settings_Updates_DownloadFailed(ex.Message);
            _updateDownloading = false;
        }

        StateHasChanged();
    }

    private static string FormatSize(long bytes)
    {
        if (bytes >= 1024 * 1024)
            return $"{bytes / (1024.0 * 1024.0):F1} MB";
        if (bytes >= 1024)
            return $"{bytes / 1024.0:F1} KB";
        return $"{bytes} B";
    }

}
