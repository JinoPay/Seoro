<div class="settings-section-title">@Strings.Settings_Advanced_Title</div>
<div class="settings-section-desc">@Strings.Settings_Advanced_Desc</div>

<div class="stack gap-3">
    <div class="settings-toggle-row">
        <div>
            <span class="typo-body2">@Strings.Settings_Advanced_DebugModeLabel</span>
            <div class="typo-caption text-secondary">@Strings.Settings_Advanced_DebugModeHint</div>
        </div>
        <MudSwitch T="bool" @bind-Value="Settings.DebugMode"
                   Color="Color.Warning" UncheckedColor="Color.Default"/>
    </div>
</div>

<div class="settings-group-title mt">@Strings.Settings_Advanced_EnvVarsTitle</div>
<small class="typo-caption text-secondary" style="margin-top: -4px;">
    @Strings.Settings_Advanced_EnvVarsHint
</small>

<div class="stack gap-2">
    @foreach (var key in Settings.EnvironmentVariables.Keys.ToList())
    {
        <div class="stack-row gap-1 items-center">
            <MudTextField T="string" Value="@key" ReadOnly="true"
                          Variant="Variant.Outlined" Margin="Margin.Dense"
                          Style="flex: 0.4;"/>
            <MudTextField T="string" Value="@Settings.EnvironmentVariables[key]"
                          ValueChanged="@(v => Settings.EnvironmentVariables[key] = v)"
                          Variant="Variant.Outlined" Margin="Margin.Dense"
                          Style="flex: 0.6;"
                          InputType="@(key.Contains("KEY", StringComparison.OrdinalIgnoreCase) ? InputType.Password : InputType.Text)"/>
            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                           Color="Color.Error"
                           OnClick="@(() => RemoveEnvVar(key))"/>
        </div>
    }

    <div class="stack-row gap-1 items-center">
        <MudTextField @bind-Value="_newEnvKey" Placeholder="@Strings.Settings_Advanced_EnvKeyPlaceholder"
                      Variant="Variant.Outlined" Margin="Margin.Dense"
                      Style="flex: 0.4;"/>
        <MudTextField @bind-Value="_newEnvValue" Placeholder="@Strings.Settings_Advanced_EnvValuePlaceholder"
                      Variant="Variant.Outlined" Margin="Margin.Dense"
                      Style="flex: 0.6;"/>
        <MudIconButton Icon="@Icons.Material.Filled.Add" Size="Size.Small"
                       Color="Color.Primary"
                       OnClick="AddEnvVar"
                       Disabled="@(string.IsNullOrWhiteSpace(_newEnvKey))"/>
    </div>

    <small class="typo-caption text-secondary">
        예: ANTHROPIC_API_KEY, CLAUDE_CODE_USE_BEDROCK, CLAUDE_CODE_MAX_OUTPUT_TOKENS
    </small>
</div>

@code {
    [Parameter][EditorRequired] public AppSettings Settings { get; set; } = null!;

    private string _newEnvKey = "";
    private string _newEnvValue = "";

    private void AddEnvVar()
    {
        if (!string.IsNullOrWhiteSpace(_newEnvKey))
        {
            Settings.EnvironmentVariables[_newEnvKey.Trim()] = _newEnvValue;
            _newEnvKey = "";
            _newEnvValue = "";
        }
    }

    private void RemoveEnvVar(string key)
    {
        Settings.EnvironmentVariables.Remove(key);
    }

}
