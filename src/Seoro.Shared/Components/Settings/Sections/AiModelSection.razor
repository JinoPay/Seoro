@inject ICliAvailabilityService CliAvailability

<div class="settings-section-title">@Strings.Settings_Ai_Title</div>
<div class="settings-section-desc">@Strings.Settings_Ai_Desc</div>

<div class="stack gap-3">
    <div class="settings-section-title" style="font-size: 0.8rem; opacity: 0.6; margin-bottom: -8px;">Claude</div>

    <MudSelect T="string" @bind-Value="Settings.DefaultModel" Label="@Strings.Settings_Ai_DefaultModelLabel"
               Variant="Variant.Outlined" Margin="Margin.Dense"
               MaxHeight="400"
               HelperText="@Strings.Settings_Ai_DefaultModelHint">
        @foreach (var model in ModelDefinitions.All.Where(m => m.Provider != "codex"))
        {
            <MudSelectItem T="string" Value="@model.Id">
                <div class="model-select-option">
                    <div class="model-select-name">
                        <span>@model.DisplayName</span>
                        @if (model.Pricing != null)
                        {
                            <span class="model-select-price">$@model.Pricing.Input/$@model.Pricing.Output</span>
                        }
                        else if (model.IsAlias)
                        {
                            <span class="model-select-price" style="opacity: 0.5;">alias</span>
                        }
                    </div>
                    @if (!string.IsNullOrEmpty(model.Description))
                    {
                        <span class="model-select-desc" title="@model.Description">@model.Description</span>
                    }
                </div>
            </MudSelectItem>
        }
    </MudSelect>

    <div>
        <div class="settings-field-label">@Strings.Settings_Ai_EffortLevelLabel</div>
        <div class="settings-segmented">
            <button class="settings-seg-item @(Settings.DefaultEffortLevel == "auto" ? "active" : "")"
                    @onclick="@(() => Settings.DefaultEffortLevel = "auto")">Auto</button>
            <button class="settings-seg-item @(Settings.DefaultEffortLevel != "auto" ? "active" : "")"
                    @onclick="@(() => Settings.DefaultEffortLevel = ModelDefinitions.GetMaxEffortLevel(Settings.DefaultModel))">@Strings.Settings_Ai_EffortLevelMax</button>
        </div>
        <div class="settings-field-hint">@Strings.Settings_Ai_EffortLevelHint</div>
    </div>

    <div>
        <div class="settings-field-label">@Strings.Settings_Ai_PermissionModeLabel</div>
        <div class="settings-segmented">
            <button class="settings-seg-item @(Settings.DefaultPermissionMode == "bypassAll" ? "active" : "")"
                    @onclick="@(() => Settings.DefaultPermissionMode = "bypassAll")">@Strings.Settings_Ai_PermissionModeNormal</button>
            <button class="settings-seg-item @(Settings.DefaultPermissionMode == "plan" ? "active" : "")"
                    @onclick="@(() => Settings.DefaultPermissionMode = "plan")">@Strings.Settings_Ai_PermissionModePlan</button>
        </div>
        <div class="settings-field-hint">@Strings.Settings_Ai_PermissionModeHint</div>
    </div>

    <MudTextField @bind-Value="Settings.FallbackModel" Label="@Strings.Settings_Ai_FallbackModelLabel"
                  Variant="Variant.Outlined" Margin="Margin.Dense"
                  Placeholder="sonnet"
                  HelperText="@Strings.Settings_Ai_FallbackModelHint"/>

    <MudTextField @bind-Value="Settings.McpConfigPath" Label="@Strings.Settings_Ai_McpConfigPathLabel"
                  Variant="Variant.Outlined" Margin="Margin.Dense"
                  Placeholder="./mcp.json"
                  HelperText="@Strings.Settings_Ai_McpConfigPathHint"/>

    @if (_codexAvailable)
    {
        <div class="settings-section-title" style="font-size: 0.8rem; opacity: 0.6; margin-top: 8px; margin-bottom: -8px;">Codex</div>

        <MudSelect T="string" @bind-Value="Settings.DefaultCodexModel" Label="@Strings.Settings_Ai_CodexDefaultModelLabel"
                   Variant="Variant.Outlined" Margin="Margin.Dense"
                   MaxHeight="400"
                   HelperText="@Strings.Settings_Ai_CodexDefaultModelHint">
            @foreach (var model in ModelDefinitions.All.Where(m => m.Provider == "codex"))
            {
                <MudSelectItem T="string" Value="@model.Id">
                    <div class="model-select-option">
                        <div class="model-select-name">
                            <span>@model.DisplayName</span>
                            @if (model.Pricing != null)
                            {
                                <span class="model-select-price">$@model.Pricing.Input/$@model.Pricing.Output</span>
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(model.Description))
                        {
                            <span class="model-select-desc" title="@model.Description">@model.Description</span>
                        }
                    </div>
                </MudSelectItem>
            }
        </MudSelect>

        <div>
            <div class="settings-field-label">@Strings.Settings_Ai_ReasoningEffortLabel</div>
            <div class="settings-segmented">
                @foreach (var level in _codexReasoningLevelKeys)
                {
                    <button class="settings-seg-item @(Settings.CodexReasoningEffort == level ? "active" : "")"
                            @onclick="@(() => Settings.CodexReasoningEffort = level)">@GetReasoningLevelLabel(level)</button>
                }
            </div>
            <div class="settings-field-hint">@Strings.Settings_Ai_ReasoningEffortHint</div>
        </div>

        <div>
            <div class="settings-field-label">@Strings.Settings_Ai_SandboxModeLabel</div>
            <div class="settings-segmented">
                <button class="settings-seg-item @(Settings.CodexSandboxMode == "read-only" ? "active" : "")"
                        @onclick="@(() => Settings.CodexSandboxMode = "read-only")">@Strings.Settings_Ai_SandboxReadOnly</button>
                <button class="settings-seg-item @(Settings.CodexSandboxMode == "workspace-write" ? "active" : "")"
                        @onclick="@(() => Settings.CodexSandboxMode = "workspace-write")">@Strings.Settings_Ai_SandboxWorkspace</button>
                <button class="settings-seg-item @(Settings.CodexSandboxMode == "danger-full-access" ? "active" : "")"
                        @onclick="@(() => Settings.CodexSandboxMode = "danger-full-access")">@Strings.Settings_Ai_SandboxFullAccess</button>
            </div>
            <div class="settings-field-hint">@Strings.Settings_Ai_SandboxModeHint</div>
        </div>

        <div>
            <div class="settings-field-label">@Strings.Settings_Ai_ApprovalPolicyLabel</div>
            <div class="settings-segmented">
                <button class="settings-seg-item @(Settings.CodexApprovalPolicy == "untrusted" ? "active" : "")"
                        @onclick="@(() => Settings.CodexApprovalPolicy = "untrusted")">@Strings.Settings_Ai_ApprovalAlways</button>
                <button class="settings-seg-item @(Settings.CodexApprovalPolicy == "on-request" ? "active" : "")"
                        @onclick="@(() => Settings.CodexApprovalPolicy = "on-request")">@Strings.Settings_Ai_ApprovalOnRequest</button>
                <button class="settings-seg-item @(Settings.CodexApprovalPolicy == "never" ? "active" : "")"
                        @onclick="@(() => Settings.CodexApprovalPolicy = "never")">@Strings.Settings_Ai_ApprovalAuto</button>
            </div>
            <div class="settings-field-hint">@Strings.Settings_Ai_ApprovalPolicyHint</div>
        </div>

        <div>
            <MudSwitch @bind-Value="Settings.CodexWebSearch" Label="@Strings.Settings_Ai_WebSearchLabel" Color="Color.Primary"/>
            <div class="settings-field-hint" style="margin-top: -8px;">@Strings.Settings_Ai_WebSearchHint</div>
        </div>
    }
</div>

@code {
    [Parameter][EditorRequired] public AppSettings Settings { get; set; } = null!;

    private bool _codexAvailable;

    private static readonly string[] _codexReasoningLevelKeys = ["minimal", "low", "medium", "high", "xhigh"];

    private static string GetReasoningLevelLabel(string key) => key switch
    {
        "minimal" => Strings.Settings_Ai_ReasoningMinimal,
        "low" => Strings.Settings_Ai_ReasoningLow,
        "medium" => Strings.Settings_Ai_ReasoningMedium,
        "high" => Strings.Settings_Ai_ReasoningHigh,
        "xhigh" => Strings.Settings_Ai_ReasoningXHigh,
        _ => key
    };

    protected override async Task OnInitializedAsync()
    {
        _codexAvailable = await CliAvailability.IsAvailableAsync("codex");
    }
}
