@* Git / 머지 설정 섹션 *@

<div class="settings-section-title">@Strings.Settings_GitMerge_Title</div>
<div class="settings-section-desc">@Strings.Settings_GitMerge_Desc</div>

<div class="stack gap-3">

    @* ── 기본 머지 전략 ── *@
    <div>
        <div class="settings-field-label">@Strings.Settings_GitMerge_DefaultStrategyLabel</div>
        <div class="settings-segmented">
            <button class="settings-seg-item @(Settings.DefaultMergeStrategy == "Merge" ? "active" : "")"
                    @onclick="@(() => Settings.DefaultMergeStrategy = "Merge")">Merge</button>
            <button class="settings-seg-item @(Settings.DefaultMergeStrategy == "Squash" ? "active" : "")"
                    @onclick="@(() => Settings.DefaultMergeStrategy = "Squash")">Squash</button>
            <button class="settings-seg-item @(Settings.DefaultMergeStrategy == "Rebase" ? "active" : "")"
                    @onclick="@(() => Settings.DefaultMergeStrategy = "Rebase")">Rebase</button>
        </div>
        <div class="settings-field-hint">@Strings.Settings_GitMerge_DefaultStrategyHint</div>
    </div>

    @* ── 머지 성공 시 자동 아카이브 ── *@
    <div class="stack-row items-center gap-2" style="padding: 2px 0;">
        <Switch @bind-Value="Settings.AutoArchiveOnMergeSuccess" Style="margin: 0;"/>
        <div>
            <div class="settings-field-label" style="margin-bottom: 0;">@Strings.Settings_GitMerge_AutoArchiveLabel</div>
            <div class="settings-field-hint" style="margin-top: 2px;">@Strings.Settings_GitMerge_AutoArchiveHint</div>
        </div>
    </div>

    <div class="settings-group-title mt">@Strings.Settings_GitMerge_AiPromptsTitle</div>
    <div class="settings-section-desc" style="margin-top: -8px;">
        @Strings.Settings_GitMerge_AiPromptsDesc
    </div>

    @* ── PR 생성 프롬프트 ── *@
    <div>
        <div class="stack-row items-center gap-1" style="margin-bottom: 4px;">
            <div class="settings-field-label" style="flex: 1; margin-bottom: 0;">@Strings.Settings_GitMerge_CreatePrPromptLabel</div>
            <div class="settings-field-hint" style="margin: 0;">변수: <code>{branch}</code> <code>{target}</code> <code>{uncommittedNote}</code></div>
            @if (!string.IsNullOrEmpty(Settings.MergePromptCreatePr))
            {
                <Button ButtonStyle="ButtonStyle.Text"
                        OnClick="@(() => Settings.MergePromptCreatePr = null)"
                        Style="padding: 0 6px; min-width: 0; font-size: var(--text-xs);">
                    @Strings.Settings_GitMerge_ResetToDefault
                </Button>
            }
        </div>
        <TextField @bind-Value="Settings.MergePromptCreatePr" Lines="6"
                   Placeholder="@SeoroConstants.DefaultMergePromptCreatePr"
                   Style="font-size: var(--text-sm); font-family: var(--font-mono);"/>
    </div>

    @* ── 커밋·푸시 프롬프트 ── *@
    <div>
        <div class="stack-row items-center gap-1" style="margin-bottom: 4px;">
            <div class="settings-field-label" style="flex: 1; margin-bottom: 0;">@Strings.Settings_GitMerge_PushPromptLabel</div>
            <div class="settings-field-hint" style="margin: 0;">변수: <code>{branch}</code></div>
            @if (!string.IsNullOrEmpty(Settings.MergePromptPush))
            {
                <Button ButtonStyle="ButtonStyle.Text"
                        OnClick="@(() => Settings.MergePromptPush = null)"
                        Style="padding: 0 6px; min-width: 0; font-size: var(--text-xs);">
                    @Strings.Settings_GitMerge_ResetToDefault
                </Button>
            }
        </div>
        <TextField @bind-Value="Settings.MergePromptPush" Lines="6"
                   Placeholder="@SeoroConstants.DefaultMergePromptPush"
                   Style="font-size: var(--text-sm); font-family: var(--font-mono);"/>
    </div>

    @* ── 충돌 해결 프롬프트 ── *@
    <div>
        <div class="stack-row items-center gap-1" style="margin-bottom: 4px;">
            <div class="settings-field-label" style="flex: 1; margin-bottom: 0;">@Strings.Settings_GitMerge_ConflictPromptLabel</div>
            <div class="settings-field-hint" style="margin: 0;">변수: <code>{conflictFiles}</code></div>
            @if (!string.IsNullOrEmpty(Settings.MergePromptResolveConflict))
            {
                <Button ButtonStyle="ButtonStyle.Text"
                        OnClick="@(() => Settings.MergePromptResolveConflict = null)"
                        Style="padding: 0 6px; min-width: 0; font-size: var(--text-xs);">
                    @Strings.Settings_GitMerge_ResetToDefault
                </Button>
            }
        </div>
        <TextField @bind-Value="Settings.MergePromptResolveConflict" Lines="6"
                   Placeholder="@SeoroConstants.DefaultMergePromptResolveConflict"
                   Style="font-size: var(--text-sm); font-family: var(--font-mono);"/>
    </div>

    @* ── 충돌 예상 시 리베이스 프롬프트 ── *@
    <div>
        <div class="stack-row items-center gap-1" style="margin-bottom: 4px;">
            <div class="settings-field-label" style="flex: 1; margin-bottom: 0;">@Strings.Settings_GitMerge_RebasePromptLabel</div>
            <div class="settings-field-hint" style="margin: 0;">변수: <code>{branch}</code> <code>{target}</code></div>
            @if (!string.IsNullOrEmpty(Settings.MergePromptRebaseOnTarget))
            {
                <Button ButtonStyle="ButtonStyle.Text"
                        OnClick="@(() => Settings.MergePromptRebaseOnTarget = null)"
                        Style="padding: 0 6px; min-width: 0; font-size: var(--text-xs);">
                    @Strings.Settings_GitMerge_ResetToDefault
                </Button>
            }
        </div>
        <TextField @bind-Value="Settings.MergePromptRebaseOnTarget" Lines="6"
                   Placeholder="@SeoroConstants.DefaultMergePromptRebaseOnTarget"
                   Style="font-size: var(--text-sm); font-family: var(--font-mono);"/>
    </div>

</div>

@code {
    [Parameter][EditorRequired] public AppSettings Settings { get; set; } = null!;
}
