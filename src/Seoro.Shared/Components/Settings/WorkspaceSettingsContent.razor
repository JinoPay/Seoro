@inject IWorkspaceService WorkspaceService
@inject ISessionService SessionService
@inject IGitService GitService
@inject IChatState ChatState
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<div class="settings-content-area">
    @if (_workspace != null)
    {
        <div class="settings-content-header">
            <h6 class="typo-h6" style="font-size: var(--text-lg);">@_workspace.Name</h6>
            <div style="flex: 1;"></div>
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Save"
                       Size="Size.Small" Style="text-transform: none;">
                @Strings.Common_Save
            </MudButton>
        </div>

        <div class="ws-settings-tabs">
            <button class="ws-settings-tab @(_tab == "general" ? "active" : "")"
                    @onclick="@(() => _tab = "general")">@Strings.Settings_Workspace_TabGeneral
            </button>
            <button class="ws-settings-tab @(_tab == "git" ? "active" : "")"
                    @onclick="@(() => _tab = "git")">Git
            </button>
            <button class="ws-settings-tab @(_tab == "prompts" ? "active" : "")"
                    @onclick="@(() => _tab = "prompts")">@Strings.Settings_Workspace_TabPrompts
            </button>
        </div>

        <div class="settings-content-body">
            @if (_tab == "general")
            {
                <div class="settings-section-title">@Strings.Settings_Workspace_TabGeneral</div>
                <div class="settings-section-desc">@Strings.Settings_Workspace_GeneralDesc</div>

                <div class="stack gap-3">
                    <MudTextField @bind-Value="_workspace.Name" Label="@Strings.Settings_Workspace_NameLabel"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"/>

                    <MudSelect T="string" @bind-Value="_workspace.DefaultModel" Label="@Strings.Settings_Ai_DefaultModelLabel"
                               Variant="Variant.Outlined" Margin="Margin.Dense"
                               HelperText="@Strings.Settings_Workspace_DefaultModelHint"
                               Clearable="true">
                        <MudSelectItem T="string" Value="@("")">@Strings.Settings_Workspace_UseAppDefault</MudSelectItem>
                        @foreach (var model in ModelDefinitions.All.Where(m => m.Provider != "codex"))
                        {
                            <MudSelectItem T="string" Value="@model.Id">@model.DisplayName</MudSelectItem>
                        }
                    </MudSelect>

                    @if (!string.IsNullOrEmpty(_workspace.RepoLocalPath))
                    {
                        <MudTextField Value="@ShortenPath(_workspace.RepoLocalPath)" Label="@Strings.Settings_Workspace_RepoPathLabel"
                                      Variant="Variant.Outlined" Margin="Margin.Dense" ReadOnly="true"/>
                    }

                    @if (!string.IsNullOrEmpty(_workspace.RepoUrl))
                    {
                        <MudTextField Value="@_workspace.RepoUrl" Label="@Strings.Settings_Workspace_RepoUrlLabel"
                                      Variant="Variant.Outlined" Margin="Margin.Dense" ReadOnly="true"/>
                    }

                    <MudTextField @bind-Value="_workspace.SystemPrompt" Label="@Strings.Settings_Workspace_SystemPromptLabel"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" Lines="4"
                                  Placeholder="@Strings.Settings_Workspace_SystemPromptPlaceholder"
                                  HelperText="@Strings.Settings_Workspace_SystemPromptHint"/>
                </div>
            }
            else if (_tab == "git")
            {
                <div class="settings-section-title">Git</div>
                <div class="settings-section-desc">@Strings.Settings_Workspace_GitDesc</div>

                <div class="stack gap-3">
                    @if (_branches.Count > 0)
                    {
                        <MudSelect T="string" @bind-Value="_workspace.DefaultBaseBranch"
                                   Label="@Strings.Settings_Workspace_DefaultBranchLabel"
                                   Variant="Variant.Outlined" Margin="Margin.Dense"
                                   HelperText="@Strings.Settings_Workspace_DefaultBranchHint"
                                   Clearable="true">
                            @foreach (var branch in _branches)
                            {
                                <MudSelectItem T="string" Value="@branch">@branch</MudSelectItem>
                            }
                        </MudSelect>
                    }
                    else
                    {
                        <MudTextField @bind-Value="_workspace.DefaultBaseBranch"
                                      Label="@Strings.Settings_Workspace_DefaultBranchLabel"
                                      Variant="Variant.Outlined" Margin="Margin.Dense"
                                      Placeholder="origin/main"
                                      HelperText="@Strings.Settings_Workspace_DefaultBranchAutoHint"/>
                    }

                    <MudTextField @bind-Value="_workspace.DefaultRemote" Label="@Strings.Settings_Workspace_DefaultRemoteLabel"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Placeholder="origin"/>
                </div>
            }
            else if (_tab == "prompts")
            {
                <div class="settings-section-title">@Strings.Settings_Workspace_TabPrompts</div>
                <div class="settings-section-desc">@Strings.Settings_Workspace_PromptsDesc</div>

                <div class="stack gap-4">
                    <MudTextField @bind-Value="_workspace.Preferences.CodeReviewPrompt"
                                  Label="@Strings.Settings_Workspace_CodeReviewLabel"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" Lines="4"
                                  Placeholder="@Strings.Settings_Workspace_CodeReviewPlaceholder"/>

                    <MudTextField @bind-Value="_workspace.Preferences.GeneralPrompt"
                                  Label="@Strings.Settings_Workspace_GeneralPromptLabel"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" Lines="4"
                                  Placeholder="@Strings.Settings_Workspace_GeneralPromptPlaceholder"/>
                </div>
            }

            <div class="settings-danger-zone">
                <div class="settings-group-title" style="color: var(--mud-palette-error);">@Strings.Settings_Workspace_DangerZoneTitle</div>
                <MudButton Variant="Variant.Outlined" Color="Color.Error"
                           StartIcon="@Icons.Material.Filled.Delete"
                           OnClick="DeleteWorkspace"
                           Style="text-transform: none;">
                    @Strings.Settings_Workspace_DeleteButton
                </MudButton>
                <small class="typo-caption text-secondary" style="margin-top: 4px;">
                    @Strings.Settings_Workspace_DeleteWarning
                </small>
            </div>
        </div>
    }
    else
    {
        <div style="padding: var(--space-6); text-align: center;">
            <MudProgressCircular Indeterminate="true" Size="Size.Small"/>
        </div>
    }
</div>

@code {
    [Parameter] public string WorkspaceId { get; set; } = "";
    [Parameter] public EventCallback OnWorkspaceDeleted { get; set; }

    private Workspace? _workspace;
    private string _tab = "general";
    private List<string> _branches = [];
    private string _lastWorkspaceId = "";

    protected override async Task OnParametersSetAsync()
    {
        if (WorkspaceId != _lastWorkspaceId)
        {
            _lastWorkspaceId = WorkspaceId;
            _tab = "general";
            await LoadWorkspace();
        }
    }

    private async Task LoadWorkspace()
    {
        _workspace = await WorkspaceService.LoadWorkspaceAsync(WorkspaceId);
        if (_workspace != null && !string.IsNullOrEmpty(_workspace.RepoLocalPath))
        {
            _ = LoadBranches();
        }
    }

    private async Task LoadBranches()
    {
        try
        {
            var groups = await GitService.ListAllBranchesGroupedAsync(_workspace!.RepoLocalPath);
            _branches = groups
                .SelectMany(g => g.Branches)
                .OrderBy(b => b)
                .ToList();
            await InvokeAsync(StateHasChanged);
        }
        catch
        {
            _branches = [];
        }
    }

    private async Task Save()
    {
        if (_workspace == null) return;
        _workspace.UpdatedAt = DateTime.UtcNow;
        await WorkspaceService.SaveWorkspaceAsync(_workspace);

        if (ChatState.CurrentWorkspace?.Id == _workspace.Id)
            ChatState.SetWorkspace(_workspace);

        Snackbar.SettingsSaved();
    }

    private async Task DeleteWorkspace()
    {
        if (_workspace == null) return;

        var result = await DialogService.ShowMessageBoxAsync(
            Strings.Settings_Workspace_DeleteDialogTitle,
            Strings.Settings_Workspace_DeleteDialogMsg(_workspace.Name),
            Strings.Common_Delete, cancelText: Strings.Common_Cancel);

        if (result != true) return;

        try
        {
            var sessions = await SessionService.GetSessionsByWorkspaceAsync(_workspace.Id);
            foreach (var session in sessions)
            {
                await SessionService.DeleteSessionAsync(session.Id);
            }

            await WorkspaceService.DeleteWorkspaceAsync(_workspace.Id);

            if (ChatState.CurrentWorkspace?.Id == _workspace.Id)
            {
                ChatState.SetWorkspace(null!);
            }

            Snackbar.Add(Strings.Settings_Workspace_DeleteSuccess(_workspace.Name), Severity.Success);
            await OnWorkspaceDeleted.InvokeAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(Strings.Settings_Workspace_DeleteError(ex.Message), Severity.Error);
        }
    }

    private static string ShortenPath(string path)
    {
        var home = Environment.GetFolderPath(Environment.SpecialFolder.UserProfile);
        if (path.StartsWith(home))
            return "~" + path[home.Length..];
        return path;
    }

}
