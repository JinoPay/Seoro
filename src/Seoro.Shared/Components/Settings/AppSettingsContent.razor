@inject ISettingsService SettingsService
@inject ISnackbar Snackbar

<div class="settings-content-area">
    <div class="settings-content-header">
        <span class="typo-h6">@GetSectionTitle()</span>
        <div style="flex: 1;"></div>
        @if (Section != "shortcuts")
        {
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Save"
                       Size="Size.Small" Style="text-transform: none;">
                @Strings.Common_Save
            </MudButton>
        }
    </div>

    <div class="settings-content-body">
        @switch (Section)
        {
            case "general":
                <GeneralSection Settings="_settings"/>
                break;
            case "notifications":
                <NotificationsSection Settings="_settings" OnSave="Save"/>
                break;
            case "terminal":
                <TerminalSection Settings="_settings" OnSave="Save"/>
                break;
            case "shortcuts":
                <ShortcutsSection/>
                break;
            case "ai":
                <AiModelSection Settings="_settings"/>
                break;
            case "integrations":
                <IntegrationsSection Settings="_settings"/>
                break;
            case "advanced":
                <AdvancedSection Settings="_settings"/>
                break;
            case "updates":
                <UpdatesSection Settings="_settings"/>
                break;
            case "git-merge":
                <GitMergeSection Settings="_settings"/>
                break;
        }
    </div>
</div>

@code {
    [Parameter] public string Section { get; set; } = "general";

    private AppSettings _settings = new();

    protected override async Task OnInitializedAsync()
    {
        _settings = await SettingsService.LoadAsync();
    }

    private string GetSectionTitle() => Section switch
    {
        "general" => Strings.Nav_General,
        "ai" => Strings.Nav_AiModel,
        "notifications" => Strings.Nav_Notifications,
        "terminal" => Strings.Nav_Terminal,
        "shortcuts" => Strings.Nav_Shortcuts,
        "integrations" => Strings.Nav_Integrations,
        "advanced" => Strings.Nav_Advanced,
        "updates" => Strings.Nav_Updates,
        "git-merge" => Strings.Nav_GitMerge,
        _ => Strings.Common_Settings
    };

    private async Task Save()
    {
        // culture를 먼저 확정해야 OnSettingsChanged cascade 시 올바른 culture로 렌더링됨
        Strings.SetCulture(_settings.UiLanguage);
        await SettingsService.SaveAsync(_settings);
        Snackbar.SettingsSaved();
    }

}
