<div class="stack gap-4">
    @* Allow rules *@
    <div>
        <div class="d-flex align-center gap-2 mb-2">
            <Icon Svg="@Lucide.CircleCheck" Tone="Tone.Success" Size="14"/>
            <span class="typo-subtitle2" style="color: var(--color-success);">Allow</span>
            <Chip>@(Permissions?.Allow?.Count ?? 0)</Chip>
        </div>
        <div class="d-flex flex-wrap gap-1 mb-2">
            @if (Permissions?.Allow != null)
            {
                @foreach (var rule in Permissions.Allow)
                {
                    <Chip Tone="Tone.Success" ButtonStyle="ButtonStyle.Outlined"
                          OnClose="@(() => RemoveRule("allow", rule))">
                        @rule
                    </Chip>
                }
            }
        </div>
        <div class="d-flex gap-2">
            <TextField @bind-Value="_allowInput" Placeholder="Bash(npm run *)"
                       Immediate="true" Style="flex: 1;"
                       OnKeyDown="@(e =>
                                  {
                                      if (e.Key == "Enter") AddRule("allow");
                                  })"
                       HelperText="도구 패턴 입력 후 Enter 또는 추가 버튼"/>
            <IconButton Icon="@Lucide.Plus" Tone="Tone.Success"
                        OnClick="@(() => AddRule("allow"))"/>
        </div>
    </div>

    @* Ask rules *@
    <div>
        <div class="d-flex align-center gap-2 mb-2">
            <Icon Svg="@Lucide.CircleHelp" Tone="Tone.Warning" Size="14"/>
            <span class="typo-subtitle2" style="color: var(--color-warning);">Ask</span>
            <Chip>@(Permissions?.Ask?.Count ?? 0)</Chip>
        </div>
        <div class="d-flex flex-wrap gap-1 mb-2">
            @if (Permissions?.Ask != null)
            {
                @foreach (var rule in Permissions.Ask)
                {
                    <Chip Tone="Tone.Warning" ButtonStyle="ButtonStyle.Outlined"
                          OnClose="@(() => RemoveRule("ask", rule))">
                        @rule
                    </Chip>
                }
            }
        </div>
        <div class="d-flex gap-2">
            <TextField @bind-Value="_askInput" Placeholder="Edit(/src/**/*.config)"
                       Immediate="true" Style="flex: 1;"
                       OnKeyDown="@(e =>
                                  {
                                      if (e.Key == "Enter") AddRule("ask");
                                  })"
                       HelperText="확인이 필요한 도구 패턴"/>
            <IconButton Icon="@Lucide.Plus" Tone="Tone.Warning"
                        OnClick="@(() => AddRule("ask"))"/>
        </div>
    </div>

    @* Deny rules *@
    <div>
        <div class="d-flex align-center gap-2 mb-2">
            <Icon Svg="@Lucide.Ban" Tone="Tone.Error" Size="14"/>
            <span class="typo-subtitle2" style="color: var(--color-error);">Deny</span>
            <Chip>@(Permissions?.Deny?.Count ?? 0)</Chip>
        </div>
        <div class="d-flex flex-wrap gap-1 mb-2">
            @if (Permissions?.Deny != null)
            {
                @foreach (var rule in Permissions.Deny)
                {
                    <Chip Tone="Tone.Error" ButtonStyle="ButtonStyle.Outlined"
                          OnClose="@(() => RemoveRule("deny", rule))">
                        @rule
                    </Chip>
                }
            }
        </div>
        <div class="d-flex gap-2">
            <TextField @bind-Value="_denyInput" Placeholder="WebFetch(domain:*)"
                       Immediate="true" Style="flex: 1;"
                       OnKeyDown="@(e =>
                                  {
                                      if (e.Key == "Enter") AddRule("deny");
                                  })"
                       HelperText="차단할 도구 패턴"/>
            <IconButton Icon="@Lucide.Plus" Tone="Tone.Error"
                        OnClick="@(() => AddRule("deny"))"/>
        </div>
    </div>
</div>

@code {
    [Parameter] public PermissionRules? Permissions { get; set; }
    [Parameter] public EventCallback<PermissionRules> PermissionsChanged { get; set; }

    private string _allowInput = "";
    private string _askInput = "";
    private string _denyInput = "";

    private async Task AddRule(string action)
    {
        var input = action switch
        {
            "allow" => _allowInput,
            "ask" => _askInput,
            "deny" => _denyInput,
            _ => ""
        };

        if (string.IsNullOrWhiteSpace(input)) return;

        Permissions ??= new PermissionRules();

        switch (action)
        {
            case "allow":
                Permissions.Allow ??= [];
                if (!Permissions.Allow.Contains(input)) Permissions.Allow.Add(input);
                _allowInput = "";
                break;
            case "ask":
                Permissions.Ask ??= [];
                if (!Permissions.Ask.Contains(input)) Permissions.Ask.Add(input);
                _askInput = "";
                break;
            case "deny":
                Permissions.Deny ??= [];
                if (!Permissions.Deny.Contains(input)) Permissions.Deny.Add(input);
                _denyInput = "";
                break;
        }

        await PermissionsChanged.InvokeAsync(Permissions);
    }

    private async Task RemoveRule(string action, string rule)
    {
        if (Permissions == null) return;

        switch (action)
        {
            case "allow": Permissions.Allow?.Remove(rule); break;
            case "ask": Permissions.Ask?.Remove(rule); break;
            case "deny": Permissions.Deny?.Remove(rule); break;
        }

        await PermissionsChanged.InvokeAsync(Permissions);
    }

}
