@inject IChatState ChatState
@inject IWorkspaceService WorkspaceService
@inject SessionListDataService DataService
@implements IDisposable

<div class="settings-page">
    <div class="settings-page-nav">
        <button class="settings-back-btn" @onclick="GoBack">
            <Icon Svg="@Lucide.ArrowLeft" Size="14"/>
            @Strings.Nav_BackToApp
        </button>

        <div class="settings-nav-section">
            <button class="settings-nav-item @ActiveClass("dashboard")"
                    @onclick="@(() => SetSection("dashboard"))">
                <Icon Svg="@Lucide.LayoutDashboard" Size="14"/>
                @Strings.Nav_Dashboard
            </button>
            <button class="settings-nav-item @ActiveClass("usage")"
                    @onclick="@(() => SetSection("usage"))">
                <Icon Svg="@Lucide.ChartColumn" Size="14"/>
                @Strings.Nav_Usage
            </button>
        </div>

        <div class="settings-nav-label">@Strings.Nav_AppSettings</div>
        <div class="settings-nav-section">
            <button class="settings-nav-item @ActiveClass("general")"
                    @onclick="@(() => SetSection("general"))">
                <Icon Svg="@Lucide.SlidersHorizontal" Size="14"/>
                @Strings.Nav_General
            </button>
            <button class="settings-nav-item @ActiveClass("ai")"
                    @onclick="@(() => SetSection("ai"))">
                <Icon Svg="@Lucide.Brain" Size="14"/>
                @Strings.Nav_AiModel
            </button>
            <button class="settings-nav-item @ActiveClass("notifications")"
                    @onclick="@(() => SetSection("notifications"))">
                <Icon Svg="@Lucide.Bell" Size="14"/>
                @Strings.Nav_Notifications
            </button>
            <button class="settings-nav-item @ActiveClass("terminal")"
                    @onclick="@(() => SetSection("terminal"))">
                <Icon Svg="@Lucide.Terminal" Size="14"/>
                @Strings.Nav_Terminal
            </button>
            <button class="settings-nav-item @ActiveClass("git-merge")"
                    @onclick="@(() => SetSection("git-merge"))">
                <Icon Svg="@Lucide.GitMerge" Size="14"/>
                @Strings.Nav_GitMerge
            </button>
            <button class="settings-nav-item @ActiveClass("shortcuts")"
                    @onclick="@(() => SetSection("shortcuts"))">
                <Icon Svg="@Lucide.Keyboard" Size="14"/>
                @Strings.Nav_Shortcuts
            </button>
        </div>

        <div class="settings-nav-label">@Strings.Nav_IntegrationsAndExtensions</div>
        <div class="settings-nav-section">
            <button class="settings-nav-item @ActiveClass("integrations")"
                    @onclick="@(() => SetSection("integrations"))">
                <Icon Svg="@Lucide.Puzzle" Size="14"/>
                @Strings.Nav_Integrations
            </button>
            <button class="settings-nav-item @ActiveClass("slash-commands")"
                    @onclick="@(() => SetSection("slash-commands"))">
                <Icon Svg="@Lucide.Code" Size="14"/>
                @Strings.Nav_SlashCommands
            </button>
        </div>

        <div class="settings-nav-divider"></div>

        <div class="settings-nav-label">Claude CLI</div>
        <div class="settings-nav-section">
            <button class="settings-nav-item @ActiveClass("claude-settings")"
                    @onclick="@(() => SetSection("claude-settings"))">
                <Icon Svg="@Lucide.SlidersHorizontal" Size="14"/>
                @Strings.Nav_ClaudeSettings
            </button>
            <button class="settings-nav-item @ActiveClass("mcp")"
                    @onclick="@(() => SetSection("mcp"))">
                <Icon Svg="@Lucide.Network" Size="14"/>
                @Strings.Nav_McpServers
            </button>
            <button class="settings-nav-item @ActiveClass("hooks")"
                    @onclick="@(() => SetSection("hooks"))">
                <Icon Svg="@Lucide.Zap" Size="14"/>
                @Strings.Nav_Hooks
            </button>
            <button class="settings-nav-item @ActiveClass("rules")"
                    @onclick="@(() => SetSection("rules"))">
                <Icon Svg="@Lucide.Shield" Size="14"/>
                @Strings.Nav_Rules
            </button>
            <button class="settings-nav-item @ActiveClass("instructions")"
                    @onclick="@(() => SetSection("instructions"))">
                <Icon Svg="@Lucide.FileText" Size="14"/>
                @Strings.Nav_Instructions
            </button>
            <button class="settings-nav-item @ActiveClass("plugins")"
                    @onclick="@(() => SetSection("plugins"))">
                <Icon Svg="@Lucide.Puzzle" Size="14"/>
                @Strings.Nav_Plugins
            </button>
            <button class="settings-nav-item @ActiveClass("accounts")"
                    @onclick="@(() => SetSection("accounts"))">
                <Icon Svg="@Lucide.UserCog" Size="14"/>
                @Strings.Nav_Accounts
            </button>
        </div>

        <div class="settings-nav-label">@Strings.Nav_Tools</div>
        <div class="settings-nav-section">
            <button class="settings-nav-item @ActiveClass("session-replay")"
                    @onclick="@(() => SetSection("session-replay"))">
                <Icon Svg="@Lucide.History" Size="14"/>
                @Strings.Nav_SessionHistory
            </button>
            <button class="settings-nav-item @ActiveClass("memory")"
                    @onclick="@(() => SetSection("memory"))">
                <Icon Svg="@Lucide.Cpu" Size="14"/>
                @Strings.Nav_Memory
            </button>
        </div>

        <div class="settings-nav-label">@Strings.Nav_System</div>
        <div class="settings-nav-section">
            <button class="settings-nav-item @ActiveClass("advanced")"
                    @onclick="@(() => SetSection("advanced"))">
                <Icon Svg="@Lucide.Settings" Size="14"/>
                @Strings.Nav_Advanced
            </button>
            <button class="settings-nav-item @ActiveClass("updates")"
                    @onclick="@(() => SetSection("updates"))">
                <Icon Svg="@Lucide.HardDriveDownload" Size="14"/>
                @Strings.Nav_Updates
            </button>
        </div>

        <div class="settings-nav-divider"></div>
        <div class="settings-nav-label">@Strings.Nav_Workspaces</div>

        @foreach (var ws in _workspaces)
        {
            var projectName = GetProjectName(ws);
            <button class="settings-nav-item ws-nav-item @(ChatState.SettingsWorkspaceId == ws.Id ? "active" : "")"
                    @onclick="@(() => SelectWorkspace(ws.Id))">
                <span class="ws-nav-letter">@projectName[0]</span>
                @projectName
            </button>
        }
    </div>

    <div class="settings-page-content">
        @if (ChatState.SettingsWorkspaceId != null)
        {
            <WorkspaceSettingsContent WorkspaceId="@ChatState.SettingsWorkspaceId"
                                      OnWorkspaceDeleted="HandleWorkspaceDeleted"/>
        }
        else if (ChatState.SettingsSection == "dashboard")
        {
            <DashboardPage/>
        }
        else if (ChatState.SettingsSection == "claude-settings")
        {
            <ClaudeSettingsSection/>
        }
        else if (ChatState.SettingsSection == "mcp")
        {
            <McpPage/>
        }
        else if (ChatState.SettingsSection == "hooks")
        {
            <HooksPage/>
        }
        else if (ChatState.SettingsSection == "rules")
        {
            <RulesPage/>
        }
        else if (ChatState.SettingsSection == "instructions")
        {
            <InstructionsPage/>
        }
        else if (ChatState.SettingsSection == "accounts")
        {
            <AccountsPage/>
        }
        else if (ChatState.SettingsSection == "session-replay")
        {
            <SessionReplayPage/>
        }
        else if (ChatState.SettingsSection == "memory")
        {
            <MemoryBrowserPage/>
        }
        else if (ChatState.SettingsSection == "slash-commands")
        {
            <SlashCommandsPage/>
        }
        else if (ChatState.SettingsSection == "plugins")
        {
            <PluginsPage/>
        }
        else if (ChatState.SettingsSection == "usage")
        {
            <div class="settings-content-area wide">
                <div class="settings-content-header">
                    <span class="typo-h6">@Strings.Nav_Usage</span>
                </div>
                <div class="settings-content-body">
                    <UsageDashboard/>
                </div>
            </div>
        }
        else
        {
            <AppSettingsContent Section="@ChatState.SettingsSection"/>
        }
    </div>
</div>

@code {
    private List<Workspace> _workspaces = [];

    protected override async Task OnInitializedAsync()
    {
        ChatState.OnChange += HandleStateChanged;
        _workspaces = await WorkspaceService.GetWorkspacesAsync();
    }

    private void SetSection(string section)
    {
        ChatState.SetSettingsWorkspace(null);
        ChatState.SetSettingsSection(section);
    }

    private void SelectWorkspace(string workspaceId)
    {
        ChatState.SetSettingsWorkspace(workspaceId);
    }

    private void GoBack()
    {
        ChatState.CloseSettings();
    }

    private async Task HandleWorkspaceDeleted()
    {
        _workspaces = await WorkspaceService.GetWorkspacesAsync();
        ChatState.SetSettingsWorkspace(null);
        await DataService.RefreshWorkspacesAsync();
    }

    private string ActiveClass(string section)
    {
        return ChatState.SettingsWorkspaceId == null && ChatState.SettingsSection == section ? "active" : "";
    }

    private static string GetProjectName(Workspace ws)
    {
        if (!string.IsNullOrEmpty(ws.RepoUrl))
        {
            var url = ws.RepoUrl.TrimEnd('/');
            if (url.EndsWith(".git"))
                url = url[..^4];

            var slashIdx = url.LastIndexOf('/');
            if (slashIdx >= 0)
                return url[(slashIdx + 1)..];
            var colonIdx = url.LastIndexOf(':');
            if (colonIdx >= 0)
                return url[(colonIdx + 1)..];
        }

        if (!string.IsNullOrEmpty(ws.RepoLocalPath))
        {
            return Path.GetFileName(ws.RepoLocalPath.TrimEnd(Path.DirectorySeparatorChar, '/'));
        }

        return ws.Name;
    }

    private void HandleStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        ChatState.OnChange -= HandleStateChanged;
    }

}
