@inject IClaudeSettingsService ClaudeSettingsService
@inject IChatState ChatState
@inject ISnackbar Snackbar

<div class="settings-content-area">
    <ClaudeSettingScopeHeader Scope="_scope" ScopeChanged="OnScopeChanged"
                              ProjectPath="@_projectPath" ProjectPathChanged="OnProjectPathChanged"
                              Saving="_saving" OnSave="Save"/>

    <div class="settings-content-body">
        @if (_loading)
        {
            <div style="display: flex; justify-content: center; padding: 40px;">
                <MudProgressCircular Indeterminate="true"/>
            </div>
        }
        else
        {
            <div class="settings-section-title">@Strings.Settings_Claude_Title</div>
            <div class="settings-section-desc">
                @(_scope switch
                {
                    ClaudeSettingsScope.Global => Strings.Settings_Claude_ScopeGlobal,
                    ClaudeSettingsScope.Project => Strings.Settings_Claude_ScopeProject,
                    ClaudeSettingsScope.Local => Strings.Settings_Claude_ScopeLocal,
                    _ => ""
                })
            </div>

            <div class="stack gap-4">
                @* ── Group 1: 모델 및 동작 ── *@
                <div class="settings-group">
                    <div class="settings-group-title">
                        <MudIcon Icon="@Icons.Material.Filled.Psychology" Size="Size.Small"/>
                        @Strings.Settings_Claude_ModelBehaviorTitle
                    </div>

                    <div class="stack gap-3">
                        <MudTextField T="string" @bind-Value="_settings.Model" Label="@Strings.Settings_Claude_ModelLabel"
                                      Variant="Variant.Outlined" Margin="Margin.Dense"
                                      Placeholder="claude-sonnet-4-20250514"
                                      HelperText="@Strings.Settings_Claude_ModelHint"/>

                        <div>
                            <div class="settings-field-label">@Strings.Settings_Claude_EffortLabel</div>
                            <div class="settings-segmented">
                                <button class="settings-seg-item @(_settings.EffortLevel == null ? "active" : "")"
                                        @onclick="@(() => _settings.EffortLevel = null)">@Strings.Settings_Claude_NotSet</button>
                                <button class="settings-seg-item @(_settings.EffortLevel == EffortLevel.Low ? "active" : "")"
                                        @onclick="@(() => _settings.EffortLevel = EffortLevel.Low)">Low</button>
                                <button class="settings-seg-item @(_settings.EffortLevel == EffortLevel.Medium ? "active" : "")"
                                        @onclick="@(() => _settings.EffortLevel = EffortLevel.Medium)">Medium</button>
                                <button class="settings-seg-item @(_settings.EffortLevel == EffortLevel.High ? "active" : "")"
                                        @onclick="@(() => _settings.EffortLevel = EffortLevel.High)">High</button>
                                <button class="settings-seg-item @(_settings.EffortLevel == EffortLevel.XHigh ? "active" : "")"
                                        @onclick="@(() => _settings.EffortLevel = EffortLevel.XHigh)">X-High</button>
                                <button class="settings-seg-item @(_settings.EffortLevel == EffortLevel.Max ? "active" : "")"
                                        @onclick="@(() => _settings.EffortLevel = EffortLevel.Max)">Max</button>
                            </div>
                            <div class="settings-field-hint">@Strings.Settings_Claude_EffortHint</div>
                        </div>

                        <div>
                            <div class="settings-field-label">@Strings.Settings_Claude_DefaultModeLabel</div>
                            <div class="settings-segmented">
                                <button class="settings-seg-item @(_settings.DefaultMode == null ? "active" : "")"
                                        @onclick="@(() => _settings.DefaultMode = null)">@Strings.Settings_Claude_NotSet</button>
                                <button class="settings-seg-item @(_settings.DefaultMode == ClaudeDefaultMode.Default ? "active" : "")"
                                        @onclick="@(() => _settings.DefaultMode = ClaudeDefaultMode.Default)">Default</button>
                                <button class="settings-seg-item @(_settings.DefaultMode == ClaudeDefaultMode.Plan ? "active" : "")"
                                        @onclick="@(() => _settings.DefaultMode = ClaudeDefaultMode.Plan)">Plan</button>
                                <button class="settings-seg-item @(_settings.DefaultMode == ClaudeDefaultMode.AcceptEdits ? "active" : "")"
                                        @onclick="@(() => _settings.DefaultMode = ClaudeDefaultMode.AcceptEdits)">Accept Edits</button>
                                <button class="settings-seg-item @(_settings.DefaultMode == ClaudeDefaultMode.DontAsk ? "active" : "")"
                                        @onclick="@(() => _settings.DefaultMode = ClaudeDefaultMode.DontAsk)">Don't Ask</button>
                                <button class="settings-seg-item @(_settings.DefaultMode == ClaudeDefaultMode.BypassPermissions ? "active" : "")"
                                        @onclick="@(() => _settings.DefaultMode = ClaudeDefaultMode.BypassPermissions)">Bypass</button>
                            </div>
                            <div class="settings-field-hint">@Strings.Settings_Claude_DefaultModeHint</div>
                        </div>

                        <div class="settings-toggle-row">
                            <div>
                                <span class="typo-body2">@Strings.Settings_Claude_AlwaysThinkingLabel</span>
                                <div class="typo-caption text-secondary">@Strings.Settings_Claude_AlwaysThinkingHint</div>
                            </div>
                            <MudSwitch T="bool?" @bind-Value="_settings.AlwaysThinkingEnabled" Color="Color.Primary"/>
                        </div>

                        <div class="settings-toggle-row">
                            <div>
                                <span class="typo-body2">@Strings.Settings_Claude_AutoMemoryLabel</span>
                                <div class="typo-caption text-secondary">@Strings.Settings_Claude_AutoMemoryHint</div>
                            </div>
                            <MudSwitch T="bool?" @bind-Value="_settings.AutoMemoryEnabled" Color="Color.Primary"/>
                        </div>
                    </div>
                </div>

                @* ── Group 2: 권한 규칙 ── *@
                <div class="settings-group">
                    <div class="settings-group-title">
                        <MudIcon Icon="@Icons.Material.Filled.Security" Size="Size.Small"/>
                        @Strings.Settings_Claude_PermissionsTitle
                    </div>
                    <PermissionsEditor @bind-Permissions="_settings.Permissions"/>
                </div>

                @* ── Group 3: 환경변수 ── *@
                <div class="settings-group">
                    <div class="settings-group-title">
                        <MudIcon Icon="@Icons.Material.Filled.Terminal" Size="Size.Small"/>
                        @Strings.Settings_Claude_EnvVarsTitle
                    </div>
                    <div class="typo-caption text-secondary mb-2">
                        @Strings.Settings_Claude_EnvVarsHint
                    </div>
                    <EnvVarsEditor @bind-EnvVars="_settings.Env"/>
                </div>

                @* ── Group 4: 추가 디렉토리 ── *@
                <div class="settings-group">
                    <div class="settings-group-title">
                        <MudIcon Icon="@Icons.Material.Filled.CreateNewFolder" Size="Size.Small"/>
                        @Strings.Settings_Claude_AddDirsTitle
                    </div>
                    <div class="typo-caption text-secondary mb-2">
                        @Strings.Settings_Claude_AddDirsHint
                    </div>
                    <AdditionalDirectoriesEditor @bind-Directories="_settings.AdditionalDirectories"/>
                </div>

                @* ── Group 5: MCP 서버 (링크) ── *@
                <div class="settings-group">
                    <div class="settings-group-title">
                        <MudIcon Icon="@Icons.Material.Filled.Hub" Size="Size.Small"/>
                        @Strings.Nav_McpServers
                        <div style="flex: 1;"></div>
                        <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small"
                                   OnClick="NavigateToMcp" Style="text-transform: none;">
                            @Strings.Settings_Claude_Manage
                        </MudButton>
                    </div>
                    <div class="typo-caption text-secondary">
                        @Strings.Settings_Claude_McpDesc
                    </div>
                </div>

                @* ── Group 6: 훅 (요약) ── *@
                <div class="settings-group">
                    <div class="settings-group-title">
                        <MudIcon Icon="@Icons.Material.Filled.Bolt" Size="Size.Small"/>
                        @Strings.Nav_Hooks
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Text">@GetTotalHookCount()</MudChip>
                        <div style="flex: 1;"></div>
                        <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small"
                                   OnClick="NavigateToHooks" Style="text-transform: none;">
                            @Strings.Settings_Claude_Manage
                        </MudButton>
                    </div>
                    @if (_settings.Hooks is { Count: > 0 })
                    {
                        <div class="d-flex flex-wrap gap-1">
                            @foreach (var (evt, configs) in _settings.Hooks)
                            {
                                var count = configs.Sum(c => c.Hooks.Count);
                                @if (count > 0)
                                {
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                             Color="Color.Primary">
                                        @evt (@count)
                                    </MudChip>
                                }
                            }
                        </div>
                    }
                    else
                    {
                        <div class="typo-caption text-secondary">@Strings.Settings_Claude_NoHooks</div>
                    }
                </div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public string? ProjectPath { get; set; }

    private ClaudeSettings _settings = new();
    private ClaudeSettingsScope _scope = ClaudeSettingsScope.Global;
    private string? _projectPath;
    private bool _loading;
    private bool _saving;

    protected override async Task OnInitializedAsync()
    {
        _projectPath = ProjectPath ?? ChatState.CurrentWorkspace?.RepoLocalPath;

        _loading = true;
        StateHasChanged();

        try
        {
            _settings = await ClaudeSettingsService.ReadAsync(_scope,
                _scope == ClaudeSettingsScope.Global ? null : _projectPath);
        }
        catch
        {
            _settings = new ClaudeSettings();
        }

        _loading = false;
    }

    private async Task OnScopeChanged(ClaudeSettingsScope scope)
    {
        _scope = scope;
        await LoadSettings();
    }

    private async Task OnProjectPathChanged(string? path)
    {
        _projectPath = path;
        await LoadSettings();
    }

    private async Task LoadSettings()
    {
        _loading = true;
        StateHasChanged();

        try
        {
            _settings = await ClaudeSettingsService.ReadAsync(_scope,
                _scope == ClaudeSettingsScope.Global ? null : _projectPath);
        }
        catch
        {
            _settings = new ClaudeSettings();
        }

        _loading = false;
    }

    private async Task Save()
    {
        _saving = true;
        try
        {
            await ClaudeSettingsService.WriteAsync(_scope, _settings,
                _scope == ClaudeSettingsScope.Global ? null : _projectPath);
            Snackbar.Add(Strings.Settings_Claude_Saved, Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(Strings.Settings_Claude_SaveFailed(ex.Message), Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private int GetTotalHookCount()
    {
        if (_settings.Hooks == null) return 0;
        return _settings.Hooks.Values.Sum(configs => configs.Sum(c => c.Hooks.Count));
    }

    private void NavigateToHooks()
    {
        ChatState.SetSettingsSection("hooks");
    }

    private void NavigateToMcp()
    {
        ChatState.SetSettingsSection("mcp");
    }

}
