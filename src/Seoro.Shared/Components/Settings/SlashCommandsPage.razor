@inject ISkillRegistry SkillRegistry
@inject IChatState ChatState
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<div class="settings-content-area wide">
    @if (_editingCommand == null)
    {
        <ClaudeSettingScopeHeader Scope="_scope" ScopeChanged="OnScopeChanged"
                                  ProjectPath="@_projectPath" ProjectPathChanged="OnProjectPathChanged"
                                  ShowLocalScope="false"
                                  ShowSaveButton="false"
                                  Saving="false" OnSave="@(() => Task.CompletedTask)">
            <ExtraActions>
                <MudTextField @bind-Value="_searchText" Placeholder="@Strings.SlashCommands_SearchPlaceholder"
                              Variant="Variant.Outlined" Margin="Margin.Dense"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                              Immediate="true" Style="max-width: 200px;"/>
                <MudButton Variant="Variant.Outlined" Color="Color.Secondary"
                           StartIcon="@Icons.Material.Filled.AutoAwesome"
                           OnClick="OpenTemplates" Size="Size.Small"
                           Style="text-transform: none;">
                    @Strings.SlashCommands_Templates
                </MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Add"
                           OnClick="CreateNew" Size="Size.Small"
                           Style="text-transform: none;">
                    @Strings.SlashCommands_New
                </MudButton>
                <MudButton StartIcon="@Icons.Material.Filled.Refresh" Size="Size.Small"
                           Variant="Variant.Text" OnClick="RefreshCommands">
                    @Strings.Common_Refresh
                </MudButton>
            </ExtraActions>
        </ClaudeSettingScopeHeader>
    }
    else
    {
        <div class="settings-content-header">
            <div class="stack-row items-center gap-2">
                <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Size="Size.Small"
                               OnClick="CancelEdit"/>
                <span class="typo-subtitle1">@GetEditTitle()</span>
            </div>
        </div>
    }

    <div class="settings-content-body">
        @if (_editingCommand != null)
        {
            <div class="stack gap-3 pa-3">
                <MudTextField @bind-Value="_editName" Label="@Strings.SlashCommands_NameLabel"
                              Variant="Variant.Outlined" Margin="Margin.Dense"
                              Placeholder="my-command" Required="true"
                              Disabled="_isViewOnly"
                              HelperText="@Strings.SlashCommands_NameHelper"/>

                <MudTextField @bind-Value="_editDescription" Label="@Strings.Common_Description"
                              Variant="Variant.Outlined" Margin="Margin.Dense"
                              Placeholder="@Strings.SlashCommands_DescriptionPlaceholder"
                              Disabled="_isViewOnly"/>

                <MudSelect T="string" @bind-Value="_editScope" Label="@Strings.SlashCommands_ScopeLabel"
                           Variant="Variant.Outlined" Margin="Margin.Dense"
                           Disabled="_isViewOnly">
                    <MudSelectItem T="string" Value="@("user")">@Strings.SlashCommands_ScopeUserGlobal</MudSelectItem>
                    <MudSelectItem T="string" Value="@("project")" Disabled="@(string.IsNullOrEmpty(_projectPath))">
                        @Strings.SlashCommands_ScopeProject@(string.IsNullOrEmpty(_projectPath) ? Strings.SlashCommands_NoWorkspaceSuffix : "")
                    </MudSelectItem>
                </MudSelect>

                <MudTextField @bind-Value="_editContent" Label="@Strings.SlashCommands_ContentLabel"
                              Variant="Variant.Outlined" Lines="10"
                              Placeholder="@Strings.SlashCommands_ContentPlaceholder"
                              Disabled="_isViewOnly"/>

                <div>
                    <div class="typo-subtitle2 mb-1">@Strings.SlashCommands_AllowedTools</div>
                    <div class="slash-command-tools-panel">
                        @foreach (var tool in _availableTools)
                        {
                            var isChecked = _editAllowedTools.Contains(tool);
                            <MudChip T="string" Size="Size.Small"
                                     Variant="@(isChecked ? Variant.Filled : Variant.Outlined)"
                                     Color="@(isChecked ? Color.Primary : Color.Default)"
                                     Disabled="_isViewOnly"
                                     OnClick="@(() => ToggleTool(tool))">
                                @tool
                            </MudChip>
                        }
                    </div>
                </div>

                <div class="stack-row gap-2">
                    @if (!_isViewOnly)
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveCommand"
                                   Disabled="@(string.IsNullOrWhiteSpace(_editName))">
                            @(_isNewCommand ? Strings.SlashCommands_Add : Strings.Common_Save)
                        </MudButton>
                    }
                    <MudButton Variant="Variant.Text" OnClick="CancelEdit">
                        @(_isViewOnly ? Strings.SlashCommands_Back : Strings.Common_Cancel)
                    </MudButton>
                </div>
            </div>
        }
        else if (_loading)
        {
            <div style="display: flex; justify-content: center; padding: 24px;">
                <MudProgressCircular Indeterminate="true" Size="Size.Small"/>
            </div>
        }
        else if (!FilteredCommands.Any())
        {
            <p class="typo-body2 text-secondary pa-4 text-center">
                @Strings.SlashCommands_NotFound
            </p>
        }
        else
        {
            <div class="skill-card-list">
                @foreach (var cmd in FilteredCommands)
                {
                    <div @key="@($"{(cmd.IsBuiltIn ? "b" : "c")}:{cmd.Name}")" class="@($"skill-card {(cmd.IsBuiltIn ? "builtin" : "custom")}")">
                        <div class="skill-card-header">
                            <span style="font-family: var(--font-mono); font-weight: 600;">/@cmd.Name</span>
                            <div style="margin-left: auto; display: flex; gap: 2px; align-items: center;">
                                @if (cmd.IsBuiltIn)
                                {
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Filled"
                                             Color="Color.Default">@Strings.SlashCommands_BuiltIn
                                    </MudChip>
                                }
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                         Color="@GetScopeColor(cmd.Scope)">
                                    @GetScopeLabel(cmd.Scope)
                                </MudChip>
                                @if (!cmd.IsBuiltIn)
                                {
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                                   Color="Color.Primary"
                                                   OnClick="@(() => EditCommand(cmd))"/>
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                   Color="Color.Error"
                                                   OnClick="@(() => ConfirmDelete(cmd))"/>
                                }
                                else
                                {
                                    <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small"
                                                   Color="Color.Default"
                                                   OnClick="@(() => ViewCommand(cmd))"/>
                                }
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(cmd.Description))
                        {
                            <div class="typo-body2 text-secondary"
                                 style="margin-top: 2px;">@cmd.Description</div>
                        }
                        @if (cmd.AcceptsArguments || cmd.AllowedTools.Count > 0)
                        {
                            <div class="skill-card-badges">
                                @if (cmd.AcceptsArguments)
                                {
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Text"
                                             Color="Color.Info">$ARGS
                                    </MudChip>
                                }
                                @foreach (var tool in cmd.AllowedTools)
                                {
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Text"
                                             Color="Color.Warning">@tool</MudChip>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        }
    </div>
</div>

<TemplateGalleryDialog IsOpen="_showTemplates"
                       IsOpenChanged="@(v =>
                                      {
                                          _showTemplates = v;
                                          StateHasChanged();
                                      })"
                       DefaultCategory="TemplateCategory.Skill"
                       OnTemplateSelected="OnTemplateSelected"/>

@code {
    private bool _loading;
    private string _searchText = "";
    private bool _showTemplates;
    private ClaudeSettingsScope _scope = ClaudeSettingsScope.Global;
    private string? _projectPath;

    // 편집 양식 상태
    private SkillDefinition? _editingCommand;
    private bool _isNewCommand;
    private bool _isViewOnly;
    private string _editName = "";
    private string _editDescription = "";
    private string _editScope = "user";
    private string _editContent = "";
    private List<string> _editAllowedTools = [];

    private static readonly string[] _availableTools = ["Read", "Write", "Edit", "Bash", "Grep", "Glob", "Agent", "WebFetch", "WebSearch"];

    private IEnumerable<SkillDefinition> FilteredCommands
    {
        get
        {
            var all = SkillRegistry.GetAll();

            // 스코프 탭 필터: 글로벌 탭 = 내장+사용자, 프로젝트 탭 = 내장+프로젝트
            IEnumerable<SkillDefinition> scoped = _scope == ClaudeSettingsScope.Project
                ? all.Where(c => c.Scope is "default" or "project")
                : all.Where(c => c.Scope is "default" or "user");

            if (string.IsNullOrWhiteSpace(_searchText))
                return scoped;

            return scoped.Where(c =>
                c.Name.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
                c.Description.Contains(_searchText, StringComparison.OrdinalIgnoreCase));
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _projectPath = ChatState.CurrentWorkspace?.RepoLocalPath;
        await RefreshCommands();
    }

    private async Task RefreshCommands()
    {
        _loading = true;
        StateHasChanged();
        await SkillRegistry.LoadCustomCommandsAsync(_projectPath);
        _loading = false;
        StateHasChanged();
    }

    private async Task OnScopeChanged(ClaudeSettingsScope scope)
    {
        _scope = scope;
        StateHasChanged();
    }

    private async Task OnProjectPathChanged(string? path)
    {
        _projectPath = path;
        await RefreshCommands();
    }

    private void CreateNew()
    {
        ResetEditForm();
        // 현재 탭에 맞는 스코프로 기본값 설정
        _editScope = _scope == ClaudeSettingsScope.Project && !string.IsNullOrEmpty(_projectPath)
            ? "project"
            : "user";
        _isNewCommand = true;
        _editingCommand = new SkillDefinition { IsBuiltIn = false, Scope = _editScope };
        StateHasChanged();
    }

    private void EditCommand(SkillDefinition cmd)
    {
        _editName = cmd.Name;
        _editDescription = cmd.Description;
        _editScope = cmd.Scope;
        _editContent = cmd.PromptTemplate;
        _editAllowedTools = new List<string>(cmd.AllowedTools);
        _editingCommand = cmd;
        _isNewCommand = false;
        _isViewOnly = false;
        StateHasChanged();
    }

    private void ViewCommand(SkillDefinition cmd)
    {
        _editName = cmd.Name;
        _editDescription = cmd.Description;
        _editScope = cmd.Scope;
        _editContent = cmd.PromptTemplate;
        _editAllowedTools = new List<string>(cmd.AllowedTools);
        _editingCommand = cmd;
        _isNewCommand = false;
        _isViewOnly = true;
        StateHasChanged();
    }

    private async Task ConfirmDelete(SkillDefinition cmd)
    {
        var result = await DialogService.ShowMessageBoxAsync(
            Strings.SlashCommands_DeleteTitle,
            Strings.SlashCommands_DeleteConfirm(cmd.Name),
            Strings.Common_Delete, cancelText: Strings.Common_Cancel);

        if (result != true) return;

        await SkillRegistry.DeleteCommandAsync(cmd.Name, cmd.Scope, _projectPath);
        Snackbar.Add(Strings.SlashCommands_Deleted(cmd.Name), Severity.Success);
        StateHasChanged();
    }

    private async Task SaveCommand()
    {
        if (string.IsNullOrWhiteSpace(_editName)) return;

        var command = new SkillDefinition
        {
            Name = _editName,
            Description = _editDescription,
            Scope = _editScope,
            PromptTemplate = _editContent,
            AcceptsArguments = _editContent.Contains("$ARGUMENTS"),
            AllowedTools = [.._editAllowedTools],
            IsBuiltIn = false
        };

        await SkillRegistry.SaveCommandAsync(command, _projectPath);

        var savedScope = _editScope == "project" ? Strings.SlashCommands_ScopeProject : Strings.SlashCommands_ScopeUserGlobal;
        Snackbar.Add(Strings.SlashCommands_Saved(_editName, savedScope), Severity.Success);
        ResetEditForm();
        StateHasChanged();
    }

    private void CancelEdit()
    {
        ResetEditForm();
        StateHasChanged();
    }

    private void ResetEditForm()
    {
        _editingCommand = null;
        _editName = "";
        _editDescription = "";
        _editScope = "user";
        _editContent = "";
        _editAllowedTools = [];
        _isNewCommand = false;
        _isViewOnly = false;
    }

    private void ToggleTool(string tool)
    {
        if (_isViewOnly) return;
        if (_editAllowedTools.Contains(tool))
            _editAllowedTools.Remove(tool);
        else
            _editAllowedTools.Add(tool);
    }

    private string GetEditTitle()
    {
        if (_isViewOnly) return Strings.SlashCommands_DetailTitle;
        if (!_isNewCommand) return Strings.SlashCommands_EditTitle;
        return Strings.SlashCommands_New;
    }

    private void OpenTemplates()
    {
        _showTemplates = true;
        StateHasChanged();
    }

    private void OnTemplateSelected(TemplateDefinition template)
    {
        _showTemplates = false;
        ResetEditForm();
        _editName = template.Name.ToLowerInvariant().Replace(' ', '-');
        _editDescription = template.Description;
        _editContent = template.Content ?? "";
        _editScope = _scope == ClaudeSettingsScope.Project && !string.IsNullOrEmpty(_projectPath)
            ? "project"
            : "user";
        _isNewCommand = true;
        _editingCommand = new SkillDefinition { IsBuiltIn = false, Scope = _editScope };
        StateHasChanged();
    }

    private static Color GetScopeColor(string scope)
    {
        return scope switch
        {
            "project" => Color.Info,
            "user" => Color.Warning,
            _ => Color.Default
        };
    }

    private static string GetScopeLabel(string scope)
    {
        return scope switch
        {
            "default" => Strings.SlashCommands_ScopeShort_Default,
            "user" => Strings.SlashCommands_ScopeShort_User,
            "project" => Strings.SlashCommands_ScopeShort_Project,
            _ => scope
        };
    }
}

<style>
    .skill-card-list {
        display: flex;
        flex-direction: column;
        gap: 4px;
        padding: 8px;
    }

    .skill-card {
        border: 1px solid var(--mud-palette-lines-default);
        border-radius: 8px;
        padding: 10px 12px;
    }

    .skill-card.builtin {
        opacity: 0.75;
    }

    .skill-card-header {
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .skill-card-badges {
        display: flex;
        flex-wrap: wrap;
        gap: 2px;
        margin-top: 4px;
    }
</style>
