@inject IWorkspaceService WorkspaceService
@inject IGitService GitService
@inject IFolderPickerService FolderPickerService
@inject ISnackbar Snackbar

<MudDialog Visible="IsOpen" VisibleChanged="OnVisibleChanged" Options="_dialogOptions" Class="create-ws-dialog">
    <TitleContent>
        <div class="create-ws-header">
            <div class="create-ws-icon-badge">
                <MudIcon Icon="@Icons.Material.Filled.Add" Style="font-size: 18px;"/>
            </div>
            <div class="stack gap-1">
                <span class="create-ws-title">@Strings.Sidebar_CreateWorkspace_Title</span>
                <span class="create-ws-subtitle">@Strings.Sidebar_CreateWorkspace_Subtitle</span>
            </div>
        </div>
    </TitleContent>
    <DialogContent>
        <div class="create-ws-body">
            @if (_isCreating)
            {
                <div class="create-ws-progress-overlay">
                    <div class="create-ws-progress-spinner">
                        <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Medium"/>
                    </div>
                    <p class="typo-body2 text-secondary">@_progressMessage</p>
                </div>
            }

            <div class="create-ws-segmented">
                <button type="button" class="create-ws-segment @(_activeTab == 0 ? "active" : "")"
                        @onclick="@(() => _activeTab = 0)">
                    <MudIcon Icon="@Icons.Material.Filled.Cloud" Style="font-size: 16px;"/>
                    @Strings.Sidebar_CreateWorkspace_CloneFromUrl
                </button>
                <button type="button" class="create-ws-segment @(_activeTab == 1 ? "active" : "")"
                        @onclick="@(() => _activeTab = 1)">
                    <MudIcon Icon="@Icons.Material.Filled.Folder" Style="font-size: 16px;"/>
                    @Strings.Sidebar_CreateWorkspace_LocalRepository
                </button>
            </div>

            <div class="create-ws-panel">
                @if (_activeTab == 0)
                {
                    <div class="stack gap-3">
                        <div class="create-ws-field-group">
                            <label class="create-ws-label">@Strings.Sidebar_CreateWorkspace_RepoUrlLabel</label>
                            <MudTextField @bind-Value="_repoUrl" Variant="Variant.Outlined"
                                          Margin="Margin.Dense" Placeholder="https://github.com/org/repo"
                                          Immediate="true" TextChanged="OnUrlChanged"
                                          Adornment="Adornment.Start"
                                          AdornmentIcon="@Icons.Material.Filled.Link"/>
                        </div>
                        <div class="create-ws-field-group">
                            <label class="create-ws-label">@Strings.Sidebar_CreateWorkspace_ClonePathLabel</label>
                            <div class="create-ws-path-input">
                                <MudTextField @bind-Value="_clonePath" Variant="Variant.Outlined"
                                              Margin="Margin.Dense" Placeholder="/경로/저장소"
                                              Style="flex: 1;"/>
                                <button type="button" class="create-ws-browse-btn"
                                        @onclick="BrowseCloneFolder" title="@Strings.Sidebar_CreateWorkspace_Browse">
                                    <MudIcon Icon="@Icons.Material.Filled.FolderOpen" Style="font-size: 18px;"/>
                                </button>
                            </div>
                        </div>
                        <div class="create-ws-field-group">
                            <label class="create-ws-label">@Strings.Sidebar_CreateWorkspace_WorkspaceNameLabel</label>
                            <MudTextField @bind-Value="_editName" Variant="Variant.Outlined"
                                          Margin="Margin.Dense"/>
                        </div>
                        <div class="create-ws-field-group">
                            <label class="create-ws-label">@Strings.Sidebar_CreateWorkspace_DefaultModelLabel</label>
                            <MudSelect T="string" @bind-Value="_editModel"
                                       Variant="Variant.Outlined" Margin="Margin.Dense"
                                       HelperText="@Strings.Sidebar_CreateWorkspace_DefaultModelHelper">
                                <MudSelectItem T="string" Value="@("")">@Strings.Sidebar_CreateWorkspace_UseAppDefault</MudSelectItem>
                                @foreach (var model in ModelDefinitions.All.Where(m => m.Provider != "codex"))
                                {
                                    <MudSelectItem T="string" Value="@model.Id">@model.DisplayName</MudSelectItem>
                                }
                            </MudSelect>
                        </div>
                    </div>
                }
                else
                {
                    <div class="stack gap-3">
                        <div class="create-ws-field-group">
                            <label class="create-ws-label">@Strings.Sidebar_CreateWorkspace_RepoPathLabel</label>
                            <div class="create-ws-path-input">
                                <MudTextField @bind-Value="_localPath" Variant="Variant.Outlined"
                                              Margin="Margin.Dense" Placeholder="/경로/저장소"
                                              Style="flex: 1;"/>
                                <button type="button" class="create-ws-browse-btn"
                                        @onclick="BrowseLocalFolder" title="@Strings.Sidebar_CreateWorkspace_Browse">
                                    <MudIcon Icon="@Icons.Material.Filled.FolderOpen" Style="font-size: 18px;"/>
                                </button>
                            </div>
                        </div>
                        @if (_localPathValidation != null)
                        {
                            <div class="create-ws-validation @(_isLocalPathGitRepo ? "success" : "warning")">
                                <MudIcon
                                    Icon="@(_isLocalPathGitRepo ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Warning)"
                                    Style="font-size: 16px;"/>
                                <span>@_localPathValidation</span>
                                @if (!_isLocalPathGitRepo)
                                {
                                    <button type="button" class="create-ws-init-btn"
                                            @onclick="InitializeGitRepo"
                                            disabled="@_isInitializingGit">
                                        @if (_isInitializingGit)
                                        {
                                            <MudProgressCircular Size="Size.Small" Indeterminate="true"
                                                                 Style="width: 14px; height: 14px;"/>
                                        }
                                        @Strings.Sidebar_CreateWorkspace_InitGit
                                    </button>
                                }
                            </div>
                        }
                        <div class="create-ws-field-group">
                            <label class="create-ws-label">@Strings.Sidebar_CreateWorkspace_WorkspaceNameLabel</label>
                            <MudTextField @bind-Value="_editName" Variant="Variant.Outlined"
                                          Margin="Margin.Dense"/>
                        </div>
                        <div class="create-ws-field-group">
                            <label class="create-ws-label">@Strings.Sidebar_CreateWorkspace_DefaultModelLabel</label>
                            <MudSelect T="string" @bind-Value="_editModel"
                                       Variant="Variant.Outlined" Margin="Margin.Dense"
                                       HelperText="@Strings.Sidebar_CreateWorkspace_DefaultModelHelper">
                                <MudSelectItem T="string" Value="@("")">@Strings.Sidebar_CreateWorkspace_UseAppDefault</MudSelectItem>
                                @foreach (var model in ModelDefinitions.All.Where(m => m.Provider != "codex"))
                                {
                                    <MudSelectItem T="string" Value="@model.Id">@model.DisplayName</MudSelectItem>
                                }
                            </MudSelect>
                        </div>
                    </div>
                }
            </div>

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div class="create-ws-error">
                    <MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Style="font-size: 16px;"/>
                    <span>@_errorMessage</span>
                </div>
            }
        </div>
    </DialogContent>
    <DialogActions>
        <div class="create-ws-actions">
            <button type="button" class="create-ws-btn-cancel" @onclick="Close" disabled="@_isCreating">
                @Strings.Common_Cancel
            </button>
            <button type="button" class="create-ws-btn-create" @onclick="Create" disabled="@(!CanCreate)">
                @if (_isCreating)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true"
                                         Style="width: 16px; height: 16px;"/>
                }
                @Strings.Sidebar_CreateWorkspace_Create
                @if (!_isCreating)
                {
                    <kbd class="create-ws-kbd">Enter</kbd>
                }
            </button>
        </div>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback<bool> IsOpenChanged { get; set; }
    [Parameter] public EventCallback OnWorkspaceCreated { get; set; }

    private int _activeTab;
    private bool _isCreating;
    private string _editName = "";
    private string _editModel = "";
    private string _repoUrl = "";
    private string _localPath = "";
    private string _progressMessage = "";
    private string _clonePath = "";
    private bool _clonePathAutoFilled;
    private string? _errorMessage;
    private string? _localPathValidation;
    private bool _isLocalPathGitRepo;
    private bool _isInitializingGit;
    private bool _nameAutoFilled;

    private readonly DialogOptions _dialogOptions = new()
    {
        MaxWidth = MaxWidth.Small,
        FullWidth = true
    };

    private bool CanCreate => !_isCreating && _activeTab switch
    {
        0 => !string.IsNullOrWhiteSpace(_repoUrl) && !string.IsNullOrWhiteSpace(_editName),
        1 => !string.IsNullOrWhiteSpace(_localPath) && !string.IsNullOrWhiteSpace(_editName)
                                                    && (_localPathValidation == null || _isLocalPathGitRepo),
        _ => false
    };

    protected override void OnParametersSet()
    {
        if (IsOpen)
        {
            ResetForm();
        }
    }

    private void ResetForm()
    {
        _activeTab = 0;
        _editName = "";
        _editModel = "";
        _repoUrl = "";
        _clonePath = "";
        _clonePathAutoFilled = false;
        _localPath = "";
        _errorMessage = null;
        _localPathValidation = null;
        _isLocalPathGitRepo = false;
        _isInitializingGit = false;
        _isCreating = false;
        _nameAutoFilled = false;
    }

    private async Task Create()
    {
        if (_activeTab == 0)
            await CreateFromUrl();
        else
            await CreateFromLocal();
    }

    private async Task CreateFromUrl()
    {
        _errorMessage = null;
        _isCreating = true;
        _progressMessage = Strings.Sidebar_CreateWorkspace_Cloning;
        StateHasChanged();

        var progress = new Progress<string>(msg =>
        {
            _progressMessage = msg;
            InvokeAsync(StateHasChanged);
        });

        try
        {
            var ws = await WorkspaceService.CreateFromUrlAsync(
                _repoUrl.Trim(), _editName.Trim(), _editModel,
                string.IsNullOrWhiteSpace(_clonePath) ? null : _clonePath.Trim(),
                progress);

            if (ws.Status == WorkspaceStatus.Error)
            {
                _errorMessage = ws.ErrorMessage ?? Strings.Sidebar_CreateWorkspace_CreationFailed;
                _isCreating = false;
            }
            else
            {
                Snackbar.WorkspaceCreated(_editName.Trim());
                await OnWorkspaceCreated.InvokeAsync();
                await Close();
            }
        }
        catch (OperationCanceledException)
        {
            _errorMessage = Strings.Sidebar_CreateWorkspace_OperationCancelled;
            _isCreating = false;
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
            _isCreating = false;
        }
    }

    private async Task CreateFromLocal()
    {
        _errorMessage = null;
        _isCreating = true;
        _progressMessage = Strings.Sidebar_CreateWorkspace_SettingUp;
        StateHasChanged();

        try
        {
            var ws = await WorkspaceService.CreateFromLocalAsync(
                _localPath.Trim(), _editName.Trim(), _editModel);

            if (ws.Status == WorkspaceStatus.Error)
            {
                _errorMessage = ws.ErrorMessage ?? Strings.Sidebar_CreateWorkspace_CreationFailed;
                _isCreating = false;
            }
            else
            {
                Snackbar.WorkspaceCreated(_editName.Trim());
                await OnWorkspaceCreated.InvokeAsync();
                await Close();
            }
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
            _isCreating = false;
        }
    }

    private async Task BrowseCloneFolder()
    {
        var path = await FolderPickerService.PickFolderAsync();
        if (string.IsNullOrEmpty(path))
            return;

        _clonePath = path;
        _clonePathAutoFilled = false;
    }

    private async Task BrowseLocalFolder()
    {
        var path = await FolderPickerService.PickFolderAsync();
        if (string.IsNullOrEmpty(path))
            return;

        _localPath = path;
        _localPathValidation = null;
        _isLocalPathGitRepo = false;

        var isGitRepo = await GitService.IsGitRepoAsync(path);
        if (!isGitRepo)
        {
            _localPathValidation = Strings.Sidebar_CreateWorkspace_NotGitRepo;
            _isLocalPathGitRepo = false;
            return;
        }

        _isLocalPathGitRepo = true;
        _localPathValidation = Strings.Sidebar_CreateWorkspace_ValidGitRepo;

        if (string.IsNullOrEmpty(_editName) || _nameAutoFilled)
        {
            _editName = Path.GetFileName(path.TrimEnd(Path.DirectorySeparatorChar, Path.AltDirectorySeparatorChar)) ?? "";
            _nameAutoFilled = true;
        }
    }

    private async Task InitializeGitRepo()
    {
        if (string.IsNullOrWhiteSpace(_localPath)) return;

        _isInitializingGit = true;
        _errorMessage = null;
        StateHasChanged();

        try
        {
            var initResult = await GitService.InitAsync(_localPath);
            if (!initResult.Success)
            {
                _errorMessage = Strings.Sidebar_CreateWorkspace_GitInitFailed(initResult.Error ?? "");
                return;
            }

            // 초기 커밋 시도 (빈 디렉터리면 실패해도 무시)
            var stageResult = await GitService.StageAllAsync(_localPath);
            if (stageResult.Success)
                await GitService.CommitAsync(_localPath, "Initial commit");

            // 재검증
            if (await GitService.IsGitRepoAsync(_localPath))
            {
                _isLocalPathGitRepo = true;
                _localPathValidation = Strings.Sidebar_CreateWorkspace_GitInitialized;

                if (string.IsNullOrEmpty(_editName) || _nameAutoFilled)
                {
                    _editName = Path.GetFileName(_localPath.TrimEnd(
                        Path.DirectorySeparatorChar, Path.AltDirectorySeparatorChar)) ?? "";
                    _nameAutoFilled = true;
                }
            }
            else
            {
                _errorMessage = Strings.Sidebar_CreateWorkspace_GitInitError;
            }
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isInitializingGit = false;
            StateHasChanged();
        }
    }

    private async void OnUrlChanged(string url)
    {
        _repoUrl = url;
        if (!string.IsNullOrWhiteSpace(url) && (string.IsNullOrEmpty(_editName) || _nameAutoFilled))
        {
            _editName = ExtractRepoName(url);
            _nameAutoFilled = true;
        }

        if (!string.IsNullOrWhiteSpace(url) && (string.IsNullOrEmpty(_clonePath) || _clonePathAutoFilled))
        {
            _clonePath = await WorkspaceService.GetDefaultClonePathAsync(url);
            _clonePathAutoFilled = true;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task OnVisibleChanged(bool visible)
    {
        if (IsOpen != visible)
        {
            IsOpen = visible;
            await IsOpenChanged.InvokeAsync(visible);
        }
    }

    private async Task Close()
    {
        IsOpen = false;
        _isCreating = false;
        await IsOpenChanged.InvokeAsync(false);
    }

    private static string ExtractRepoName(string url)
    {
        var cleaned = url.Trim().TrimEnd('/');
        if (cleaned.EndsWith(".git", StringComparison.OrdinalIgnoreCase))
            cleaned = cleaned[..^4];
        var lastSlash = cleaned.LastIndexOfAny(['/', ':']);
        return lastSlash >= 0 ? cleaned[(lastSlash + 1)..] : cleaned;
    }

}
