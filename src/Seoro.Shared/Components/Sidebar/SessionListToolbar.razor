<div class="tree-header">
    <span class="tree-header-label">Workspaces</span>
    <div class="tree-header-actions">
        <IconButton Icon="@(FilterVisible ? Lucide.FilterX : Lucide.ListFilter)"
                    Style="width: 24px; height: 24px; opacity: 0.5;"
                    OnClick="@OnToggleFilter"/>
        <IconButton Icon="@Lucide.Plus"
                    Style="width: 24px; height: 24px; opacity: 0.5;"
                    OnClick="@OnCreateWorkspace"/>
    </div>
</div>

@if (FilterVisible)
{
    <div class="tree-filter" style="position: relative;">
        <TextField Value="@FilterText"
                   ValueChanged="@(v => FilterTextChanged.InvokeAsync(v ?? ""))"
                   Placeholder="@Strings.Sidebar_Search"
                   Immediate="true"
                   Style="font-size: var(--text-xs);"/>
        @if (FilterText?.Length > 0)
        {
            <IconButton Icon="@Lucide.X" Size="UiSize.Xs"
                        Style="position: absolute; right: 6px; top: 50%; transform: translateY(-50%);"
                        OnClick="@(() => FilterTextChanged.InvokeAsync(""))"/>
        }
    </div>
}

@code {
    [Parameter] public bool FilterVisible { get; set; }
    [Parameter] public string? FilterText { get; set; }
    [Parameter] public EventCallback OnToggleFilter { get; set; }
    [Parameter] public EventCallback OnCreateWorkspace { get; set; }
    [Parameter] public EventCallback<string> FilterTextChanged { get; set; }
}
