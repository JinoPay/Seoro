@foreach (var node in Nodes)
{
    var indent = Depth * 12;
    if (node.IsDirectory)
    {
        var expanded = ExpandedDirs.Contains(node.FullPath);
        var hasDiff = DirsWithDiff != null && DirsWithDiff.Contains(node.FullPath);
        <div class="sidebar-file-item dir@(hasDiff ? " has-diff" : "")"
             style="padding-left: @(indent + 8)px;"
             @onclick="() => OnToggleDir.InvokeAsync(node.FullPath)">
            <Icon Svg="@(expanded ? Lucide.FolderOpen : Lucide.Folder)"
                  Size="14"
                  Style="@(hasDiff ? "opacity: 0.8; color: var(--color-info);" : "opacity: 0.6;")"/>
            <span class="sidebar-file-name">@node.Name</span>
        </div>

        if (expanded)
        {
            <FileTreeNode Nodes="node.Children"
                          Depth="Depth + 1"
                          ExpandedDirs="ExpandedDirs"
                          DiffByPath="DiffByPath"
                          DirsWithDiff="DirsWithDiff"
                          OnToggleDir="OnToggleDir"
                          OnOpenFile="OnOpenFile"/>
        }
    }
    else
    {
        FileChangeType? changeType = DiffByPath != null && DiffByPath.TryGetValue(node.FullPath, out var ct) ? ct : null;
        <div class="sidebar-file-item file@(changeType != null ? " modified" : "")"
             style="padding-left: @(indent + 8)px;"
             @onclick="() => OnOpenFile.InvokeAsync(node.FullPath)">
            <Icon Svg="@GetFileIcon(changeType)"
                  Size="14"
                  Style="@GetFileIconColor(changeType)"/>
            <span class="sidebar-file-name">@node.Name</span>
        </div>
    }
}

@code {
    [Parameter][EditorRequired] public List<FileNode> Nodes { get; set; } = new();

    [Parameter] public int Depth { get; set; }

    [Parameter][EditorRequired] public HashSet<string> ExpandedDirs { get; set; } = new();

    /// <summary>파일 경로 → 변경 타입. O(1) 조회를 위해 부모가 사전 계산해서 내려준다.</summary>
    [Parameter] public IReadOnlyDictionary<string, FileChangeType>? DiffByPath { get; set; }

    /// <summary>diff 파일의 조상 디렉터리 경로 집합 — 디렉터리 배지용.</summary>
    [Parameter] public IReadOnlySet<string>? DirsWithDiff { get; set; }

    [Parameter][EditorRequired] public EventCallback<string> OnToggleDir { get; set; }

    [Parameter][EditorRequired] public EventCallback<string> OnOpenFile { get; set; }

    private static string GetFileIcon(FileChangeType? changeType)
    {
        if (changeType == null) return Lucide.File;
        return changeType switch
        {
            FileChangeType.Added => Lucide.FilePlus,
            FileChangeType.Deleted => Lucide.Trash2,
            FileChangeType.Renamed => Lucide.FilePen,
            FileChangeType.Untracked => Lucide.CirclePlus,
            _ => Lucide.SquarePen
        };
    }

    private static string GetFileIconColor(FileChangeType? changeType)
    {
        if (changeType == null) return "opacity: 0.4;";
        return changeType switch
        {
            FileChangeType.Added => "color: var(--color-success);",
            FileChangeType.Deleted => "color: var(--color-error);",
            FileChangeType.Renamed => "color: var(--color-warning);",
            FileChangeType.Untracked => "color: var(--text-secondary);",
            _ => "color: var(--color-info);"
        };
    }

}
