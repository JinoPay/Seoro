@inject IChatState ChatState
@inject IGitService GitService
@inject IWorktreeChangeWatcherService WorktreeWatcher
@inject ISessionService SessionService
@inject ILogger<SidebarExplorer> Logger
@using Microsoft.Extensions.Logging
@implements IDisposable

<div class="sidebar-explorer">
    <div class="tree-header">
        <span class="tree-header-label">Explorer</span>
        <div class="tree-header-actions">
            <IconButton Icon="@Lucide.ChevronsUpDown"
                        Style="width: 22px; height: 22px; opacity: 0.5;"
                        OnClick="ExpandAll" Disabled="_loading || _tree.Count == 0"
                        Title="@Strings.Sidebar_Explorer_ExpandAll"/>
            <IconButton Icon="@Lucide.ChevronsDownUp"
                        Style="width: 22px; height: 22px; opacity: 0.5;"
                        OnClick="CollapseAll" Disabled="_loading || _tree.Count == 0"
                        Title="@Strings.Sidebar_Explorer_CollapseAll"/>
            <IconButton Icon="@Lucide.RefreshCw"
                        Style="width: 22px; height: 22px; opacity: 0.5;"
                        OnClick="LoadFilesAsync" Disabled="_loading"/>
        </div>
    </div>

    @if (_loading)
    {
        <ProgressBar Indeterminate="true" Class="my-2"/>
    }
    else if (_error != null)
    {
        <Alert Tone="Tone.Error" Dense="true" Class="my-2">@_error</Alert>
    }
    else if (_tree.Count == 0)
    {
        <div class="sidebar-explorer-empty">
            <Icon Svg="@Lucide.FolderX" Size="24" Style="opacity: 0.15;"/>
            <span>@Strings.Sidebar_Explorer_NoFilesFound</span>
        </div>
    }
    else
    {
        <div class="sidebar-explorer-tree">
            <FileTreeNode Nodes="_tree"
                          ExpandedDirs="_expandedDirs"
                          DiffByPath="_diffByPath"
                          DirsWithDiff="_dirsWithDiff"
                          OnToggleDir="ToggleDir"
                          OnOpenFile="OpenFile"/>
        </div>
    }
</div>

@code {
    private const int ExpandedSaveDebounceMs = 1000;

    private List<FileNode> _tree = new();
    private bool _loading;
    private string? _error;
    private DiffSummary? _diff;
    private Dictionary<string, FileChangeType>? _diffByPath;
    private HashSet<string>? _dirsWithDiff;
    private string? _lastSessionId;
    private HashSet<string> _knownFiles = new();
    private HashSet<string> _expandedDirs = new();
    private bool _stale;
    private CancellationTokenSource? _expandedSaveCts;

    protected override async Task OnInitializedAsync()
    {
        ChatState.OnChange += HandleStateChanged;
        WorktreeWatcher.FilesChanged += HandleWorktreeFilesChanged;
        RestoreExpandedDirs();
        await LoadFilesAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        var sessionId = ChatState.CurrentSession?.Id;
        if (sessionId != _lastSessionId)
        {
            _lastSessionId = sessionId;
            RestoreExpandedDirs();
            await LoadFilesAsync();
        }
    }

    private void RestoreExpandedDirs()
    {
        var saved = ChatState.CurrentSession?.ExplorerExpandedDirs;
        _expandedDirs = saved != null ? new HashSet<string>(saved) : new HashSet<string>();
    }

    private void HandleWorktreeFilesChanged(string workingDir)
    {
        if (ChatState.CurrentSession?.Git.WorktreePath != workingDir) return;

        // 패널이 숨겨져 있으면 새로고침을 미루고 표시될 때 한 번만 로드
        if (ChatState.RightPanel != RightPanelMode.Explorer)
        {
            _stale = true;
            return;
        }

        _ = InvokeAsync(RefreshAfterChangeAsync);
    }

    /// <summary>
    ///     파일 변경 후 새로고침 — 전체 재스캔 대신 증분 갱신.
    ///     이벤트는 트리거일 뿐이고 진실은 ls-files 재조회 결과다 (FSW 유실/untracked 정책 모두 회피).
    /// </summary>
    private async Task RefreshAfterChangeAsync()
    {
        var session = ChatState.CurrentSession;
        if (session == null || string.IsNullOrEmpty(session.Git.WorktreePath)) return;

        try
        {
            var prevDiffFiles = _diff?.Files.Select(f => f.FilePath).ToHashSet() ?? [];

            var files = await GitService.ListTrackedFilesAsync(session.Git.WorktreePath);
            var (added, removed) = FileTreeBuilder.ComputeDiff(_knownFiles, files);
            var changeCount = added.Count + removed.Count;

            if (changeCount > 0 && changeCount <= SeoroConstants.ExplorerIncrementalUpdateMaxChanges)
            {
                // 기존 노드 객체를 유지한 채 변경분만 수술 — 렌더 diff 최소화, 스피너 없음
                foreach (var path in removed)
                    FileTreeBuilder.RemovePath(_tree, path);
                foreach (var path in added)
                    FileTreeBuilder.AddPath(_tree, path);
                _knownFiles = files.ToHashSet();
            }
            else if (changeCount > SeoroConstants.ExplorerIncrementalUpdateMaxChanges)
            {
                // 대량 변경(브랜치 전환, 의존성 설치 등) — 전체 재구축으로 폴백
                Logger.LogDebug("익스플로러 증분 임계값 초과({Count}건) — 전체 재구축", changeCount);
                _tree = FileTreeBuilder.Build(files);
                _knownFiles = files.ToHashSet();
            }
            // changeCount == 0: 내용만 변경됨 — 트리 구조는 그대로, diff 배지만 갱신

            await LoadDiffStatusAsync(session);

            // 새로 변경된 파일의 디렉터리 자동 확장
            var newDiffFiles = _diff?.Files.Select(f => f.FilePath).ToHashSet() ?? [];
            var newlyChanged = newDiffFiles.Except(prevDiffFiles).ToList();
            if (newlyChanged.Count > 0)
            {
                foreach (var filePath in newlyChanged)
                    ExpandParentDirs(filePath);
                QueueExpandedSave();
            }

            _error = null;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            StateHasChanged();
        }
    }

    private async Task LoadFilesAsync()
    {
        var session = ChatState.CurrentSession;
        if (session == null || string.IsNullOrEmpty(session.Git.WorktreePath)) return;

        _loading = true;
        _error = null;
        StateHasChanged();

        try
        {
            var sw = System.Diagnostics.Stopwatch.StartNew();
            var files = await GitService.ListTrackedFilesAsync(session.Git.WorktreePath);
            var listMs = sw.ElapsedMilliseconds;

            sw.Restart();
            await LoadDiffStatusAsync(session);
            var diffMs = sw.ElapsedMilliseconds;

            sw.Restart();
            _tree = FileTreeBuilder.Build(files);
            _knownFiles = files.ToHashSet();
            var buildMs = sw.ElapsedMilliseconds;

            Logger.LogDebug("익스플로러 로드: ls-files {ListMs}ms ({Count}개 파일) / diff {DiffMs}ms / 트리 {BuildMs}ms",
                listMs, files.Count, diffMs, buildMs);

            // 자동 확장 없음: 트리는 기본적으로 축소된 상태로 시작합니다

            // 항상 diff 파일 부모 확장 확인
            if (_diff != null)
            {
                foreach (var file in _diff.Files)
                    ExpandParentDirs(file.FilePath);
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task LoadDiffStatusAsync(Session session)
    {
        try
        {
            var diffBase = session.Git.GetDiffBase();
            _diff = await GitService.GetDiffStatusAsync(session.Git.WorktreePath, diffBase);
        }
        catch
        {
            _diff = null;
        }

        RebuildDiffLookups();
    }

    /// <summary>렌더 경로의 노드당 LINQ 스캔을 O(1) 조회로 바꾸기 위한 사전 계산.</summary>
    private void RebuildDiffLookups()
    {
        if (_diff == null)
        {
            _diffByPath = null;
            _dirsWithDiff = null;
            return;
        }

        var byPath = new Dictionary<string, FileChangeType>(StringComparer.Ordinal);
        var dirs = new HashSet<string>(StringComparer.Ordinal);
        foreach (var file in _diff.Files)
        {
            byPath[file.FilePath] = file.ChangeType;
            var parts = file.FilePath.Split('/');
            var currentPath = "";
            for (var i = 0; i < parts.Length - 1; i++)
            {
                currentPath = i == 0 ? parts[i] : $"{currentPath}/{parts[i]}";
                dirs.Add(currentPath);
            }
        }

        _diffByPath = byPath;
        _dirsWithDiff = dirs;
    }

    private async Task OpenFile(string filePath)
    {
        var session = ChatState.CurrentSession;
        if (session == null || string.IsNullOrEmpty(session.Git.WorktreePath)) return;

        try
        {
            var content = await GitService.ReadFileAsync(session.Git.WorktreePath, filePath);
            ChatState.Tabs.OpenFileContentTab(filePath, content);
        }
        catch (Exception ex)
        {
            ChatState.Tabs.OpenFileContentTab(filePath, Strings.Sidebar_Explorer_FileReadError(ex.Message));
        }
    }

    private void ToggleDir(string path)
    {
        if (!_expandedDirs.Remove(path))
            _expandedDirs.Add(path);
        QueueExpandedSave();
    }

    private void ExpandParentDirs(string filePath)
    {
        var parts = filePath.Split('/');
        var currentPath = "";
        for (var i = 0; i < parts.Length - 1; i++)
        {
            currentPath = i == 0 ? parts[i] : $"{currentPath}/{parts[i]}";
            _expandedDirs.Add(currentPath);
        }
    }

    private void ExpandAll()
    {
        ExpandAllDirs(_tree);
        QueueExpandedSave();
    }

    private void CollapseAll()
    {
        _expandedDirs.Clear();
        QueueExpandedSave();
    }

    private void ExpandAllDirs(List<FileNode> nodes)
    {
        foreach (var node in nodes)
        {
            if (node.IsDirectory)
            {
                _expandedDirs.Add(node.FullPath);
                ExpandAllDirs(node.Children);
            }
        }
    }

    /// <summary>펼침 상태를 세션에 반영하고 디바운스 후 저장 (InputArea 의 초안 저장 패턴).</summary>
    private void QueueExpandedSave()
    {
        var session = ChatState.CurrentSession;
        if (session == null) return;

        // 거대 repo 의 ExpandAll 직후 등 — 세션 JSON 비대화 방지를 위해 저장 생략
        if (_expandedDirs.Count > SeoroConstants.ExplorerExpandedDirsSaveLimit) return;

        // 세션 객체에는 즉시 반영 — 디바운스 저장이 취소돼도 다음 저장 시 함께 영속화됨
        session.ExplorerExpandedDirs = new HashSet<string>(_expandedDirs);

        _expandedSaveCts?.Cancel();
        var cts = new CancellationTokenSource();
        _expandedSaveCts = cts;
        _ = PersistExpandedLaterAsync(session, cts.Token);
    }

    private async Task PersistExpandedLaterAsync(Session session, CancellationToken ct)
    {
        try
        {
            await Task.Delay(ExpandedSaveDebounceMs, ct);
            await SessionService.SaveSessionAsync(session);
        }
        catch (OperationCanceledException)
        {
        }
        catch (Exception ex)
        {
            Logger.LogDebug(ex, "익스플로러 펼침 상태 저장 실패");
        }
    }

    private void HandleStateChanged()
    {
        _ = InvokeAsync(async () =>
        {
            var sessionId = ChatState.CurrentSession?.Id;
            if (sessionId != _lastSessionId)
            {
                _lastSessionId = sessionId;
                _stale = false;

                if (sessionId != null)
                {
                    RestoreExpandedDirs();
                    await LoadFilesAsync();
                }
                else
                {
                    _tree = new List<FileNode>();
                    _knownFiles = new HashSet<string>();
                    _diff = null;
                    RebuildDiffLookups();
                    _error = null;
                    _expandedDirs = new HashSet<string>();
                    StateHasChanged();
                }

                return;
            }

            // 숨겨진 동안 미뤄둔 새로고침을 패널이 표시될 때 수행
            if (_stale && ChatState.RightPanel == RightPanelMode.Explorer)
            {
                _stale = false;
                await RefreshAfterChangeAsync();
                return;
            }

            StateHasChanged();
        });
    }

    public void Dispose()
    {
        ChatState.OnChange -= HandleStateChanged;
        WorktreeWatcher.FilesChanged -= HandleWorktreeFilesChanged;
    }

}
