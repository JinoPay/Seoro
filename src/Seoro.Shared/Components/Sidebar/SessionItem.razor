<Popover @key="Session.Id" @bind-Open="_contextMenuOpen"
         Fixed="true" Placement="PopoverPlacement.BottomEnd"
         PopoverClass="ui-menu ui-menu--dense"
         Style="display: block;">
<AnchorContent>
<div class="tree-session @(IsActive ? "active" : "") @(IsStreaming ? "streaming" : "") @(Session.Status == SessionStatus.Archived ? "archived" : "")"
     @onclick="@OnClick"
     @oncontextmenu="OpenContextMenu"
     @oncontextmenu:preventDefault="true">

    @if (Session.Provider == "codex")
    {
        <span class="status-badge" style="background: rgba(0,200,120,0.15); color: #00c878;" title="Codex">Codex</span>
    }

    @if (IsSynced)
    {
        <span class="status-badge synced" title="@Strings.Common_Status_Synced">@Strings.Common_Status_Synced</span>
    }

    @if (IsCompleted)
    {
        <span class="status-badge completed" title="@Strings.Common_Status_Completed">@Strings.Common_Status_Completed</span>
    }
    else if (Session.Status == SessionStatus.Error)
    {
        <span class="status-badge error" title="@Strings.Common_Status_Error">@GetStatusLabel(Session.Status)</span>
    }
    else if (Session.Status == SessionStatus.Archived)
    {
        <span class="status-badge archived" title="@Strings.Common_Status_Archived">@GetStatusLabel(Session.Status)</span>
    }

    <div class="tree-session-info">
        <span class="tree-session-title @(_titleChanged ? "title-changed" : "")"
              @onanimationend="@(() => _titleChanged = false)">@Session.Title</span>
        <div class="tree-session-meta">
            @if (Session.Git.IsLocalDir)
            {
                @if (!string.IsNullOrEmpty(Session.Git.BranchName))
                {
                    <span class="tree-session-branch">
                        <span class="local-badge">@Strings.Common_Status_Local</span> @Session.Git.BranchName
                    </span>
                }
                else
                {
                    <span class="tree-session-branch"><span class="local-badge">로컬</span></span>
                }
            }
            else if (!string.IsNullOrEmpty(Session.Git.BranchName))
            {
                <span class="tree-session-branch">@Session.Git.BranchName</span>
            }

            @if (DiffAdditions > 0 || DiffDeletions > 0)
            {
                <span class="tree-session-diff-stats">
                    @if (DiffAdditions > 0)
                    {
                        <span class="diff-add">+@DiffAdditions</span>
                    }
                    @if (DiffDeletions > 0)
                    {
                        <span class="diff-del">-@DiffDeletions</span>
                    }
                </span>
            }

            @if (IsStreaming)
            {
                <span class="tree-session-status">@StreamingStatusText</span>
            }
        </div>
    </div>

    <div class="tree-session-actions">
        <IconButton Icon="@Lucide.X"
                    Style="width: 20px; height: 20px; opacity: 0.4;"
                    OnClick="@OnDelete"
                    StopPropagation="true"/>
    </div>

    @if (DeleteShortcutLabel != null || ShortcutLabel != null)
    {
        <div class="tree-session-shortcuts @(ShowShortcuts ? "show" : "")">
            @if (DeleteShortcutLabel != null)
            {
                <span
                    class="tree-session-shortcut delete @(ShowShortcuts ? "visible" : "")">× @DeleteShortcutLabel</span>
            }
            @if (ShortcutLabel != null)
            {
                <span class="tree-session-shortcut @(ShowShortcuts ? "visible" : "")">@ShortcutLabel</span>
            }
        </div>
    }
</div>
</AnchorContent>
<ChildContent>
    <MenuItem OnClick="@HandleOpenFolder"
              Icon="@Lucide.FolderOpen">
        @Strings.Sidebar_OpenFolder
    </MenuItem>
    @if (AvailableIdes?.Count > 0)
    {
        @foreach (var ide in AvailableIdes)
        {
            <MenuItem OnClick="@(() => HandleOpenInIde(ide.Command))"
                      Icon="@Lucide.Code">
                @Strings.Sidebar_OpenInIde(ide.Name)
            </MenuItem>
        }
    }
    <Divider/>
    <MenuItem OnClick="@HandleDelete"
              Icon="@Lucide.X">
        @Strings.Common_Delete
    </MenuItem>
</ChildContent>
</Popover>

@code {
    [Parameter][EditorRequired] public Session Session { get; set; } = null!;
    [Parameter] public bool IsActive { get; set; }
    [Parameter] public bool IsStreaming { get; set; }
    [Parameter] public bool IsCompleted { get; set; }
    [Parameter] public bool IsSynced { get; set; }
    [Parameter] public string? StreamingStatusText { get; set; }
    [Parameter] public int DiffAdditions { get; set; }
    [Parameter] public int DiffDeletions { get; set; }
    [Parameter] public string? ShortcutLabel { get; set; }
    [Parameter] public string? DeleteShortcutLabel { get; set; }
    [Parameter] public bool ShowShortcuts { get; set; }
    [Parameter] public EventCallback OnClick { get; set; }
    [Parameter] public EventCallback OnDelete { get; set; }
    [Parameter] public EventCallback OnOpenFolder { get; set; }
    [Parameter] public EventCallback<string> OnOpenInIde { get; set; }
    [Parameter] public List<IdeInfo>? AvailableIdes { get; set; }

    /// <summary>Blazor 변경 감지용 — Session.Title의 스칼라 복사본. 렌더링은 Session에서 직접 읽음.</summary>
    [Parameter] public string? SessionTitle { get; set; }

    /// <summary>Blazor 변경 감지용 — Session.Git.BranchName의 스칼라 복사본. 렌더링은 Session에서 직접 읽음.</summary>
    [Parameter] public string? SessionBranch { get; set; }

    private bool _contextMenuOpen;
    private string? _prevTitle;
    private bool _titleChanged;

    protected override void OnParametersSet()
    {
        if (_prevTitle != null && _prevTitle != Session.Title)
            _titleChanged = true;
        _prevTitle = Session.Title;
    }

    private void OpenContextMenu()
    {
        _contextMenuOpen = true;
    }

    private async Task HandleOpenFolder()
    {
        _contextMenuOpen = false;
        await OnOpenFolder.InvokeAsync();
    }

    private async Task HandleOpenInIde(string command)
    {
        _contextMenuOpen = false;
        await OnOpenInIde.InvokeAsync(command);
    }

    private async Task HandleDelete()
    {
        _contextMenuOpen = false;
        await OnDelete.InvokeAsync();
    }

    private static string GetStatusLabel(SessionStatus status)
    {
        return status switch
        {
            SessionStatus.Error => Strings.Common_Status_Error,
            SessionStatus.Archived => Strings.Common_Status_Archived,
            _ => ""
        };
    }

}
