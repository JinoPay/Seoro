<div class="@($"ui-card hook-card {(_expanded ? "expanded" : "")}")">
    <div class="hook-card-header" @onclick="Toggle">
        <div class="d-flex align-center gap-2" style="flex: 1; min-width: 0;">
            <Icon Svg="@GetTypeIcon()" Size="14" Tone="@GetTypeTone()"/>
            <Chip ButtonStyle="ButtonStyle.Filled" Tone="@GetTypeTone()">
                @Hook.Type
            </Chip>
            @if (!string.IsNullOrEmpty(Matcher))
            {
                <Chip ButtonStyle="ButtonStyle.Outlined">
                    @Matcher
                </Chip>
            }
            <span class="typo-caption text-secondary"
                  style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                @GetSummary()
            </span>
        </div>
        <div class="d-flex align-center gap-1">
            <IconButton Icon="@Lucide.Trash2" Tone="Tone.Error"
                        OnClick="@(async () => await OnDelete.InvokeAsync())"/>
            <Icon Svg="@(_expanded ? Lucide.ChevronUp : Lucide.ChevronDown)" Size="14"/>
        </div>
    </div>

    @if (_expanded)
    {
        <div class="hook-card-body">
            <HookHandlerForm Hook="Hook" HookChanged="@(async h => await OnChanged.InvokeAsync(h))"/>
        </div>
    }
</div>

@code {
    [Parameter][EditorRequired] public ClaudeHookHandler Hook { get; set; } = null!;
    [Parameter] public string? Matcher { get; set; }
    [Parameter] public EventCallback<ClaudeHookHandler> OnChanged { get; set; }
    [Parameter] public EventCallback OnDelete { get; set; }

    private bool _expanded;

    private void Toggle()
    {
        _expanded = !_expanded;
    }

    private string GetTypeIcon()
    {
        return Hook.Type switch
        {
            ClaudeHookHandlerType.Command => Lucide.Terminal,
            ClaudeHookHandlerType.Http => Lucide.Globe,
            ClaudeHookHandlerType.Prompt => Lucide.Brain,
            ClaudeHookHandlerType.Agent => Lucide.Bot,
            _ => Lucide.Code
        };
    }

    private Tone GetTypeTone()
    {
        return Hook.Type switch
        {
            ClaudeHookHandlerType.Command => Tone.Success,
            ClaudeHookHandlerType.Http => Tone.Info,
            ClaudeHookHandlerType.Prompt => Tone.Warning,
            ClaudeHookHandlerType.Agent => Tone.Secondary,
            _ => Tone.Default
        };
    }

    private string GetSummary()
    {
        return Hook.Type switch
        {
            ClaudeHookHandlerType.Command => Hook.Command ?? "(no command)",
            ClaudeHookHandlerType.Http => Hook.Url ?? "(no URL)",
            ClaudeHookHandlerType.Prompt => Hook.Prompt?.Length > 50
                ? Hook.Prompt[..50] + "..."
                : Hook.Prompt ?? "(no prompt)",
            ClaudeHookHandlerType.Agent => Hook.Model ?? "default model",
            _ => ""
        };
    }

}

<style>
    .hook-card {
        border-radius: 8px;
        overflow: hidden;
        transition: border-color 0.15s;
    }

    .hook-card:hover, .hook-card.expanded {
        border-color: var(--accent) !important;
    }

    .hook-card-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 10px 14px;
        cursor: pointer;
    }

    .hook-card-body {
        padding: 0 14px 14px;
        border-top: 1px solid var(--border-default);
    }
</style>
