<div class="stack gap-3 pt-3">
    <Select T="ClaudeHookHandlerType" Value="Hook.Type" ValueChanged="OnTypeChanged"
            Label="핸들러 타입" Fixed="true">
        <SelectItem T="ClaudeHookHandlerType" Value="ClaudeHookHandlerType.Command"
                    Text="Command — 셸 명령어 실행">
            <div class="d-flex align-center gap-2">
                <Icon Svg="@Lucide.Terminal" Size="14"/>
                Command — 셸 명령어 실행
            </div>
        </SelectItem>
        <SelectItem T="ClaudeHookHandlerType" Value="ClaudeHookHandlerType.Http"
                    Text="HTTP — 웹훅 POST 요청">
            <div class="d-flex align-center gap-2">
                <Icon Svg="@Lucide.Globe" Size="14"/>
                HTTP — 웹훅 POST 요청
            </div>
        </SelectItem>
        <SelectItem T="ClaudeHookHandlerType" Value="ClaudeHookHandlerType.Prompt"
                    Text="Prompt — AI 검증/필터">
            <div class="d-flex align-center gap-2">
                <Icon Svg="@Lucide.Brain" Size="14"/>
                Prompt — AI 검증/필터
            </div>
        </SelectItem>
        <SelectItem T="ClaudeHookHandlerType" Value="ClaudeHookHandlerType.Agent"
                    Text="Agent — 서브에이전트 트리거">
            <div class="d-flex align-center gap-2">
                <Icon Svg="@Lucide.Bot" Size="14"/>
                Agent — 서브에이전트 트리거
            </div>
        </SelectItem>
    </Select>

    @switch (Hook.Type)
    {
        case ClaudeHookHandlerType.Command:
            <TextField Value="@Hook.Command" Label="명령어"
                       Placeholder="echo 'hello'" Lines="2"
                       ValueChanged="@(async v => { Hook.Command = v; await NotifyChanged(); })"/>
            break;

        case ClaudeHookHandlerType.Http:
            <TextField Value="@Hook.Url" Label="URL"
                       Placeholder="https://example.com/webhook"
                       ValueChanged="@(async v => { Hook.Url = v; await NotifyChanged(); })"/>
            <div class="typo-caption text-secondary">헤더 (key: value, 줄당 하나):</div>
            <TextField Value="@SerializeHeaders()" ValueChanged="@(v => ParseHeaders(v))"
                       Lines="2"
                       Placeholder="Authorization: Bearer xxx&#10;Content-Type: application/json"/>
            break;

        case ClaudeHookHandlerType.Prompt:
            <TextField Value="@Hook.Prompt" Label="프롬프트"
                       Placeholder="Check if this action is safe and appropriate" Lines="3"
                       ValueChanged="@(async v => { Hook.Prompt = v; await NotifyChanged(); })"/>
            <TextField Value="@Hook.Model" Label="모델 (선택)"
                       Placeholder="claude-haiku-4-5-20251001"
                       ValueChanged="@(async v => { Hook.Model = v; await NotifyChanged(); })"/>
            break;

        case ClaudeHookHandlerType.Agent:
            <TextField Value="@Hook.Prompt" Label="에이전트 프롬프트"
                       Placeholder="Analyze and summarize the results" Lines="3"
                       ValueChanged="@(async v => { Hook.Prompt = v; await NotifyChanged(); })"/>
            <TextField Value="@Hook.Model" Label="모델"
                       Placeholder="claude-sonnet-4-20250514"
                       ValueChanged="@(async v => { Hook.Model = v; await NotifyChanged(); })"/>
            break;
    }

    @* Common fields *@
    <div class="d-flex gap-2">
        <div class="ui-field" style="flex: 1;">
            <label class="ui-field__label">타임아웃 (초)</label>
            <div class="ui-field__control">
                <input class="ui-field__input" type="number" min="1" max="300"
                       value="@Hook.Timeout"
                       @onchange="@(e => Hook.Timeout = int.TryParse(e.Value?.ToString(), out var t) ? Math.Clamp(t, 1, 300) : null)"/>
            </div>
        </div>
        <TextField Value="@Hook.StatusMessage" Label="상태 메시지"
                   Placeholder="Running hook..." Style="flex: 1;"
                   ValueChanged="@(async v => { Hook.StatusMessage = v; await NotifyChanged(); })"/>
    </div>

    <Switch Value="@(Hook.Async ?? false)" ValueChanged="@(v => Hook.Async = v)" Label="비동기 실행"/>
</div>

@code {
    [Parameter][EditorRequired] public ClaudeHookHandler Hook { get; set; } = null!;
    [Parameter] public EventCallback<ClaudeHookHandler> HookChanged { get; set; }

    private async Task OnTypeChanged(ClaudeHookHandlerType type)
    {
        Hook.Type = type;
        await NotifyChanged();
    }

    private async Task NotifyChanged()
    {
        await HookChanged.InvokeAsync(Hook);
    }

    private string SerializeHeaders()
    {
        if (Hook.Headers == null || Hook.Headers.Count == 0) return "";
        return string.Join("\n", Hook.Headers.Select(h => $"{h.Key}: {h.Value}"));
    }

    private async Task ParseHeaders(string? text)
    {
        Hook.Headers = new Dictionary<string, string>();
        if (string.IsNullOrWhiteSpace(text))
        {
            await NotifyChanged();
            return;
        }

        foreach (var line in text.Split('\n', StringSplitOptions.RemoveEmptyEntries))
        {
            var colonIdx = line.IndexOf(':');
            if (colonIdx > 0)
            {
                var key = line[..colonIdx].Trim();
                var value = line[(colonIdx + 1)..].Trim();
                if (!string.IsNullOrEmpty(key))
                    Hook.Headers[key] = value;
            }
        }

        await NotifyChanged();
    }

}
