@inject IClaudeSettingsService ClaudeSettingsService
@inject IChatState ChatState
@inject IToastService Snackbar

<div class="settings-content-area wide">
    <ClaudeSettingScopeHeader Scope="_scope" ScopeChanged="OnScopeChanged"
                              ProjectPath="@_projectPath" ProjectPathChanged="OnProjectPathChanged"
                              ShowLocalScope="false"
                              Saving="_saving" OnSave="Save"/>

    <div class="settings-content-body">
        <div class="hooks-layout">
            @* Left: Event sidebar *@
            <div class="hooks-event-sidebar">
                <div class="typo-subtitle2 mb-2" style="padding: 0 8px;">이벤트</div>
                @foreach (var evt in ClaudeHookEvents.All)
                {
                    var count = GetHookCount(evt);
                    <button class="hooks-event-item @(_selectedEvent == evt ? "active" : "")"
                            @onclick="@(() => SelectEvent(evt))">
                        <span class="hooks-event-name">@evt</span>
                        @if (count > 0)
                        {
                            <Chip ButtonStyle="ButtonStyle.Filled"
                                  Tone="Tone.Primary" Class="hooks-event-count">
                                @count
                            </Chip>
                        }
                    </button>
                }
            </div>

            @* Right: Hook config editor *@
            <div class="hooks-config-panel">
                @if (_selectedEvent != null)
                {
                    <div class="d-flex justify-space-between align-center mb-3">
                        <div>
                            <div class="typo-subtitle1">@_selectedEvent</div>
                            <div class="typo-caption text-secondary">
                                @(ClaudeHookEvents.Descriptions.TryGetValue(_selectedEvent, out var desc) ? desc : "")
                            </div>
                        </div>
                        <Button ButtonStyle="ButtonStyle.Outlined" Tone="Tone.Primary"
                                StartIcon="@Lucide.Plus"
                                OnClick="AddHookToEvent">
                            훅 추가
                        </Button>
                    </div>

                    @if (GetEventConfigs().Count == 0)
                    {
                        <Alert Tone="Tone.Default" Class="mb-3">
                            이 이벤트에 등록된 훅이 없습니다. "훅 추가" 버튼으로 새 훅을 만드세요.
                        </Alert>
                    }

                    @foreach (var (config, configIdx) in GetEventConfigs().Select((c, i) => (c, i)))
                    {
                        @if (!string.IsNullOrEmpty(config.Matcher) || GetEventConfigs().Count > 1)
                        {
                            <div class="d-flex align-center gap-2 mb-2">
                                <TextField @bind-Value="config.Matcher" Label="매처 패턴"
                                           Placeholder="Bash, Edit, * 등" Style="max-width: 200px;"/>
                            </div>
                        }

                        @foreach (var (handler, handlerIdx) in config.Hooks.Select((h, i) => (h, i)))
                        {
                            var ci = configIdx;
                            var hi = handlerIdx;
                            <div class="mb-3">
                                <HookCard Hook="handler" Matcher="@config.Matcher"
                                          OnChanged="@(h => UpdateHandler(ci, hi, h))"
                                          OnDelete="@(() => DeleteHandler(ci, hi))"/>
                            </div>
                        }
                    }
                }
                else
                {
                    <div class="d-flex flex-column align-center justify-center" style="height: 200px; opacity: 0.5;">
                        <Icon Svg="@Lucide.Zap" Size="24"/>
                        <div class="typo-body2 mt-2">왼쪽에서 이벤트를 선택하세요</div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private ClaudeSettings _settings = new();
    private ClaudeSettingsScope _scope = ClaudeSettingsScope.Global;
    private string? _projectPath;
    private string? _selectedEvent;
    private bool _saving;

    protected override async Task OnInitializedAsync()
    {
        _projectPath = ChatState.CurrentWorkspace?.RepoLocalPath;
        _selectedEvent = ClaudeHookEvents.PreToolUse;
        await LoadSettings();
    }

    private async Task OnScopeChanged(ClaudeSettingsScope scope)
    {
        _scope = scope;
        await LoadSettings();
    }

    private async Task OnProjectPathChanged(string? path)
    {
        _projectPath = path;
        await LoadSettings();
    }

    private async Task LoadSettings()
    {
        try
        {
            _settings = await ClaudeSettingsService.ReadAsync(_scope,
                _scope == ClaudeSettingsScope.Global ? null : _projectPath);
        }
        catch
        {
            _settings = new ClaudeSettings();
        }
    }

    private void SelectEvent(string evt)
    {
        _selectedEvent = evt;
    }

    private int GetHookCount(string evt)
    {
        if (_settings.Hooks == null || !_settings.Hooks.TryGetValue(evt, out var configs))
            return 0;
        return configs.Sum(c => c.Hooks.Count);
    }

    private List<ClaudeHookEventConfig> GetEventConfigs()
    {
        if (_selectedEvent == null) return [];
        _settings.Hooks ??= new Dictionary<string, List<ClaudeHookEventConfig>>();
        if (!_settings.Hooks.TryGetValue(_selectedEvent, out var configs))
            return [];
        return configs;
    }

    private void AddHookToEvent()
    {
        if (_selectedEvent == null) return;
        _settings.Hooks ??= new Dictionary<string, List<ClaudeHookEventConfig>>();
        if (!_settings.Hooks.ContainsKey(_selectedEvent))
            _settings.Hooks[_selectedEvent] = [];

        // 하나의 빈 명령 핸들러가 있는 새로운 구성 추가
        _settings.Hooks[_selectedEvent].Add(new ClaudeHookEventConfig
        {
            Hooks = [new ClaudeHookHandler { Type = ClaudeHookHandlerType.Command }]
        });
    }

    private void UpdateHandler(int configIdx, int handlerIdx, ClaudeHookHandler handler)
    {
        var configs = GetEventConfigs();
        if (configIdx < configs.Count && handlerIdx < configs[configIdx].Hooks.Count)
            configs[configIdx].Hooks[handlerIdx] = handler;
    }

    private void DeleteHandler(int configIdx, int handlerIdx)
    {
        if (_selectedEvent == null) return;
        var configs = GetEventConfigs();
        if (configIdx >= configs.Count) return;

        var config = configs[configIdx];
        if (handlerIdx < config.Hooks.Count)
            config.Hooks.RemoveAt(handlerIdx);

        // 비어있으면 구성 항목 제거
        if (config.Hooks.Count == 0)
            configs.RemoveAt(configIdx);

        // 구성이 없으면 이벤트 키 제거
        if (configs.Count == 0)
            _settings.Hooks?.Remove(_selectedEvent);
    }

    private async Task Save()
    {
        _saving = true;
        try
        {
            await ClaudeSettingsService.WriteAsync(_scope, _settings,
                _scope == ClaudeSettingsScope.Global ? null : _projectPath);
            Snackbar.Add("훅 설정이 저장되었습니다.", ToastSeverity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"저장 실패: {ex.Message}", ToastSeverity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

}

<style>
    .hooks-layout {
        display: flex;
        gap: 0;
        min-height: 500px;
    }

    .hooks-event-sidebar {
        width: 220px;
        min-width: 220px;
        border-right: 1px solid var(--border-default);
        padding: 12px 0;
        overflow-y: auto;
        max-height: 70vh;
    }

    .hooks-event-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        width: 100%;
        padding: 6px 12px;
        font-size: 0.8125rem;
        text-align: left;
        background: none;
        border: none;
        cursor: pointer;
        transition: background 0.1s;
        color: var(--text-secondary);
    }

    .hooks-event-item:hover {
        background: var(--bg-hover);
    }

    .hooks-event-item.active {
        background: var(--accent-subtle);
        color: var(--accent);
        font-weight: 600;
        border-left: 2px solid var(--accent);
    }

    .hooks-event-name {
        font-family: monospace;
        font-size: 0.75rem;
    }

    .hooks-event-count {
        height: 20px !important;
        min-width: 20px;
    }

    .hooks-config-panel {
        flex: 1;
        padding: 16px 20px;
        overflow-y: auto;
        max-height: 70vh;
    }
</style>
