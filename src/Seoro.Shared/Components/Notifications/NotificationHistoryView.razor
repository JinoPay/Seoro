@inject INotificationHistoryService History
@inject IChatState ChatState
@inject ISessionService SessionService
@inject IToastService Snackbar
@implements IDisposable

<div class="overlay-page">
    <div class="overlay-page-header">
        <button class="overlay-back-btn" @onclick="Close">
            <Icon Svg="@Lucide.ArrowLeft" Size="14"/>
            앱으로 돌아가기
        </button>
    </div>
    <div class="overlay-page-content">
        <div class="notification-history-view">
            <div class="notification-history-header">
                <span class="notification-history-title">Notifications</span>
                <div style="display: flex; align-items: center; gap: 4px;">
                    @if (History.UnreadCount > 0)
                    {
                        <Button ButtonStyle="ButtonStyle.Text" Tone="Tone.Primary"
                                OnClick="@History.MarkAllAsRead">
                            모두 읽음
                        </Button>
                    }
                </div>
            </div>

            @if (_entries.Count == 0)
            {
                <div class="notification-history-empty">
                    <Icon Svg="@Lucide.Bell" Size="24" Style="opacity: 0.15;"/>
                    <p class="typo-body2" style="opacity: 0.4;">알림이 없습니다</p>
                </div>
            }
            else
            {
                <div class="notification-history-list">
                    @foreach (var group in _groups)
                    {
                        <div class="notification-date-header">@group.Label</div>

                        @foreach (var entry in group.Entries)
                        {
                            <div class="notification-entry @(entry.IsRead ? "" : "unread")"
                                 @key="entry.Id"
                                 @onclick="@(() => HandleClick(entry))">
                                <Icon Svg="@GetTypeIcon(entry.Type)"
                                      Size="16"
                                      Tone="@GetTypeColor(entry.Type)"
                                      Style="margin-top: 2px; flex-shrink: 0;"/>

                                <div class="notification-entry-content">
                                    <span class="notification-message">@entry.Body</span>
                                    <div class="notification-meta">
                                        <span class="notification-session-badge">@entry.Title</span>
                                        <span class="notification-time">@FormatRelativeTime(entry.Timestamp)</span>
                                    </div>
                                </div>

                                @if (!entry.IsRead)
                                {
                                    <div class="notification-unread-dot"></div>
                                }
                            </div>
                        }
                    }
                </div>
            }
        </div>
    </div>
</div>

@code {
    private IReadOnlyList<NotificationRecord> _entries = [];
    private List<NotificationDateGroup> _groups = [];

    protected override void OnInitialized()
    {
        History.OnChange += HandleChange;
        Refresh();
    }

    private void Refresh()
    {
        _entries = History.Entries;
        _groups = GroupByDate(_entries);
    }

    private void Close()
    {
        ChatState.CloseNotifications();
    }

    private async Task HandleClick(NotificationRecord entry)
    {
        if (!entry.IsRead)
            History.MarkAsRead(entry.Id);

        if (entry.SessionId != null)
        {
            var session = await SessionService.LoadSessionAsync(entry.SessionId);
            if (session != null)
            {
                ChatState.CloseNotifications();
                ChatState.SetSession(session);
            }
            else
            {
                Snackbar.Add("삭제된 세션입니다.", ToastSeverity.Normal);
            }
        }
    }

    private void HandleChange()
    {
        _ = InvokeAsync(() =>
        {
            Refresh();
            StateHasChanged();
        });
    }

    private static string GetTypeIcon(NotificationType type)
    {
        return type switch
        {
            NotificationType.Success => Lucide.CircleCheck,
            NotificationType.Error => Lucide.CircleAlert,
            NotificationType.Question => Lucide.MessagesSquare,
            NotificationType.PlanReview => Lucide.MessageSquareText,
            _ => Lucide.Info
        };
    }

    private static Tone GetTypeColor(NotificationType type)
    {
        return type switch
        {
            NotificationType.Success => Tone.Success,
            NotificationType.Error => Tone.Error,
            NotificationType.Question => Tone.Warning,
            NotificationType.PlanReview => Tone.Info,
            _ => Tone.Default
        };
    }

    private static string FormatRelativeTime(DateTime utcTime)
    {
        var diff = DateTime.UtcNow - utcTime;
        if (diff.TotalMinutes < 1) return "방금 전";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}분 전";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}시간 전";
        if (diff.TotalDays < 7) return $"{(int)diff.TotalDays}일 전";
        return utcTime.ToLocalTime().ToString("M월 d일");
    }

    private static List<NotificationDateGroup> GroupByDate(IReadOnlyList<NotificationRecord> entries)
    {
        var today = DateTime.UtcNow.Date;
        var yesterday = today.AddDays(-1);

        return entries
            .GroupBy(e => e.Timestamp.ToLocalTime().Date)
            .OrderByDescending(g => g.Key)
            .Select(g => new NotificationDateGroup
            {
                Label = g.Key == today ? "Today"
                    : g.Key == yesterday ? "Yesterday"
                    : g.Key.ToString("yyyy년 M월 d일"),
                Entries = g.ToList()
            })
            .ToList();
    }

    public void Dispose()
    {
        History.OnChange -= HandleChange;
    }

    private class NotificationDateGroup
    {
        public string Label { get; init; } = "";
        public List<NotificationRecord> Entries { get; init; } = [];
    }

}
